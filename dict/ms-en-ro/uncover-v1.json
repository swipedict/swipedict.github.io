  ],
  "examples": [
    {
      "sourceText": "I uncover the secret.",
      "targetText": "Eu descopăr secretul."
    },
    {
      "sourceText": "Do you uncover the puzzle?",
      "targetText": "Descoperi tu enigma?"
    },
    {
      "sourceText": "He uncovers the truth.",
      "targetText": "El descoperă adevărul."
    },
    {
      "sourceText": "We uncover the problem.",
      "targetText": "Noi descoperim problema."
    },
    {
      "sourceText": "Do you (plural) uncover the lie?",
      "targetText": "Descoperiți minciuna?"
    },
    {
      "sourceText": "They uncover the facts.",
      "targetText": "Ei descoperă faptele."
    },
    {
      "sourceText": "I have uncovered the secret.",
      "targetText": "Am descoperit secretul."
    },
    {
      "sourceText": "They have uncovered the truth.",
      "targetText": "Au descoperit adevărul."
    },
    {
      "sourceText": "He always uncovered the facts.",
      "targetText": "El descoperea întotdeauna faptele."
    },
    {
      "sourceText": "I had already uncovered the lie.",
      "targetText": "Descoperisem deja minciuna."
    },
    {
      "sourceText": "I will uncover the secret.",
      "targetText": "Voi descoperi secretul."
    },
    {
      "sourceText": "She will uncover the truth.",
      "targetText": "Ea o să descopere adevărul."
    },
    {
      "sourceText": "I would uncover the secret if I could.",
      "targetText": "Aș descoperi secretul dacă aș putea."
    },
    {
      "sourceText": "It is necessary that you uncover the puzzle.",
      "targetText": "Este necesar să descoperi enigma."
    },
    {
      "sourceText": "Uncover the secret!",
      "targetText": "Descoperă secretul!"
    },
    {
      "sourceText": "Uncover the truth!",
      "targetText": "Descoperiți adevărul!"
    },
    {
      "sourceText": "The uncovered secret is interesting.",
      "targetText": "Secretul descoperit este interesant."
    },
    {
      "sourceText": "The truth is now uncovered.",
      "targetText": "Adevărul este acum descoperit."
    },
    {
      "sourceText": "By uncovering the secret, I created clarity.",
      "targetText": "Descoperind secretul, am creat claritate."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Think of \"uncover\" as literally removing a cover to reveal something hidden, just like the Romanian \"a descoperi\"."
    },
    {
      "lang": "en",
      "text": "Remember that \"descoperi\" sounds like \"discover,\" which also means to find or reveal something new."
    },
    {
      "lang": "en",
      "text": "Imagine uncovering a treasure chest to link the English and Romanian words in your mind."
    },
    {
      "lang": "en",
      "text": "Use the phrase \"uncover the truth\" to connect the English verb with the Romanian usage in revealing secrets."
    },
    {
      "lang": "en",
      "text": "Practice saying \"a descoperi\" aloud whenever you learn something new to reinforce the meaning."
    }
  ],
