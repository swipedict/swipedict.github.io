  "source": {
    "lang": "en",
    "headword": "uncover",
    "definition": "to reveal or make something visible that was hidden",
    "pronunciation": "/ʌnˈkʌvər/",
    "etymology": {
      "explanation": {
        "sourceText": "The verb \"uncover\" is formed from the prefix \"un-\" meaning 'reverse' or 'remove' and the verb \"cover\" meaning 'to put something over or on top of'. \"Cover\" comes from Old English \"coferian\", meaning 'to cover or protect'.",
        "targetText": "Cuvântul englezesc „uncover” este format din prefixul „un-” care înseamnă „a inversa” sau „a îndepărta” și verbul „cover” care înseamnă „a acoperi sau a pune ceva deasupra”. „Cover” provine din engleza veche „coferian”, însemnând „a acoperi sau a proteja”."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "The word is often used figuratively, for example in the context of revealing information or truths."
  },
  "target": {
    "lang": "ro",
    "headword": "a descoperi",
    "definition": "a face ceva vizibil sau a dezvălui",
    "pronunciation": "/a des.koˈpe.ri/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a descoperi” comes from the Latin „discooperire”, composed of „dis-” (to remove) and „cooperire” (to cover), meaning 'to reveal something'.",
        "targetText": "Românescul „a descoperi” derivă din latină, din „discooperire”, compus din „dis-“ (a separa) și „cooperire“ (a acoperi), însemnând „a dezvălui“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-i). Oft verwendet, wenn es um das Entdecken von Geheimnissen oder die Aufklärung von Situationen geht."
  },
  "senses": [
    {
      "gloss": "Revealing information",
      "explanation": {
        "sourceText": "Specifically used for revealing in a journalistic context.",
        "targetText": "În special pentru dezvăluiri în context jurnalistic."
      },
      "examples": [
        {
          "sourceText": "The uncovering of the truth was necessary.",
          "targetText": "Dezvăluirea adevărului a fost necesară."
        }
      ]
    },
    {
      "gloss": "Discovery",
      "explanation": {
        "sourceText": "Used for the discovery of new information.",
        "targetText": "Pentru descoperirea unor informații noi."
      },
      "examples": [
        {
          "sourceText": "The discovery of new facts changed the situation.",
          "targetText": "Descoperirea de noi fapte a schimbat situația."
        }
      ]
    },
    {
      "gloss": "Revelation",
      "explanation": {
        "sourceText": "Used for revealing secrets.",
        "targetText": "Ca în germană, pentru dezvăluirea secretelor."
      },
      "examples": [
        {
          "sourceText": "The revelation of the secret was shocking.",
          "targetText": "Dezvăluirea secretului a fost șocantă."
        }
      ]
    }
  ],
