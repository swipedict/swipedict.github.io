  "source": {
    "lang": "en",
    "headword": "describe",
    "definition": "to explain or present something in detail using words",
    "pronunciation": "/dɪˈskraɪb/",
    "etymology": {
      "explanation": {
        "sourceText": "From Middle English 'describen', derived from Latin 'describere', meaning 'to write down' or 'to depict in words'. The prefix 'de-' intensifies the meaning.",
        "targetText": "Cuvântul englezesc „describe” provine din engleza mijlocie „describen”, derivat din latină „describere”, care înseamnă „a scrie” sau „a reprezenta în cuvinte”. Prefixul „de-” intensifică sensul."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Commonly used when explaining, reporting, or detailing something."
  },
  "target": {
    "lang": "ro",
    "headword": "a descrie",
    "definition": "a explica sau a prezenta ceva în detaliu",
    "pronunciation": "/a deˈskri.e/",
    "etymology": {
      "explanation": {
        "sourceText": "Derived from Latin 'describere', meaning 'to describe' or 'to write in detail'. The prefix 'de-' strengthens the meaning.",
        "targetText": "Derivat din latinescul „describere”, care înseamnă „a descrie” sau „a scrie detaliat“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb of the 4th conjugation (-ie). Frequently used to present things in detail."
  },
  "relatedWords": [
    {
      "sourceText": "example",
      "targetText": "exemplu"
    },
    {
      "sourceText": "representation",
      "targetText": "reprezentare"
    },
    {
      "sourceText": "details",
      "targetText": "detalii"
    },
    {
      "sourceText": "explanation",
      "targetText": "explicație"
    }
  ],
  "antonyms": [
    {
      "sourceText": "conceal",
      "targetText": "ascunde"
    }
  ],
  "examples": [
    {
      "sourceText": "I describe the picture.",
      "targetText": "Eu descriu imaginea."
    },
    {
      "sourceText": "Do you describe the place?",
      "targetText": "Descrei tu locul?"
    },
    {
      "sourceText": "He describes the situation.",
      "targetText": "El descrie situația."
    },
    {
      "sourceText": "We describe the events.",
      "targetText": "Noi descriem evenimentele."
    },
    {
      "sourceText": "Do you (plural) describe the plan?",
      "targetText": "Descreiți planul?"
    },
    {
      "sourceText": "They describe the details.",
      "targetText": "Ei descriu detaliile."
    },
    {
      "sourceText": "I have described the book.",
      "targetText": "Am descris cartea."
    },
    {
      "sourceText": "She described the incident.",
      "targetText": "Ea descria incidentul."
    },
    {
      "sourceText": "I will describe the story.",
      "targetText": "Voi descrie povestea."
    },
    {
      "sourceText": "I would describe it if I knew.",
      "targetText": "Aș descrie dacă aș ști."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember that 'describe' contains 'scribe', which relates to writing—think of a scribe writing down details."
    },
    {
      "lang": "en",
      "text": "The Romanian 'a descrie' sounds similar to 'describe', making it easier to recall its meaning."
    },
    {
      "lang": "en",
      "text": "Think of 'describe' as 'de-' (down) + 'scribe' (write), meaning to write down or explain something in detail."
    },
    {
      "lang": "en",
      "text": "When you describe something, you paint a picture with words—like an author or storyteller."
    }
  ],
