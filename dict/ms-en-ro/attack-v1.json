  "source": {
    "lang": "en",
    "headword": "attack",
    "definition": "to take aggressive action against someone or something, often to cause harm or gain advantage",
    "pronunciation": "/əˈtæk/",
    "etymology": {
      "explanation": {
        "sourceText": "The English word 'attack' comes from the French verb 'attaquer', which itself derives from the late Latin 'attaccare', meaning to fasten onto or to attach.",
        "targetText": "Cuvântul englezesc „attack” provine din verbul francez „attaquer”, care la rândul său derivă din latina târzie „attaccare”, însemnând a se fixa sau a atașa."
      },
      "source": "AI"
    },
    "additional": "Regular verb. Commonly used in military, sports, and metaphorical contexts to describe aggressive or offensive actions."
  },
  "target": {
    "lang": "ro",
    "headword": "a ataca",
    "definition": "a face un atac asupra cuiva sau a ceva",
    "pronunciation": "/a a.tʃaˈka/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian word „a ataca” is borrowed from the French „attaquer”, which in turn comes from the late Latin „attaccare”.",
        "targetText": "Cuvântul românesc „a ataca” este împrumutat din franceza „attaquer”, care provine la rândul său din latina târzie „attaccare”."
      },
      "source": "AI"
    },
    "additional": "Regular first conjugation verb (-a). Used to describe an aggressive or competitive approach."
  },
  "relatedWords": [
