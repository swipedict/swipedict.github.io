  "source": {
    "lang": "en",
    "headword": "hurry",
    "definition": "to move or act quickly, often because of limited time",
    "pronunciation": "/ˈhɜːri/",
    "etymology": {
      "explanation": {
        "sourceText": "The verb \"hurry\" originates from Middle English \"hurien\" meaning to move swiftly or hasten, with roots in Old English and related Germanic languages.",
        "targetText": "Cuvântul englezesc „hurry” provine din engleza mijlocie „hurien”, care înseamnă a se mișca rapid sau a se grăbi, având rădăcini în engleza veche și limbi germanice înrudite."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb, commonly used to express urgency or the need to save time."
  },
  "target": {
    "lang": "ro",
    "headword": "a se grăbi",
    "definition": "a merge sau a se mișca repede",
    "pronunciation": "/a se ɡrəˈbi/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a se grăbi” derives from the Slavic word „grabu” or „grabiti”, meaning to hurry or rush.",
        "targetText": "Verbul românesc „a se grăbi” provine din slavonul „grabu” sau „grabiti”, care înseamnă „a se grăbi” sau „a se precipita”."
      },
      "source": "AI, Wiktionary, Linguistic Analysis"
    },
    "additional": "The verb „a se grăbi” is used reflexively to express the desire not to waste time."
  },
  "relatedWords": [
    {
      "sourceText": "run",
      "targetText": "a alerga"
    },
    {
      "sourceText": "fast",
      "targetText": "repede"
    },
    {
      "sourceText": "step",
      "targetText": "pas"
    },
    {
      "sourceText": "time",
      "targetText": "timp"
    }
  ],
  "antonyms": [
    {
      "sourceText": "linger",
      "targetText": "a rămâne"
    }
  ],
  "examples": [
    {
      "sourceText": "I hurry to work.",
      "targetText": "Eu mă grăbesc la muncă."
    },
    {
      "sourceText": "Are you hurrying to school?",
      "targetText": "Te grăbești la școală?"
    },
    {
      "sourceText": "He hurries to the appointment.",
      "targetText": "El se grăbește la întâlnire."
    },
    {
      "sourceText": "We hurry so we won't be late.",
      "targetText": "Noi ne grăbim să nu întârziem."
    },
    {
      "sourceText": "Are you hurrying to your exam?",
      "targetText": "Voi vă grăbiți la examen?"
    },
    {
      "sourceText": "They hurry home.",
      "targetText": "Ei se grăbesc acasă."
    },
    {
      "sourceText": "I hurried yesterday.",
      "targetText": "M-am grăbit ieri."
    },
    {
      "sourceText": "They hurried late.",
      "targetText": "S-au grăbit târziu."
    },
    {
      "sourceText": "He often hurried to work.",
      "targetText": "El se grăbea adesea la muncă."
    },
    {
      "sourceText": "I will hurry tomorrow.",
      "targetText": "Mă voi grăbi mâine."
    },
    {
      "sourceText": "I would hurry if I could.",
      "targetText": "M-aș grăbi dacă aș putea."
    },
    {
      "sourceText": "Hurry now!",
      "targetText": "Grăbește-te acum!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Think of 'hurry' as 'hurrying' to catch a bus—quick movement to save time."
    },
    {
      "lang": "en",
      "text": "The Romanian 'grăbi' sounds like 'grab'—imagine grabbing time quickly."
    },
    {
      "lang": "en",
      "text": "Practice saying 'Mă grăbesc' to express everyday urgency and time pressure."
    },
    {
      "lang": "en",
      "text": "Remember: when you 'hurry', you want to avoid being late—just like in English!"
    }
  ],
