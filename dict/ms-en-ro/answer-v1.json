  "examples": [
    {
      "sourceText": "I answer the questions quickly.",
      "targetText": "Eu răspund rapid la întrebări."
    },
    {
      "sourceText": "Do you answer the email?",
      "targetText": "Răspunzi la e-mail?"
    },
    {
      "sourceText": "He answers the request immediately.",
      "targetText": "El răspunde rapid la solicitare."
    },
    {
      "sourceText": "We answer all feedback.",
      "targetText": "Noi răspundem la toate feedback-urile."
    },
    {
      "sourceText": "Do you answer the customers' questions?",
      "targetText": "Răspundeți la întrebările clienților?"
    },
    {
      "sourceText": "They answer the questions in the chat.",
      "targetText": "Ei răspund la întrebările din chat."
    },
    {
      "sourceText": "I have answered the request.",
      "targetText": "Am răspuns la cerere."
    },
    {
      "sourceText": "She did not answer the messages.",
      "targetText": "Ea nu răspundea la mesaje."
    },
    {
      "sourceText": "I will answer the invitation.",
      "targetText": "Voi răspunde la invitație."
    },
    {
      "sourceText": "I would answer the question if I could.",
      "targetText": "Aș răspunde la întrebare, dacă aș putea."
    },
    {
      "sourceText": "Answer the requests!",
      "targetText": "Răspunde la cereri!"
    },
    {
      "sourceText": "The answered questions are documented.",
      "targetText": "Întrebările răspunse sunt documentate."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember the Romanian verb \"a răspunde\" by linking it to the English word \"response\"—both relate to giving an answer."
    },
    {
      "lang": "en",
      "text": "Think of \"răspuns\" as the Romanian noun for \"answer\"; this helps you recall the verb \"a răspunde\" easily."
    },
    {
      "lang": "en",
      "text": "Associate \"answer\" with \"a răspunde\" since both involve replying to questions or messages."
    },
    {
      "lang": "en",
      "text": "Imagine you’re responding to an email or message—this action is \"a răspunde\" in Romanian."
    }
  ],
