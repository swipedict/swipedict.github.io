  "source": {
    "lang": "en",
    "headword": "paint",
    "definition": "To apply color to a surface to create an image or representation",
    "pronunciation": "/peɪnt/",
    "etymology": {
      "explanation": {
        "sourceText": "The English word \"paint\" originates from the Old French \"peint\", derived from the Latin \"pingere\", meaning to decorate or color a surface.",
        "targetText": "Cuvântul englezesc „paint“ provine din franceza veche „peint“, derivat din latină „pingere“, care înseamnă a decora sau a colora o suprafață."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "A regular verb commonly used in artistic contexts."
  },
  "target": {
    "lang": "ro",
    "headword": "a picta",
    "definition": "a aplica culori pe o suprafață pentru a crea o imagine sau o reprezentare",
    "pronunciation": "/a ˈpik.ta/",
    "etymology": {
      "explanation": {
        "sourceText": "\"A picta\" comes from the Latin \"pictare\", meaning to paint or draw, and is deeply rooted in Romanian artistic tradition.",
        "targetText": "„A picta“ provine din latină, din „pictare“, care înseamnă „a picta“ sau „a desena“, fiind adânc înrădăcinat în tradiția artistică românească."
      },
      "source": "Etymological Dictionaries, Wiktionary"
    },
    "additional": "A regular verb frequently used for creating paintings and drawings."
  },
  "senses": [
    {
      "gloss": "Creating images",
      "explanation": {
        "sourceText": "It also means to create and design images.",
        "targetText": "Înseamnă și a crea și a realiza imagini."
      },
      "examples": [
        {
          "sourceText": "I want to create images.",
          "targetText": "Vreau să creez imagini."
        }
      ]
    },
    {
      "gloss": "Painting",
      "explanation": {
        "sourceText": "The word 'a picta' is often used in relation to painting.",
        "targetText": "Cuvântul „a picta“ este folosit adesea în contextul picturii."
      },
      "examples": [
        {
          "sourceText": "I made a painting.",
          "targetText": "Am făcut o pictură."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "images",
      "targetText": "imagini"
    },
    {
      "sourceText": "colors",
      "targetText": "culori"
    },
    {
      "sourceText": "artist",
      "targetText": "artist"
    },
    {
      "sourceText": "brush",
      "targetText": "pensulă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "erase",
      "targetText": "a șterge"
    }
  ],
  "examples": [
    {
      "sourceText": "I am painting a picture.",
      "targetText": "Eu pictez o pictură."
    },
    {
      "sourceText": "Are you painting the walls?",
      "targetText": "Pictați pereții?"
    },
    {
      "sourceText": "She is painting a portrait.",
      "targetText": "Ea pictează un portret."
    },
    {
      "sourceText": "We are painting together.",
      "targetText": "Noi pictăm împreună."
    },
    {
      "sourceText": "Are you painting the bedroom?",
      "targetText": "Pictați dormitorul?"
    },
    {
      "sourceText": "They are painting in the studio.",
      "targetText": "Ei pictează în atelier."
    },
    {
      "sourceText": "I painted the picture.",
      "targetText": "Am pictat tabloul."
    },
    {
      "sourceText": "He often painted landscapes.",
      "targetText": "El picta adesea peisaje."
    },
    {
      "sourceText": "I will paint a new picture.",
      "targetText": "Voi picta o pictură nouă."
    },
    {
      "sourceText": "I would like to paint if I had time.",
      "targetText": "Aș picta dacă aș avea timp."
    },
    {
      "sourceText": "Paint the house!",
      "targetText": "Pictați casa!"
    },
    {
      "sourceText": "The painted work is impressive.",
      "targetText": "Ceea ce a fost pictat este impresionant."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember that \"a picta\" is used in artistic contexts, helping you associate it with painting and creativity."
    },
    {
      "lang": "en",
      "text": "Practice sentences describing what you like to paint to strengthen your use of \"a picta\"."
    },
    {
      "lang": "en",
      "text": "Link the English word \"paint\" with Romanian \"a picta\" by thinking of artists and colorful images."
    },
    {
      "lang": "en",
      "text": "Think of the English word \"picture\" which shares the root with \"paint\" and \"a picta\" to help remember the meaning."
    }
  ],
