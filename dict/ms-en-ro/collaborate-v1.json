  "source": {
    "lang": "en",
    "headword": "collaborate",
    "definition": "to work jointly with others on a task or project",
    "pronunciation": "/kəˈlæbəreɪt/",
    "etymology": {
      "explanation": {
        "sourceText": "The word comes from the Latin prefix 'com-' meaning 'together' and 'laborare' meaning 'to work', describing working together.",
        "targetText": "Cuvântul este format din prefixul „zusammen-“ și verbul „arbeiten“, indicând colaborarea."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Commonly used in professional and academic contexts."
  },
  "target": {
    "lang": "ro",
    "headword": "a colabora",
    "definition": "a lucra împreună la o sarcină",
    "pronunciation": "/a kolaˈboɾa/",
    "etymology": {
      "explanation": {
        "sourceText": "Derived from the Latin 'collaborare', meaning 'to work together'.",
        "targetText": "Derivat din latină „collaborare“, care înseamnă „a lucra împreună“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a)."
  },
