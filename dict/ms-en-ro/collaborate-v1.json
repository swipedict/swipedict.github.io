  "learningTips": [
    {
      "lang": "en",
      "text": "Think of 'collaborate' as 'co-' meaning together and 'labor' meaning work, so it literally means 'work together'."
    },
    {
      "lang": "en",
      "text": "The Romanian 'colabora' sounds like 'collaborate' in English, making it easy to remember as a cognate."
    },
    {
      "lang": "en",
      "text": "Remember 'collaborate' by associating it with famous collaborations in music or business, like a band working together."
    },
    {
      "lang": "en",
      "text": "The root 'labor' in 'collaborate' is the same as in 'laboratory' or 'labor', linking work and effort."
    }
  ],
