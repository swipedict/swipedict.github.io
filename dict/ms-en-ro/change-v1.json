  "source": {
    "lang": "en",
    "headword": "change",
    "definition": "to make something different or to modify it",
    "pronunciation": "/tʃeɪndʒ/",
    "etymology": {
      "explanation": {
        "sourceText": "The English word \"change\" comes from Old French \"changier\", which derives from Latin \"cambiare\" meaning \"to exchange or barter\". Over time, it evolved to mean making something different or altering it.",
        "targetText": "Cuvântul englezesc „change” provine din franceza veche „changier”, care derivă din latină „cambiare” însemnând „a schimba sau a face un schimb”. În timp, a evoluat să însemne a face ceva diferit sau a modifica."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Commonly used to describe making modifications or adjustments."
  },
  "target": {
    "lang": "ro",
    "headword": "a schimba",
    "definition": "a modifica sau a transforma ceva",
    "pronunciation": "/a ʃkimˈba/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a schimba” originates from Slavic, probably from Bulgarian „skimbam” or Serbian „škimbati”, meaning \"to change\" or \"to replace\".",
        "targetText": "Verbul românesc „a schimba” provine din limba slavă, probabil din bulgară „skimbam” sau sârbă „škimbati”, cu sensul de „a schimba” sau „a înlocui”."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular first conjugation verb (-a). Frequently used to express changes or adjustments."
  },
  "senses": [
    {
      "gloss": "change / schimbare",
      "explanation": {
        "sourceText": "\"Change\" can also mean modifications in a plan or decision.",
        "targetText": "„Schimbare“ se referă la modificări într-un plan sau decizie."
      },
      "examples": [
        {
          "sourceText": "The change of the plan was necessary.",
          "targetText": "Schimbarea planului a fost necesară."
        }
      ]
    },
    {
      "gloss": "modify / a modifica",
      "explanation": {
        "sourceText": "The word is also used for editing documents.",
        "targetText": "Folosit și pentru modificarea documentelor."
      },
      "examples": [
        {
          "sourceText": "I need to modify the documents.",
          "targetText": "Trebuie să modific documentele."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "better",
      "targetText": "mai bine"
    },
    {
      "sourceText": "modification",
      "targetText": "modificare"
    },
    {
      "sourceText": "new",
      "targetText": "nou"
    },
    {
      "sourceText": "alteration",
      "targetText": "schimbare"
    }
  ],
  "antonyms": [
    {
      "sourceText": "maintain",
      "targetText": "a menține"
    }
  ],
  "examples": [
    {
      "sourceText": "I change the document.",
      "targetText": "Eu schimb documentul."
    },
    {
      "sourceText": "Do you change the color?",
      "targetText": "Schimbi culoarea?"
    },
    {
      "sourceText": "He changes the plan.",
      "targetText": "El schimbă planul."
    },
    {
      "sourceText": "We change the strategy.",
      "targetText": "Noi schimbăm strategia."
    },
    {
      "sourceText": "Do you change your lifestyle?",
      "targetText": "Schimbați stilul vostru de viață?"
    },
    {
      "sourceText": "They change the rules.",
      "targetText": "Ei schimbă regulile."
    },
    {
      "sourceText": "I have changed the setting.",
      "targetText": "Am schimbat setarea."
    },
    {
      "sourceText": "She often changed her opinion.",
      "targetText": "Ea schimba adesea părerea."
    },
    {
      "sourceText": "I will change the system.",
      "targetText": "Voi schimba sistemul."
    },
    {
      "sourceText": "I would change everything if I could.",
      "targetText": "Aș schimba totul dacă aș putea."
    },
    {
      "sourceText": "Change the password!",
      "targetText": "Schimbă parola!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember the Romanian verb \"a schimba\" sounds like \"scheme\" – think of changing a plan or scheme."
    },
    {
      "lang": "en",
      "text": "The English word \"change\" and Romanian \"schimba\" both relate to making something different, so linking the sounds helps."
    },
    {
      "lang": "en",
      "text": "Think of 'change' as swapping something out, just like 'a schimba' means to replace or modify."
    },
    {
      "lang": "en",
      "text": "The present tense endings in Romanian for \"a schimba\" are easy to remember: -ez, -i, -ă, -ăm, -ați, -ă, similar to common verb patterns."
    }
  ],
