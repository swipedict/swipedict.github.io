  "source": {
    "lang": "en",
    "headword": "wash",
    "definition": "to clean something using water, soap, or another cleaning agent",
    "pronunciation": "/wɒʃ/",
    "etymology": {
      "explanation": {
        "sourceText": "The verb 'wash' originates from Old English 'wascan', meaning to cleanse with water, reflecting the action of removing dirt or impurities.",
        "targetText": "Cuvântul englezesc „wash” provine din engleza veche „wascan”, care însemna a curăța cu apă, reflectând acțiunea de a îndepărta murdăria sau impuritățile."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "The verb is commonly used in contexts such as washing dishes or personal hygiene."
  },
  "target": {
    "lang": "ro",
    "headword": "a spăla",
    "definition": "a curăța ceva cu apă, săpun sau un alt detergent",
    "pronunciation": "/a spəˈla/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a spăla” derives from the Latin „spolare”, which originally meant “to strip off, to clean” and evolved to the current meaning “to wash”.",
        "targetText": "Verbul românesc „a spăla” provine din latină, de la „spolare”, care însemna inițial „a curăța” sau „a dezbrăca”, evoluând spre sensul actual de „a spăla”."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regulary conjugated verb of the 1st conjugation (-a). Frequently used to describe washing clothes, dishes, and personal hygiene."
  },
  "relatedWords": [
    {
      "sourceText": "dishcloth",
      "targetText": "pânză de bucătărie"
    },
    {
      "sourceText": "cleaning",
      "targetText": "curățare"
    },
    {
      "sourceText": "soap",
      "targetText": "săpun"
    },
    {
      "sourceText": "water",
      "targetText": "apă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "to make dirty",
      "targetText": "a murdări"
    }
  ],
  "examples": [
    {
      "sourceText": "I wash the dishes.",
      "targetText": "Eu spăl vasele."
    },
    {
      "sourceText": "Do you wash your hands before eating?",
      "targetText": "Te speli pe mâini înainte de masă?"
    },
    {
      "sourceText": "She washes the car.",
      "targetText": "Ea spală mașina."
    },
    {
      "sourceText": "We wash the laundry.",
      "targetText": "Noi spălăm rufele."
    },
    {
      "sourceText": "Do you wash the fruit?",
      "targetText": "Spălați fructele?"
    },
    {
      "sourceText": "They wash the windows.",
      "targetText": "Ei spală ferestrele."
    },
    {
      "sourceText": "I have washed the plates.",
      "targetText": "Am spălat farfuriile."
    },
    {
      "sourceText": "He washed the car regularly.",
      "targetText": "El spăla mașina regulat."
    },
    {
      "sourceText": "I will wash the dishes.",
      "targetText": "Voi spăla vasele."
    },
    {
      "sourceText": "I would wash the bathroom if I had time.",
      "targetText": "Aș spăla baia, dacă aș avea timp."
    },
    {
      "sourceText": "Wash your hands!",
      "targetText": "Spală-ți mâinile!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "The Romanian verb 'a spăla' sounds like 'spa-la' – imagine going to a spa to get clean and refreshed."
    },
    {
      "lang": "en",
      "text": "Remember the present tense endings: I -ez, you -i, he/she -ă, we -ăm, you (plural) -ați, they -ă – this helps conjugate 'a spăla' easily."
    },
    {
      "lang": "en",
      "text": "Think of 'spăla' as similar to the English word 'spill' but reversed – instead of spilling dirt, you wash it away."
    },
    {
      "lang": "en",
      "text": "Associate 'spăla' with 'soap' since both start with 'sp' and relate to cleaning."
    }
  ],
