    {
      "sourceText": "I am copying the text.",
      "targetText": "Eu copiez textul."
    },
    {
      "sourceText": "Are you copying the homework?",
      "targetText": "Copiază tu temele?"
    },
    {
      "sourceText": "He is copying the notes.",
      "targetText": "El copiază notițele."
    },
    {
      "sourceText": "We are copying the answers.",
      "targetText": "Noi copiem răspunsurile."
    },
    {
      "sourceText": "Are you copying the rules?",
      "targetText": "Copiați regulile?"
    },
    {
