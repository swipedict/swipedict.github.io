  "source": {
    "lang": "en",
    "headword": "copy",
    "definition": "to reproduce or write down something from another text or source",
    "pronunciation": "/ˈkɒpi/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb “copy” comes from the Old French word “copier,” which itself derives from the Latin verb “copiare,” meaning to reproduce or make abundant.",
        "targetText": "Cuvântul englezesc „copy” provine din vechiul francez „copier”, care la rândul său derivă din verbul latin „copiare”, însemnând a reproduce sau a face ceva din abundență."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "The verb “copy” is commonly used in educational contexts when students reproduce text or information from a source."
  },
  "target": {
    "lang": "ro",
    "headword": "a copia",
    "definition": "a reproduce sau a transfera ceva dintr-un alt text sau sursă",
    "pronunciation": "/a koˈpi.a/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a copia” is a modern loanword from the French „copier”, which in turn comes from the Latin „copiare”.",
        "targetText": "Verbul românesc „a copia” este un împrumut modern din francezul „copier”, care provine la rândul său din latinescul „copiare”."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb of the 1st conjugation (-a). Often used to describe copying documents or texts."
  },
  "senses": [
    {
      "gloss": "Copying assignments",
      "explanation": {
        "sourceText": "Commonly used in school",
        "targetText": "Folosit frecvent în școală."
      },
      "examples": [
        {
          "sourceText": "Are you copying the rules?",
          "targetText": "Copiați regulile?"
        }
      ]
    },
    {
      "gloss": "Copying texts",
      "explanation": {
        "sourceText": "In a school context",
        "targetText": "În context școlar."
      },
      "examples": [
        {
          "sourceText": "I am copying the text.",
          "targetText": "Eu copiez textul."
        },
        {
          "sourceText": "He is copying the notes.",
          "targetText": "El copiază notițele."
        }
      ]
    },
    {
      "gloss": "Working with a document",
      "explanation": {
        "sourceText": "When something is transferred from a document.",
        "targetText": "Când ceva este transferat dintr-un document."
      },
      "examples": [
        {
          "sourceText": "I copied the document.",
          "targetText": "Am copiat documentul."
        }
      ]
    }
  ],
