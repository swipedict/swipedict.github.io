  "source": {
    "lang": "en",
    "headword": "stand up",
    "definition": "to rise from a lying or sitting position to a standing position",
    "pronunciation": "/stænd ʌp/",
    "etymology": {
      "explanation": {
        "sourceText": "The English phrasal verb 'stand up' combines the verb 'stand', from Old English 'standan', meaning 'to be upright', with the particle 'up', indicating movement to a higher or vertical position.",
        "targetText": "Verbul compus englezesc „stand up“ combină verbul „stand“, din engleza veche „standan“, care înseamnă „a sta drept“, cu particula „up“, indicând mișcarea către o poziție verticală."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "'Stand up' is often used as a sign of respect in many cultures, especially during greetings."
  },
  "target": {
    "lang": "ro",
    "headword": "a se ridica",
    "definition": "a se ridica dintr-o poziție culcată sau așezată",
    "pronunciation": "/a se riˈdi.ka/",
    "etymology": {
      "explanation": {
        "sourceText": "The verb 'a se ridica' comes from the Latin 'ridicare', meaning 'to raise, to lift'. It refers to the action of bringing oneself into an upright position.",
        "targetText": "Verbul românesc „a se ridica“ provine din latină, de la „ridicare“, care înseamnă „a ridica“ sau „a înălța“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Cuvântul are adesea o conotație metaforică, în special pentru depășirea dificultăților în viață."
  },
  "senses": [
    {
      "gloss": "Stand up (to have breakfast)",
      "explanation": {
        "sourceText": "'Stand up' often implies being ready to have breakfast.",
        "targetText": "Adesea implică pregătirea pentru micul dejun."
      },
      "examples": [
        {
          "sourceText": "I stand up to have breakfast.",
          "targetText": "Mă ridic să iau micul dejun."
        }
      ]
    },
    {
      "gloss": "Stand up (to rise)",
      "explanation": {
        "sourceText": "Here, 'stand up' refers to the general action of rising.",
        "targetText": "Se referă la acțiunea generală de a te ridica."
      },
      "examples": [
        {
          "sourceText": "He had to stand up to open the door.",
          "targetText": "El a trebuit să se ridice pentru a deschide ușa."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Wake up",
      "targetText": "a se trezi"
    },
    {
      "sourceText": "Bed",
      "targetText": "pat"
    },
    {
      "sourceText": "Morning",
      "targetText": "dimineață"
    },
    {
      "sourceText": "Sleep",
      "targetText": "a dormi"
    }
  ],
  "antonyms": [
    {
      "sourceText": "sit",
      "targetText": "a sta jos"
    }
  ],
  "examples": [
    {
      "sourceText": "I stand up at 7 o'clock.",
      "targetText": "Eu mă ridic la ora 7."
    },
    {
      "sourceText": "Do you stand up early?",
      "targetText": "Te ridici devreme?"
    },
    {
      "sourceText": "He always stands up late.",
      "targetText": "El se ridică întotdeauna târziu."
    },
    {
      "sourceText": "We are standing up now.",
      "targetText": "Noi ne ridicăm acum."
    },
    {
      "sourceText": "Are you standing up?",
      "targetText": "Vă ridicați?"
    },
    {
      "sourceText": "They stand up slowly.",
      "targetText": "Ei se ridică încet."
    },
    {
      "sourceText": "I have stood up.",
      "targetText": "M-am ridicat."
    },
    {
      "sourceText": "They stood up early.",
      "targetText": "Ei s-au ridicat devreme."
    },
    {
      "sourceText": "He stood up every morning.",
      "targetText": "El se ridica în fiecare dimineață."
    },
    {
      "sourceText": "I had already stood up when he called.",
      "targetText": "M-am ridicat deja când a sunat."
    },
    {
      "sourceText": "I will stand up tomorrow.",
      "targetText": "Voi să mă ridic mâine."
    },
    {
      "sourceText": "He will stand up quickly.",
      "targetText": "El o să se ridice repede."
    },
    {
      "sourceText": "I would stand up if I were not tired.",
      "targetText": "Aș ridica, dacă nu aș fi obosit."
    },
    {
      "sourceText": "It is important that you stand up.",
      "targetText": "Este important să te ridici."
    },
    {
      "sourceText": "Stand up!",
      "targetText": "Ridică-te!"
    },
    {
      "sourceText": "Stand up! (plural)",
      "targetText": "Ridicați-vă!"
    },
    {
      "sourceText": "The standing child is awake.",
      "targetText": "Copilul ridicat este treaz."
    },
    {
      "sourceText": "Standing up, I noticed the time.",
      "targetText": "Ridicându-mă, am observat că e vremea."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Think of 'stand up' as literally standing tall—just like the Romanian 'a se ridica' means to rise up."
    },
    {
      "lang": "en",
      "text": "Remember the phrase 'stand up for yourself' to connect the idea of rising and asserting, similar to 'a se ridica'."
    },
    {
      "lang": "en",
      "text": "Imagine waking up and standing up to start your day—this helps link 'stand up' with 'a se ridica'."
    },
    {
      "lang": "en",
      "text": "The English word 'rise' is a synonym of 'stand up', and 'ridica' in Romanian also means 'to raise'—this connection can help you remember."
    }
  ],
