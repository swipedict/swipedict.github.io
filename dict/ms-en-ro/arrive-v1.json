  "source": {
    "lang": "en",
    "headword": "arrive",
    "definition": "to reach a destination or come to a place",
    "pronunciation": "/əˈraɪv/",
    "etymology": {
      "explanation": {
        "sourceText": "The English word 'arrive' comes from the Old French 'arriver', which means 'to reach the shore' or 'to come to land', originally derived from the Late Latin 'arripare' meaning 'to reach the shore'.",
        "targetText": "Cuvântul englezesc „arrive“ provine din franceza veche „arriver“, care înseamnă „a ajunge la țărm“ sau „a veni la uscat“, derivat inițial din latina târzie „arripare“, care înseamnă „a ajunge la țărm“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Used when someone or something reaches a specific place."
  },
  "target": {
    "lang": "ro",
    "headword": "a sosi",
    "definition": "a ajunge la o destinație sau a se prezenta",
    "pronunciation": "/a soˈsi/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a sosi“ probably derives from the Latin „surgere“ (to rise, to get up), which evolved in the vernacular to mean 'to arrive'.",
        "targetText": "Verbul românesc „a sosi” provine probabil din latină, din „surgere” (a se ridica), evoluând în limba română cu sensul de „a ajunge” sau „a sosi”."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb of the 1st conjugation (-a). Commonly used to describe arrival at a specific place."
  },
  "senses": [
    {
      "gloss": "to reach a destination",
      "explanation": {
        "sourceText": "'A sosi' describes the process of reaching a goal or destination.",
        "targetText": "„A sosi“ descrie procesul de a ajunge la o destinație."
      },
      "examples": [
        {
          "sourceText": "He arrives tomorrow.",
          "targetText": "El sosește mâine."
        }
      ]
    },
    {
      "gloss": "to arrive (arrival)",
      "explanation": {
        "sourceText": "'A sosi' means the arrival at a specific place.",
        "targetText": "„A sosi“ înseamnă sosirea într-un loc specific."
      },
      "examples": [
        {
          "sourceText": "I arrive on Tuesday.",
          "targetText": "Eu sosesc marți."
        }
      ]
    },
    {
      "gloss": "to present oneself",
      "explanation": {
        "sourceText": "'A sosi' can also mean to present oneself at a place.",
        "targetText": "„A sosi“ poate însemna și a se prezenta într-un loc."
      },
      "examples": [
        {
          "sourceText": "Do you arrive on time?",
          "targetText": "Sosești la timp?"
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "arrival",
      "targetText": "sosire"
    },
    {
      "sourceText": "ride",
      "targetText": "călătorie"
    },
    {
      "sourceText": "journey",
