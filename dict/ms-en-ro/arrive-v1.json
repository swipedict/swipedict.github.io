    },
    {
      "sourceText": "destination",
      "targetText": "destinație"
    }
  ],
  "antonyms": [
    {
      "sourceText": "give away",
      "targetText": "a da"
    }
  ],
  "examples": [
    {
      "sourceText": "I arrive on Tuesday.",
      "targetText": "Eu sosesc marți."
    },
    {
      "sourceText": "Do you arrive on time?",
      "targetText": "Sosești la timp?"
    },
    {
      "sourceText": "He arrives tomorrow.",
      "targetText": "El sosește mâine."
    },
    {
      "sourceText": "We arrive in the evening.",
      "targetText": "Noi sosim seara."
    },
    {
      "sourceText": "Do you arrive by train?",
      "targetText": "Sosiți cu trenul?"
    },
    {
      "sourceText": "They arrive immediately.",
      "targetText": "Ei sosesc imediat."
    },
    {
      "sourceText": "I arrived yesterday.",
      "targetText": "Am sosit ieri."
    },
    {
      "sourceText": "They always arrived on time.",
      "targetText": "Ei sosesc întotdeauna la timp."
    },
    {
      "sourceText": "I will arrive at 8 o'clock.",
      "targetText": "Voi sosii la ora 8."
    },
    {
      "sourceText": "I would arrive if the weather is good.",
      "targetText": "Aș sosi dacă vremea este bună."
    },
    {
      "sourceText": "Arrive quickly!",
      "targetText": "Sosește repede!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Think of 'arrive' as 'a river' flowing to a destination—just like water reaches the shore, you 'arrive' at a place."
    },
    {
      "lang": "en",
      "text": "The Romanian 'a sosi' sounds like 'so see'—imagine arriving somewhere so you can see new things."
    },
    {
      "lang": "en",
      "text": "Remember 'arrive' by associating it with 'arrival' at airports or train stations, common words in travel contexts."
    },
    {
      "lang": "en",
      "text": "Practice with phrases like 'I arrive on Tuesday' to connect the English verb with the Romanian 'a sosii'."
    }
  ],
