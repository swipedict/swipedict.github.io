  "source": {
    "lang": "en",
    "headword": "own",
    "definition": "to have something as your property or to be the legal possessor of something",
    "pronunciation": "/oʊn/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"own\" originates from Old English \"āgan\", meaning to possess or have property. It is related to the concept of having legal rights over something.",
        "targetText": "Cuvântul englezesc „own“ provine din engleza veche „āgan“, care înseamnă a poseda sau a avea proprietate. Este legat de conceptul de a avea drepturi legale asupra unui lucru."
      },
      "source": "Etymological Dictionaries"
    },
    "additional": "The word is used to describe possession or ownership and can be applied in both formal (legal) and informal contexts."
  },
  "target": {
    "lang": "ro",
    "headword": "a deține",
    "definition": "a avea sau a fi proprietarul unui lucru",
    "pronunciation": "/a deziˈne/",
    "etymology": {
      "explanation": {
        "sourceText": "Comes from the Latin \"detinere\", meaning \"to hold\" or \"to possess\", combined with the prefix \"de-\" which conveys the idea of \"taking\" or \"holding\".",
        "targetText": "Verbul „a deține“ provine din latină, din „detinere“, care înseamnă a ține sau a poseda, format prin prefixul „de-“ ce exprimă acțiunea de a ține."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Verb ist wichtig in rechtlichen und wirtschaftlichen Kontexten, um Eigentum oder Besitz zu kennzeichnen."
  },
  "senses": [
    {
      "gloss": "to possess property",
      "explanation": {
        "sourceText": "In a legal context, it means to have the lawful ownership of something.",
        "targetText": "În context juridic, înseamnă a avea proprietatea legală asupra unui lucru."
      },
      "examples": [
        {
          "sourceText": "I own a condominium.",
          "targetText": "Eu dețin un apartament proprietate."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "owner",
      "targetText": "proprietar"
    },
    {
      "sourceText": "property",
      "targetText": "proprietate"
    },
    {
      "sourceText": "law",
      "targetText": "drept"
    },
    {
      "sourceText": "resource",
      "targetText": "resursă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "to lose",
      "targetText": "a pierde"
    }
  ],
  "examples": [
    {
      "sourceText": "I own a new car.",
      "targetText": "Eu dețin o mașină nouă."
    },
    {
      "sourceText": "Do you own an apartment?",
      "targetText": "Deții un apartament?"
    },
    {
      "sourceText": "He owns the house.",
      "targetText": "El deține casa."
    },
    {
      "sourceText": "We own several plots of land.",
      "targetText": "Noi deținem mai multe terenuri."
    },
    {
      "sourceText": "Do you own a company?",
      "targetText": "Dețineți o companie?"
    },
    {
      "sourceText": "They own several firms.",
      "targetText": "Ei dețin mai multe firme."
    },
    {
      "sourceText": "I have owned my house.",
      "targetText": "Am deținut casa mea."
    },
    {
      "sourceText": "They owned a large company.",
      "targetText": "Ei dețineau o companie mare."
    },
    {
      "sourceText": "I will own a new office.",
      "targetText": "Voi deține un birou nou."
    },
    {
      "sourceText": "I would like to own a house.",
      "targetText": "Aș dori să dețin o casă."
    },
    {
      "sourceText": "Own your happiness!",
      "targetText": "Deține-ți fericirea!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember that \"own\" is used to express legal possession or personal property, similar to \"I own a car.\""
    },
    {
      "lang": "en",
      "text": "The Romanian verb \"a deține\" sounds like \"to detain\" in English, which can help you remember it means to hold or possess something."
    },
    {
      "lang": "en",
      "text": "Think of \"own\" as having something truly yours, like \"owning\" your success or your belongings."
    },
    {
      "lang": "en",
      "text": "Use the phrase \"I own it\" to connect with \"eu dețin\" in Romanian, reinforcing the idea of possession."
    }
  ],
