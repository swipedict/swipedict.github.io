    "register:neutral",
    "property:action"
  ],
  "sourceLanguage": "en",
  "targetLanguage": "ro",
  "metadata": {
    "author": "mschwehl",
    "source": "swipedict-en-ro",
    "contentVersion": 1,
    "schemaVersion": "1.0"
  },
  "source": {
    "lang": "en",
    "headword": "share",
    "definition": "to divide something into parts and give a portion to others",
    "pronunciation": "/ʃɛər/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb 'share' comes from Old English 'scearu', meaning 'cutting, division', related to the noun 'share' which means a part or portion.",
        "targetText": "Verbul englezesc „share“ provine din engleza veche „scearu“, care însemna „tăiere, diviziune“, fiind legat de substantivul „share“ ce înseamnă o parte sau porțiune."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Often used to describe dividing both tangible items and intangible things like information."
  },
  "target": {
    "lang": "ro",
    "headword": "a împărți",
    "definition": "a descompune ceva în două sau mai multe părți și a le oferi altora",
    "pronunciation": "/a ɨmpərˈtsi/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb 'a împărți' derives from the Latin 'partire', meaning 'to divide', and has established itself as a regular verb in Romanian.",
        "targetText": "Verbul românesc „a împărți“ derivă din latină „partire“, însemnând „a împărți“, păstrând sensul originar."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb of the 3rd conjugation (-i). It is used to share both material and immaterial things."
  },
  "senses": [
    {
      "gloss": "share (in the sense of sharing information)",
      "explanation": {
        "sourceText": "As in English: to pass on information or thoughts.",
        "targetText": "Ca în germană: a transmite informații sau gânduri altora."
      },
      "examples": [
        {
          "sourceText": "I share the news.",
          "targetText": "Împărtășesc știrile."
        }
      ]
    },
    {
      "gloss": "share (in the sense of splitting costs)",
      "explanation": {
        "sourceText": "Sharing costs among several people.",
        "targetText": "Împărțirea costurilor între mai multe persoane."
      },
      "examples": [
        {
          "sourceText": "We share the rent costs.",
          "targetText": "Împărțim costul chiriei."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "family",
      "targetText": "familie"
    },
    {
      "sourceText": "friend",
      "targetText": "prieten"
    },
    {
      "sourceText": "gift",
      "targetText": "cadou"
    },
    {
      "sourceText": "help",
      "targetText": "ajutor"
    }
  ],
  "antonyms": [
    {
      "sourceText": "claim",
      "targetText": "a susține"
    }
  ],
  "examples": [
    {
      "sourceText": "I like to share my ideas.",
      "targetText": "Îmi place să împărtășesc ideile mele."
    },
    {
      "sourceText": "Do you often share information?",
      "targetText": "Împărtășești adesea informații?"
    },
    {
      "sourceText": "He manages his time well.",
      "targetText": "El își împărățește bine timpul."
    },
    {
      "sourceText": "We share the costs.",
      "targetText": "Împărțim costurile."
    },
    {
      "sourceText": "Are you sharing the dessert?",
      "targetText": "Împărțiți desertul?"
    },
    {
      "sourceText": "They share the news.",
      "targetText": "Ei împărtășesc știrile."
    },
    {
      "sourceText": "I shared the joy with others.",
      "targetText": "Am împărțit bucuria cu alții."
    },
    {
      "sourceText": "They shared the costs fairly.",
      "targetText": "Ei au împărțit costurile corect."
    },
    {
      "sourceText": "He shared everything with his friends.",
      "targetText": "El împărtășea totul cu prietenii lui."
    },
    {
      "sourceText": "I had shared the video before you saw it.",
      "targetText": "Împărțisem video-ul înainte să-l vezi."
    },
    {
      "sourceText": "I will share the news.",
      "targetText": "Voi împărtăși noutățile."
    },
    {
      "sourceText": "They will share the information.",
      "targetText": "Ei o să împărtășească informațiile."
    },
    {
      "sourceText": "I would share the graphic if I could.",
      "targetText": "Aș împărți grafica dacă aș putea."
    },
    {
      "sourceText": "It is necessary that you share.",
      "targetText": "Este important să împarți."
    },
    {
      "sourceText": "Share the good news!",
      "targetText": "Împărtășește veștile bune!"
    },
    {
      "sourceText": "Share the info!",
      "targetText": "Împărtășiți informațiile!"
    },
    {
      "sourceText": "Shared joy is double joy.",
      "targetText": "Bucuria împărțită este o bucurie dublă."
    },
    {
      "sourceText": "The information is shared.",
      "targetText": "Informațiile sunt împărtășite."
    },
    {
      "sourceText": "Sharing means being happy.",
      "targetText": "Împărțind, ești fericit."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Think of 'share' as 'sheer' joy multiplied when you give a part of something to others."
    },
    {
      "lang": "en",
      "text": "The Romanian 'împărți' starts with 'îm-', like 'in' or 'im-' in English, indicating division or distribution."
    },
    {
      "lang": "en",
      "text": "Remember 'part' inside 'împărți'—both relate to dividing something into parts."
    },
    {
      "lang": "en",
      "text": "Imagine cutting a cake into pieces and sharing it with friends to recall 'a împărți'."
    },
    {
      "lang": "en",
      "text": "Use sentences like 'I share with friends' to practice the verb and connect it to English 'share'."
    }
  ],
