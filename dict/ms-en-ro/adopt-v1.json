  "source": {
    "lang": "en",
    "headword": "adopt",
    "definition": "to legally take another's child or pet as one's own",
    "pronunciation": "/əˈdɒpt/",
    "etymology": {
      "explanation": {
        "sourceText": "The English word 'adopt' comes from the Latin 'adoptare', meaning 'to take up' or 'to choose'. It is commonly used in legal and familial contexts.",
        "targetText": "Cuvântul englezesc „adopt“ provine din latină, de la „adoptare“, care înseamnă „a lua“ sau „a alege“. Este folosit frecvent în contexte legale și familiale."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Commonly used in legal and family contexts."
  },
  "target": {
    "lang": "ro",
    "headword": "a adopta",
    "definition": "a accepta un copil ca fiind al tău din punct de vedere legal",
    "pronunciation": "/a a.dopˈta/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb 'a adopta' derives from the Latin 'adoptare' and refers to the legal act of accepting a child or an animal.",
        "targetText": "Verbul românesc „a adopta“ provine din latină, de la „adoptare“, și desemnează actul legal de a primi un copil sau un animal ca parte a familiei."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular first conjugation verb (-a). Used for both children and pets."
  },
  "senses": [
    {
      "gloss": "adopt (legally accept)",
      "explanation": {
        "sourceText": "As in English: for the legal acceptance of a child.",
        "targetText": "Ca în germană: pentru acceptarea legală a unui copil."
      },
      "examples": [
        {
          "sourceText": "I adopt a child.",
          "targetText": "Eu adoptez un copil."
        },
        {
          "sourceText": "Do you adopt the child?",
          "targetText": "Adoptați copilul?"
        }
      ]
    },
    {
      "gloss": "adopt pets",
      "explanation": {
        "sourceText": "Also used for the adoption of pets.",
        "targetText": "Folosit și pentru adoptarea animalelor de companie."
      },
      "examples": [
        {
          "sourceText": "I adopt a dog.",
          "targetText": "Eu adopt un câine."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "parents",
      "targetText": "părinți"
    },
    {
      "sourceText": "family",
      "targetText": "familie"
    },
    {
      "sourceText": "law",
      "targetText": "lege"
    },
    {
      "sourceText": "child",
      "targetText": "copil"
    }
  ],
  "antonyms": [
    {
      "sourceText": "give up",
      "targetText": "renunța"
    }
  ],
  "examples": [
    {
      "sourceText": "I adopt a pet.",
      "targetText": "Eu adopt un animal de companie."
    },
    {
      "sourceText": "Do you adopt the child?",
      "targetText": "Adopți copilul?"
    },
    {
      "sourceText": "She adopts a girl.",
      "targetText": "Ea adoptă o fetiță."
    },
    {
      "sourceText": "We adopt a child.",
      "targetText": "Noi adoptăm un copil."
    },
    {
      "sourceText": "Do you adopt the animal?",
      "targetText": "Adoptați animalul?"
    },
    {
      "sourceText": "They adopt a boy.",
      "targetText": "Ei adoptă un băiat."
    },
    {
      "sourceText": "I have adopted a child.",
      "targetText": "Am adoptat un copil."
    },
    {
      "sourceText": "He adopted a dog.",
      "targetText": "El adopta un câine."
    },
    {
      "sourceText": "I will adopt the animal.",
      "targetText": "Voi adopta animalul."
    },
    {
      "sourceText": "I would adopt it if I could.",
      "targetText": "Aș adopta dacă aș putea."
    },
    {
      "sourceText": "Adopt the animal!",
      "targetText": "Adoptă animalul!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "The Romanian 'a adopta' sounds very similar to the English 'adopt', making it easy to remember."
    },
    {
      "lang": "en",
      "text": "Think of 'a adopta' as 'adopt a pet or child'—the meaning is almost the same in both languages."
    },
    {
      "lang": "en",
      "text": "Remember the phrase: 'I adopt a dog!' to keep the verb lively and memorable."
    },
    {
      "lang": "en",
      "text": "The root 'adopt-' is common in English words like 'adoption' and 'adoptive', helping you link the Romanian verb to familiar English terms."
    }
  ],
