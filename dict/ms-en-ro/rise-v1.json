  "source": {
    "lang": "en",
    "headword": "rise",
    "definition": "to move from a lying or sitting position to a standing position",
    "pronunciation": "/raɪz/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"rise\" originates from the Old English \"rīsan\", meaning to get up or stand up. It describes the action of moving upwards or standing from a lower position.",
        "targetText": "Cuvântul englezesc „rise” provine din engleza veche „rīsan”, care înseamnă a se ridica sau a sta în picioare. Descrie acțiunea de a se mișca în sus sau de a se ridica dintr-o poziție inferioară."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "\"Rise\" is often associated with starting the day or showing respect by standing up."
  },
  "target": {
    "lang": "ro",
    "headword": "a se ridica",
    "definition": "a se ridica dintr-o poziție culcată sau așezată",
    "pronunciation": "/a se riˈdi.ka/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a se ridica“ comes from the Latin „levare“ or „erigere“, meaning to lift or to rise.",
        "targetText": "Verbul românesc „a se ridica” provine din latină, de la „levare” sau „erigere”, care înseamnă „a ridica” sau „a se înălța”."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Wort hat oft eine Metapher, insbesondere für das Überwinden von Schwierigkeiten im Leben."
  },
  "senses": [
    {
      "gloss": "Rising (for breakfast)",
      "explanation": {
        "sourceText": "\"Rise\" often implies being ready to have breakfast.",
        "targetText": "Adesea implică pregătirea pentru micul dejun."
      },
      "examples": [
        {
          "sourceText": "I rise to have breakfast.",
          "targetText": "Mă ridic să iau micul dejun."
        }
      ]
    },
    {
      "gloss": "Rising (to stand up)",
      "explanation": {
        "sourceText": "Here, \"rise\" refers to the general action of getting up.",
        "targetText": "Se referă la acțiunea generală de a te ridica."
      },
      "examples": [
        {
          "sourceText": "He had to rise to open the door.",
          "targetText": "El a trebuit să se ridice pentru a deschide ușa."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Wake up",
      "targetText": "a se trezi"
    },
    {
      "sourceText": "Bed",
      "targetText": "pat"
    },
    {
      "sourceText": "Morning",
      "targetText": "dimineață"
    },
    {
      "sourceText": "Sleep",
      "targetText": "a dormi"
    }
  ],
  "antonyms": [
    {
      "sourceText": "sit",
      "targetText": "a sta jos"
    }
  ],
  "examples": [
    {
      "sourceText": "I rise at 7 o'clock.",
      "targetText": "Eu mă ridic la ora 7."
    },
    {
      "sourceText": "Do you rise early?",
      "targetText": "Te ridici devreme?"
    },
    {
      "sourceText": "He always rises late.",
      "targetText": "El se ridică întotdeauna târziu."
    },
    {
      "sourceText": "We are rising now.",
      "targetText": "Noi ne ridicăm acum."
    },
    {
      "sourceText": "Are you rising?",
      "targetText": "Vă ridicați?"
    },
    {
      "sourceText": "They rise slowly.",
      "targetText": "Ei se ridică încet."
    },
    {
      "sourceText": "I have risen.",
      "targetText": "M-am ridicat."
    },
    {
      "sourceText": "They rose early.",
      "targetText": "Ei s-au ridicat devreme."
    },
    {
      "sourceText": "He rose every morning.",
      "targetText": "El se ridica în fiecare dimineață."
    },
    {
      "sourceText": "I had already risen when he called.",
      "targetText": "M-am ridicat deja când a sunat."
    },
    {
      "sourceText": "I will rise tomorrow.",
      "targetText": "Voi să mă ridic mâine."
    },
    {
      "sourceText": "He will rise quickly.",
      "targetText": "El o să se ridice repede."
    },
    {
      "sourceText": "I would rise if I were not tired.",
      "targetText": "Aș ridica, dacă nu aș fi obosit."
    },
    {
      "sourceText": "It is important that you rise.",
      "targetText": "Este important să te ridici."
    },
    {
      "sourceText": "Rise!",
      "targetText": "Ridică-te!"
    },
    {
      "sourceText": "Rise up!",
      "targetText": "Ridicați-vă!"
    },
    {
      "sourceText": "The risen child is awake.",
      "targetText": "Copilul ridicat este treaz."
    },
    {
      "sourceText": "Rising, I noticed the time.",
      "targetText": "Ridicându-mă, am observat că e vremea."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Think of the word \"rise\" as climbing up or getting out of bed, just like the Romanian \"a se ridica\" means to get up."
    },
    {
      "lang": "en",
      "text": "Remember the phrase \"rise and shine\" to connect the idea of waking up and standing up with \"a se ridica.\""
    },
    {
      "lang": "en",
      "text": "The sound of \"rise\" is similar to \"ride\"—imagine riding up from a lying position to standing."
    },
    {
      "lang": "en",
      "text": "Link \"rise\" with the image of the sun rising, which also means to go up, just like \"a se ridica\" means to get up."
    }
  ],
