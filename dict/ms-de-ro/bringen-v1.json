  "source": {
    "lang": "de",
    "headword": "bringen",
    "definition": "etwas an einen bestimmten Ort transportieren oder übergeben",
    "pronunciation": "/ˈbʁɪŋən/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom mittelhochdeutschen „brin(gen)“, verwandt mit althochdeutsch „bringan“, ursprünglich „tragen, bringen“.",
        "targetText": "Provine din germana mijlocie (mittelhochdeutsch) „brin(gen)“, înrudit cu germana veche „bringan“, însemnând „a aduce“ sau „a transporta“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Unregelmäßiges Verb. Häufig in der Form „bringt“ oder „brachte“ verwendet. Im übertragenen Sinne kann es auch freundliche oder unerwünschte Nachrichten bringen."
  },
  "target": {
    "lang": "ro",
    "headword": "a aduce",
    "definition": "a transporta sau a preda ceva într-un anumit loc",
    "pronunciation": "/a aˈdu.tʃe/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom lateinischen „adducere“ abgeleitet, was „heranführen“ oder „hinbringen“ bedeutet und in romanischen Sprachen übernommen wurde.",
        "targetText": "Provine din latinescul „adducere“, care înseamnă „a aduce“ sau „a conduce spre“ și a fost preluat în limbile romanice."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird oft benutzt, um Bewegung und Transfer von Dingen zu thematisieren."
  },
  "relatedWords": [
    {
      "sourceText": "Familie",
      "targetText": "familie"
    },
    {
      "sourceText": "Freund",
      "targetText": "prieten"
    },
    {
      "sourceText": "Geschenk",
      "targetText": "cadou"
    },
    {
      "sourceText": "Zuhause",
      "targetText": "acasă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "nehmen",
      "targetText": "a lua"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich bringe das Essen mit.",
      "targetText": "Eu aduc mâncarea."
    },
    {
      "sourceText": "Bringst du die Bücher zurück?",
      "targetText": "Aduci cărțile înapoi?"
    },
    {
      "sourceText": "Sie bringt die Kinder zur Schule.",
      "targetText": "Ea aduce copiii la școală."
    },
    {
      "sourceText": "Wir bringen das Geschenk morgen.",
      "targetText": "Noi aducem cadoul mâine."
    },
    {
      "sourceText": "Bringt ihr die Getränke?",
      "targetText": "Aduceți băuturile?"
    },
    {
      "sourceText": "Sie bringen die Nachrichten.",
      "targetText": "Ei aduc știrile."
    },
    {
      "sourceText": "Ich habe das Geschenk gebracht.",
      "targetText": "Am adus cadoul."
    },
    {
      "sourceText": "Sie haben die Unterlagen gebracht.",
      "targetText": "Au adus documentele."
    },
    {
      "sourceText": "Er brachte immer die gute Laune.",
      "targetText": "El aducea mereu buna dispoziție."
    },
    {
      "sourceText": "Ich hatte das Essen schon gebracht, als er kam.",
      "targetText": "Aduceasem deja mâncarea când a venit."
    },
    {
      "sourceText": "Ich werde die Blumen bringen.",
      "targetText": "Voi aduce florile."
    },
    {
      "sourceText": "Sie wird das Auto bringen.",
      "targetText": "Ea o să aducă mașina."
    },
    {
      "sourceText": "Ich würde dir das Buch bringen.",
      "targetText": "Ti-aș aduce cartea."
    },
    {
      "sourceText": "Es ist wichtig, dass du das genau bringst.",
      "targetText": "Este important să aduci exact asta."
    },
    {
      "sourceText": "Bring die Bücher!",
      "targetText": "Adu cărțile!"
    },
    {
      "sourceText": "Bringen Sie die Unterlagen!",
      "targetText": "Aduceți documentele!"
    },
    {
      "sourceText": "Das gebrachte Geschenk ist schön.",
      "targetText": "Cadoul adus este frumos."
    },
    {
      "sourceText": "Die Unterlagen sind schon gebracht.",
      "targetText": "Documentele sunt deja aduse."
    },
    {
      "sourceText": "Indem er das Essen bringt, erfreut er alle.",
      "targetText": "Aducând mâncarea, bucură pe toată lumea."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„a aduce“ klingt wie „ad“ + „duce“ (führen) – stelle dir vor, wie du etwas zu jemandem hinführst."
    },
    {
      "lang": "de",
      "text": "Merke dir die Formen „aduc“ (ich bringe) und „aduceți“ (ihr bringt) als typische Endungen."
    },
    {
      "lang": "de",
      "text": "Wie im Deutschen steht das Verb oft mit Akkusativobjekten – übe Sätze mit direkten Objekten!"
    }
  ],
