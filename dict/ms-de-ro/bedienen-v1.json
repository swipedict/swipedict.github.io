  "source": {
    "lang": "de",
    "headword": "bedienen",
    "definition": "etwas in Betrieb nehmen oder jemandem helfen, etwas zu nutzen",
    "pronunciation": "/bəˈdiːnən/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom mittelhochdeutschen „bedienen“, abgeleitet von „dien“ (dienen).",
        "targetText": "Provine din germana mijlocie „bedienen“, derivat din „dien“ care înseamnă „a sluji“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Es bezieht sich oft auf die Durchführung von Dienstleistungen oder die Handhabung von Maschinen."
  },
  "target": {
    "lang": "ro",
    "headword": "a deservi",
    "definition": "a folosi sau a ajuta pe cineva să folosească ceva",
    "pronunciation": "/a deˈservi/",
    "etymology": {
      "explanation": {
        "sourceText": "„A deservi“ stammt aus dem lateinischen „servire“, was „dienen“ bedeutet. Es wird verwendet, um Bedienung von Geräten oder Personen zu beschreiben.",
        "targetText": "Verbul românesc „a deservi“ provine din latină, din „servire“, care înseamnă „a sluji“ sau „a deservi“."
      },
      "source": "Etymological Dictionaries, Wiktionary"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation. Oft im Bezug auf den Service von Kunden oder die Bedienung von Maschinen verwendet."
  },
  "relatedWords": [
    {
      "sourceText": "Bedienung",
      "targetText": "serviciu"
    },
    {
      "sourceText": "Gerät",
      "targetText": "dispozitiv"
    },
    {
      "sourceText": "Hilfsangebot",
      "targetText": "ofertă de ajutor"
    },
    {
      "sourceText": "Kunde",
      "targetText": "client"
    }
  ],
  "antonyms": [
    {
      "sourceText": "vernachlässigen",
      "targetText": "ignora"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich bediene den Computer.",
      "targetText": "Eu deservesc computerul."
    },
    {
      "sourceText": "Bedienst du die Kunden?",
      "targetText": "Deservești clienții?"
    },
    {
      "sourceText": "Die Kellnerin bedient die Gäste.",
      "targetText": "Camerista deservește oaspeții."
    },
    {
      "sourceText": "Wir bedienen die Maschinen.",
      "targetText": "Noi deservim mașinile."
    },
    {
      "sourceText": "Bedient ihr die neue Software?",
      "targetText": "Deserveți noua aplicație?"
    },
    {
      "sourceText": "Sie bedienen die Geräte.",
      "targetText": "Ei deservesc aparatele."
    },
    {
      "sourceText": "Ich habe den Kunden gut bedient.",
      "targetText": "Am deservit bine clientul."
    },
    {
      "sourceText": "Er bediente die Maschine täglich.",
      "targetText": "El deservi mașina zilnic."
    },
    {
      "sourceText": "Ich werde die Gäste bedienen.",
      "targetText": "Voi deservi oaspeții."
    },
    {
      "sourceText": "Ich würde die Maschine bedienen, wenn ich könnte.",
      "targetText": "Aș deservi mașina, dacă aș putea."
    },
    {
      "sourceText": "Bediene den Fernseher!",
      "targetText": "Deservește televizorul!"
    },
    {
      "sourceText": "Die bediente Maschine läuft reibungslos.",
      "targetText": "Mașina deservită funcționează fără probleme."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„deservi“ klingt wie das englische „serve“ – denk daran, dass du jemandem dienst oder etwas bedienst."
    },
    {
      "lang": "de",
      "text": "Merke dir die Präsensendungen: -esc, -ești, -ește, -im, -iți, -esc – so konjugierst du „a deservi“ richtig."
    }
  ],
