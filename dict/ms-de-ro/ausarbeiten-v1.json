  },
  "source": {
    "lang": "de",
    "headword": "ausarbeiten",
    "definition": "etwas detailliert und gründlich entwickeln oder formulieren",
    "pronunciation": "/ˈaʊ̯sˌaʁbaɪ̯tən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb besteht aus dem Präfix „aus-“ (nach außen) und „arbeiten“ (arbeiten). Es beschreibt den Prozess, etwas gründlich und detailliert zu entwickeln oder zu gestalten.",
        "targetText": "Verbul „a elabora“ provine din latinescul „elaborare“, care înseamnă „a lucra cu atenție“ sau „a dezvolta“. Este folosit pentru procese creative și academice."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Beschreibt das detaillierte Entwickeln von Texten, Plänen oder Konzepten."
  },
  "target": {
    "lang": "ro",
    "headword": "a elabora",
    "definition": "a dezvolta sau a formula ceva în detaliu",
    "pronunciation": "/a e.laˈbora/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „a elabora“ stammt vom lateinischen „elaborare“, was „ausarbeiten“ oder „herstellen“ bedeutet. Es hat sich in der rumänischen Sprache etabliert und wird oft verwendet, um kreative Prozesse und Entwicklung zu beschreiben.",
        "targetText": "Verbul românesc „a elabora“ derivă din latinescul „elaborare“, care înseamnă „a lucra cu atenție“ sau „a dezvolta“. Este folosit în contexte academice și creative."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Häufig in akademischen und kreativen Kontexten verwendet."
  },
  "senses": [
    {
      "gloss": "ausarbeiten (detailliert entwickeln)",
      "explanation": {
        "sourceText": "Bedeutet, etwas gründlich und detailliert zu entwickeln.",
        "targetText": "Înseamnă a dezvolta ceva în mod detaliat și atent."
      },
      "examples": [
        {
          "sourceText": "Ich arbeite den Bericht aus.",
          "targetText": "Eu elaborez raportul."
        }
      ]
    },
    {
      "gloss": "erarbeiten",
      "explanation": {
        "sourceText": "Wird oft in Forschung und Planung verwendet.",
        "targetText": "Este folosit frecvent în cercetare și planificare."
      },
      "examples": [
        {
          "sourceText": "Wir erarbeiten eine neue Strategie.",
          "targetText": "Noi elaborăm o nouă strategie."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Idee",
      "targetText": "idee"
    },
    {
      "sourceText": "Plan",
      "targetText": "plan"
    },
    {
      "sourceText": "Projekt",
      "targetText": "proiect"
    },
    {
      "sourceText": "Strategie",
      "targetText": "strategie"
    }
  ],
  "antonyms": [
    {
      "sourceText": "vereinfachen",
      "targetText": "simplifica"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich arbeite den Bericht aus.",
      "targetText": "Eu elaborez raportul."
    },
    {
      "sourceText": "Arbeitest du an dem Projekt?",
      "targetText": "Elaborezi proiectul?"
    },
    {
      "sourceText": "Er arbeitet den Plan aus.",
      "targetText": "El elaborează planul."
    },
    {
      "sourceText": "Wir arbeiten das Konzept aus.",
      "targetText": "Noi elaborăm conceptul."
    },
    {
      "sourceText": "Arbeitet ihr auch an der Präsentation?",
      "targetText": "Elaborați și voi prezentarea?"
    },
    {
      "sourceText": "Sie arbeiten an dem neuen Projekt.",
      "targetText": "Ei elaborează noul proiect."
    },
    {
      "sourceText": "Ich habe die Strategie ausgearbeitet.",
      "targetText": "Am elaborat strategia."
    },
    {
      "sourceText": "Sie haben die Lösung ausgearbeitet.",
      "targetText": "Ei au elaborat soluția."
    },
    {
      "sourceText": "Er arbeitete an dem Projekt jeden Tag.",
      "targetText": "El elabora proiectul în fiecare zi."
    },
    {
      "sourceText": "Ich hatte die Idee bereits ausgearbeitet, als du kamst.",
      "targetText": "Elaborasem deja ideea când ai venit."
    },
    {
      "sourceText": "Ich werde das Konzept morgen ausarbeiten.",
      "targetText": "Voi elabora conceptul mâine."
    },
    {
      "sourceText": "Sie werden die Präsentation später ausarbeiten.",
      "targetText": "Ei o să elaboreze prezentarea mai târziu."
    },
    {
      "sourceText": "Ich würde die Arbeit ausarbeiten, wenn ich Zeit hätte.",
      "targetText": "Aș elabora lucrarea dacă aș avea timp."
    },
    {
      "sourceText": "Es ist wichtig, dass du die Details ausarbeitest.",
      "targetText": "Este important să elaborezi detaliile."
    },
    {
      "sourceText": "Arbeite das Konzept aus!",
      "targetText": "Elaborează conceptul!"
    },
    {
      "sourceText": "Arbeitet die Pläne aus!",
      "targetText": "Elaborați planurile!"
    },
    {
      "sourceText": "Die ausgearbeitete Präsentation war beeindruckend.",
      "targetText": "Prezentarea elaborată a fost impresionantă."
    },
    {
      "sourceText": "Die Ergebnisse sind ausgearbeitet.",
      "targetText": "Rezultatele sunt elaborate."
    },
    {
      "sourceText": "Indem ich das Konzept ausarbeite, verbessere ich meine Fähigkeiten.",
      "targetText": "Elaborând conceptul, îmi îmbunătățesc abilitățile."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„A elabora“ wird oft in der Schule oder Uni verwendet – ein nützliches Wort für akademische Kontexte!"
    },
    {
      "lang": "de",
      "text": "Das Präfix „aus-“ in „ausarbeiten“ hilft dir, das rumänische „a elabora“ zu merken, das ähnlich wie „ausarbeiten“ bedeutet."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du bastelst ein Kunstwerk – so kannst du dir den kreativen Prozess von „a elabora“ besser vorstellen."
    }
  ],
