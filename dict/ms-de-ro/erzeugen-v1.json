      "targetText": "produs"
    }
  ],
  "antonyms": [
    {
      "sourceText": "zerstören",
      "targetText": "a distruge"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich erzeuge eine neue Idee.",
      "targetText": "Eu generez o idee nouă."
    },
    {
      "sourceText": "Erzeugst du den Bericht?",
      "targetText": "Generezi raportul?"
    },
    {
      "sourceText": "Sie erzeugt eine Lösung.",
      "targetText": "Ea generează o soluție."
    },
    {
      "sourceText": "Wir erzeugen neues Wissen.",
      "targetText": "Noi generăm cunoștințe noi."
    },
    {
      "sourceText": "Erzeugt ihr die Produkte?",
      "targetText": "Generați produsele?"
    },
    {
      "sourceText": "Sie (Pl.) erzeugen innovative Lösungen.",
      "targetText": "Ei generează soluții inovatoare."
    },
    {
      "sourceText": "Ich habe das Programm erzeugt.",
      "targetText": "Am generat programul."
    },
    {
      "sourceText": "Er erzeugte das Bild.",
      "targetText": "El genera imaginea."
    },
    {
      "sourceText": "Ich werde neue Inhalte erzeugen.",
      "targetText": "Voi genera noi conținuturi."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Genera“ klingt wie „Generator“ – stelle dir vor, du bist ein Generator für neue Ideen, um dir das Wort zu merken."
    },
    {
      "lang": "de",
      "text": "Visualisiere dich als „Ideen-Guru“, der ständig Neues erzeugt – so bleibt „a genera“ im Gedächtnis."
    }
  ],
