  "source": {
    "lang": "de",
    "headword": "erzeugen",
    "definition": "etwas herstellen oder schaffen",
    "pronunciation": "/ɛʁˈt͡soʏɡn̩/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „erzeugen“ stammt vom mittelhochdeutschen „zerüegen“, was „erschaffen“ oder „produzieren“ bedeutet.",
        "targetText": "Verbul „erzeugen“ provine din germana mijlocie „zerüegen“, cu sensul de „a crea“ sau „a produce“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Unregelmäßiges Verb, häufig in technischen und kreativen Kontexten verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a genera",
    "definition": "a crea sau a produce ceva",
    "pronunciation": "/a d͡ʒeˈneɾa/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a genera“ stammt vom lateinischen „generare“, was „herstellen“ oder „erzeugen“ bedeutet. Es umfasst materielle und immaterielle Schöpfung.",
        "targetText": "Verbul românesc „a genera“ derivă din latină, de la „generare“, cu sensul de „a produce“ sau „a crea“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wichtig für kreative und technische Prozesse."
  },
  "relatedWords": [
    {
      "sourceText": "Herstellung",
