  "examples": [
    {
      "sourceText": "Der Lehrer ist sehr streng.",
      "targetText": "Profesorul este foarte strict."
    },
    {
      "sourceText": "Eure Regeln sind zu streng.",
      "targetText": "Regulile voastre sunt prea stricte."
    },
    {
      "sourceText": "Wir haben strenge Vorschriften.",
      "targetText": "Avem reglementări stricte."
    },
    {
      "sourceText": "Er hat strenge Kriterien.",
      "targetText": "El are criterii stricte."
    },
    {
      "sourceText": "Der Chef ist sehr streng.",
      "targetText": "Șeful este foarte strict."
    },
    {
      "sourceText": "Es gilt strenger Disziplin.",
      "targetText": "Se aplică disciplină strictă."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Streng“ und „strict“ klingen fast gleich – stelle dir eine strenge Lehrerin vor, die strikte Regeln aufstellt!"
    },
    {
      "lang": "de",
      "text": "Denke an eine gerade Linie (strict = streng), die man nicht überschreiten darf."
    },
    {
      "lang": "de",
      "text": "Stell dir einen strengen König vor, der seinen Rittern strikte Befehle gibt."
    },
    {
      "lang": "de",
      "text": "Verbinde „strict“ mit strengen Regeln, die wie ein unsichtbarer Zaun wirken."
    }
  ],
