  "source": {
    "lang": "de",
    "headword": "streng",
    "definition": "hart, rigoros, nicht nachgiebig",
    "pronunciation": "/ʃtrɛŋ/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort „streng“ leitet sich vom mittelhochdeutschen „strengt“ ab und bedeutet „hart“ oder „rigoros“.",
        "targetText": "Cuvântul „streng“ provine din germana mijlocie „strengt“ și înseamnă „dur“ sau „rigoros“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": ""
  },
  "target": {
    "lang": "ro",
    "headword": "strict",
    "genus": "masculine",
    "definition": "rigoros, sever, care aplică reguli cu fermitate",
    "pronunciation": "/strikt/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Wort „strict“ stammt vom lateinischen „strictus“ ab, was „eng“ oder „streng“ bedeutet.",
        "targetText": "Cuvântul românesc „strict“ derivă din latinescul „strictus“, care înseamnă „strâns“ sau „rigoros“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Oft genutzt in Bezug auf Regeln oder Autorität."
  },
