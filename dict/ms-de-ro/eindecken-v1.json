    {
      "sourceText": "Tisch",
      "targetText": "masă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "abdecken",
      "targetText": "a descoperi"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich decke den Tisch ein.",
      "targetText": "Eu acopăr masa."
    },
    {
      "sourceText": "Deckst du das Bett ein?",
      "targetText": "Acoperi patul?"
    },
    {
      "sourceText": "Die Kellnerin deckt die Tische ein.",
      "targetText": "Camerista acoperă mesele."
    },
    {
      "sourceText": "Wir decken den Garten ein.",
      "targetText": "Noi acoperim grădina."
    },
    {
      "sourceText": "Deckt ihr die Stühle ein?",
      "targetText": "Acoperiți scaunele?"
    },
    {
      "sourceText": "Sie decken die Geräte ein.",
      "targetText": "Ei acoperă aparatele."
    },
    {
      "sourceText": "Ich habe die Stühle eingedeckt.",
      "targetText": "Am acoperit scaunele."
    },
    {
      "sourceText": "Sie haben den Tisch eingedeckt.",
      "targetText": "Au acoperit masa."
    },
    {
      "sourceText": "Er deckte die Möbel ein.",
      "targetText": "El acoperea mobila."
    },
    {
      "sourceText": "Ich werde den Tisch morgen eindecken.",
      "targetText": "Voi acoperi masa mâine."
    },
    {
      "sourceText": "Ich würde den Garten eindecken, wenn es regnen würde.",
      "targetText": "Aș acoperi grădina dacă ar ploua."
    },
    {
      "sourceText": "Decke den Tisch ein!",
      "targetText": "Acoperă masa!"
    },
    {
      "sourceText": "Das eingedeckte Bett sieht schön aus.",
      "targetText": "Patul acoperit arată bine."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„A acoperi“ klingt wie „abdecken“ – denke daran, wie du den Tisch mit Geschirr bedeckst."
    },
    {
      "lang": "de",
      "text": "Stelle dir vor, wie du den Tisch mit einer Decke abdeckst – so merkst du dir „a acoperi“ leicht."
    }
  ],
