  "source": {
    "lang": "de",
    "headword": "eindecken",
    "definition": "den Tisch für eine Mahlzeit vorbereiten",
    "pronunciation": "/ˈaɪnˌdɛkən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „eindecken“ setzt sich aus „ein“ und „decken“ zusammen, wobei „decken“ vom althochdeutschen „dechōn“ stammt und „bedecken“ bedeutet.",
        "targetText": "Verbul „eindecken“ provine din combinarea lui „ein“ și „decken“, unde „decken“ înseamnă a acoperi."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Kann auch verwendet werden, um das Bedecken eines Tisches (z.B. mit Geschirr) zu beschreiben."
  },
  "target": {
    "lang": "ro",
    "headword": "a acoperi",
    "definition": "a pregăti masa pentru o masă",
    "pronunciation": "/a a.koˈpe.ri/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a acoperi“ stammt vom lateinischen „cooperire“ ab, was „bedecken“ oder „verstecken“ bedeutet und wird auch für das Eindecken verwendet.",
        "targetText": "Verbul românesc „a acoperi“ derivă din latină, din „cooperire“, care înseamnă a acoperi sau a ascunde."
      },
      "source": "AI, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-i). Wird oft für das Bedecken von Möbeln oder Tischen verwendet."
  },
  "relatedWords": [
    {
      "sourceText": "Gabel",
      "targetText": "furculiță"
    },
    {
      "sourceText": "Messer",
      "targetText": "cuțit"
    },
