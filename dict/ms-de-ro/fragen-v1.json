  "source": {
    "lang": "de",
    "headword": "fragen",
    "definition": "eine Auskunft verlangen oder um Informationen bitten",
    "pronunciation": "/ˈfʁaɡn̩/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „fragen“ stammt vom mittelhochdeutschen „fragen“, was ‚bitten‘ oder ‚fordern‘ bedeutet, und entwickelte sich zur Bedeutung ‚um Auskunft bitten‘.",
        "targetText": "Verbul „fragen“ provine din germana mijlocie „fragen“, însemnând „a cere“ sau „a solicita“, evoluând spre sensul de „a întreba“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Oft verwendet in alltäglichen Gesprächen."
  },
  "target": {
    "lang": "ro",
    "headword": "a întreba",
    "definition": "a solicita o informație sau a cere detalii",
    "pronunciation": "/a ˈɨntreˈba/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a întreba“ stammt vom lateinischen „interrogare“ ab, was ‚befragen‘ bedeutet, und wird für das Stellen von Fragen verwendet.",
        "targetText": "Verbul românesc „a întreba“ derivă din latină, din „interrogare“, însemnând „a întreba“ sau „a solicita informații“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Verwendung in formellen und informellen Kontexten."
  },
  "relatedWords": [
    {
      "sourceText": "Antwort",
      "targetText": "răspuns"
    },
    {
      "sourceText": "Frage",
      "targetText": "întrebare"
    },
    {
      "sourceText": "Neugier",
      "targetText": "curiozitate"
    },
    {
      "sourceText": "Wissen",
      "targetText": "a cunoaște"
    }
  ],
  "antonyms": [
    {
      "sourceText": "antworten",
      "targetText": "a răspunde"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich frage dich eine wichtige Sache.",
      "targetText": "Te întreb o chestiune importantă."
    },
    {
      "sourceText": "Fragst du mich nach dem Weg?",
      "targetText": "Întrebi dacă știu drumul?"
    },
    {
      "sourceText": "Der Schüler fragt den Lehrer.",
      "targetText": "Elevul întreabă profesorul."
    },
    {
      "sourceText": "Wir fragen alle nach deiner Meinung.",
      "targetText": "Noi întrebăm pe toată lumea despre părerea ta."
    },
    {
      "sourceText": "Fragt ihr nach dem Rezept?",
      "targetText": "Întrebați de rețetă?"
    },
    {
      "sourceText": "Sie fragen die Anwesenden.",
      "targetText": "Ei întreabă participanții."
    },
    {
      "sourceText": "Ich habe ihn gefragt.",
      "targetText": "L-am întrebat."
    },
    {
      "sourceText": "Er fragte den Experten damals.",
      "targetText": "El întreba expertul pe atunci."
    },
    {
      "sourceText": "Ich werde dich später fragen.",
      "targetText": "Te voi întreba mai târziu."
    },
    {
      "sourceText": "Ich würde dich fragen, wenn ich wüsste.",
      "targetText": "Te-aș întreba, dacă aș ști."
    },
    {
      "sourceText": "Frag mich nicht!",
      "targetText": "Nu mă întreba!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Fragen“ und „a întreba“ sind Kognaten – beide stammen vom lateinischen Wortstamm „inter-“, was das Lernen erleichtert."
    },
    {
      "lang": "de",
      "text": "Lerne häufige Fragen und benutze sie im Alltag, um das Verb „a întreba“ besser zu verinnerlichen."
    },
    {
      "lang": "de",
      "text": "Übe die Zeitformen mit „Întreb“ (ich frage), „Am întrebat“ (ich habe gefragt) und „Voi întreba“ (ich werde fragen)."
    }
  ],
