  "source": {
    "lang": "de",
    "headword": "bleiben",
    "definition": "an einem Ort verweilen oder bei etwas nicht weggehen",
    "pronunciation": "/ˈblaɪ̯bən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort stammt vom althochdeutschen „bleiban“ und mittelhochdeutschen „blibe“. Es bedeutet „seinen Platz nicht verlassen, verweilen“.",
        "targetText": "Cuvântul german „bleiben“ provine din germana veche „bleiban“ și înseamnă a rămâne sau a nu pleca."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Unregelmäßiges Verb, das oft in vielen Wendungen und Redewendungen verwendet wird. Es hat auch eine Bedeutung im Kontext von Zeit, z.B. „Bleib noch ein bisschen länger“."
  },
  "target": {
    "lang": "ro",
    "headword": "a rămâne",
    "definition": "a sta într-un loc sau a nu pleca de la ceva",
    "pronunciation": "/a rəˈmɨ.ne/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a rămâne“ stammt aus dem lateinischen „remanere“, was „übrig bleiben“ oder „verweilen“ bedeutet. Es setzt sich aus „re-“ (wieder) und „manere“ (bleiben) zusammen.",
        "targetText": "Verbul românesc „a rămâne“ provine din latină, din „remanere“, format din „re-“ (din nou) și „manere“ (a rămâne), însemnând a rămâne sau a persista."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 2. Konjugation mit viel Gebrauch in der alltäglichen Sprache. Es wird oft in Redewendungen wie „a rămâne fără cuvinte“ (sprachlos bleiben) verwendet."
  },
  "relatedWords": [
    {
      "sourceText": "aufhören",
      "targetText": "a se opri"
    },
    {
      "sourceText": "bleibend",
      "targetText": "permanent"
    },
    {
      "sourceText": "verweilen",
      "targetText": "a rămâne"
    },
    {
      "sourceText": "warten",
      "targetText": "a aștepta"
    }
  ],
  "antonyms": [
    {
      "sourceText": "gehen",
      "targetText": "a merge"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich bleibe hier.",
      "targetText": "Eu rămân aici."
    },
    {
      "sourceText": "Bleibst du noch etwas?",
      "targetText": "Rămâi puțin?"
    },
    {
      "sourceText": "Er bleibt am Bahnhof.",
      "targetText": "El rămâne la gară."
    },
    {
      "sourceText": "Wir bleiben hier für die Nacht.",
      "targetText": "Noi rămânem aici pentru noapte."
    },
    {
      "sourceText": "Bleibt bitte hier!",
      "targetText": "Rămâneți aici, vă rog!"
    },
    {
      "sourceText": "Sie bleiben heute zu Hause.",
      "targetText": "Ei rămân acasă astăzi."
    },
    {
      "sourceText": "Ich bin geblieben.",
      "targetText": "Am rămas."
    },
    {
      "sourceText": "Er blieb den ganzen Tag.",
      "targetText": "El a rămas toată ziua."
    },
    {
      "sourceText": "Ich werde hier bleiben.",
      "targetText": "Voi rămâne aici."
    },
    {
      "sourceText": "Ich würde bleiben, wenn ich könnte.",
      "targetText": "Aș rămâne dacă aș putea."
    },
    {
      "sourceText": "Bleib hier!",
      "targetText": "Rămâi aici!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „a rămâne“ klingt ähnlich wie „remmene“ – stell dir vor, du bleibst an einem Ort und „remmene“ dich nicht weg!"
    },
    {
      "lang": "de",
      "text": "Übe Sätze wie „Rămân la școală“ (Ich bleibe in der Schule), um das Verb im Alltag zu verinnerlichen."
    },
    {
      "lang": "de",
      "text": "Visualisiere, dass du an einem Ort bleibst und nicht gehst – so verankerst du die Bedeutung von „a rămâne“."
    }
  ],
