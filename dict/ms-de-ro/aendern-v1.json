  "source": {
    "lang": "de",
    "headword": "ändern",
    "definition": "etwas modifizieren oder verändern",
    "pronunciation": "/ˈɛːndɐn/",
    "etymology": {
      "explanation": {
        "sourceText": "Stammt vom mittelhochdeutschen „endern“ und ist verwandt mit dem althochdeutschen „andaran“, was „verändern“ bedeutet.",
        "targetText": "Cuvântul german „ändern“ provine din mijlocul germanului vechi „endern“, înrudit cu vechiul german „andaran“, care înseamnă „a schimba“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird häufig verwendet, um eine Modifikation oder Anpassung zu beschreiben."
  },
  "target": {
    "lang": "ro",
    "headword": "a schimba",
    "definition": "a modifica sau a transforma ceva",
    "pronunciation": "/a ʃkimˈba/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort kommt vom lateinischen „scambiare“, was „wechseln“ oder „tauschen“ bedeutet. In rumänischer Sprache hat es sich zu „a schimba“ entwickelt.",
        "targetText": "Cuvântul românesc „a schimba“ provine din latină, de la „scambiare“, care înseamnă „a schimba“ sau „a înlocui“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Häufig verwendet, um Veränderungen oder Anpassungen auszudrücken."
  },
  "senses": [
    {
      "gloss": "Änderung / schimbare",
      "explanation": {
        "sourceText": "'Änderung' kann auch 'schimbare' im Sinne von Änderungen in einem Plan oder einer Entscheidung bedeuten.",
        "targetText": "„Schimbare“ se referă la modificări într-un plan sau decizie."
      },
      "examples": [
        {
          "sourceText": "Die Änderung des Plans war notwendig.",
          "targetText": "Schimbarea planului a fost necesară."
        }
      ]
    },
    {
      "gloss": "modifizieren / a modifica",
      "explanation": {
        "sourceText": "Das Wort wird auch für das Bearbeiten von Dokumenten verwendet.",
        "targetText": "Folosit și pentru modificarea documentelor."
      },
      "examples": [
        {
          "sourceText": "Ich muss die Dokumente modifizieren.",
          "targetText": "Trebuie să modific documentele."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Besser",
      "targetText": "mai bine"
    },
    {
      "sourceText": "Modifikation",
      "targetText": "modificare"
    },
    {
      "sourceText": "Neu",
      "targetText": "nou"
    },
    {
      "sourceText": "Veränderung",
      "targetText": "schimbare"
    }
  ],
  "antonyms": [
    {
      "sourceText": "beibehalten",
      "targetText": "a menține"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich ändere das Dokument.",
      "targetText": "Eu schimb documentul."
    },
    {
      "sourceText": "Änderst du die Farbe?",
      "targetText": "Schimbi culoarea?"
    },
    {
      "sourceText": "Er ändert den Plan.",
      "targetText": "El schimbă planul."
    },
    {
      "sourceText": "Wir ändern die Strategie.",
      "targetText": "Noi schimbăm strategia."
    },
    {
      "sourceText": "Ändert ihr euren Lebensstil?",
      "targetText": "Schimbați stilul vostru de viață?"
    },
    {
      "sourceText": "Sie ändern die Regeln.",
      "targetText": "Ei schimbă regulile."
    },
    {
      "sourceText": "Ich habe die Einstellung verändert.",
      "targetText": "Am schimbat setarea."
    },
    {
      "sourceText": "Sie änderte oft ihre Meinung.",
      "targetText": "Ea schimba adesea părerea."
    },
    {
      "sourceText": "Ich werde das System ändern.",
      "targetText": "Voi schimba sistemul."
    },
    {
      "sourceText": "Ich würde alles ändern, wenn ich könnte.",
      "targetText": "Aș schimba totul dacă aș putea."
    },
    {
      "sourceText": "Ändere das Passwort!",
      "targetText": "Schimbă parola!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „a schimba“ klingt wie „schieben“ – stell dir vor, du schiebst etwas weg und ersetzt es durch etwas Neues."
    },
    {
      "lang": "de",
      "text": "Merke dir die Präsensendungen: ich -ez, du -i, er/sie -ă, wir -ăm, ihr -ați, sie -ă – wichtig für die Konjugation von „a schimba“."
    }
  ],
