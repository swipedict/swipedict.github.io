  "source": {
    "lang": "de",
    "headword": "gedeihen",
    "definition": "sich gut entwickeln oder wachsen",
    "pronunciation": "/ɡəˈdaɪ̯ən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „gedeihen“ stammt vom mittelhochdeutschen „gedeihen“ ab, das „wachsen“ oder „gedeihen“ bedeutet, und ist germanischen Ursprungs.",
        "targetText": "Verbul german „gedeihen“ provine din germana mijlocie „gedeihen“, care înseamnă „a crește“ sau „a prospera“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Verb wird oft im Kontext der Natur oder Entwicklung verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a înflori",
    "definition": "a se dezvolta bine sau a crește",
    "pronunciation": "/a ɨnˈflo.ri/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a înflori“ stammt vom lateinischen „florere“ ab, was „blühen“ oder „gedeihen“ bedeutet und beschreibt Wachstum und Entfaltung.",
        "targetText": "Verbul românesc „a înflori“ provine din latină, din „florere“, care înseamnă „a înflori“ sau „a prospera“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Oft verwendet im Kontext von Pflanzen, aber auch metaphorisch für persönliche Entwicklung."
  },
  "relatedWords": [
    {
      "sourceText": "Entwicklung",
      "targetText": "dezvoltare"
    },
    {
      "sourceText": "Fortschritt",
      "targetText": "progres"
    },
    {
      "sourceText": "Wachstum",
      "targetText": "creștere"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verwelken",
      "targetText": "a se ofili"
    }
  ],
  "examples": [
    {
      "sourceText": "Die Blumen gedeihen im Frühling.",
      "targetText": "Florile înfloresc primăvara."
    },
    {
      "sourceText": "Gedeihst du gut im Garten?",
      "targetText": "Înfloarești bine în grădină?"
    },
    {
      "sourceText": "Es gedeiht prächtig.",
      "targetText": "A înflorit magnific."
    },
    {
      "sourceText": "Wir gedeihen zusammen.",
      "targetText": "Noi înflorim împreună."
    },
    {
      "sourceText": "Gedeiht ihr alle gut?",
      "targetText": "Înfloriți toți bine?"
    },
    {
      "sourceText": "Die Pflanzen gedeihen im besten Licht.",
      "targetText": "Plantele înfloresc la cea mai bună lumină."
    },
    {
      "sourceText": "Die Pflanzen haben gut gedeihen.",
      "targetText": "Plantele au înflorit bine."
    },
    {
      "sourceText": "Früher gediehen die Pflanzen besser.",
      "targetText": "În trecut, plantele înfloreau mai bine."
    },
    {
      "sourceText": "Ich werde bald gedeihen!",
      "targetText": "Voi înflori în curând!"
    },
    {
      "sourceText": "Gedeihe gut!",
      "targetText": "Înflorește bine!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„A înflori“ wird oft metaphorisch für persönliches Wachstum verwendet – visualisiere deine eigene Blüte, um das Wort zu merken."
    },
    {
      "lang": "de",
      "text": "Übe die Konjugationen: „Eu înfloresc“ (ich blühe), „Tu înflorești“ (du blühst) – so bleibt das Verb lebendig."
    },
    {
      "lang": "de",
      "text": "Verbinde „gedeihen“ mit blühenden Blumen – stelle dir vor, wie Pflanzen wachsen und blühen, genau wie „a înflori“ im Rumänischen."
    }
  ],
