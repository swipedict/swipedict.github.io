  "source": {
    "lang": "de",
    "headword": "ansprechen",
    "definition": "jemanden anreden oder kontaktieren, um mit ihm zu kommunizieren",
    "pronunciation": "/ˈanʃpʁɛçən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort setzt sich aus dem Präfix ‚an-‘ und dem Verb ‚sprechen‘ zusammen, was ‚reden‘ oder ‚kommunizieren‘ bedeutet.",
        "targetText": "Cuvântul este format din prefixul „an-“ și verbul „sprechen“, care înseamnă „a vorbi“ sau „a comunica“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Wird oft verwendet, um zu beschreiben, dass man jemanden direkt anspricht oder ein Thema zur Sprache bringt."
  },
  "target": {
    "lang": "ro",
    "headword": "a aborda",
    "definition": "a se adresa cuiva sau a contacta pentru a comunica",
    "pronunciation": "/a aborˈda/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort ‚aborda‘ stammt aus dem Französischen ‚aborder‘, mit lateinischen Wurzeln in ‚ad‘ (an, zu) und ‚horda‘ (Heranbringen).",
        "targetText": "Verbul „aborda“ provine din franceză, din „aborder“, cu rădăcini latine în „ad“ (către) și „horda“ (a aduce aproape)."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Häufig verwendet, um zu beschreiben, dass man ein Thema einführt oder jemanden direkt anspricht."
  },
  "relatedWords": [
    {
      "sourceText": "Antwort",
      "targetText": "răspuns"
    },
    {
      "sourceText": "Frage",
      "targetText": "întrebare"
    },
    {
      "sourceText": "Gespräch",
      "targetText": "discuție"
    },
    {
      "sourceText": "Thema",
      "targetText": "temă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "ignorieren",
      "targetText": "a ignora"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich spreche die Mitarbeiter an.",
      "targetText": "Eu abordez angajații."
    },
    {
      "sourceText": "Sprichst du die neuen Ideen an?",
      "targetText": "Abordezi noile idei?"
    },
    {
      "sourceText": "Der Lehrer spricht das Thema an.",
      "targetText": "Profesorul abordează tema."
    },
    {
      "sourceText": "Wir sprechen die Probleme an.",
      "targetText": "Noi abordăm problemele."
    },
    {
      "sourceText": "Sprecht ihr die Herausforderungen an?",
      "targetText": "Abordați provocările?"
    },
    {
      "sourceText": "Sie sprechen die Änderungen an.",
      "targetText": "Ei abordează modificările."
    },
    {
      "sourceText": "Ich habe das Thema angesprochen.",
      "targetText": "Am abordat subiectul."
    },
    {
      "sourceText": "Er sprach das Thema oft an.",
      "targetText": "El aborda adesea subiectul."
    },
    {
      "sourceText": "Ich werde ihn morgen ansprechen.",
      "targetText": "Voi aborda mâine."
    },
    {
      "sourceText": "Ich würde das Problem ansprechen.",
      "targetText": "Aș aborda problema."
    },
    {
      "sourceText": "Sprich das Problem an!",
      "targetText": "Abordează problema!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Ansprechen“ und „aborda“ klingen ähnlich und bedeuten beide, jemanden direkt anzureden oder ein Thema zu behandeln."
    },
    {
      "lang": "de",
      "text": "Merke dir, dass „aborda“ oft für Themen oder Personen verwendet wird, ähnlich wie „ansprechen“."
    },
    {
      "lang": "de",
      "text": "Übe die Formen: „Eu abordez“ (ich spreche an), „Am abordat“ (ich habe angesprochen)."
    }
  ],
