  "source": {
    "lang": "de",
    "headword": "aufmachen",
    "definition": "eine Tür, ein Fenster oder ein Behälter öffnen",
    "pronunciation": "/ˈaʊ̯fˌma.χən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „aufmachen“ setzt sich aus dem Präfix „auf-“ und dem Verb „machen“ zusammen, was „etwas öffnen“ bedeutet.",
        "targetText": "Das deutsche Verb „aufmachen“ kombiniert das Präfix „auf-“ mit „machen“ im Sinne von „öffnen“ oder „zugänglich machen“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Verwendung zum Öffnen von physischen Objekten oder metaphorischen Konzepten, wie z.B. „aufmachen für neue Möglichkeiten“."
  },
  "target": {
    "lang": "ro",
    "headword": "a deschide",
    "definition": "a deschide o ușă, o fereastră sau un recipient",
    "pronunciation": "/a deˈʃki.de/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „a deschide“ hat seinen Ursprung im lateinischen „discadere“, was „öffnen“ bedeutet.",
        "targetText": "Verbul românesc „a deschide“ provine din latinescul „discadere“, care înseamnă „a deschide“ sau „a separa“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation. Verwendung häufig in alltäglichen Situationen, um Türen, Fenster, Buchdeckel usw. zu öffnen."
  },
  "senses": [
    {
      "gloss": "Eine Möglichkeit finden",
      "explanation": {
        "sourceText": "Vor allem im übertragenen Sinne gebraucht.",
        "targetText": "Folosit mai ales în sens figurat."
      },
      "examples": [
        {
          "sourceText": "Manchmal muss man neue Perspektiven aufmachen.",
          "targetText": "Uneori trebuie să deschidem noi perspective."
        }
      ]
    },
    {
      "gloss": "Öffnen (einer Tür, Fenster)",
      "explanation": {
        "sourceText": "Verwendung im deutschen Alltag für das Öffnen von Zugängen.",
        "targetText": "Utilizat în viața de zi cu zi pentru a deschide accesul."
      },
      "examples": [
        {
          "sourceText": "Ich mache die Tür auf.",
          "targetText": "Eu deschid ușa."
        },
        {
          "sourceText": "Könnte jemand das Fenster aufmachen?",
          "targetText": "Poate cineva să deschidă fereastra?"
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Behälter",
      "targetText": "recipient"
    },
    {
      "sourceText": "Fenster",
      "targetText": "fereastră"
    },
    {
      "sourceText": "Öffnen",
      "targetText": "a deschide"
    },
    {
      "sourceText": "Tür",
      "targetText": "ușă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "zumachen",
      "targetText": "a închide"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich mache die Tür auf.",
      "targetText": "Eu deschid ușa."
    },
    {
      "sourceText": "Machst du das Fenster auf?",
      "targetText": "Deschizi fereastra?"
    },
    {
      "sourceText": "Er macht den Koffer auf.",
      "targetText": "El deschide valiza."
    },
    {
      "sourceText": "Wir machen heute die Fenster auf.",
      "targetText": "Noi deschidem astăzi feroneria."
    },
    {
      "sourceText": "Macht ihr die Bücher auf?",
      "targetText": "Deschideți cărțile?"
    },
    {
      "sourceText": "Sie machen die Geschenke auf.",
      "targetText": "Ei deschid cadourile."
    },
    {
      "sourceText": "Ich habe die Schublade aufgemacht.",
      "targetText": "Am deschis sertarul."
    },
    {
      "sourceText": "Er machte das Buch auf.",
      "targetText": "El deschidea cartea."
    },
    {
      "sourceText": "Ich werde die Augen aufmachen.",
      "targetText": "Voi deschide ochii."
    },
    {
      "sourceText": "Ich würde das Spiel aufmachen, wenn ich könnte.",
      "targetText": "Aș deschide jocul, dacă aș putea."
    },
    {
      "sourceText": "Mach das auf!",
      "targetText": "Deschide asta!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Aufmachen“ und „a deschide“ sind direkte Entsprechungen – beide bedeuten „öffnen“. Denk an das Bild einer geöffneten Tür!"
    },
    {
      "lang": "de",
      "text": "Das rumänische „deschide“ klingt wie „deschido“ – stell dir vor, du öffnest etwas mit einem Schlüssel namens „Schido“."
    },
    {
      "lang": "de",
      "text": "Merke dir „ușă“ (Tür) klingt ähnlich wie „uise“ – so kannst du dir leichter merken, was du öffnest."
    },
    {
      "lang": "de",
      "text": "Verbinde das deutsche „auf-“ mit dem rumänischen „des-“ als Präfixe, die oft Öffnung oder Beginn anzeigen."
    }
  ],
