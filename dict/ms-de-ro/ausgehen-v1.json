  "source": {
    "lang": "de",
    "headword": "ausgehen",
    "definition": "das Haus verlassen, um etwas zu tun oder zu unternehmen",
    "pronunciation": "/ˈaʊsˌɡeːən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort setzt sich aus „aus“ und „gehen“ zusammen, was das Verlassen eines Ortes beschreibt.",
        "targetText": "Cuvântul este format din „aus“ și „gehen“, indicând ieșirea dintr-un loc."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Oft für soziale Aktivitäten oder das Verlassen des Hauses verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a ieși",
    "definition": "a părăsi casa pentru a face ceva sau a întreprinde ceva",
    "pronunciation": "/a ieˈʃi/",
    "etymology": {
      "explanation": {
        "sourceText": "„A ieși“ stammt vom lateinischen „exire“ ab, was „hinausgehen“ bedeutet. Es beschreibt das Verlassen eines Ortes oder Raumes.",
        "targetText": "Verbul românesc „a ieși“ derivă din latinescul „exire“, care înseamnă „a ieși afară“. Este folosit pentru a descrie părăsirea unui loc."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-i). Häufig für soziale Aktivitäten verwendet."
  },
  "senses": [
    {
      "gloss": "ausgehen (Freizeit)",
      "explanation": {
        "sourceText": "Wird oft verwendet, um einen sozialen Ausgang zu beschreiben.",
        "targetText": "Este folosit frecvent pentru a descrie ieșiri sociale."
      },
      "examples": [
        {
          "sourceText": "Ich gehe heute Abend aus.",
          "targetText": "Eu ies diseară."
        },
        {
          "sourceText": "Geht ihr zum Fest aus?",
          "targetText": "Ieșiți la festival?"
        }
      ]
    },
    {
      "gloss": "ausgehen (örtlich)",
      "explanation": {
        "sourceText": "Kann auch bedeuten, dass man einen bestimmten Ort verlässt.",
        "targetText": "Poate însemna și părăsirea unui loc specific."
      },
      "examples": [
        {
          "sourceText": "Er geht gerne ins Kino aus.",
          "targetText": "El îi place să iasă la cinema."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Freund",
      "targetText": "prieten"
    },
    {
      "sourceText": "Restaurant",
      "targetText": "restaurant"
    },
    {
      "sourceText": "Unterhaltung",
      "targetText": "divertisment"
    },
    {
      "sourceText": "Veranstaltung",
      "targetText": "eveniment"
    }
  ],
  "antonyms": [
    {
      "sourceText": "einziehen",
      "targetText": "a intra"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich gehe heute Abend aus.",
      "targetText": "Eu ies diseară."
    },
    {
      "sourceText": "Geht du oft aus?",
      "targetText": "Ieși des?"
    },
    {
      "sourceText": "Er geht gerne ins Kino aus.",
      "targetText": "El îi place să iasă la cinema."
    },
    {
      "sourceText": "Wir gehen morgen aus essen.",
      "targetText": "Noi ieșim mâine la masă."
    },
    {
      "sourceText": "Geht ihr zum Fest aus?",
      "targetText": "Ieșiți la festival?"
    },
    {
      "sourceText": "Sie gehen oft zusammen aus.",
      "targetText": "Ei ies împreună adesea."
    },
    {
      "sourceText": "Ich bin gestern ausgegangen.",
      "targetText": "Am ieșit ieri."
    },
    {
      "sourceText": "Ich werde morgen ausgehen.",
      "targetText": "Voi ieși mâine."
    },
    {
      "sourceText": "Geh aus!",
      "targetText": "Ieși!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Ausgehen“ kannst du dir als „nach draußen gehen“ vorstellen – so merkst du dir die Bedeutung von „a ieși“."
    },
    {
      "lang": "de",
      "text": "Das rumänische „a ieși“ ist kurz und klar – perfekt, um das deutsche „ausgehen“ zu ersetzen."
    },
    {
      "lang": "de",
      "text": "Erinnere dich an die lateinische Wurzel „exire“ für „hinausgehen“ – das hilft beim Merken von „a ieși“."
    }
  ],
