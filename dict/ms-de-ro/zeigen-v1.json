  "source": {
    "lang": "de",
    "headword": "zeigen",
    "definition": "etwas sichtbar machen oder darlegen",
    "pronunciation": "/ˈtsaɪ̯ɡn̩/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „zeigen“ stammt vom mittelhochdeutschen „zeigen“ ab, verwandt mit althochdeutschem „zeigōn“ und gotischem „gaitwō“, alle bedeutend „zeigen“ oder „offenbaren“.",
        "targetText": "Verbul german „zeigen“ provine din germana mijlocie „zeigen“, înrudit cu germana veche „zeigōn“ și goticul „gaitwō“, toate însemnând „a arăta“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Verb wird verwendet, um Informationen oder Objekte zu präsentieren oder zu demonstrieren, sowohl verbal als auch visuell."
  },
  "target": {
    "lang": "ro",
    "headword": "a arăta",
    "definition": "a face ceva vizibil sau a demonstra",
    "pronunciation": "/a a.rəˈta/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a arăta“ stammt vom lateinischen „ad radere“ ab, was „zeigen“ oder „enthüllen“ bedeutet und im Alltag häufig verwendet wird.",
        "targetText": "Verbul românesc „a arăta“ provine din latină, de la „ad radere“, care înseamnă „a arăta“ sau „a dezvălui“ și este folosit frecvent în limbajul cotidian."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird verwendet, um etwas zu demonstrieren oder zu offenbaren."
  },
  "relatedWords": [
    {
      "sourceText": "Blick",
      "targetText": "privire"
    },
