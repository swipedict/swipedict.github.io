      "targetText": "a ascunde"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich zeige dir mein neues Buch.",
      "targetText": "Îți arăt cartea mea nouă."
    },
    {
      "sourceText": "Zeigst du mir das Bild?",
      "targetText": "Îmi arăți poza?"
    },
    {
      "sourceText": "Er zeigt dir seine Skills.",
      "targetText": "El îți arată abilitățile lui."
    },
    {
      "sourceText": "Wir zeigen euch die Stadt.",
      "targetText": "Noi vă arătăm orașul."
    },
    {
      "sourceText": "Zeigen Sie uns die Fotos!",
      "targetText": "Arătați-ne fotografiile!"
    },
    {
      "sourceText": "Sie zeigen ihre Unterstützung.",
      "targetText": "Ei își arată susținerea."
    },
    {
      "sourceText": "Ich habe dir die Lösung gezeigt.",
      "targetText": "Ți-am arătat soluția."
    },
    {
      "sourceText": "Ich werde dir das Geheimnis zeigen.",
      "targetText": "Îți voi arăta secretul."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Übe Sätze mit „a arăta“, um zu lernen, wie man Dinge präsentiert oder zeigt."
    },
    {
      "lang": "de",
      "text": "Verbinde „a arăta“ mit dem Bild eines Zeigens mit dem Finger – so merkst du dir die Bedeutung leicht."
    }
  ],
