  "source": {
    "lang": "de",
    "headword": "tun",
    "definition": "eine Handlung ausführen oder vollziehen",
    "pronunciation": "/tuːn/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „tun“ stammt vom althochdeutschen „tonu“ und mittelhochdeutschen „tun“, was „machen“ oder „ausführen“ bedeutet.",
        "targetText": "Verbul „tun“ provine din germana veche „tonu“ și germana mijlocie „tun“, care înseamnă „a face“ sau „a executa“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Unregelmäßiges Verb mit vielseitiger Verwendung, oft als Hilfsverb in bestimmten Redewendungen."
  },
  "target": {
    "lang": "ro",
    "headword": "a face",
    "definition": "a efectua sau a realiza o acțiune",
    "pronunciation": "/a ˈfa.t͡ʃe/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a face“ stammt vom lateinischen „facere“, was „machen“ oder „tun“ bedeutet. Es ist ein häufig genutztes Verb für Handlungen.",
        "targetText": "Verbul românesc „a face“ provine din latină „facere“, care înseamnă „a face“ sau „a executa“. Este un verb frecvent folosit pentru acțiuni."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 3. Konjugation (-e). „a face“ ist eines der häufigsten Verben in der rumänischen Sprache."
  },
  "relatedWords": [
    {
      "sourceText": "arbeiten",
      "targetText": "a lucra"
    },
    {
      "sourceText": "handeln",
      "targetText": "a acționa"
    },
    {
      "sourceText": "machen",
      "targetText": "a face"
    },
    {
      "sourceText": "verrichten",
      "targetText": "a îndeplini"
    }
  ],
  "antonyms": [
    {
      "sourceText": "lassen",
      "targetText": "a lăsa"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich tue mein Bestes.",
      "targetText": "Fac tot ce pot."
    },
    {
      "sourceText": "Was tust du da?",
      "targetText": "Ce faci acolo?"
    },
    {
      "sourceText": "Er/Sie tut das Richtige.",
      "targetText": "El/Ea face ceea ce este corect."
    },
    {
      "sourceText": "Wir tun es gemeinsam.",
      "targetText": "Facem asta împreună."
    },
    {
      "sourceText": "Was tut ihr da?",
      "targetText": "Ce faceți acolo?"
    },
    {
      "sourceText": "Sie tun alles dafür.",
      "targetText": "Ei fac tot posibilul."
    },
    {
      "sourceText": "Ich habe das nötige getan.",
      "targetText": "Am făcut ceea ce trebuie."
    },
    {
      "sourceText": "Er/Sie tat es oft.",
      "targetText": "El/Ea făcea frecvent asta."
    },
    {
      "sourceText": "Ich werde es morgen tun.",
      "targetText": "Voi face asta mâine."
    },
    {
      "sourceText": "Ich würde es gerne tun.",
      "targetText": "Aș dori să fac asta."
    },
    {
      "sourceText": "Tu es einfach!",
      "targetText": "Fă-o simplu!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Tun“ und „a face“ sind Kognaten – beide bedeuten „machen“ und sind häufig genutzte Verben für Handlungen."
    },
    {
      "lang": "de",
      "text": "Merke dir „a face“ als vielseitiges Verb, das viele Arten von Tätigkeiten beschreibt – ähnlich wie „tun“ im Deutschen."
    }
  ],
