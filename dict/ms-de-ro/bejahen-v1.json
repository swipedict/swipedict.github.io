  "source": {
    "lang": "de",
    "headword": "bejahen",
    "definition": "etwas bestätigen oder zustimmen",
    "pronunciation": "/beˈjaːən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „bejahen“ setzt sich aus dem Präfix „be-“ und dem Wort „ja“ zusammen, was „ja sagen“ bedeutet. Es beschreibt die Handlung, etwas zu bestätigen oder zuzustimmen.",
        "targetText": "Verbul german „bejahen“ este format din prefixul „be-“ și cuvântul „ja“ (da), exprimând acordul sau confirmarea."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Häufig in Kontexten der Zustimmung oder Bestätigung verwendet, z. B. in Gesprächen oder Abstimmungen."
  },
  "target": {
    "lang": "ro",
    "headword": "a aproba",
    "definition": "a aproba sau a spune da la ceva",
    "pronunciation": "/a a.proˈba/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a aproba“ stammt vom lateinischen „approbare“ ab, was „billigen“ oder „zustimmen“ bedeutet. Es beschreibt die Handlung, etwas positiv zu bewerten oder zu akzeptieren.",
        "targetText": "Verbul românesc „a aproba“ provine din latină, de la „approbare“, care înseamnă a accepta sau a aproba ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird oft in formellen sowie informellen Kontexten verwendet, um Zustimmung auszudrücken."
  },
  "relatedWords": [
    {
      "sourceText": "Antwort",
      "targetText": "răspuns"
    },
    {
      "sourceText": "Einverständnis",
      "targetText": "consimțământ"
    },
    {
      "sourceText": "Ja",
      "targetText": "da"
    },
    {
      "sourceText": "Zustimmung",
      "targetText": "aprobat"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verneinen",
      "targetText": "a nega"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich bejahe den Vorschlag.",
      "targetText": "Eu aprob propunerea."
    },
    {
      "sourceText": "Bejahst du die Idee?",
      "targetText": "Aprobi ideea?"
    },
    {
      "sourceText": "Der Vorstand bejaht den Plan.",
      "targetText": "Consiliul aprobă planul."
    },
    {
      "sourceText": "Wir bejahen die neue Regelung.",
      "targetText": "Noi aprobăm noua reglementare."
    },
    {
      "sourceText": "Bejaht ihr die Änderung?",
      "targetText": "Aprobați modificarea?"
    },
    {
      "sourceText": "Sie (Pl.) bejahen die Entscheidung.",
      "targetText": "Ei aprobă decizia."
    },
    {
      "sourceText": "Ich habe den Antrag bejaht.",
      "targetText": "Am aprobat cererea."
    },
    {
      "sourceText": "Er bejahte die Fragen des Interviewers.",
      "targetText": "El aproba întrebările interviewerului."
    },
    {
      "sourceText": "Ich werde den Bericht bejahen.",
      "targetText": "Voi aproba raportul."
    },
    {
      "sourceText": "Ich würde es bejahen, wenn ich könnte.",
      "targetText": "Aș aproba, dacă aș putea."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Merke dir die Endung „-a“ bei „aproba“ als typisches Verb der 1. Konjugation, ähnlich wie viele deutsche Verben mit „-en“."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du sagst in beiden Sprachen „Ja“ zu einem Vorschlag – so merkst du dir die Wörter besser."
    },
    {
      "lang": "de",
      "text": "Verbinde „bejahen“ mit „aproba“ durch die gemeinsame Bedeutung „zustimmen“ – beide drücken ein klares Ja aus."
    }
  ],
