  "source": {
    "lang": "de",
    "headword": "enden",
    "definition": "zum Abschluss kommen; das Ende erreichen",
    "pronunciation": "/ˈɛndn̩/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom mittelhochdeutschen „enden“, was so viel wie „zu Ende bringen“ bedeutet und sich von der Wurzel „int“ leitet, die mit „Ende“ verwandt ist.",
        "targetText": "Verbul provine din germana mijlocie „enden“, însemnând „a aduce la sfârșit“, legat de rădăcina „int“ asociată cu „sfârșit“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": ""
  },
  "target": {
    "lang": "ro",
    "headword": "a termina",
    "definition": "a ajunge la sfârșit; a încheia",
    "pronunciation": "/a terˈmi.na/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a termina“ stammt vom lateinischen „terminare“ ab, was „beenden“ bedeutet. Es bezieht sich auf das Setzen eines Endpunkts in einem Prozess.",
        "targetText": "Verbul românesc „a termina“ derivă din latinescul „terminare“, care înseamnă „a încheia“, indicând stabilirea unui punct final într-un proces."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Verwendung in vielen Kontexten, von alltäglichen Aufgaben bis hin zu komplexen Projekten."
  },
  "relatedWords": [
    {
      "sourceText": "Beginn",
      "targetText": "început"
    },
    {
      "sourceText": "Dauer",
      "targetText": "durată"
    },
    {
      "sourceText": "Prozess",
      "targetText": "proces"
    },
    {
      "sourceText": "Schluss",
      "targetText": "sfârșit"
    }
  ],
  "antonyms": [
    {
      "sourceText": "anfangen",
      "targetText": "a începe"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich ende meine Arbeit um fünf Uhr.",
      "targetText": "Termin munca mea la cinci."
    },
    {
      "sourceText": "Endest du oft spät?",
      "targetText": "Termini adesea târziu?"
    },
    {
      "sourceText": "Er endet seine Rede.",
      "targetText": "El își termină discursul."
    },
    {
      "sourceText": "Wir enden die Sitzung um eins.",
      "targetText": "Terminăm ședința la una."
    },
    {
      "sourceText": "Endet ihr das Projekt?",
      "targetText": "Terminați proiectul?"
    },
    {
      "sourceText": "Sie beenden das Treffen.",
      "targetText": "Ei termină întâlnirea."
    },
    {
      "sourceText": "Ich habe meine Studie erfolgreich beendet.",
      "targetText": "Am terminat cu succes studiul meu."
    },
    {
      "sourceText": "Er endete die Diskussion.",
      "targetText": "El termina discuția."
    },
    {
      "sourceText": "Ich werde es heute beenden.",
      "targetText": "Voi termina astăzi."
    },
    {
      "sourceText": "Ich würde es beenden müssen, wenn ich Zeit hätte.",
      "targetText": "Ar trebui să îl termin, dacă aș avea timp."
    },
    {
      "sourceText": "Beende deine Arbeit!",
      "targetText": "Termină-ți munca!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Achte auf die Präsens-Endungen im Rumänischen, z.B. „termini“ (du beendest), die dir helfen, das Verb zu erkennen."
    },
    {
      "lang": "de",
      "text": "Das deutsche „enden“ und das rumänische „a termina“ bedeuten beide ‚beenden‘. Denk an „terminator“ im Deutschen, der etwas beendet – so merkst du dir „termina“ leicht."
    },
    {
      "lang": "de",
      "text": "Übe einfache Sätze wie „Eu termin“ (Ich beende), um das Verb in Alltagssituationen zu verinnerlichen."
    }
  ],
