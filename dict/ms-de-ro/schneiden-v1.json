  },
  "source": {
    "lang": "de",
    "headword": "schneiden",
    "definition": "mit einem scharfen Werkzeug etwas in Stücke teilen",
    "pronunciation": "/ˈʃnaɪ̯dən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort geht zurück auf das mittelhochdeutsche „snīden“, was „schneiden“ bedeutet, und verweist auf eine alte Wurzel in der indogermanischen Sprachfamilie.",
        "targetText": "Cuvântul german „schneiden“ provine din mijlocul germanicului „snīden“, care înseamnă „a tăia“, având rădăcini indo-europene vechi."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "„Schneiden“ ist ein häufig verwendetes Wort in vielen Handwerken, sei es in der Küche oder in der Textilindustrie."
  },
  "target": {
    "lang": "ro",
    "headword": "a tăia",
    "definition": "a împărți ceva în bucăți cu un instrument ascuțit",
    "pronunciation": "/təˈja/",
    "etymology": {
      "explanation": {
        "sourceText": "„A tăia“ entstammt dem lateinischen „tangere“, was „berühren, schneiden“ bedeutet. Das Wort entwickelte sich im Rumänischen und beschreibt das Schneiden.",
        "targetText": "Verbul românesc „a tăia“ derivă din latinul „tangere“, care înseamnă „a atinge, a tăia“. Este folosit pentru a descrie acțiunea de a tăia ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Verb ist wichtig in der Küche, Holzbearbeitung und anderen Handwerken."
  },
  "relatedWords": [
    {
      "sourceText": "Gemüse",
      "targetText": "legume"
    },
    {
      "sourceText": "Küchenmaschine",
      "targetText": "robot de bucătărie"
    },
    {
      "sourceText": "Messer",
      "targetText": "cuțit"
    },
    {
      "sourceText": "Obst",
      "targetText": "fructe"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verbinden",
      "targetText": "a uni"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich schneide das Gemüse.",
      "targetText": "Eu tai legumele."
    },
    {
      "sourceText": "Schneidest du das Brot?",
      "targetText": "Tai pâinea?"
    },
    {
      "sourceText": "Sie schneidet die Blumen.",
      "targetText": "Ea taie florile."
    },
    {
      "sourceText": "Wir schneiden das Fleisch.",
      "targetText": "Noi tăiem carnea."
    },
    {
      "sourceText": "Schneidet ihr die Karte?",
      "targetText": "Tăiați harta?"
    },
    {
      "sourceText": "Sie schneiden die Stoffe.",
      "targetText": "Ei taie materialele."
    },
    {
      "sourceText": "Ich habe das Papier geschnitten.",
      "targetText": "Am tăiat hârtia."
    },
    {
      "sourceText": "Er schnitt die Wurst jeden Morgen.",
      "targetText": "El tăia cârnații în fiecare dimineață."
    },
    {
      "sourceText": "Ich werde das Obst schneiden.",
      "targetText": "Voi tăia fructele."
    },
    {
      "sourceText": "Ich würde die Holzlatte schneiden, wenn ich die Säge hätte.",
      "targetText": "Aș tăia scandura dacă aș avea ferăstrăul."
    },
    {
      "sourceText": "Der geschnittene Stoff ist bereit.",
      "targetText": "Materialul tăiat este pregătit."
    },
    {
      "sourceText": "Indem ich das Papier schneide, erstelle ich eine Karte.",
      "targetText": "Tăind hârtia, fac o felicitare."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „a tăia“ kannst du dir merken, indem du an das Schneiden in der Küche denkst – einfach „tăia“ wie „teilen“."
    },
    {
      "lang": "de",
      "text": "Die Präsensendungen „-ez“, „-i“ und „-ă“ helfen dir, die Konjugation von „a tăia“ zu lernen."
    },
    {
      "lang": "de",
      "text": "Stell dir einen Koch vor, der Gemüse schneidet – so bleibt das Wort lebendig und leicht zu merken."
    }
  ],
