  "sourceLanguage": "de",
  "targetLanguage": "ro",
  "metadata": {
    "author": "mschwehl",
    "source": "Etymological Dictionaries, Linguistic Analysis",
    "contentVersion": 1,
    "schemaVersion": "1.0"
  },
  "source": {
    "lang": "de",
    "headword": "nutzen",
    "definition": "etwas verwenden oder einen Vorteil daraus ziehen",
    "pronunciation": "/ˈnʊt͡sən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „nutzen“ stammt vom mittelhochdeutschen „nützen“, was „vorteilhaft sein“ bedeutet.",
        "targetText": "Verbul „nutzen“ provine din germana mijlocie „nützen“, care înseamnă „a fi avantajos“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Oft im Kontext von Ressourcen verwenden, um deren Vorteile zu maximieren."
  },
  "target": {
    "lang": "ro",
    "headword": "a folosi",
    "definition": "a utiliza sau a obține un beneficiu din ceva",
    "pronunciation": "/a foˈlosi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „a folosi“ stammt vom rumänischen „folose“, mit lateinischem Einfluss von „folere“ (gebrauchen).",
        "targetText": "Verbul „a folosi“ provine din românescul „folose“, cu influențe latine din „folere“ (a folosi)."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-i). Oft in Kombination mit Werkzeugen oder Ressourcen verwendet."
  },
  "senses": [
    {
      "gloss": "Benutzen / Verwenden",
      "explanation": {
        "sourceText": "Normalerweise verwendet, um Ressourcen optimal zu nutzen.",
        "targetText": "Folosit de obicei pentru a utiliza resursele în mod optim."
      },
      "examples": [
        {
          "sourceText": "Ich benutze mein Handy.",
          "targetText": "Eu folosesc telefonul meu."
        }
      ]
    },
    {
      "gloss": "Nutzen ziehen",
      "explanation": {
        "sourceText": "Oft in der Bedeutung 'Vorteile aus etwas ziehen' verwendet.",
        "targetText": "Adesea folosit cu sensul de a obține avantaje din ceva."
      },
      "examples": [
        {
          "sourceText": "Sie nutzen die Vorteile der Schule.",
          "targetText": "Ei folosesc avantajele școlii."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Anwendung",
      "targetText": "aplicare"
    },
    {
      "sourceText": "Ressource",
      "targetText": "resursă"
    },
    {
      "sourceText": "Verwendung",
      "targetText": "utilizare"
    },
    {
      "sourceText": "Vorteil",
      "targetText": "avantaj"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verschwenden",
      "targetText": "a risipi"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich nutze diese Gelegenheit.",
      "targetText": "Eu folosesc această oportunitate."
    },
    {
      "sourceText": "Nutze deine Ressourcen weise!",
      "targetText": "Folosește-ți resursele cu înțelepciune!"
    },
    {
      "sourceText": "Er nutzt die Zeit gut.",
      "targetText": "El folosește bine timpul."
    },
    {
      "sourceText": "Wir nutzen die Möglichkeit.",
      "targetText": "Noi folosim oportunitatea."
    },
    {
      "sourceText": "Nutzt ihr die Vorteile daraus?",
      "targetText": "Folosiți avantajele de acolo?"
    },
    {
      "sourceText": "Sie nutzen die Software effektiv.",
      "targetText": "Ei folosesc software-ul eficient."
    },
    {
      "sourceText": "Ich habe die Möglichkeit genutzt.",
      "targetText": "Am folosit oportunitatea."
    },
    {
      "sourceText": "Ich werde die Chance nutzen.",
      "targetText": "Voi folosi ocazia."
    },
    {
      "sourceText": "Nutze deinen Verstand!",
      "targetText": "Folosește-ți mintea!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Denke daran, dass „a folosi“ oft im Alltag benutzt wird, z.B. beim Verwenden von Geräten oder Ressourcen."
    },
    {
      "lang": "de",
      "text": "Merke dir die Präsensformen: „folosesc“ (ich), „folosești“ (du), „folosește“ (er/sie/es)."
    },
    {
      "lang": "de",
      "text": "Wenn du „nutzen“ hörst, stelle dir vor, wie du ein Werkzeug oder eine Ressource einsetzt – das ist „a folosi“."
    }
  ],
