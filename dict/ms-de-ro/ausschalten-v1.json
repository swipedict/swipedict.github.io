      "targetText": "curent"
    }
  ],
  "antonyms": [
    {
      "sourceText": "einschalten",
      "targetText": "a porni"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich schalte das Licht aus.",
      "targetText": "Eu opresc lumina."
    },
    {
      "sourceText": "Schaltest du den Fernseher aus?",
      "targetText": "Oprești televizorul?"
    },
    {
      "sourceText": "Er schaltet den Computer aus.",
      "targetText": "El oprește calculatorul."
    },
    {
      "sourceText": "Wir schalten jetzt die Anlage aus.",
      "targetText": "Noi oprim acum sistemul."
    },
    {
      "sourceText": "Schaltet ihr die Geräte aus?",
      "targetText": "Opriți aparatele?"
    },
    {
      "sourceText": "Sie (Pl.) schalten die Lichter aus.",
      "targetText": "Ei opresc luminile."
    },
    {
      "sourceText": "Ich habe den Computer ausgestellt.",
      "targetText": "Am oprit calculatorul."
    },
    {
      "sourceText": "Er schaltete das Radio jeden Abend aus.",
      "targetText": "El oprea radioul în fiecare seară."
    },
    {
      "sourceText": "Ich werde die Heizung ausschalten.",
      "targetText": "Voi opri încălzirea."
    },
    {
      "sourceText": "Ich würde das Licht ausschalten.",
      "targetText": "Aș opri lumina."
    },
    {
      "sourceText": "Schalte das Gerät aus!",
      "targetText": "Oprește aparatul!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„A opri“ klingt wie „stoppen“ – stelle dir vor, wie du den Stecker ziehst und das Gerät ausschaltest."
    },
    {
      "lang": "de",
      "text": "„A opri“ wird oft bei Geräten benutzt – genau wie „ausschalten“ im Deutschen."
    },
    {
      "lang": "de",
      "text": "Merke dir die Form „opresc“ (ich schalte aus) als Verbindung zu „ich schalte“ im Deutschen."
    }
  ],
