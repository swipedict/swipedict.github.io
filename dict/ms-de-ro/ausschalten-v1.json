  "source": {
    "lang": "de",
    "headword": "ausschalten",
    "definition": "etwas in einen Zustand versetzen, in dem es nicht mehr funktioniert oder aktiv ist",
    "pronunciation": "/ˈaʊsˌʃaltən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „ausschalten“ setzt sich aus „aus“ und „schalten“ zusammen. „Schalten“ stammt vom mittelhochdeutschen „schalten“ und bedeutet „steuern“ oder „umschalten“.",
        "targetText": "Verbul german „ausschalten“ provine din „aus“ + „schalten“ (a comuta), indicând oprirea unui aparat."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Häufig im Kontext von elektronischen Geräten verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a opri",
    "definition": "a face ca ceva să nu mai funcționeze sau să nu mai fie activ",
    "pronunciation": "/a oˈpri/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a opri“ stammt vom slawischen „oprìti“, was „anhalten“ oder „stoppen“ bedeutet. Es wird verwendet, um das Ausschalten oder Stoppen eines Geräts oder Prozesses zu beschreiben.",
        "targetText": "Verbul român „a opri“ provine din slavonă „oprìti“, însemnând a opri sau a întrerupe funcționarea."
      },
      "source": "AI, Wiktionary, Etymological Dictionaries"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-i). In technischen Kontexten oft verwendet."
  },
  "senses": [
    {
      "gloss": "a opri (Gerät ausschalten)",
      "explanation": {
        "sourceText": "Ein Gerät in einen inaktiven Zustand versetzen.",
        "targetText": "A face un aparat să nu mai funcționeze."
      },
      "examples": [
        {
          "sourceText": "Ich schalte das Licht aus.",
          "targetText": "Eu opresc lumina."
        },
        {
          "sourceText": "Schaltest du den Fernseher aus?",
          "targetText": "Oprești televizorul?"
        }
      ]
    },
    {
      "gloss": "a opri (Prozess stoppen)",
      "explanation": {
        "sourceText": "Einen Vorgang oder Prozess anhalten.",
        "targetText": "A întrerupe un proces."
      },
      "examples": [
        {
          "sourceText": "Wir schalten jetzt die Anlage aus.",
          "targetText": "Noi oprim acum sistemul."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Fernbedienung",
