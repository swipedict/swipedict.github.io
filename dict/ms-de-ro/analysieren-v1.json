  "source": {
    "lang": "de",
    "headword": "analysieren",
    "definition": "Etwas genau untersuchen, um seine Bestandteile oder Eigenschaften zu verstehen.",
    "pronunciation": "/anaˈlyːziːʁən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „analysieren“ stammt vom griechischen Wort 'analusis' ab, was 'Auflösung' oder 'Zerlegung' bedeutet.",
        "targetText": "Verbul german „analysieren” provine din grecescul 'analusis', care înseamnă 'dezlegare' sau 'descompunere'."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "target": {
    "lang": "ro",
    "headword": "a analiza",
    "definition": "A examina ceva în detaliu pentru a înțelege componentele sau proprietățile sale.",
    "pronunciation": "/a aˈna.li.za/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a analiza“ stammt vom griechischen 'analusis' über das Lateinische und Französische ins Rumänische.",
        "targetText": "Verbul românesc „a analiza” provine din grecescul 'analusis', prin latină și franceză, păstrând sensul de a examina în detaliu."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Verb der 1. Konjugation."
  },
  "senses": [],
  "relatedWords": [
