  "examples": [
    {
      "sourceText": "Ich analysiere die Daten sorgfältig.",
      "targetText": "Eu analizez datele cu atenție."
    },
    {
      "sourceText": "Wir haben das Problem analysiert.",
      "targetText": "Am analizat problema."
    },
    {
      "sourceText": "Er analysierte die Situation genau.",
      "targetText": "El analiza situația cu atenție."
    },
    {
      "sourceText": "Sie wird die Ergebnisse analysieren.",
      "targetText": "Ea va analiza rezultatele."
    },
    {
      "sourceText": "Analysiere die Informationen gründlich!",
      "targetText": "Analizează informațiile temeinic!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische Verb endet auf '-a', typisch für die 1. Konjugation – übe die Formen: eu analizez, tu analizezi, el analizează."
    },
    {
      "lang": "de",
      "text": "Das Wort „analysieren“ und das rumänische „a analiza“ klingen sehr ähnlich – beide stammen vom griechischen 'analusis'."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du zerlegst ein Puzzle – 'analysieren' bedeutet genau das: etwas in seine Teile zerlegen, um es zu verstehen."
    },
    {
      "lang": "de",
      "text": "Verbinde 'analysieren' mit dem englischen 'analysis' – so merkst du dir die Bedeutung und die Herkunft leichter."
    }
  ],
