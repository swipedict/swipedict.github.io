  "source": {
    "lang": "de",
    "headword": "binden",
    "definition": "etwas zusammenfügen oder festmachen mit einem Band oder Schnur",
    "pronunciation": "/ˈbɪndən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „binden“ stammt vom mittelhochdeutschen „binden“, was „verbinden“ oder „fixieren“ bedeutet.",
        "targetText": "Verbul german „binden“ provine din mijlocul german și înseamnă „a lega“ sau „a fixa“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Es wird oft in physischer und metaphorischer Form verwendet, z.B. um Dinge zusammenzuhalten oder Beziehungen herzustellen."
  },
  "target": {
    "lang": "ro",
    "headword": "a lega",
    "definition": "a aduna sau a fixa ceva cu un band sau o sfoară",
    "pronunciation": "/a leˈɡa/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a lega“ stammt vom lateinischen „ligare“, was „verbinden“ oder „festbinden“ bedeutet. Es hat viele verwandte Begriffe in romanischen Sprachen hervorgebracht.",
        "targetText": "Verbul românesc „a lega“ provine din latină, din „ligare“, care înseamnă „a lega“ sau „a fixa“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Es wird häufig in verschiedenen Kontexten verwendet, von physischen Bindungen bis hin zu metaphorischen Bindungen zwischen Menschen."
  },
  "senses": [
    {
      "gloss": "binden (festmachen)",
      "explanation": {
        "sourceText": "Kann verwendet werden, um eine physische Verbindung herzustellen.",
        "targetText": "Poate fi folosit pentru a crea o legătură fizică."
      },
      "examples": [
        {
          "sourceText": "Ich binde das Geschenk fest.",
          "targetText": "Îmi leg cadoul bine."
        }
      ]
    },
    {
      "gloss": "binden (verknüpfen)",
      "explanation": {
        "sourceText": "Bedeutet, Dinge oder Menschen miteinander zu verbinden.",
        "targetText": "Înseamnă a conecta lucruri sau oameni între ei."
      },
      "examples": [
        {
          "sourceText": "Wir binden uns in der Gemeinschaft.",
          "targetText": "Ne legăm în comunitate."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Band",
      "targetText": "bandă"
    },
    {
      "sourceText": "Halsband",
      "targetText": "zgardă"
    },
    {
      "sourceText": "Knoten",
      "targetText": "nod"
    },
    {
      "sourceText": "Schnur",
      "targetText": "sfoară"
    }
  ],
  "antonyms": [
    {
      "sourceText": "lösen",
      "targetText": "a desfășura"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich binde die Schnur fest.",
      "targetText": "Îmi leg sfoara bine."
    },
    {
      "sourceText": "Bindest du das Paket für mich?",
      "targetText": "Legești tu pachetul pentru mine?"
    },
    {
      "sourceText": "Er bindet die Bücher mit einer Schnur.",
      "targetText": "El leagă cărțile cu o sfoară."
    },
    {
      "sourceText": "Wir binden uns an die Vereinbarung.",
      "targetText": "Ne legăm de acord."
    },
    {
      "sourceText": "Bindet ihr die Materialien zusammen?",
      "targetText": "Legeați voi materialele împreună?"
    },
    {
      "sourceText": "Sie binden eine enge Freundschaft.",
      "targetText": "Ei leagă o prietenie strânsă."
    },
    {
      "sourceText": "Ich habe das Projekt erfolgreich gebunden.",
      "targetText": "Am legat proiectul cu succes."
    },
    {
      "sourceText": "Er band die Hände zusammen.",
      "targetText": "El lega mâinile împreună."
    },
    {
      "sourceText": "Ich werde das Geschenk binden.",
      "targetText": "Voi lega cadoul."
    },
    {
      "sourceText": "Binde das Seil!",
      "targetText": "Legați frânghia!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „a lega“ klingt ähnlich wie das deutsche „legen“ – stell dir vor, du legst etwas zusammen und bindest es fest!"
    },
    {
      "lang": "de",
      "text": "Denk an das lateinische „ligare“ – viele Wörter rund um „binden“ stammen davon, das hilft dir, „a lega“ zu behalten."
    }
  ],
