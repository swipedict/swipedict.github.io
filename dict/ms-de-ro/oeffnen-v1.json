  },
  "source": {
    "lang": "de",
    "headword": "öffnen",
    "definition": "eine Tür oder ein Behälter aufmachen",
    "pronunciation": "/ˈœfn̩/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort „öffnen“ stammt vom mittelhochdeutschen „öffen“, was „öffnen, aufmachen“ bedeutet.",
        "targetText": "Cuvântul „öffnen“ provine din germana mijlocie „öffen“, care înseamnă „a deschide“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb, das oft im technischen Kontext oder bei physischen Objekten verwendet wird."
  },
  "target": {
    "lang": "ro",
    "headword": "a deschide",
    "definition": "a deschide o ușă sau un recipient",
    "pronunciation": "/a deˈʃkide/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a deschide“ stammt vom lateinischen „apertura“ (Öffnung) ab und ist mit dem altrumänischen „deschid“ verwandt.",
        "targetText": "Verbul românesc „a deschide“ provine din latinescul „apertura“ (deschidere) și este înrudit cu vechiul românesc „deschid“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-i). Wird verwendet, um Türen, Fenster usw. zu öffnen."
  },
  "senses": [
    {
      "gloss": "öffnen (Möglichkeit)",
      "explanation": {
        "sourceText": "Bedeutet, Möglichkeiten oder Chancen zu eröffnen.",
        "targetText": "Înseamnă a deschide posibilități sau oportunități."
      },
      "examples": [
        {
          "sourceText": "Wir öffnen die Gelegenheit.",
          "targetText": "Noi deschidem oportunitatea."
        }
      ]
    },
    {
      "gloss": "öffnen (Tür, Behälter)",
      "explanation": {
        "sourceText": "Bezieht sich auf das Öffnen physischer Objekte.",
        "targetText": "Se referă la deschiderea obiectelor fizice."
      },
      "examples": [
        {
          "sourceText": "Ich öffne die Tür.",
          "targetText": "Eu deschid ușa."
        },
        {
          "sourceText": "Öffnest du das Fenster?",
          "targetText": "Deschizi fereastra?"
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Behälter",
      "targetText": "recipient"
    },
    {
      "sourceText": "Fenster",
      "targetText": "fereastră"
    },
    {
      "sourceText": "Schlüssel",
      "targetText": "cheie"
    },
    {
      "sourceText": "Tür",
      "targetText": "ușă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "schließen",
      "targetText": "a închide"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich öffne die Tür.",
      "targetText": "Eu deschid ușa."
    },
    {
      "sourceText": "Öffnest du das Fenster?",
      "targetText": "Deschizi fereastra?"
    },
    {
      "sourceText": "Er öffnet die Flasche.",
      "targetText": "El deschide sticla."
    },
    {
      "sourceText": "Wir öffnen das Portal.",
      "targetText": "Noi deschidem portalul."
    },
    {
      "sourceText": "Öffnet ihr die Anwendung?",
      "targetText": "Deschideți aplicația?"
    },
    {
      "sourceText": "Sie öffnen die Gelegenheit.",
      "targetText": "Ei deschid oportunitatea."
    },
    {
      "sourceText": "Ich habe den Deckel geöffnet.",
      "targetText": "Am deschis capacul."
    },
    {
      "sourceText": "Ich werde das Geschenk öffnen.",
      "targetText": "Voi deschide cadoul."
    },
    {
      "sourceText": "Öffne das Buch!",
      "targetText": "Deschide cartea!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„a deschide“ wird für physische und metaphorische Öffnungen verwendet – z.B. Türen oder Möglichkeiten."
    },
    {
      "lang": "de",
      "text": "Achte auf die Verbformen: „deschid“ (ich), „deschizi“ (du), „deschide“ (er/sie/es)."
    },
    {
      "lang": "de",
      "text": "Das Wort „deschide“ benutzt du oft, wenn du Türen oder Chancen „öffnest“ – merke dir die Verbindung!"
    }
  ],
