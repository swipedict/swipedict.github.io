  "source": {
    "lang": "de",
    "headword": "abräumen",
    "definition": "Tische oder Flächen von Dingen oder Essensresten befreien",
    "pronunciation": "/ˈapʁɔʏ̯mən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „abräumen“ besteht aus dem Präfix „ab-“ und dem Verb „räumen“, was „etwas wegzuräumen“ oder „aufzuräumen“ bedeutet.",
        "targetText": "Verbul german „abräumen“ este compus din prefixul „ab-“ și verbul „räumen“, care înseamnă „a elibera“ sau „a curăța“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Häufig in Bezug auf die Reinigung oder das Beseitigen von Unordnung benutzt."
  },
  "target": {
    "lang": "ro",
    "headword": "a curăța",
    "definition": "a elibera mese sau suprafețe de lucruri sau resturi de mâncare",
    "pronunciation": "/a kuˈɾəzi.t͡sa/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a curăța“ stammt vom lateinischen „purificare“ ab, was „reinigen“ bedeutet, und wird für das Säubern oder Aufräumen verwendet.",
        "targetText": "Verbul românesc „a curăța“ provine din latinescul „purificare“, care înseamnă „a curăța“ sau „a purifica“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Es wird oft verwendet, um sowohl physische Ordnung als auch metaphorische Reinigung zu beschreiben."
  },
  "senses": [
    {
      "gloss": "Küche aufräumen",
      "explanation": {
        "sourceText": "Wenn man sagt, die Küche abzuräumen, befreit man sie von Unordnung.",
        "targetText": "Când spui să „rămuți bucătăria“, înseamnă să o cureți de dezordine."
      },
      "examples": [
        {
          "sourceText": "Räumst du die Küche ab?",
          "targetText": "Curăți bucătăria?"
        }
      ]
    },
    {
      "gloss": "Tisch abräumen",
      "explanation": {
        "sourceText": "Das bedeutet, den Tisch von Gegenständen zu befreien.",
        "targetText": "Înseamnă a elibera masa de obiecte."
      },
      "examples": [
        {
          "sourceText": "Ich räume den Tisch ab.",
          "targetText": "Curăț masa."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Geschirr",
      "targetText": "vase"
    },
    {
      "sourceText": "Küche",
      "targetText": "bucătărie"
    },
    {
      "sourceText": "Müll",
      "targetText": "gunoi"
    },
    {
      "sourceText": "Tisch",
      "targetText": "masă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "decken",
      "targetText": "a acoperi"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich räume den Tisch ab.",
      "targetText": "Curăț masa."
    },
    {
      "sourceText": "Räumst du die Küche ab?",
      "targetText": "Curăți bucătăria?"
    },
    {
      "sourceText": "Er räumt den Schreibtisch ab.",
      "targetText": "El curăță biroul."
    },
    {
      "sourceText": "Wir räumen die Wohnung ab.",
      "targetText": "Noi curățăm apartamentul."
    },
    {
      "sourceText": "Räumt ihr nach dem Essen ab?",
      "targetText": "Curățați după masă?"
    },
    {
      "sourceText": "Sie (Pl.) räumen die Zimmmer ab.",
      "targetText": "Ei curăță camerele."
    },
    {
      "sourceText": "Ich habe den Tisch abgeräumt.",
      "targetText": "Am curățat masa."
    },
    {
      "sourceText": "Sie räumte das Zimmer immer ab.",
      "targetText": "Ea curăța mereu camera."
    },
    {
      "sourceText": "Ich werde den Tisch abräumen.",
      "targetText": "Voi curăța masa."
    },
    {
      "sourceText": "Ich würde abräumen, wenn du mir hilfst.",
      "targetText": "Aș curăța dacă mă ajuți."
    },
    {
      "sourceText": "Räum ab!",
      "targetText": "Curăță!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Abräumen“ und „a curăța“ hängen zusammen: Stell dir vor, du räumst den Tisch ab und machst ihn sauber – so merkst du „curăța“."
    },
    {
      "lang": "de",
      "text": "Mach eine kleine Aufräum-Challenge und sage dabei „Ich curăța masa“ – so verknüpfst du Wort und Handlung."
    },
    {
      "lang": "de",
      "text": "Verbinde „a curăța“ mit einem sauberen Raum – je ordentlicher, desto besser fühlt man sich, und desto klarer bleibt das Wort im Gedächtnis."
    }
  ],
