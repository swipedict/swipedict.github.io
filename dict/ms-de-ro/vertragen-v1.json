  "source": {
    "lang": "de",
    "headword": "vertragen",
    "definition": "mit jemandem oder etwas in Harmonie leben oder umgehen",
    "pronunciation": "/fɛʁˈtʁaːɡn̩/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „vertragen“ stammt vom mittelhochdeutschen „vertragen“, was „eins werden“ oder „vereinbaren“ bedeutet.",
        "targetText": "Verbul „a suporta“ provine din latină, de la „supportare“, care înseamnă „a susține“ sau „a purta“, reflectând ideea de a tolera sau a suporta."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Unregelmäßiges Verb. Oft verwendet, um Beziehungen oder Kompromisse zwischen Personen zu beschreiben."
  },
  "target": {
    "lang": "ro",
    "headword": "a suporta",
    "definition": "a conviețui sau a interacționa în armonie cu cineva sau ceva",
    "pronunciation": "/a suˈpɔr.ta/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „a suporta“ stammt vom lateinischen „supportare“, was „unterstützen“ oder „tragen“ bedeutet und im Rumänischen die Bedeutung von „ertragen“ oder „tolerieren“ angenommen hat.",
        "targetText": "Verbul românesc „a suporta“ provine din latină, de la „supportare“, care înseamnă „a susține“ sau „a purta“, și a evoluat spre sensul de „a tolera“ sau „a suporta“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Häufig in zwischenmenschlichen Beziehungen verwendet, um das Ertragen oder Tolerieren von Unterschieden zu beschreiben."
  },
  "relatedWords": [
    {
      "sourceText": "Freund",
      "targetText": "prieten"
    },
    {
      "sourceText": "Respekt",
      "targetText": "respect"
    },
    {
      "sourceText": "Verhältnis",
      "targetText": "relație"
    },
    {
      "sourceText": "Verständnis",
      "targetText": "înțelegere"
    }
  ],
  "antonyms": [
    {
      "sourceText": "ablehnen",
      "targetText": "a respinge"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich vertrage die Hitze nicht gut.",
      "targetText": "Eu nu suport căldura bine."
    },
    {
      "sourceText": "Verträgst du scharfe Speisen?",
      "targetText": "Suporti mâncărurile picante?"
    },
    {
      "sourceText": "Er verträgt keine Laktose.",
      "targetText": "El nu suportă lactoza."
    },
    {
      "sourceText": "Wir vertragen uns gut.",
      "targetText": "Noi ne suportăm bine."
    },
    {
      "sourceText": "Vertragt ihr euch?",
      "targetText": "Voi vă suportați?"
    },
    {
      "sourceText": "Sie (Pl.) vertragen sich nie.",
      "targetText": "Ei nu se suportă niciodată."
    },
    {
      "sourceText": "Ich habe die Situation gut vertragen.",
      "targetText": "Eu am suportat bine situația."
    },
    {
      "sourceText": "Er vertrug die Kälte schlecht.",
      "targetText": "El suporta răceala prost."
    },
    {
      "sourceText": "Ich werde die Herausforderung vertragen.",
      "targetText": "Eu voi suporta provocarea."
    },
    {
      "sourceText": "Ich würde das nicht vertragen.",
      "targetText": "Aș suporta asta."
    },
    {
      "sourceText": "Vertrage die Unterschiede!",
      "targetText": "Suportă diferențele!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Vertragen“ und „a suporta“ teilen die Bedeutung von „ertragen“ – stelle dir vor, du „trägst“ etwas mit Geduld."
    },
    {
      "lang": "de",
      "text": "Merke dir, dass „a suporta“ vom lateinischen „supportare“ kommt, was „unterstützen“ heißt – so kannst du dir das Wort leichter merken."
    },
    {
      "lang": "de",
      "text": "Übe Sätze, in denen du ausdrückst, wie du mit Menschen oder Situationen „verträgtst“."
    }
  ],
