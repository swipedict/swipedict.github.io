  "source": {
    "lang": "de",
    "headword": "entdecken",
    "definition": "etwas finden oder herausfinden, was vorher nicht bekannt war",
    "pronunciation": "/ɛntˈdɛk.ən/",
    "etymology": {
      "explanation": {
        "sourceText": "Kommt vom mittelhochdeutschen „entdecken“, was „deutlich machen, offenlegen“ bedeutet.",
        "targetText": "Verbul provine din germana mijlocie „entdecken“, care înseamnă „a face clar, a dezvălui“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Ein unregelmäßiges Verb. Wichtig in der Wissenschaft und beim Reisen."
  },
  "target": {
    "lang": "ro",
    "headword": "a descoperi",
    "definition": "a găsi sau a afla ceva care nu era cunoscut anterior",
    "pronunciation": "/a des.koˈpe.ri/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „a descoperi“ stammt vom lateinischen „descoperire“ ab, zusammengesetzt aus „de-“ (weg) und „cooperire“ (bedecken). Es bedeutet „aufdecken“ oder „entdecken“.",
        "targetText": "Verbul românesc „a descoperi“ derivă din latinescul „descoperire“, format din „de-“ (departe) și „cooperire“ (a acoperi), însemnând „a dezvălui, a descoperi“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Ein regelmäßiges Verb der 4. Konjugation (-i). Wird häufig verwendet, wenn etwas Neuartiges oder Unbekanntes entdeckt wird."
  },
  "senses": [
    {
      "gloss": "Entwicklung",
      "explanation": {
        "sourceText": "Bezieht sich auf einen Prozess des Findens in der persönlichen oder wissenschaftlichen Entdeckung.",
        "targetText": "Se referă la procesul de găsire în descoperirea personală sau științifică."
      },
      "examples": [
        {
          "sourceText": "Die Entwicklung neuer Ideen ist wichtig.",
          "targetText": "Dezvoltarea de idei noi este importantă."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Beobachten",
      "targetText": "a observa"
    },
    {
      "sourceText": "Erforschen",
      "targetText": "a explora"
    },
    {
      "sourceText": "Finden",
      "targetText": "a găsi"
    },
    {
      "sourceText": "Suchen",
      "targetText": "a căuta"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verstecken",
      "targetText": "a ascunde"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich entdecke neue Möglichkeiten.",
      "targetText": "Eu descopăr noi oportunități."
    },
    {
      "sourceText": "Entdeckst du die versteckten Schätze?",
      "targetText": "Descoperi comorile ascunse?"
    },
    {
      "sourceText": "Die Forscher entdecken neue Arten.",
      "targetText": "Cercetătorii descoperă specii noi."
    },
    {
      "sourceText": "Wir entdecken das Geheimnis.",
      "targetText": "Noi descoperim secretul."
    },
    {
      "sourceText": "Entdeckt ihr das Rätsel?",
      "targetText": "Descoperiți enigma?"
    },
    {
      "sourceText": "Sie entdecken neue Technologien.",
      "targetText": "Ei descoperă tehnologii noi."
    },
    {
      "sourceText": "Ich habe eine neue Stadt entdeckt.",
      "targetText": "Am descoperit un nou oraș."
    },
    {
      "sourceText": "Er entdeckte die alte Landkarte.",
      "targetText": "El descoperea harta veche."
    },
    {
      "sourceText": "Ich werde neue Dinge entdecken.",
      "targetText": "Voi descoperi lucruri noi."
    },
    {
      "sourceText": "Ich würde es entdecken, wenn ich die Zeit hätte.",
      "targetText": "Aș descoperi dacă aș avea timp."
    },
    {
      "sourceText": "Entdecke die Wahrheit!",
      "targetText": "Descoperă adevărul!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das deutsche „entdecken“ und das rumänische „a descoperi“ bedeuten beide ‚aufdecken‘ – denk an „de-“ als Wegnehmen der Decke, um etwas sichtbar zu machen."
    },
    {
      "lang": "de",
      "text": "Merke dir „a descoperi“ durch die Verbindung zu „cooperire“ (bedecken) – du entfernst die Decke, um etwas zu entdecken."
    },
    {
      "lang": "de",
      "text": "Übe Sätze wie „a descoperi un secret“ (ein Geheimnis entdecken), um die Verwendung zu festigen."
    },
    {
      "lang": "de",
      "text": "Vergleiche die Konjugationen von „entdecken“ und „descoperi“, um die Formen besser zu verstehen."
    }
  ],
