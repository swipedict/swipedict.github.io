  "source": {
    "lang": "de",
    "headword": "angreifen",
    "definition": "jemanden oder etwas attackieren oder schädigen",
    "pronunciation": "/anˈɡʁaɪ̯fən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort 'angreifen' kommt aus der Zusammensetzung von 'an' und 'greifen'. Es hat seine Wurzeln im Althochdeutschen 'grīfan', was 'festhalten' bedeutet.",
        "targetText": "Provine din combinarea prefixului „an-“ cu verbul „greifen” (a apuca)."
      },
      "source": "AI"
    },
    "additional": "Regelmäßiges Verb. Wird oft in militärischen, sportlichen oder metaphorischen Kontexten verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a ataca",
    "definition": "a face un atac asupra cuiva sau a ceva",
    "pronunciation": "/a a.tʃaˈka/",
    "etymology": {
      "explanation": {
        "sourceText": "Entlehnt aus dem Französischen 'attaquer', mit lateinischen Wurzeln im 'attractare', was 'anziehen, angreifen' bedeutet. Abgeleitet von 'ad' und 'tacere' ('still sein').",
        "targetText": "Împrumutat din franceza „attaquer”, cu rădăcini latine în „attractare” (a atrage, a ataca)."
      },
      "source": "AI"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird verwendet, um einen aggressiven oder konkurrierenden Ansatz zu beschreiben."
  },
  "relatedWords": [
    {
      "sourceText": "Angreifer",
      "targetText": "atacator"
    },
    {
      "sourceText": "Kampf",
      "targetText": "luptă"
    },
    {
      "sourceText": "Opfer",
      "targetText": "victimă"
    },
    {
      "sourceText": "Strategie",
      "targetText": "strategie"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verteidigen",
      "targetText": "a apăra"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich greife den Gegner an.",
      "targetText": "Eu atac adversarul."
    },
    {
      "sourceText": "Greifst du ihn an?",
      "targetText": "Îl ataci?"
    },
    {
      "sourceText": "Der Feind greift an.",
      "targetText": "Dușmanul atacă."
    },
    {
      "sourceText": "Wir greifen zuerst an.",
      "targetText": "Noi atacăm mai întâi."
    },
    {
      "sourceText": "Greift ihr die Burg an?",
      "targetText": "Atacați castelul?"
    },
    {
      "sourceText": "Sie greifen den Bereich an.",
      "targetText": "Ei atacă zona."
    },
    {
      "sourceText": "Ich habe den Plan angegriffen.",
      "targetText": "Am atacat planul."
    },
    {
      "sourceText": "Er griff an, wann immer er konnte.",
      "targetText": "El ataca ori de câte ori avea ocazia."
    },
    {
      "sourceText": "Ich werde an diesem Punkt angreifen.",
      "targetText": "Voi ataca acest punct."
    },
    {
      "sourceText": "Ich würde angreifen, wenn ich die Chance hätte.",
      "targetText": "Aș ataca dacă aș avea ocazia."
    },
    {
      "sourceText": "Greif an!",
      "targetText": "Atacă!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "'Angreifen' klingt hart, 'ataca' erinnert an die französische Herkunft – beide Wörter sind kraftvoll."
    },
    {
      "lang": "de",
      "text": "'Ataca' reimt sich auf 'până' – stell dir vor, du greifst mit einer spitzen 'Până' an."
    },
    {
      "lang": "de",
      "text": "Denk an 'angreifen' und 'a ataca' – beide bedeuten Angriff, das hilft dir, die Wörter zu verbinden."
    },
    {
      "lang": "de",
      "text": "Stell dir einen sportlichen Wettkampf vor, bei dem du 'ataci' den Gegner – so merkst du dir das Wort."
    }
  ],
