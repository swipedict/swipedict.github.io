  "source": {
    "lang": "de",
    "headword": "abnehmen",
    "definition": "Gewicht verlieren oder schlanker werden",
    "pronunciation": "/ˈapˌneːmən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „abnehmen“ setzt sich aus dem Präfix „ab-“ und dem Verb „nehmen“ zusammen. Ursprünglich bedeutete es „etwas von einem Ort entfernen“.",
        "targetText": "Verbul german „abnehmen“ este format din prefixul „ab-“ și verbul „nehmen“, inițial însemnând „a lua ceva de undeva“ sau „a îndepărta“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Much used in contexts of weight loss or to remove something."
  },
  "target": {
    "lang": "ro",
    "headword": "a pierde",
    "definition": "a pierde în greutate sau a deveni mai suplu",
    "pronunciation": "/a ˈpjeɾ.de/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a pierde“ stammt vom lateinischen „perdere“ ab, was „verlieren“ bedeutet. Es ist verwandt mit dem deutschen Wort „verlieren“.",
        "targetText": "Verbul românesc „a pierde“ provine din latinescul „perdere“, care înseamnă „a pierde“ și este înrudit cu verbul german „verlieren“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 2. Konjugation. Oft benutzt im Zusammenhang mit Gewichtsverlust oder dem Verlust von Objekten."
  },
  "senses": [
    {
      "gloss": "Abladen (Gewicht verlieren)",
      "explanation": {
        "sourceText": "Im Kontext des Gewichtsverlusts.",
        "targetText": "În contextul pierderii în greutate."
      },
      "examples": [
        {
          "sourceText": "Ich möchte abnehmen und fit bleiben.",
          "targetText": "Vreau să pierd în greutate și să rămân în formă."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Diät",
      "targetText": "dietă"
    },
    {
      "sourceText": "Ernährung",
      "targetText": "nutriție"
    },
    {
      "sourceText": "Gewicht",
      "targetText": "greutate"
    },
    {
      "sourceText": "Sport",
      "targetText": "sport"
    }
  ],
  "antonyms": [
    {
      "sourceText": "zunehmen",
      "targetText": "a câștiga în greutate"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich nehme 5 Kilogramm ab.",
      "targetText": "Pierd 5 kilograme."
    },
    {
      "sourceText": "Nimmst du auch ab?",
      "targetText": "Pierzi și tu?"
    },
    {
      "sourceText": "Er nimmt schnell ab.",
      "targetText": "El pierde repede."
    },
    {
      "sourceText": "Wir nehmen immer mehr ab.",
      "targetText": "Noi pierdem tot mai mult."
    },
    {
      "sourceText": "Nehmt ihr Medikamente ab?",
      "targetText": "Pireți medicamente?"
    },
    {
      "sourceText": "Sie (Pl.) nehmen ihr Gepäck ab.",
      "targetText": "Ei își pierd bagajele."
    },
    {
      "sourceText": "Ich habe 2 Kilogramm abgenommen.",
      "targetText": "Am pierdut 2 kilograme."
    },
    {
      "sourceText": "Sie nahm jeden Monat ab.",
      "targetText": "Ea pierdea fiecare lună."
    },
    {
      "sourceText": "Ich werde abnehmen.",
      "targetText": "Voi pierde."
    },
    {
      "sourceText": "Ich würde abnehmen, wenn ich mehr trainieren würde.",
      "targetText": "Aș pierde dacă aș antrena mai mult."
    },
    {
      "sourceText": "Nimm ab!",
      "targetText": "Pierde!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Abnehmen“ und „a pierde“ sind Kognaten, die beide das Verlieren ausdrücken – das erleichtert das Lernen."
    },
    {
      "lang": "de",
      "text": "Denk an die Eselsbrücke: „Ich verliere Gewicht“ = „Eu pierd greutate“ – so merkst du „a pierde“ als „abnehmen“."
    },
    {
      "lang": "de",
      "text": "Erstelle eine Liste mit Dingen, die man „verliert“ oder „abnimmt“, um die Bedeutung spielerisch zu verinnerlichen."
    }
  ],
