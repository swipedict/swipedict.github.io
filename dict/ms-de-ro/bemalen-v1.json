  "source": {
    "lang": "de",
    "headword": "bemalen",
    "definition": "etwas mit Farbe versehen oder gestalten",
    "pronunciation": "/bəˈmaːlən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „bemalen“ setzt sich aus dem Präfix „be-“ und dem Verb „malen“ zusammen, das „mit Farbe gestalten“ bedeutet. Es stammt vom althochdeutschen „malōn“ ab.",
        "targetText": "Verbul german „bemalen“ este format din prefixul „be-“ și verbul „malen“ (a picta), provenind din germana veche „malōn“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Häufig in künstlerischen und handwerklichen Kontexten verwendet, um den Akt des Farbgebens zu beschreiben."
  },
  "target": {
    "lang": "ro",
    "headword": "a picta",
    "definition": "a acoperi ceva cu culoare",
    "pronunciation": "/a ˈpikt.a/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a picta“ stammt vom lateinischen „pingere“ ab, was „malen“ bedeutet. Es beschreibt das Auftragen von Farbe auf eine Oberfläche.",
        "targetText": "Verbul românesc „a picta“ provine din latină, de la „pingere“, care înseamnă a picta sau a colora."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Wird oft verwendet in Bezug auf Kunst, Gestaltung und kreative Ausdrucksformen."
  },
  "senses": [
    {
      "gloss": "Färben (etwas eine Farbe geben)",
      "explanation": {
        "sourceText": "Das Auftragen von Farbe auf eine Oberfläche.",
        "targetText": "Aplicarea culorii pe o suprafață."
      },
      "examples": [
        {
          "sourceText": "Ich färbe die Haare.",
          "targetText": "Îmi vopsesc părul."
        }
      ]
    },
    {
      "gloss": "Gestalten (kreatives Arbeiten)",
      "explanation": {
        "sourceText": "Künstlerische Tätigkeit des Farbauftrags.",
        "targetText": "Activitate artistică de aplicare a culorii."
      },
      "examples": [
        {
          "sourceText": "Ich gestalte die Wand neu.",
          "targetText": "Îmi reamenajez zidul."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Farbe",
      "targetText": "culoare"
    },
    {
      "sourceText": "Künstler",
      "targetText": "artist"
    },
    {
      "sourceText": "Leinwand",
      "targetText": "pânză"
    },
    {
      "sourceText": "Pinsel",
      "targetText": "pensulă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "abdecken",
      "targetText": "a descoperi"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich bemale das Fenster mit neuer Farbe.",
      "targetText": "Eu pictez fereastra cu o culoare nouă."
    },
    {
      "sourceText": "Bemalst du das Bild schon?",
      "targetText": "Pictați deja imaginea?"
    },
    {
      "sourceText": "Er bemalt die Wand in kräftigen Farben.",
      "targetText": "El pictează zidul în culori vibrante."
    },
    {
      "sourceText": "Wir bemalen das Bild gemeinsam.",
      "targetText": "Noi pictăm imaginea împreună."
    },
    {
      "sourceText": "Bemalt ihr dießen Raum?",
      "targetText": "Pictați această cameră?"
    },
    {
      "sourceText": "Sie bemalen die Wände des Hauses.",
      "targetText": "Ei pictează pereții casei."
    },
    {
      "sourceText": "Ich habe das Bild bemalt.",
      "targetText": "Am pictat imaginea."
    },
    {
      "sourceText": "Sie bemalte die Wand jeden Sonntag.",
      "targetText": "Ea picta zidul în fiecare duminică."
    },
    {
      "sourceText": "Ich werde das Bild morgen bemalen.",
      "targetText": "Voi picta imaginea mâine."
    },
    {
      "sourceText": "Ich würde das Zimmer bemalen, wenn ich Zeit hätte.",
      "targetText": "Aș picta camera dacă aș avea timp."
    },
    {
      "sourceText": "Bemale das Bild!",
      "targetText": "Pictați imaginea!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Bemalen“ und „a picta“ sind leicht vorstellbar: beide beschreiben kreative Tätigkeiten mit Farbe."
    },
    {
      "lang": "de",
      "text": "Merke dir die Endung „-a“ bei „a picta“ als typisches Verb der 1. Konjugation."
    },
    {
      "lang": "de",
      "text": "Übe Sätze wie „Eu pictez“ (Ich male) und „Eu am pictat“ (Ich habe gemalt)."
    },
    {
      "lang": "de",
      "text": "Verbinde das Wort mit dem Bild eines Pinsels und einer Leinwand für bessere Erinnerung."
    }
  ],
