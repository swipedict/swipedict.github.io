  "source": {
    "lang": "de",
    "headword": "versuchen",
    "definition": "etwas probieren oder testen, um zu sehen, ob es funktioniert",
    "pronunciation": "/fɛʁˈzuːχən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „versuchen“ stammt vom mittelhochdeutschen „versuoch“, was „prüfen“ oder „testen“ bedeutet.",
        "targetText": "Verbul „a încerca“ provine din latină, vom „intricare“, das „verwickeln“ oder „erschweren“ bedeutet, was auf die Anstrengung beim Ausprobieren hinweist."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird häufig verwendet, um das Bemühen oder Testen von etwas zu beschreiben."
  },
  "target": {
    "lang": "ro",
    "headword": "a încerca",
    "definition": "a proba sau a testa ceva, pentru a vedea dacă funcționează",
    "pronunciation": "/a ɨn.t͡ʃeˈka/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „a încerca“ stammt vom lateinischen „intricare“, was „verwickeln“ oder „erschweren“ bedeutet, und beschreibt den Prozess des Ausprobierens trotz möglicher Schwierigkeiten.",
        "targetText": "Verbul „a încerca“ provine din latină, de la „intricare“, care înseamnă „a încurca“ sau „a face dificil“, reflectând efortul implicat în încercare."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird oft verwendet, um den Versuch oder die Bemühung, etwas zu erreichen, auszudrücken."
  },
  "relatedWords": [
    {
      "sourceText": "Probieren",
      "targetText": "a testa"
    },
    {
      "sourceText": "Test",
      "targetText": "test"
    },
    {
      "sourceText": "Versuch",
      "targetText": "încercare"
    },
    {
      "sourceText": "Ziel",
      "targetText": "scop"
    }
  ],
  "antonyms": [
    {
      "sourceText": "aufgeben",
      "targetText": "renunța"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich versuche, das Problem zu lösen.",
      "targetText": "Eu încerc să rezolv problema."
    },
    {
      "sourceText": "Versuchst du das neue Rezept?",
      "targetText": "Încerci rețeta nouă?"
    },
    {
      "sourceText": "Er versucht, die Aufgabe zu erledigen.",
      "targetText": "El încearcă să termine sarcina."
    },
    {
      "sourceText": "Wir versuchen, pünktlich zu sein.",
      "targetText": "Noi încercăm să fim punctuali."
    },
    {
      "sourceText": "Versucht ihr es einfach mal!",
      "targetText": "Încercați pur și simplu!"
    },
    {
      "sourceText": "Sie (Pl.) versuchen ihr Bestes.",
      "targetText": "Ei își încearcă tot efortul."
    },
    {
      "sourceText": "Ich habe es gestern versucht.",
      "targetText": "Eu am încercat ieri."
    },
    {
      "sourceText": "Er versuchte, das Problem zu lösen.",
      "targetText": "El încerca să rezolve problema."
    },
    {
      "sourceText": "Ich werde es versuchen.",
      "targetText": "Eu voi încerca."
    },
    {
      "sourceText": "Ich würde es versuchen, falls ich Zeit hätte.",
      "targetText": "Aș încerca dacă aș avea timp."
    },
    {
      "sourceText": "Versuche es erneut!",
      "targetText": "Încercă din nou!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Versuchen“ und „a încerca“ klingen ähnlich – verbinde das mit dem Gedanken, etwas auszuprobieren!"
    },
    {
      "lang": "de",
      "text": "Denke daran, dass „a încerca“ oft mit Anstrengung verbunden ist, ähnlich wie das lateinische „intricare“ (erschweren)."
    },
    {
      "lang": "de",
      "text": "Stelle dir vor, du „ver-suchst“ etwas, also machst einen Versuch – das hilft dir, „a încerca“ zu merken."
    }
  ],
