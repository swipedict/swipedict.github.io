  "source": {
    "lang": "de",
    "headword": "absolut",
    "definition": "vollständig oder unbedingt, ohne Einschränkung",
    "pronunciation": "/ˈapsoˌluːt/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort „absolut“ kommt vom lateinischen „absolutus“, was „losgelöst“ oder „vollständig“ bedeutet.",
        "targetText": "Cuvântul german „absolut“ provine din latină, de la „absolutus“, care înseamnă „eliberat“ sau „complet“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": ""
  },
  "target": {
    "lang": "ro",
    "headword": "absolut",
    "genus": "masculine",
    "definition": "complet sau absolut, fără restricții",
    "pronunciation": "/absoˈlut/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „absolut“ stammt ebenfalls vom lateinischen „absolutus“ ab, was „vollständig“ oder „unbedingt“ bedeutet.",
        "targetText": "Cuvântul românesc „absolut“ provine tot din latină, de la „absolutus“, cu sensul de „complet“ sau „necondiționat“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": ""
  },
  "senses": [
    {
      "gloss": "absolut",
      "explanation": {
        "sourceText": "Das Wort ‚absolut‘ meint eine uneingeschränkte Ganzheit.",
        "targetText": "Cuvântul „absolut“ înseamnă o totalitate fără restricții."
      },
      "examples": [
        {
          "sourceText": "Das Buch ist absolut lesenswert.",
          "targetText": "Cartea este absolut demnă de citit."
        }
      ]
    },
    {
      "gloss": "absolut",
      "explanation": {
        "sourceText": "In einer emotionalen Diskussion verwendet, um unumstößliche Überzeugung auszudrücken.",
        "targetText": "Folosit pentru a exprima o convingere fermă într-o discuție emoțională."
      },
      "examples": [
        {
          "sourceText": "Du musst absolut an dich glauben.",
          "targetText": "Trebuie să crezi absolut în tine."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "cert",
      "targetText": "cert"
    },
    {
      "sourceText": "de plin",
      "targetText": "de plin"
    },
    {
      "sourceText": "total",
      "targetText": "total"
    },
    {
      "sourceText": "totalitate",
      "targetText": "totalitate"
    }
  ],
  "antonyms": [
    {
      "sourceText": "relativ",
      "targetText": "parțial"
    }
  ],
  "examples": [
    {
      "sourceText": "Das ist eine absolut gute Idee.",
      "targetText": "Este o idee absolut bună."
    },
    {
      "sourceText": "Ich habe absolut keine Ahnung.",
      "targetText": "Nu am absolut nicio idee."
    },
    {
      "sourceText": "Er ist absolut davon überzeugt.",
      "targetText": "El este absolut convins de asta."
    },
    {
      "sourceText": "Das ist absolut unglaublich.",
      "targetText": "Este absolut incredibil."
    },
    {
      "sourceText": "Ich habe absolut kein Interesse.",
      "targetText": "Nu am absolut niciun interes."
    },
    {
      "sourceText": "Sie hat mich absolut überzeugt.",
      "targetText": "M-a convins absolut."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das „ab-“ am Anfang erinnert an „absolut“ als etwas, das von allem losgelöst und vollständig ist."
    },
    {
      "lang": "de",
      "text": "Das Wort „absolut“ ist im Deutschen und Rumänischen gleich – denk an etwas, das komplett und uneingeschränkt ist."
    },
    {
      "lang": "de",
      "text": "Merke dir „absolut“ wie eine absolute Wahrheit – etwas, das niemals zweifelhaft ist."
    },
    {
      "lang": "de",
      "text": "Verbinde „absolut“ mit dem Bild eines absoluten Gewinners – der Beste ohne Zweifel!"
    }
  ],
