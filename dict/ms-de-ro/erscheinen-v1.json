  "source": {
    "lang": "de",
    "headword": "erscheinen",
    "definition": "sichtbar werden oder auftreten",
    "pronunciation": "/ɛʁˈʃaɪ̯nən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „erscheinen“ stammt vom mittelhochdeutschen „erschinen“ ab, verwandt mit althochdeutschen „irskinon“.",
        "targetText": "Verbul german „erscheinen“ provine din germana mijlocie „erschinen“, legat de „irskinon“ din germana veche."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb, verwendet in literarischen und alltäglichen Kontexten."
  },
  "target": {
    "lang": "ro",
    "headword": "a apărea",
    "definition": "a deveni vizibil sau a avea loc",
    "pronunciation": "/a apəˈrea/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a apărea“ stammt vom lateinischen „apparere“ ab, was „sichtbar werden“ bedeutet.",
        "targetText": "Verbul românesc „a apărea“ provine din latină, de la „apparere“, care înseamnă „a deveni vizibil“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a), häufig verwendet um das Erscheinen von etwas Sichtbarem zu beschreiben."
  },
  "relatedWords": [
    {
      "sourceText": "auftreten",
      "targetText": "a se prezenta"
    },
    {
      "sourceText": "Ereignis",
      "targetText": "eveniment"
    },
    {
      "sourceText": "Schauplatz",
      "targetText": "loc de desfășurare"
    },
    {
      "sourceText": "sichtbar",
      "targetText": "vizibil"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verschwinden",
      "targetText": "a dispărea"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich erscheine pünktlich zur Veranstaltung.",
      "targetText": "Eu apar la eveniment la timp."
    },
    {
      "sourceText": "Erscheinst du oft in der Zeitung?",
      "targetText": "Apari adesea în ziar?"
    },
    {
      "sourceText": "Sie erscheint immer freundlich.",
      "targetText": "Ea apare mereu prietenoasă."
    },
    {
      "sourceText": "Wir erscheinen gemeinsam auf der Bühne.",
      "targetText": "Noi apărem împreună pe scenă."
    },
    {
      "sourceText": "Erscheint ihr morgen zur Sitzung?",
      "targetText": "Apăreți mâine la întâlnire?"
    },
    {
      "sourceText": "Sie (Pl.) erscheinen regelmäßig im Fernsehen.",
      "targetText": "Ei apar regulat la televizor."
    },
    {
      "sourceText": "Ich bin heute erschienen.",
      "targetText": "Am apărut astăzi."
    },
    {
      "sourceText": "Sie sind rechtzeitig erschienen.",
      "targetText": "Ei au apărut la timp."
    },
    {
      "sourceText": "Er erschien jeden Sonntag in der Kirche.",
      "targetText": "El apărea în fiecare duminică la biserică."
    },
    {
      "sourceText": "Ich war bereits erschienen, als die Veranstaltung begann.",
      "targetText": "Apărasem deja când a început evenimentul."
    },
    {
      "sourceText": "Ich werde morgen erscheinen.",
      "targetText": "Voi apărea mâine."
    },
    {
      "sourceText": "Sie wird in der nächsten Sendung erscheinen.",
      "targetText": "Ea o să apară în următoarea emisiune."
    },
    {
      "sourceText": "Ich würde erscheinen, wenn ich eine Einladung hätte.",
      "targetText": "Aș apărea dacă aș avea o invitație."
    },
    {
      "sourceText": "Es wäre schön, wenn du pünktlich erscheinst.",
      "targetText": "Ar fi frumos să apari la timp."
    },
    {
      "sourceText": "Erscheine beim nächsten Meeting!",
      "targetText": "Apar la următoarea întâlnire!"
    },
    {
      "sourceText": "Erscheint bitte pünktlich!",
      "targetText": "Apăreți vă rog la timp!"
    },
    {
      "sourceText": "Die erschienene Ausgabe hat viele neue Artikel.",
      "targetText": "Numărul apărut are multe articole noi."
    },
    {
      "sourceText": "Indem ich erscheine, bringe ich neuerdings frische Ideen ein.",
      "targetText": "Apărând, aduc idei proaspete."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „a apărea“ klingt ähnlich wie das englische „appear“ – verbinde beide Wörter mit dem Bild, sichtbar zu werden."
    },
    {
      "lang": "de",
      "text": "Stelle dir eine Bühne vor, auf der du zum ersten Mal erscheinst – so merkst du dir „a apărea“ als ‚erscheinen‘."
    },
    {
      "lang": "de",
      "text": "Übe Sätze mit „apăr“ und „apare“ in verschiedenen Zeiten, um das Verb zu verinnerlichen."
    }
  ],
