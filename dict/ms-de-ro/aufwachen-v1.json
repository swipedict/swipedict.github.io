  "source": {
    "lang": "de",
    "headword": "aufwachen",
    "definition": "plötzlich die Augen öffnen und sich aus dem Schlaf erheben",
    "pronunciation": "/ˈaʊ̯fˌvaːxən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „aufwachen“ besteht aus dem Präfix „auf-“ (eine Bewegung nach oben) und dem Verb „wachen“ (wach sein). Es beschreibt den Vorgang des Erwachens aus dem Schlaf.",
        "targetText": "Verbul „a se trezi“ provine din latinescul „trescere“, care înseamnă „a deveni conștient“ sau „a se trezi“. Este folosit frecvent în limba română pentru a descrie procesul de trezire."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird im Alltag verwendet, wenn es um das Erwachen aus dem Schlaf geht."
  },
  "target": {
    "lang": "ro",
    "headword": "a se trezi",
    "definition": "a deschide ochii brusc și a se ridica din somn",
    "pronunciation": "/a se treˈzi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „a se trezi“ stammt vom lateinischen „trescere“, das „aufwachen“ bedeutet. Es hat sich vielfältig in der rumänischen Sprache entwickelt und wird oft im täglichen Leben verwendet.",
        "targetText": "Verbul românesc „a se trezi“ derivă din latinescul „trescere“, care înseamnă „a deveni conștient“ sau „a se trezi“. Este folosit frecvent în viața de zi cu zi."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Reflexives Verb der 2. Konjugation. Häufig in verschiedenen Zeiten und Kontexten verwendet."
  },
  "relatedWords": [
    {
      "sourceText": "Morgen",
      "targetText": "dimineață"
    },
    {
      "sourceText": "Schlaf",
      "targetText": "somn"
    },
    {
      "sourceText": "Traum",
      "targetText": "vis"
    },
    {
      "sourceText": "Wecker",
      "targetText": "ceas deșteptător"
    }
  ],
  "antonyms": [
    {
      "sourceText": "einschlafen",
      "targetText": "a adormi"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich wache immer früh auf.",
      "targetText": "Eu mă trezesc întotdeauna devreme."
    },
    {
      "sourceText": "Wachst du pünktlich auf?",
      "targetText": "Te trezești la timp?"
    },
    {
      "sourceText": "Sie wacht immer müde auf.",
      "targetText": "Ea se trezește întotdeauna obosită."
    },
    {
      "sourceText": "Wir wachen zusammen auf.",
      "targetText": "Noi ne trezim împreună."
    },
    {
      "sourceText": "Wacht ihr auch so auf?",
      "targetText": "Vă treziți și voi așa?"
    },
    {
      "sourceText": "Sie wachen immer glücklich auf.",
      "targetText": "Ei se trezesc întotdeauna fericiți."
    },
    {
      "sourceText": "Ich bin heute früh aufgewacht.",
      "targetText": "M-am trezit devreme astăzi."
    },
    {
      "sourceText": "Sie sind gestern aufgewacht.",
      "targetText": "Ei s-au trezit ieri."
    },
    {
      "sourceText": "Er wachte jeden Morgen auf.",
      "targetText": "El se trezea în fiecare dimineață."
    },
    {
      "sourceText": "Ich war bereits aufgewacht, als der Wecker klingelte.",
      "targetText": "Mă trezisem deja când a sunat ceasul."
    },
    {
      "sourceText": "Ich werde morgen früh aufwachen.",
      "targetText": "Mă voi trezi mâine dimineață."
    },
    {
      "sourceText": "Sie wird am Wochenende aufwachen.",
      "targetText": "Ea o să se trezească în weekend."
    },
    {
      "sourceText": "Ich würde aufwachen, wenn du mich rufst.",
      "targetText": "M-aș trezi dacă mă suni."
    },
    {
      "sourceText": "Es ist wichtig, dass du rechtzeitig aufwachst.",
      "targetText": "Este important să te trezești la timp."
    },
    {
      "sourceText": "Wach auf!",
      "targetText": "Trezeste!"
    },
    {
      "sourceText": "Wacht auf!",
      "targetText": "Treziti-vă!"
    },
    {
      "sourceText": "Der aufgewachte Mann war verwirrt.",
      "targetText": "Bărbatul trezit era confuz."
    },
    {
      "sourceText": "Ich bin aufgewacht.",
      "targetText": "M-am trezit."
    },
    {
      "sourceText": "Ich fühle mich gut, nachdem ich aufgewacht bin.",
      "targetText": "Mă simt bine după ce m-am trezit."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das Wort „aufwachen“ enthält „wachen“, was dir hilft, dich an „a se trezi“ zu erinnern – beide bedeuten wach werden."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, wie du morgens aufwachst und sagst „mă trezesc“ – das klingt wie ein fröhlicher Start in den Tag!"
    },
    {
      "lang": "de",
      "text": "Übe den Satz „Mă trezesc devreme“ laut, um dir die Bedeutung von „aufwachen“ besser einzuprägen."
    }
  ],
