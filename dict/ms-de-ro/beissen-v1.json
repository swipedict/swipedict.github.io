  "source": {
    "lang": "de",
    "headword": "beissen",
    "definition": "mit den Zähnen in etwas hineinbeissen oder verbeissen",
    "pronunciation": "/ˈbaɪ̯sən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „beißen“ stammt vom althochdeutschen „bīzan“ ab, das die Handlung des Zubeißens oder Beißens bezeichnet. Es ist verwandt mit verwandten germanischen Sprachen.",
        "targetText": "Verbul german „a mușca“ provine din germana veche „bīzan“, care înseamnă a mușca sau a înfige dinții."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Unregelmäßiges Verb; wird häufig für Tiere, aber auch für Menschen verwendet, die zubeißen oder Schmerzen zufügen."
  },
  "target": {
    "lang": "ro",
    "headword": "a mușca",
    "definition": "a înfinge dinții în ceva",
    "pronunciation": "/a muʃˈka/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a mușca“ stammt vom lateinischen „morsicare“ ab, das „beißen“ bedeutet und mit „morsus“ (Biss) verwandt ist. Es bezeichnet die Handlung des Zubeißens oder Kauens.",
        "targetText": "Verbul românesc „a mușca“ provine din latină, de la „morsicare“, care înseamnă a mușca, legat de „morsus“ (mușcătură)."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Oft verwendet, um das Verhalten von Tieren zu beschreiben, aber auch in menschlichen Interaktionen."
  },
  "senses": [
    {
      "gloss": "Biss",
      "explanation": {
        "sourceText": "'Mușcătură' bezeichnet die Verletzung durch Zähne.",
        "targetText": "'Mușcătură' desemnează o rană cauzată de dinți."
      },
      "examples": [
        {
          "sourceText": "Er hatte einen Biss vom Hund.",
          "targetText": "A avut o mușcătură de la câine."
        }
      ]
    },
    {
      "gloss": "Kauen",
      "explanation": {
        "sourceText": "Das Zerkleinern von Nahrung mit den Zähnen.",
        "targetText": "Zdrobirea alimentelor cu dinții."
      },
      "examples": [
        {
          "sourceText": "Ich kauen den Apfel.",
          "targetText": "Eu mestec mărul."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Biss",
      "targetText": "mușcătură"
    },
    {
      "sourceText": "Fressen",
      "targetText": "a mânca"
    },
    {
      "sourceText": "Kauen",
      "targetText": "mestecat"
    },
    {
      "sourceText": "Zahn",
      "targetText": "dinte"
    }
  ],
  "antonyms": [
    {
      "sourceText": "lecken",
      "targetText": "a linge"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich beiße in den Apfel.",
      "targetText": "Eu mușc din măr."
    },
    {
      "sourceText": "Biss du schon ins Brot?",
      "targetText": "Ai mușcat deja din pâine?"
    },
    {
      "sourceText": "Der Hund beißt den Postboten.",
      "targetText": "Câinele mușcă poștașul."
    },
    {
      "sourceText": "Wir beißen in die Schokolade.",
      "targetText": "Noi mușcăm din ciocolată."
    },
    {
      "sourceText": "Beißen Sie vorsichtig!",
      "targetText": "Mușcați cu atenție!"
    },
    {
      "sourceText": "Die Katzen beißen die Schnur durch.",
      "targetText": "Pisicile mușcă sfoara."
    },
    {
      "sourceText": "Ich habe in den Apfel gebissen.",
      "targetText": "Am mușcat din măr."
    },
    {
      "sourceText": "Er biss den Jungen.",
      "targetText": "El a mușcat băiatul."
    },
    {
      "sourceText": "Ich werde in die Pizza beißen.",
      "targetText": "Voi mușca din pizza."
    },
    {
      "sourceText": "Ich würde in den Schokoriegel beißen.",
      "targetText": "Aș mușca din batoanele de ciocolată."
    },
    {
      "sourceText": "Beiße nicht so fest!",
      "targetText": "Nu mușca atât de tare!"
    },
    {
      "sourceText": "Die gebissene Hand benötigt sofortige Hilfe.",
      "targetText": "Mâna mușcată are nevoie de ajutor imediat."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Stell dir ein Tier vor, das mit „mușca“ (beißen) einen Ast abbeißt – so merkst du dir das Wort lebhaft."
    },
    {
      "lang": "de",
      "text": "Übe Sätze wie „Eu mușc“ (Ich beiße), um das Verb in der Praxis zu verankern."
    },
    {
      "lang": "de",
      "text": "Verbinde „a mușca“ mit dem englischen Wort „morsel“ (Bissen) – so bleibt die Bedeutung leichter im Kopf."
    }
  ],
