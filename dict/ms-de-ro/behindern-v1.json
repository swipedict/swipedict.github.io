  ],
  "examples": [
    {
      "sourceText": "Ich behindere den Prozess nicht.",
      "targetText": "Eu nu împiedic procesul."
    },
    {
      "sourceText": "Behindert es dich, wenn ich laut spreche?",
      "targetText": "Te împiedică dacă vorbesc tare?"
    },
    {
      "sourceText": "SieBehindert ihn in seiner Arbeit.",
      "targetText": "Ea îl împiedică în munca lui."
    },
    {
      "sourceText": "Wir behindern niemanden.",
      "targetText": "Noi nu împiedicăm pe nimeni."
    },
    {
      "sourceText": "Behindert ihr mich nicht!",
      "targetText": "Nu mă împiedicați!"
    },
    {
      "sourceText": "Sie behindern den Fortschritt.",
      "targetText": "Ei împiedică progresul."
    },
    {
      "sourceText": "Ich habe ihn nicht behindert.",
      "targetText": "Nu l-am împiedicat."
    },
    {
      "sourceText": "Er hinderte mich bei der Arbeit.",
      "targetText": "El m-a împiedicat în muncă."
    },
    {
      "sourceText": "Ich werde dich nicht hindern.",
      "targetText": "Nu te voi împiedica."
    },
    {
      "sourceText": "Ich würde dich nicht hindern, wenn ich könnte.",
      "targetText": "Nu te-aș împiedica dacă aș putea."
    },
    {
      "sourceText": "Hindere mich nicht!",
      "targetText": "Nu mă împiedica!"
    },
    {
      "sourceText": "Die behinderten Personen erhalten Unterstützung.",
      "targetText": "Persoanele împiedicate primesc sprijin."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das „împie-“ am Anfang klingt wie „im Pie“ – stell dir vor, jemand wird in einem Kuchen (Pie) festgehalten und kann nicht weitergehen!"
    },
    {
      "lang": "de",
      "text": "Denke an das deutsche Wort „Hindernis“ – es klingt ähnlich wie „împiedica“ und hilft dir, die Bedeutung „hindern“ zu verknüpfen."
    },
    {
      "lang": "de",
      "text": "Merke dir die Endung „-dica“ ähnlich wie „dedica“ (widmen), aber hier heißt es, jemanden festzuhalten, also „hindern“."
    }
  ],
