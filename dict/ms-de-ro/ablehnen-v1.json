  "source": {
    "lang": "de",
    "headword": "ablehnen",
    "definition": "etwas nicht akzeptieren oder nicht einverstanden sein",
    "pronunciation": "/ˈaːbələhn/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „ablehnen“ setzt sich aus dem Verb „legen“ und dem Vorsatz „ab-“ zusammen. Ursprünglich bedeutete es „etwas beiseite legen“ oder „nicht annehmen“.",
        "targetText": "Verbul german „ablehnen“ este compus din verbul „legen“ și prefixul „ab-“, inițial însemnând „a pune deoparte“ sau „a nu accepta“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird häufig in formellen Kontexten verwendet, wenn man eine Zustimmung oder ein Angebot zurückweist."
  },
  "target": {
    "lang": "ro",
    "headword": "a refuza",
    "definition": "a nu accepta ceva sau a nu fi de acord",
    "pronunciation": "/a re.fuˈza/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a refuza“ stammt vom französischen „refuser“ ab, das vom lateinischen „refutare“ kommt und „zurückweisen“ bedeutet.",
        "targetText": "Verbul românesc „a refuza“ provine din francezul „refuser“, derivat din latinescul „refutare“, care înseamnă „a respinge“ sau „a refuza“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Oft in negativen Kontexten verwendet, wenn man Angebote, Einladungen oder Vorschläge zurückweist."
  },
  "senses": [
    {
      "gloss": "Ablehnung",
      "explanation": {
        "sourceText": "Das Ablehnen eines Angebots oder Vorschlags.",
        "targetText": "Refuzul unei oferte sau propuneri."
      },
      "examples": [
        {
          "sourceText": "Ich lehne das Angebot ab.",
          "targetText": "Refuz oferta."
        },
        {
          "sourceText": "Lehnst du die Einladung ab?",
          "targetText": "Refuzi invitația?"
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Entscheidung",
      "targetText": "decizie"
    },
    {
      "sourceText": "Kritik",
