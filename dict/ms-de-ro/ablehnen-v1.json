      "targetText": "aprobat"
    }
  ],
  "antonyms": [
    {
      "sourceText": "annehmen",
      "targetText": "a accepta"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich lehne das Angebot ab.",
      "targetText": "Refuz oferta."
    },
    {
      "sourceText": "Lehnst du die Einladung ab?",
      "targetText": "Refuzi invitația?"
    },
    {
      "sourceText": "Sie lehnt die Zusammenarbeit ab.",
      "targetText": "Ea refuză colaborarea."
    },
    {
      "sourceText": "Wir lehnen die Vorschläge ab.",
      "targetText": "Refuzăm propunerile."
    },
    {
      "sourceText": "Lehnt ihr das Projekt ab?",
      "targetText": "Refuzați proiectul?"
    },
    {
      "sourceText": "Sie (Pl.) lehnen die Bedingungen ab.",
      "targetText": "Ei refuză condițiile."
    },
    {
      "sourceText": "Ich habe das Angebot abgelehnt.",
      "targetText": "Am refuzat oferta."
    },
    {
      "sourceText": "Er lehnte die Einladung jeden Monat ab.",
      "targetText": "El refuza invitația în fiecare lună."
    },
    {
      "sourceText": "Ich werde das Projekt ablehnen.",
      "targetText": "Voi refuza proiectul."
    },
    {
      "sourceText": "Ich würde es ablehnen, wenn ich du wäre.",
      "targetText": "Aș refuza, dacă aș fi tu."
    },
    {
      "sourceText": "Lehne das nicht ab!",
      "targetText": "Nu refuza!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Ablehnen“ und „a refuza“ sind Kognaten mit ähnlichem Klang und Bedeutung – das erleichtert das Merken."
    },
    {
      "lang": "de",
      "text": "Denk an die Eselsbrücke: „Ablehnung“ ist das Gegenteil von „Übernahme“ – so merkst du, dass „a refuza“ etwas ablehnt."
    },
    {
      "lang": "de",
      "text": "Nutze Alltagssituationen, um „a refuza“ zu üben, z.B. „Eu refuz oferta“ – so festigst du die Verwendung."
    }
  ],
