  "source": {
    "lang": "de",
    "headword": "beachten",
    "definition": "auf etwas achten oder es berücksichtigen",
    "pronunciation": "/beˈaχtən/",
    "etymology": {
      "explanation": {
        "sourceText": "Leitet sich von „be-“, einer Präfix, und „achten“, das vom mittelhochdeutschen „ahten“ stammt, was „auf etwas Wert legen“ bedeutet.",
        "targetText": "Das deutsche Verb „beachten“ besteht aus der Vorsilbe „be-“ und dem Verb „achten“, das vom mittelhochdeutschen „ahten“ stammt und „achten“ bedeutet."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Verb wird oft verwendet, um auszudrücken, dass etwas beachtet oder nicht ignoriert werden soll, beispielsweise bei Anweisungen oder Hinweisen."
  },
  "target": {
    "lang": "ro",
    "headword": "a observa",
    "definition": "a fi atent la ceva sau a lua în considerare",
    "pronunciation": "/a obˈzer.va/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort „a observa“ entstammt vom lateinischen „observare“, das „beobachten“ oder „darauf achten“ bedeutet. Der Ursprung liegt im „ob-“, was „über“ oder „hinüber“ bedeutet, und „servare“, was „bewahren“ oder „aufpassen“ bedeutet.",
        "targetText": "Cuvântul românesc „a observa“ provine din latinul „observare“, care înseamnă „a privi cu atenție“ sau „a lua în considerare“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Häufig verwendet im Kontext von Anweisungen oder Beobachtungen. Das Wort kann auch in wissenschaftlichen oder formellen Kontexten verwendet werden."
  },
  "relatedWords": [
    {
      "sourceText": "Aufmerksamkeit",
      "targetText": "atenție"
    },
    {
      "sourceText": "Empfehlung",
      "targetText": "recomandare"
    },
    {
      "sourceText": "Hinweis",
      "targetText": "indicație"
    },
    {
      "sourceText": "Regel",
      "targetText": "regulă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "ignorieren",
      "targetText": "neglija"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich beachte die Hinweise sorgfältig.",
      "targetText": "Eu observ cu atenție instrucțiunile."
    },
    {
      "sourceText": "Beachtest du die Fristen?",
      "targetText": "Observi termenele?"
    },
    {
      "sourceText": "Sie beachtet die Vorschriften.",
      "targetText": "Ea observă reglementările."
    },
    {
      "sourceText": "Wir beachten die Sicherheitsbestimmungen.",
      "targetText": "Noi observăm reglementările de siguranță."
    },
    {
      "sourceText": "Beachtet ihr die Regeln?",
      "targetText": "Observați regulile?"
    },
    {
      "sourceText": "Sie beachten die Vorschläge.",
      "targetText": "Ei observă propunerile."
    },
    {
      "sourceText": "Ich habe die Änderungen beachtet.",
      "targetText": "Am observat modificările."
    },
    {
      "sourceText": "Er beachtete die Warnungen nicht.",
      "targetText": "El nu observa avertizările."
    },
    {
      "sourceText": "Ich werde die Anleitung beachten.",
      "targetText": "Voi observa manualul."
    },
    {
      "sourceText": "Ich würde das Dokument beachten, falls du mir es zeigst.",
      "targetText": "Aș observa documentul dacă mi-l arăți."
    },
    {
      "sourceText": "Beachte die Details!",
      "targetText": "Observă detaliile!"
    },
    {
      "sourceText": "Alle beachteten Vorschläge wurden umgesetzt.",
      "targetText": "Toate sugestiile observate au fost implementate."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Beachten“ und „a observa“ sind Kognaten – beide bedeuten aufmerksam sein oder etwas genau ansehen."
    },
    {
      "lang": "de",
      "text": "Denk daran: Wenn du etwas beachtest, schaust du genau hin – das gilt auch für „a observa“ im Rumänischen."
    },
    {
      "lang": "de",
      "text": "Verbinde „a observa“ mit dem englischen „to observe“ – beide bedeuten beobachten oder beachten."
    }
  ],
