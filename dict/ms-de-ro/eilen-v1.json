  "source": {
    "lang": "de",
    "headword": "eilen",
    "definition": "schnell gehen oder sich bewegen",
    "pronunciation": "/ˈaɪ̯lən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „eilen“ stammt vom mittelhochdeutschen „eiln“, das „sich beeilen“ bedeutet und auf germanische Wurzeln zurückgeht.",
        "targetText": "Verbul „eilen“ provine din germana mijlocie „eiln“, care înseamnă a se grăbi, având rădăcini germanice."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb, oft genutzt, um Zeitdruck oder Eile auszudrücken."
  },
  "target": {
    "lang": "ro",
    "headword": "a se grăbi",
    "definition": "a merge sau a se mișca repede",
    "pronunciation": "/a se ɡrəˈbi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das reflexive Verb „a se grăbi“ leitet sich von „grăbire“ ab, was „Eile“ bedeutet, und wird im Rumänischen häufig verwendet, um Schnelligkeit auszudrücken.",
        "targetText": "Verbul reflexiv „a se grăbi“ derivă din substantivul „grăbire“ (grabă) și exprimă ideea de a face ceva repede."
      },
      "source": "AI, Wiktionary, Linguistic Analysis"
    },
    "additional": "Das Verb „a se grăbi“ wird reflexiv verwendet, um auszudrücken, dass man keine Zeit verlieren möchte."
  },
  "relatedWords": [
    {
      "sourceText": "laufen",
      "targetText": "a alerga"
    },
    {
      "sourceText": "schnell",
      "targetText": "repede"
    },
    {
      "sourceText": "Schritt",
      "targetText": "pas"
    },
    {
      "sourceText": "zeit",
      "targetText": "timp"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verweilen",
      "targetText": "a rămâne"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich eile zur Arbeit.",
      "targetText": "Eu mă grăbesc la muncă."
    },
    {
      "sourceText": "Eilst du zur Schule?",
      "targetText": "Te grăbești la școală?"
    },
    {
      "sourceText": "Er eilt zur Verabredung.",
      "targetText": "El se grăbește la întâlnire."
    },
    {
      "sourceText": "Wir eilen, um nicht zu spät zu kommen.",
      "targetText": "Noi ne grăbim să nu întârziem."
    },
    {
      "sourceText": "Eilt ihr zu eurer Prüfung?",
      "targetText": "Voi vă grăbiți la examen?"
    },
    {
      "sourceText": "Sie eilen nach Hause.",
      "targetText": "Ei se grăbesc acasă."
    },
    {
      "sourceText": "Ich bin gestern geeilt.",
      "targetText": "M-am grăbit ieri."
    },
    {
      "sourceText": "Sie sind spät ge eilt.",
      "targetText": "S-au grăbit târziu."
    },
    {
      "sourceText": "Er eilte oft zur Arbeit.",
      "targetText": "El se grăbea adesea la muncă."
    },
    {
      "sourceText": "Ich werde morgen eilen.",
      "targetText": "Mă voi grăbi mâine."
    },
    {
      "sourceText": "Ich würde eilen, wenn ich könnte.",
      "targetText": "M-aș grăbi dacă aș putea."
    },
    {
      "sourceText": "Eile jetzt!",
      "targetText": "Grăbește-te acum!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Eilen“ und „a se grăbi“ drücken beide Eile aus – stell dir vor, du rennst der Uhr hinterher, um die Reflexivform zu merken."
    },
    {
      "lang": "de",
      "text": "Das „grăb-“ in „a se grăbi“ klingt wie „grab“ – schnell greifen und handeln!"
    },
    {
      "lang": "de",
      "text": "Übe Sätze mit „Mă grăbesc“, um den Alltag und Zeitdruck zu verbinden."
    }
  ],
