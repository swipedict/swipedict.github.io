  "source": {
    "lang": "de",
    "headword": "beschweren",
    "definition": "seinen Unmut über etwas äußern",
    "pronunciation": "/bəˈʃvɛːʁən/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom mittelhochdeutschen „bescwern“, was „beschweren, belasten“ bedeutet. Das Präfix „be-“ verstärkt die Bedeutung.",
        "targetText": "Verbul reflexiv „a se plânge“ provine din latină, din „plangere“, care înseamnă a bate sau a plânge, exprimând o stare de nemulțumire personală."
      },
      "source": "Etymological Dictionaries, Wiktionary"
    },
    "additional": "Regelmäßiges Verb. Häufig in der Bedeutung von Beschwerden oder Klagen gegen etwas verwendet, sei es in einer formellen oder informellen Situation."
  },
  "target": {
    "lang": "ro",
    "headword": "a se plânge",
    "definition": "a exprima nemulțumirea față de ceva",
    "pronunciation": "/a se 'plɨn.dʒe/",
    "etymology": {
      "explanation": {
        "sourceText": "Das sich reflexive Verb „a se plânge“ leitet sich vom lateinischen „plangere“ ab, was „weinen, klagen“ bedeutet. Die reflexive Form betont, dass die Klage oder Beschwerde eine persönliche Emotion widerspiegelt.",
        "targetText": "Verbul reflexiv „a se plânge“ provine din latină, din „plangere“, care înseamnă a bate sau a plânge, indicând o exprimare personală a nemulțumirii."
      },
      "source": "Etymological Dictionaries, Wiktionary"
    },
    "additional": "Wird häufig in sozialen und rechtlichen Kontexten verwendet. Das Wort kann sowohl eine einfache Klage als auch das Ausdrücken von Unzufriedenheit umfassen."
  },
  "relatedWords": [
    {
      "sourceText": "Ärger",
      "targetText": "mânie"
    },
    {
      "sourceText": "Klage",
      "targetText": "plângere"
    },
    {
      "sourceText": "Meinung",
      "targetText": "părere"
    },
    {
      "sourceText": "Unmut",
      "targetText": "nemulțumire"
    }
  ],
  "antonyms": [
    {
      "sourceText": "zufrieden sein",
      "targetText": "a fi mulțumit"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich beschwere mich über die Lärmbelästigung.",
      "targetText": "Mă plâng de zgomot."
    },
    {
      "sourceText": "Beschwerst du dich über den Service?",
      "targetText": "Te plângi de serviciu?"
    },
    {
      "sourceText": "Er beschwert sich ständig.",
      "targetText": "El se plânge tot timpul."
    },
    {
      "sourceText": "Wir beschweren uns über die Probleme.",
      "targetText": "Ne plângem de probleme."
    },
    {
      "sourceText": "Beschwert ihr euch über die Arbeit?",
      "targetText": "Vă plângeți de muncă?"
    },
    {
      "sourceText": "Sie beschweren sich immer.",
      "targetText": "Ei se plâng mereu."
    },
    {
      "sourceText": "Ich habe mich über die Sache beschwert.",
      "targetText": "M-am plâns de problema."
    },
    {
      "sourceText": "Sie beschwerte sich über alles.",
      "targetText": "Ea se plângea de orice."
    },
    {
      "sourceText": "Ich werde mich beschweren.",
      "targetText": "Mă voi plânge."
    },
    {
      "sourceText": "Ich würde mich beschweren, wenn ich könnte.",
      "targetText": "M-aș plânge dacă aș putea."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Die Reflexivität von „a se plânge“ zeigt, dass man über sich selbst klagt – denk daran, dass du dich selbst „plângi“ (beklagst)."
    },
    {
      "lang": "de",
      "text": "Verbinde „plânge“ mit „plângere“ (Beschwerde) und „plâng“ (ich weine) – so merkst du dir, dass es um das Ausdrücken von Unmut geht, ähnlich wie beim Weinen."
    }
  ],
