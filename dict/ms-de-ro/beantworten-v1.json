  "source": {
    "lang": "de",
    "headword": "beantworten",
    "definition": "auf eine Frage oder eine Nachricht reagieren und eine Antwort geben",
    "pronunciation": "/beˈantʁaɪ̯tn̩/",
    "etymology": {
      "explanation": {
        "sourceText": "Besteht aus „be-“, einer Präfix und „antworten“, was vom mittelhochdeutschen „antwurt“ kommt, was „Antwort geben“ bedeutet.",
        "targetText": "Das deutsche Verb „beantworten“ setzt sich aus der Vorsilbe „be-“ und „antworten“ zusammen, das vom mittelhochdeutschen „antwurt“ stammt."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Verb wird verwendet, um auf eine Anfrage oder Frage zu antworten."
  },
  "target": {
    "lang": "ro",
    "headword": "a răspunde",
    "definition": "a reacționa la o întrebare sau un mesaj și a oferi un răspuns",
    "pronunciation": "/a rəsˈpun.de/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort „a răspunde“ leitet sich von dem slawischen „rъsъ”, was „antworten“ bedeutet. Die Wurzel könnte auch mit dem lateinischen „respondere“ verwandt sein, was „einen Rückbezug geben“ bedeutet.",
        "targetText": "Cuvântul românesc „a răspunde“ provine din slavona „rъsъ“, care înseamnă „a răspunde“, posibil legat și de latinul „respondere“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Es wird häufig verwendet, um Fragen zu beantworten, mit dem Fokus auf die Reaktion auf Anfragen."
  },
  "relatedWords": [
    {
      "sourceText": "Antwort",
      "targetText": "răspuns"
    },
    {
      "sourceText": "Frage",
      "targetText": "întrebare"
    },
    {
      "sourceText": "Kommunikation",
      "targetText": "comunicare"
    },
    {
      "sourceText": "Nachricht",
      "targetText": "mesaj"
    }
  ],
  "antonyms": [
    {
      "sourceText": "ignorieren",
      "targetText": "neatența"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich beantworte die Fragen schnell.",
      "targetText": "Eu răspund rapid la întrebări."
    },
    {
      "sourceText": "Beantwortest du die E-Mail?",
      "targetText": "Răspunzi la e-mail?"
    },
    {
      "sourceText": "Er beantwortet die Anfrage umgehend.",
      "targetText": "El răspunde rapid la solicitare."
    },
    {
      "sourceText": "Wir beantworten alle Rückmeldungen.",
      "targetText": "Noi răspundem la toate feedback-urile."
    },
    {
      "sourceText": "Beantwortet ihr die Fragen der Kunden?",
      "targetText": "Răspundeți la întrebările clienților?"
    },
    {
      "sourceText": "Sie beantworten die Anfragen im Chat.",
      "targetText": "Ei răspund la întrebările din chat."
    },
    {
      "sourceText": "Ich habe die Anfrage beantwortet.",
      "targetText": "Am răspuns la cerere."
    },
    {
      "sourceText": "Sie beantwortete die Nachrichten nicht.",
      "targetText": "Ea nu răspundea la mesaje."
    },
    {
      "sourceText": "Ich werde die Einladung beantworten.",
      "targetText": "Voi răspunde la invitație."
    },
    {
      "sourceText": "Ich würde die Frage beantworten, wenn ich könnte.",
      "targetText": "Aș răspunde la întrebare, dacă aș putea."
    },
    {
      "sourceText": "Beantworte die Anfragen!",
      "targetText": "Răspunde la cereri!"
    },
    {
      "sourceText": "Die beantworteten Fragen sind dokumentiert.",
      "targetText": "Întrebările răspunse sunt documentate."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Denk an das rumänische „răspuns“ als Antwort – so merkst du dir das Verb „a răspunde“ leichter."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du gibst eine Antwort („răspuns“) – das hilft dir, das Verb „a răspunde“ zu verankern."
    },
    {
      "lang": "de",
      "text": "Verbinde „beantworten“ mit „a răspunde“ – beide Wörter haben mit Antworten und Reaktionen zu tun."
    }
  ],
