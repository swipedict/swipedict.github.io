  "source": {
    "lang": "de",
    "headword": "abschließen",
    "definition": "etwas zum Abschluss bringen oder einen Schluss ziehen",
    "pronunciation": "/ˈapʃliːsən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „abschließen“ setzt sich aus dem Präfix „ab-“ und dem Verb „schließen“ zusammen und bedeutet „etwas endgültig beenden“ oder „verschließen“.",
        "targetText": "Verbul german „abschließen“ este compus din prefixul „ab-“ și verbul „schließen“, însemnând „a încheia“ sau „a închide definitiv“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Oft verwendet beim Beenden von Verträgen oder Gesprächen."
  },
  "target": {
    "lang": "ro",
    "headword": "a încheia",
    "definition": "a aduce ceva la final sau a trasa o concluzie",
    "pronunciation": "/a ɨn.ˈke.a/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a încheia“ leitet sich vom lateinischen „clausum“ ab, was „geschlossen“ oder „abgeschlossen“ bedeutet, und steht für das Beenden oder Abschließen von etwas.",
        "targetText": "Verbul românesc „a încheia“ provine din latinescul „clausum“, care înseamnă „închis“ sau „finalizat“, și exprimă ideea de a termina sau a încheia ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird häufig in einem administrativen Kontext verwendet."
  },
  "senses": [
    {
      "gloss": "Gespräch abschließen",
      "explanation": {
        "sourceText": "Das Ende eines Gespräches formalisieren.",
        "targetText": "A formaliza sfârșitul unei conversații."
      },
      "examples": [
        {
          "sourceText": "Wir schließen das Gespräch ab.",
          "targetText": "Încheiem conversația."
        }
      ]
    },
    {
      "gloss": "Projekt abschließen",
      "explanation": {
        "sourceText": "Ein Projekt zum Abschluss bringen.",
        "targetText": "A finaliza un proiect."
      },
      "examples": [
        {
          "sourceText": "Ich werde das Projekt abschließen.",
          "targetText": "Voi încheia proiectul."
        }
      ]
    },
    {
      "gloss": "Vertrag abschließen",
      "explanation": {
        "sourceText": "Bedeutet einen Vertrag formal zu beenden.",
        "targetText": "Înseamnă a finaliza formal un contract."
      },
      "examples": [
        {
          "sourceText": "Ich habe den Vertrag abgeschlossen.",
          "targetText": "Am încheiat contractul."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Abschluss",
      "targetText": "finalizare"
    },
    {
      "sourceText": "Entscheidung",
      "targetText": "decizie"
    },
    {
      "sourceText": "Vertrag",
      "targetText": "contract"
    },
    {
      "sourceText": "Ziel",
      "targetText": "scop"
    }
  ],
  "antonyms": [
    {
      "sourceText": "öffnen",
      "targetText": "a deschide"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich schließe die Tür ab.",
      "targetText": "Închei ușa."
    },
    {
      "sourceText": "Schließt du das Projekt ab?",
      "targetText": "Închei proiectul?"
    },
    {
      "sourceText": "Sie schließt den Vertrag ab.",
      "targetText": "Ea încheie contractul."
    },
    {
      "sourceText": "Wir schließen die Verhandlungen ab.",
      "targetText": "Noi încheiem negocierile."
    },
    {
      "sourceText": "Schließt ihr das Kapitel ab?",
      "targetText": "Încheiați capitolul?"
    },
    {
      "sourceText": "Sie (Pl.) schließen die Sitzung ab.",
      "targetText": "Ei încheie ședința."
    },
    {
      "sourceText": "Ich habe das Dokument abgeschlossen.",
      "targetText": "Am încheiat documentul."
    },
    {
      "sourceText": "Sie schloss die Untersuchung ab.",
      "targetText": "Ea încheia investigația."
    },
    {
      "sourceText": "Ich werde den Vertrag abschließen.",
      "targetText": "Voi încheia contractul."
    },
    {
      "sourceText": "Ich würde das Projekt abschließen, wenn es keine Probleme gäbe.",
      "targetText": "Aș încheia proiectul, dacă nu ar fi probleme."
    },
    {
      "sourceText": "Schließe das ab!",
      "targetText": "Încheie asta!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Abschließen“ und „a încheia“ hängen zusammen: Stell dir eine Tür vor, die abgeschlossen wird – so merkst du das Beenden oder Abschließen."
    },
    {
      "lang": "de",
      "text": "Übe Sätze wie „Eu închei contractul“ (Ich schließe den Vertrag ab) für ein besseres Verständnis."
    },
    {
      "lang": "de",
      "text": "Versuche, eine Situation zu beschreiben, in der du ein Projekt oder eine Untersuchung abschließt – so verankerst du das Wort."
    }
  ],
