  "source": {
    "lang": "de",
    "headword": "malen",
    "definition": "Farben auf eine Oberfläche auftragen, um ein Bild oder eine Darstellung zu schaffen",
    "pronunciation": "/ˈmaːlən/",
    "etymology": {
      "explanation": {
        "sourceText": "„Malen“ kommt vom mittelhochdeutschen „malen“, das „zeichnen“ oder „bilden“ bedeutet, und vom althochdeutschen „malōn“ abstammt.",
        "targetText": "„Malen“ provine din germana mijlocie „malen“, care înseamnă „a desena“ sau „a picta“, derivat din germana veche „malōn“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Ein regelmäßiges Verb, oft in künstlerischen Kontexten verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a picta",
    "definition": "a aplica culori pe o suprafață pentru a crea o imagine sau o reprezentare",
    "pronunciation": "/a ˈpik.ta/",
    "etymology": {
      "explanation": {
        "sourceText": "„A picta“ stammt vom lateinischen „pictare“, was „malen“ oder „zeichnen“ bedeutet, und ist in der rumänischen Kunsttradition tief verwurzelt.",
        "targetText": "„A picta“ provine din latină, din „pictare“, care înseamnă „a picta“ sau „a desena“, fiind adânc înrădăcinat în tradiția artistică românească."
      },
      "source": "Etymological Dictionaries, Wiktionary"
    },
    "additional": "Ein regelmäßiges Verb, häufig für das Erstellen von Gemälden und Zeichnungen verwendet."
  },
  "senses": [
    {
      "gloss": "Bilder erstellen",
      "explanation": {
        "sourceText": "Das bedeutet auch, Bilder zu erstellen und zu gestalten.",
        "targetText": "Înseamnă și a crea și a realiza imagini."
      },
      "examples": [
        {
          "sourceText": "Ich möchte Bilder erstellen.",
          "targetText": "Vreau să creez imagini."
        }
      ]
    },
    {
      "gloss": "Malerei",
      "explanation": {
        "sourceText": "Das Wort 'a picta' wird oft in Bezug auf Malerei verwendet.",
        "targetText": "Cuvântul „a picta“ este folosit adesea în contextul picturii."
      },
      "examples": [
        {
          "sourceText": "Ich machte eine Malerei.",
          "targetText": "Am făcut o pictură."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Bilder",
      "targetText": "imagini"
    },
    {
      "sourceText": "Farben",
      "targetText": "culori"
    },
    {
      "sourceText": "Künstler",
      "targetText": "artist"
    },
    {
      "sourceText": "Pinsel",
      "targetText": "pensulă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "löschen",
      "targetText": "a șterge"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich male ein Bild.",
      "targetText": "Eu pictez o pictură."
    },
    {
      "sourceText": "Malst du die Wände?",
      "targetText": "Pictați pereții?"
    },
    {
      "sourceText": "Sie malt ein Porträt.",
      "targetText": "Ea pictează un portret."
    },
    {
      "sourceText": "Wir malen gemeinsam.",
      "targetText": "Noi pictăm împreună."
    },
    {
      "sourceText": "Malt ihr das Schlafzimmer?",
      "targetText": "Pictați dormitorul?"
    },
    {
      "sourceText": "Sie malen im Atelier.",
      "targetText": "Ei pictează în atelier."
    },
    {
      "sourceText": "Ich habe das Bild gemalt.",
      "targetText": "Am pictat tabloul."
    },
    {
      "sourceText": "Er malte oft Landschaften.",
      "targetText": "El picta adesea peisaje."
    },
    {
      "sourceText": "Ich werde ein neues Bild malen.",
      "targetText": "Voi picta o pictură nouă."
    },
    {
      "sourceText": "Ich würde gerne malen, wenn ich Zeit habe.",
      "targetText": "Aș picta dacă aș avea timp."
    },
    {
      "sourceText": "Male das Haus!",
      "targetText": "Pictați casa!"
    },
    {
      "sourceText": "Das Gemalte ist beeindruckend.",
      "targetText": "Ceea ce a fost pictat este impresionant."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Beachte, dass „a picta“ oft in künstlerischen Kontexten verwendet wird, was dir hilft, die Bedeutung zu verankern."
    },
    {
      "lang": "de",
      "text": "Übe Sätze, in denen du beschreibst, was du gerne malen würdest, um den kreativen Umgang mit „a picta“ zu fördern."
    },
    {
      "lang": "de",
      "text": "Verbinde „malen“ mit „a picta“ durch die Assoziation von Kunst und Bildern – das erleichtert das Lernen."
    }
  ],
