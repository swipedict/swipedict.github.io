  "source": {
    "lang": "de",
    "headword": "anhören",
    "definition": "jemandem oder etwas zuhören",
    "pronunciation": "/anˈhøːʁən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb setzt sich aus dem Präfix „an-“ und dem Verb „hören“ zusammen, welches vom Althochdeutschen „hōren“ stammt und „wahrnehmen durch das Ohr“ bedeutet.",
        "targetText": "Das Verb este compus din prefixul „an-“ și verbul „hören“, care provine din germana veche „hōren“ și înseamnă „a percepe prin ureche“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Oft verwendet, wenn es um das Hören von Musik oder Gesprächen geht."
  },
  "target": {
    "lang": "ro",
    "headword": "a asculta",
    "definition": "a presta atenție cuiva sau cu ceva",
    "pronunciation": "/a as.kuˈta/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb stammt vom lateinischen ‚auscultare‘ ab, was ‚zuhören‘ bedeutet. Es ist ein Kognat zu ‚a auzi‘, das ‚hören‘ bedeutet.",
        "targetText": "Verbul românesc provine din latină, din ‚auscultare‘, care înseamnă ‚a asculta cu atenție‘. Este un cognat cu ‚a auzi‘, care înseamnă ‚a auzi‘."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird häufig verwendet, um Musik zu hören oder Gespräche aktiv zu verfolgen."
  },
  "senses": [
    {
      "gloss": "anhören (im Sinne von erleben oder wahrnehmen)",
      "explanation": {
        "sourceText": "Man kann auch Melodien anhören.",
        "targetText": "Poți asculta și melodii."
      },
      "examples": [
        {
          "sourceText": "Ich habe das neue Lied angehört.",
          "targetText": "Am ascultat melodia nouă."
        }
      ]
    },
    {
      "gloss": "anhören (im Sinne von zuhören)",
      "explanation": {
        "sourceText": "Wie im Deutschen: aktiv zuhören.",
        "targetText": "Ca în germană: a asculta activ."
      },
      "examples": [
        {
          "sourceText": "Ich höre dem Lehrer zu.",
          "targetText": "Îi ascult pe profesori."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Gespräch",
      "targetText": "discuție"
    },
    {
      "sourceText": "Klang",
      "targetText": "sunet"
    },
    {
      "sourceText": "Musik",
      "targetText": "muzică"
    },
    {
      "sourceText": "Stimme",
      "targetText": "voce"
    }
  ],
  "antonyms": [
    {
      "sourceText": "ignorieren",
      "targetText": "a ignora"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich höre die Musik.",
      "targetText": "Eu ascult muzica."
    },
    {
      "sourceText": "Hörst du das Konzert?",
      "targetText": "Asculți concertul?"
    },
    {
      "sourceText": "Er hört gerne Podcasts.",
      "targetText": "El ascultă podcast-uri."
    },
    {
      "sourceText": "Wir hören die Nachrichten.",
      "targetText": "Noi ascultăm știrile."
    },
    {
      "sourceText": "Hört ihr die Musik?",
      "targetText": "Ascultați muzica?"
    },
    {
      "sourceText": "Sie hören das Radio.",
      "targetText": "Ei ascultă radioul."
    },
    {
      "sourceText": "Ich habe die Nachricht gehört.",
      "targetText": "Am ascultat vestea."
    },
    {
      "sourceText": "Er hörte täglich Musik.",
      "targetText": "El asculta muzică în fiecare zi."
    },
    {
      "sourceText": "Ich werde die Vorlesung anhören.",
      "targetText": "Voi asculta prelegerea."
    },
    {
      "sourceText": "Ich würde es anhören, wenn du es mir gibst.",
      "targetText": "Aș asculta dacă mi-l dai."
    },
    {
      "sourceText": "Hör zu!",
      "targetText": "Ascultă!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Anhören“ klingt ähnlich wie „a asculta“ – beide haben das ‚as‘ am Anfang, das hilft dir, die Wörter zu verbinden."
    },
    {
      "lang": "de",
      "text": "Das ‚a‘ am Anfang von ‚asculta‘ erinnert an das deutsche ‚an‘ in ‚anhören‘ – beide zeigen eine gezielte Handlung."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du hältst aufmerksam ein Konzert ab – du ‚hörst an‘ und ‚asculti‘ genau zu."
    }
  ],
