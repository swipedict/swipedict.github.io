      "sourceText": "Ziel",
      "targetText": "obiectiv"
    }
  ],
  "antonyms": [
    {
      "sourceText": "unplanmäßig",
      "targetText": "aleator"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich plane das Event.",
      "targetText": "Eu planific evenimentul."
    },
    {
      "sourceText": "Planst du die Reise?",
      "targetText": "Planifici călătoria?"
    },
    {
      "sourceText": "Sie plant das Meeting.",
      "targetText": "Ea planifică întâlnirea."
    },
    {
      "sourceText": "Wir planen die Strategie.",
      "targetText": "Noi planificăm strategia."
    },
    {
      "sourceText": "Plant ihr den Urlaub?",
      "targetText": "Planificați vacanța?"
    },
    {
      "sourceText": "Sie planen die neuen Projekte.",
      "targetText": "Ei planifică noile proiecte."
    },
    {
      "sourceText": "Ich habe das Meeting bereits geplant.",
      "targetText": "Am planificat întâlnirea deja."
    },
    {
      "sourceText": "Sie haben die Aktivitäten geplant.",
      "targetText": "Au planificat activitățile."
    },
    {
      "sourceText": "Er plante jedes Jahr.",
      "targetText": "El planifica în fiecare an."
    },
    {
      "sourceText": "Ich hatte die Feier bereits geplant.",
      "targetText": "Planificasem deja petrecerea."
    },
    {
      "sourceText": "Ich werde die Sitzung planen.",
      "targetText": "Voi planifica reuniunea."
    },
    {
      "sourceText": "Wir werden alles planen.",
      "targetText": "Noi o să planificăm totul."
    },
    {
      "sourceText": "Ich würde es planen, wenn ich wüsste wie.",
      "targetText": "Aș planifica dacă aș ști cum."
    },
    {
      "sourceText": "Es ist notwendig, dass du die Schritte planst.",
      "targetText": "Este necesar să planifici pașii."
    },
    {
      "sourceText": "Plane die Präsentation!",
      "targetText": "Planifică prezentarea!"
    },
    {
      "sourceText": "Plant die kommende Sitzung!",
      "targetText": "Planificați reuniunea viitoare!"
    },
    {
      "sourceText": "Die geplante Veranstaltung findet morgen statt.",
      "targetText": "Evenimentul planificat are loc mâine."
    },
    {
      "sourceText": "Die Sitzung ist nun geplant.",
      "targetText": "Reuniunea este acum planificată."
    },
    {
      "sourceText": "Durch das Planen erfüllten wir alle Anforderungen.",
      "targetText": "Planificând, am îndeplinit toate cerințele."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Planen“ und „a planifica“ sind Kognaten – beide bedeuten, etwas im Voraus zu organisieren."
    },
    {
      "lang": "de",
      "text": "Eine Eselsbrücke: „Plane nicht nur, sondern handle auch!“ So bleibt das Wort im Kopf."
    },
    {
      "lang": "de",
      "text": "Merke dir „a planifica“ mit dem Bild von „Planschritten“, die du für ein Projekt machst."
    }
  ],
