  "source": {
    "lang": "de",
    "headword": "planen",
    "definition": "etwas im Voraus festlegen oder vorbereiten",
    "pronunciation": "/ˈplaːnən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „planen“ stammt vom mittelhochdeutschen „plannen“, das „entwerfen“ oder „gestalten“ bedeutet.",
        "targetText": "Verbul german „planen“ provine din mijlocul germanului „plannen“, care înseamnă „a proiecta“ sau „a planifica“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb, häufig verwendet, um Vorbereitungen und Strategien zu formulieren."
  },
  "target": {
    "lang": "ro",
    "headword": "a planifica",
    "definition": "a stabili sau a pregăti ceva în avans",
    "pronunciation": "/a pla.niˈfi.ka/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a planifica“ stammt vom lateinischen „planificare“ und bedeutet, etwas im Voraus zu organisieren.",
        "targetText": "Verbul românesc „a planifica“ provine din latină „planificare“ și înseamnă a organiza ceva în avans."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Weit verbreitet in der Geschäftswelt und im Alltag."
  },
  "relatedWords": [
    {
      "sourceText": "Organisierung",
      "targetText": "organizare"
    },
    {
      "sourceText": "Projekt",
      "targetText": "proiect"
    },
    {
      "sourceText": "Vorbereitung",
      "targetText": "pregătire"
    },
