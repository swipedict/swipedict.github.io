  "source": {
    "lang": "de",
    "headword": "bearbeiten",
    "definition": "etwas in seiner Form oder seinem Inhalt verändern oder so gestalten, dass es einen bestimmten Zweck erfüllt",
    "pronunciation": "/beˈaʁbaɪ̯tən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „bearbeiten“ setzt sich aus dem Präfix „be-“ und dem Verb „arbeiten“ zusammen, welches vom mittelhochdeutschen „arbaidn“ stammt und „arbeiten“ bedeutet.",
        "targetText": "Verbul „bearbeiten“ provine din prefixul „be-“ și verbul „arbeiten“, derivat din germana mijlocie „arbaidn“, care înseamnă „a munci“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Verb bedeutet, eine Tätigkeit oder einen Prozess aktiv zu gestalten oder zu verändern."
  },
  "target": {
    "lang": "ro",
    "headword": "a prelucra",
    "definition": "a modifica ceva în forma sau conținutul său pentru a îndeplini un anumit scop",
    "pronunciation": "/a preˈluk.ra/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a prelucra“ stammt vom lateinischen „prae- lucrare“ ab, wobei „lucrare“ für „arbeiten“ steht und das Präfix „pre-“ „vor“ bedeutet, also „vorarbeiten“ oder „vorbereiten“.",
        "targetText": "Verbul românesc „a prelucra“ provine din latină, combinând prefixul „pre-“ (înainte) cu „lucrare“ (a lucra), însemnând „a lucra înainte“ sau „a pregăti“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). In der Regel verwendet, um die Bearbeitung von Materialien oder Informationen zu beschreiben."
  },
  "senses": [
    {
      "gloss": "Bearbeiten eines Dokuments",
      "explanation": {
        "sourceText": "Die aktive Gestaltung eines Dokuments.",
        "targetText": "Acțiunea de a modifica activ un document."
      },
      "examples": [
        {
          "sourceText": "Ich werde das Dokument bearbeiten.",
          "targetText": "Voi prelucra documentul."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Arbeit",
      "targetText": "muncă"
    },
    {
      "sourceText": "Aufgabe",
      "targetText": "sarcină"
    },
    {
      "sourceText": "Kunde",
      "targetText": "client"
    },
    {
      "sourceText": "Projekt",
      "targetText": "proiect"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verlassen",
      "targetText": "a părăsi"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich bearbeite den Bericht jetzt.",
      "targetText": "Eu prelucrez acum raportul."
    },
    {
      "sourceText": "Bearbeitest du die Daten?",
      "targetText": "Prelucrezi datele?"
    },
    {
      "sourceText": "Sie bearbeitet die Anfrage sofort.",
      "targetText": "Ea prelucrează cererea imediat."
    },
    {
      "sourceText": "Wir bearbeiten die Bestellungen.",
      "targetText": "Noi prelucrăm comenzile."
    },
    {
      "sourceText": "Bearbeitet ihr die Projekte?",
      "targetText": "Prelucrați proiectele?"
    },
    {
      "sourceText": "Sie bearbeiten die Unterlagen.",
      "targetText": "Ei prelucrează documentele."
    },
    {
      "sourceText": "Ich habe die Dateien bearbeitet.",
      "targetText": "Am prelucrat fișierele."
    },
    {
      "sourceText": "Er bearbeitete das Manuskript lange.",
      "targetText": "El prelucra manuscrisul mult."
    },
    {
      "sourceText": "Ich werde den Text bearbeiten.",
      "targetText": "Voi prelucra textul."
    },
    {
      "sourceText": "Ich würde das Projekt bearbeiten, wenn ich Zeit hätte.",
      "targetText": "Aș prelucra proiectul, dacă aș avea timp."
    },
    {
      "sourceText": "Bearbeite die Tabelle!",
      "targetText": "Prelucrează tabelul!"
    },
    {
      "sourceText": "Die bearbeiteten Unterlagen sind fertig.",
      "targetText": "Documentele prelucrate sunt gata."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„a prelucra“ enthält „lucra“, was „arbeiten“ bedeutet – denk daran, dass du beim „bearbeiten“ auch „arbeitest“ an etwas!"
    },
    {
      "lang": "de",
      "text": "Das deutsche „bearbeiten“ bedeutet aktiv etwas formen – verbinde das mit „prelucra“, das auch „vorbereiten“ und „bearbeiten“ heißt."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du „präparierst“ (pre-) etwas, bevor du es fertigstellst – so hilft dir das „pre-“ in „prelucra“ beim Merken."
    }
  ],
