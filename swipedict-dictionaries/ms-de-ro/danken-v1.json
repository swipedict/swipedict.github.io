  "source": {
    "lang": "de",
    "headword": "danken",
    "definition": "sich für etwas bedanken oder seine Dankbarkeit ausdrücken",
    "pronunciation": "/ˈdaŋkən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort „danken“ stammt vom althochdeutschen „danki“, was „Dank“ oder „Wertschätzung“ bedeutet. Es ist verwandt mit den altgermanischen Wurzeln für „denken“, da Dank eine Form des Denkens oder Erkennens ist.",
        "targetText": "Verbul german „danken“ provine din althochdeutsch „danki“, însemnând „mulțumire“ sau „apreciere“, legat de rădăcinile germanice pentru „denken“ (a gândi), deoarece mulțumirea ist eine Form des Erkennens."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Häufig verwendet, um Dank oder Anerkennung auszudrücken. Verbindung zu „dankbar“ und „Dankbarkeit“."
  },
  "target": {
    "lang": "ro",
    "headword": "a mulțumi",
    "definition": "a exprima recunoștință pentru ceva",
    "pronunciation": "/a mul.tzuˈmi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „a mulțumi“ kommt vom lateinischen „munctum“ (vollständig geben) und entwickelte sich zur Bedeutung „danken“ im Rumänischen.",
        "targetText": "Verbul românesc „a mulțumi“ derivă din latinul „munctum“, care înseamnă „a da pe deplin“, evoluând spre sensul de „a mulțumi“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-i). Typisch verwendet, um Dank auszudrücken. Man kann auch „a mulțumi de“ verwenden, um für etwas zu danken."
  },
  "relatedWords": [
    {
      "sourceText": "Dank",
      "targetText": "mulțumire"
    },
    {
      "sourceText": "Freund",
      "targetText": "prieten"
    },
    {
      "sourceText": "Geschenk",
      "targetText": "cadou"
    },
    {
      "sourceText": "Hilfe",
      "targetText": "ajutor"
    }
  ],
  "antonyms": [
    {
      "sourceText": "beleidigen",
      "targetText": "a ofensa"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich danke dir für die Hilfe.",
      "targetText": "Îți mulțumesc pentru ajutor."
    },
    {
      "sourceText": "Dankst du mir für die Unterstützung?",
      "targetText": "Îmi mulțumești pentru sprijin?"
    },
    {
      "sourceText": "Er dankt der Lehrerin.",
      "targetText": "El îi mulțumește profesoarei."
    },
    {
      "sourceText": "Wir danken für die Gelegenheit.",
      "targetText": "Îi mulțumim pentru oportunitate."
    },
    {
      "sourceText": "Dankt ihr den Helfern?",
      "targetText": "Mulțumiți ajutoarelor?"
    },
    {
      "sourceText": "Sie danken ihren Freunden.",
      "targetText": "Ei mulțumesc prietenilor lor."
    },
    {
      "sourceText": "Ich habe dir gedankt.",
      "targetText": "Îți mulțumesc."
    },
    {
      "sourceText": "Sie haben der Familie gedankt.",
      "targetText": "Ei au mulțumit familiei."
    },
    {
      "sourceText": "Er dankte oft für die Geschenke.",
      "targetText": "El mulțumea adesea pentru cadouri."
    },
    {
      "sourceText": "Ich hatte den Helfern gedankt.",
      "targetText": "Îi mulțumisem ajutoarelor."
    },
    {
      "sourceText": "Ich werde dir danken.",
      "targetText": "Îți voi mulțumi."
    },
    {
      "sourceText": "Sie wird mir danken.",
      "targetText": "Ea o să-mi mulțumească."
    },
    {
      "sourceText": "Ich würde dir gerne danken.",
      "targetText": "Ți-aș mulțumi."
    },
    {
      "sourceText": "Es ist wichtig, dass du dankst.",
      "targetText": "Este important să mulțumești."
    },
    {
      "sourceText": "Danke für die Unterstützung!",
      "targetText": "Mulțumește pentru sprijin!"
    },
    {
      "sourceText": "Danken Sie bitte!",
      "targetText": "Mulțumiți vă rog!"
    },
    {
      "sourceText": "Der dankbare Helfer ist hier.",
      "targetText": "Ajutorul mulțumitor este aici."
    },
    {
      "sourceText": "Die Familie ist dankbar.",
      "targetText": "Familia este mulțumitoare."
    },
    {
      "sourceText": "Ich bin dankend gekommen.",
      "targetText": "Am venit mulțumind."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„A mulțumi“ ist ein herzliches Wort – denke an die Momente, in denen du jemandem danken möchtest!"
    },
    {
      "lang": "de",
      "text": "Erinnere dich daran, dass „mulțumesc“ oft in der Alltagskommunikation verwendet wird – verwende es oft!"
    },
    {
      "lang": "de",
      "text": "Übe mit Freunden, „danke“ in verschiedenen Kontexten zu verwenden, um Dankbarkeit gut zu verinnerlichen!"
    }
  ],
