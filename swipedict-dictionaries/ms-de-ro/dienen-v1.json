  "source": {
    "lang": "de",
    "headword": "dienen",
    "definition": "einer Sache oder Person Hilfe oder Unterstützung anbieten",
    "pronunciation": "/ˈdiːnən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „dienen“ stammt vom mittelhochdeutschen „dienen“ ab, das „gehorchen“ oder „helfen“ bedeutete und verwandt ist mit althochdeutschen Formen.",
        "targetText": "Verbul german „dienen“ provine din germana mijlocie și însemna „a asculta“ sau „a ajuta“, fiind înrudit cu forme din germana veche."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Es handelt sich um ein unregelmäßiges Verb, das oft im Kontext von Dienstleistung, Unterstützung oder Gehorsam verwendet wird."
  },
  "target": {
    "lang": "ro",
    "headword": "a servi",
    "definition": "a oferi ajutor sau suport unei cauze sau unei persoane",
    "pronunciation": "/a serˈvi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a servi“ stammt vom lateinischen „servire“ ab, was „dienen“ oder „bedienen“ bedeutet und beschreibt den Akt, jemandem zu helfen oder zu dienen.",
        "targetText": "Verbul românesc „a servi“ derivă din latină „servire“, însemnând „a sluji“ sau „a deservi“ și exprimă ideea de a oferi ajutor sau serviciu."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Verb wird oft im Sinne von „jemanden bedienen“ oder „Dienst leisten“ verwendet."
  },
  "senses": [
    {
      "gloss": "Dienen (Gehorsam)",
      "explanation": {
        "sourceText": "Bezieht sich auf das Folgen oder Gehorchen gegenüber einer Autorität.",
        "targetText": "Se referă la a asculta sau a se supune unei autorități."
      },
      "examples": [
        {
          "sourceText": "Ich diene dem Befehl.",
          "targetText": "Servesc poruncii."
        }
      ]
    },
    {
      "gloss": "Dienen (Hilfe)",
      "explanation": {
        "sourceText": "Das Verb bedeutet, Unterstützung oder Hilfe anzubieten.",
        "targetText": "Verbul înseamnă a oferi sprijin sau ajutor."
      },
      "examples": [
        {
          "sourceText": "Ich bin hier, um zu dienen.",
          "targetText": "Sunt aici pentru a servi."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Freund",
      "targetText": "prieten"
    },
    {
      "sourceText": "Helfen",
      "targetText": "a ajuta"
    },
    {
      "sourceText": "Unterstützung",
      "targetText": "sprijin"
    },
    {
      "sourceText": "Ziel",
      "targetText": "scop"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verderben",
      "targetText": "distruge"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich diene dem Volk.",
      "targetText": "Eu servesc poporul."
    },
    {
      "sourceText": "Dienest du dem Kunden gut?",
      "targetText": "Servești bine clientul?"
    },
    {
      "sourceText": "Der Kellner dient die Gäste.",
      "targetText": "Ospătarul servește oaspeții."
    },
    {
      "sourceText": "Wir dienen den Menschen in Not.",
      "targetText": "Noi servim oamenii în nevoie."
    },
    {
      "sourceText": "Dient ihr der Gemeinde?",
      "targetText": "Serviți comunitatea?"
    },
    {
      "sourceText": "Sie dienen der Wissenschaft.",
      "targetText": "Ei servesc științei."
    },
    {
      "sourceText": "Ich habe dem Lehrer gedient.",
      "targetText": "Am servit profesorului."
    },
    {
      "sourceText": "Sie haben dem Verein gedient.",
      "targetText": "Au servit asociației."
    },
    {
      "sourceText": "Er diente der Armee.",
      "targetText": "El servea armata."
    },
    {
      "sourceText": "Ich hatte der Familie gedient.",
      "targetText": "Servisem familiei."
    },
    {
      "sourceText": "Ich werde dem Programm dienen.",
      "targetText": "Voi servi programului."
    },
    {
      "sourceText": "Er wird der Gesellschaft dienen.",
      "targetText": "El o să servească societății."
    },
    {
      "sourceText": "Ich würde dem Projekt dienen, wenn ich könnte.",
      "targetText": "Aș servi proiectului dacă aș putea."
    },
    {
      "sourceText": "Es ist wichtig, dass du dem Team dienst.",
      "targetText": "Este important să servești echipei."
    },
    {
      "sourceText": "Diene deinem Nachbarn!",
      "targetText": "Servește-ți vecinul!"
    },
    {
      "sourceText": "Dienen Sie den Gästen!",
      "targetText": "Serviți oaspeții!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Dienen“ und „a servi“ klingen ähnlich und haben fast die gleiche Bedeutung – das macht das Merken leichter!"
    },
    {
      "lang": "de",
      "text": "Merke dir die rumänischen Verbendungen von „a servi“: -esc, -ești, -ește, -im, -iți, -esc – das hilft dir bei der Konjugation."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du servierst jemandem etwas – so verbindest du „servi“ mit dem Helfen und Dienen."
    }
  ],
