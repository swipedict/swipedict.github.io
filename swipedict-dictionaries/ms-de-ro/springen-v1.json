  "source": {
    "lang": "de",
    "headword": "springen",
    "definition": "sich mit den Füßen vom Boden abstoßen und in die Luft oder über etwas springen",
    "pronunciation": "/ˈʃpʁɪŋən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „springen“ stammt vom mittelhochdeutschen „sprincen“ ab, was „springen“ oder „sich abstoßen“ bedeutet.",
        "targetText": "Verbul german „springen“ provine din vechiul germanic „sprincen“, însemnând „a sări“ sau „a se împinge“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "„Springen“ wird sowohl für physische Bewegungen als auch metaphorisch verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a sări",
    "definition": "a se împinge cu picioarele de pe sol și a se ridica în aer sau a sări peste ceva",
    "pronunciation": "/a səˈri/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „a sări“ stammt vom lateinischen „salire“ ab, was „springen“ oder „hüpfen“ bedeutet.",
        "targetText": "Verbul românesc „a sări“ provine din latinescul „salire“, care înseamnă „a sări“ sau „a hopi“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "„A sări“ ist ein unregelmäßiges Verb und wird auch metaphorisch verwendet, z.B. „a sări de bucurie“."
  },
  "senses": [
    {
      "gloss": "metaphorisches Springen",
      "explanation": {
        "sourceText": "Für Freude oder plötzliche Veränderungen.",
        "targetText": "Pentru bucurie sau schimbări bruște."
      },
      "examples": [
        {
          "sourceText": "Er springt vor Freude.",
          "targetText": "El sare de bucurie."
        }
      ]
    },
    {
      "gloss": "physisches Springen",
      "explanation": {
        "sourceText": "Sich mit den Füßen vom Boden abstoßen.",
        "targetText": "A se împinge cu picioarele de pe sol."
      },
      "examples": [
        {
          "sourceText": "Ich springe über den Zaun.",
          "targetText": "Eu săr peste gard."
        },
        {
          "sourceText": "Der Athlet springt hoch.",
          "targetText": "Atletul sare sus."
        }
      ]
    }
  ],
  "relatedWords": [
