      "targetText": "sărire"
    }
  ],
  "antonyms": [
    {
      "sourceText": "landen",
      "targetText": "a ateriza"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich springe über den Zaun.",
      "targetText": "Eu săr peste gard."
    },
    {
      "sourceText": "Springst du gerne?",
      "targetText": "Îți place să sari?"
    },
    {
      "sourceText": "Er springt in den Pool.",
      "targetText": "El sare în piscină."
    },
    {
      "sourceText": "Wir springen nach vorne.",
      "targetText": "Noi sărim înainte."
    },
    {
      "sourceText": "Springt ihr gespielt?",
      "targetText": "Săriți jocuri?"
    },
    {
      "sourceText": "Die Kinder springen überall.",
      "targetText": "Copiii sar peste tot."
    },
    {
      "sourceText": "Ich bin über den Bach gesprungen.",
      "targetText": "Am sărit peste pârâul."
    },
    {
      "sourceText": "Er sprang jeden Tag im Park.",
      "targetText": "El sărea în fiecare zi în parc."
    },
    {
      "sourceText": "Ich werde morgen springen.",
      "targetText": "Voi sari mâine."
    },
    {
      "sourceText": "Ich würde springen, wenn ich könnte.",
      "targetText": "Aș sări, dacă aș putea."
    },
    {
      "sourceText": "Spring hoch!",
      "targetText": "Sari sus!"
    },
    {
      "sourceText": "Springende Kinder sind glücklich.",
      "targetText": "Copiii sărind sunt fericiți."
    },
    {
      "sourceText": "Springend macht Freude.",
      "targetText": "Sărind, aduce bucurie."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das Wort „sări“ klingt dynamisch – stelle dir vor, wie du fröhlich auf einem Trampolin springst, um es zu merken."
    },
    {
      "lang": "de",
      "text": "Übe die verschiedenen Zeitformen von „a sări“, um ein Gefühl für das Verb zu bekommen."
    },
    {
      "lang": "de",
      "text": "Verbinde „a sări“ mit dem Bild von Kindern, die voller Energie springen – so bleibt das Wort lebendig."
    }
  ],
