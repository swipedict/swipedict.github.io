  "source": {
    "lang": "de",
    "headword": "arbeiten",
    "definition": "eine Tätigkeit ausüben, um etwas zu erreichen oder zu verdienen",
    "pronunciation": "/ˈaʁbaɪ̯tən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „arbeiten“ stammt vom althochdeutschen „arabeit“, was „Mühe, Anstrengung“ bedeutet, und entwickelte sich im Mittelhochdeutschen zu „arbeiten“ im Sinne von „sich mühen, tätig sein“.",
        "targetText": "Verbul „arbeiten“ provine din germana veche „arabeit“, însemnând „osteneală, efort“, și a evoluat în germana mijlocie ca „a munci, a fi activ“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Verwendet für alle Formen von beruflicher oder handwerklicher Tätigkeit."
  },
  "target": {
    "lang": "ro",
    "headword": "a lucra",
    "definition": "a desfășura o activitate pentru a obține sau a câștiga ceva",
    "pronunciation": "/a luˈkra/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a lucra“ stammt vom lateinischen „laborare“ ab, das „arbeiten“ oder „sich anstrengen“ bedeutet und sich auf körperliche oder geistige Tätigkeit bezieht.",
        "targetText": "Verbul românesc „a lucra“ derivă din latină, din „laborare“, care înseamnă „a munci“ sau „a depune efort“, referindu-se la activități fizice sau mentale."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Oft in beruflichen Kontexten sowie in alltäglichen Arbeiten verwendet, auch in Kombination mit anderen Substantiven."
  },
  "relatedWords": [
    {
      "sourceText": "Arbeiter",
      "targetText": "lucrător"
    },
    {
      "sourceText": "Büro",
