    }
  ],
  "antonyms": [
    {
      "sourceText": "entspannen",
      "targetText": "a se odihni"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich arbeite an einem Projekt.",
      "targetText": "Eu lucrez la un proiect."
    },
    {
      "sourceText": "Arbeitest du heute?",
      "targetText": "Lucrezi astăzi?"
    },
    {
      "sourceText": "Er arbeitet an neuen Ideen.",
      "targetText": "El lucrează la idei noi."
    },
    {
      "sourceText": "Wir arbeiten gemeinsam.",
      "targetText": "Noi lucrăm împreună."
    },
    {
      "sourceText": "Arbeitet ihr an dem Bericht?",
      "targetText": "Lucrați la raport?"
    },
    {
      "sourceText": "Sie arbeiten hart.",
      "targetText": "Ei lucrează din greu."
    },
    {
      "sourceText": "Ich habe an dem Projekt gearbeitet.",
      "targetText": "Am lucrat la proiect."
    },
    {
      "sourceText": "Sie arbeitete an ihren Zielen.",
      "targetText": "Ea lucra la obiectivele sale."
    },
    {
      "sourceText": "Ich werde nächste Woche arbeiten.",
      "targetText": "Voi lucra săptămâna viitoare."
    },
    {
      "sourceText": "Ich würde gerne an einem Projekt arbeiten.",
      "targetText": "Aș dori să lucrez la un proiect."
    },
    {
      "sourceText": "Arbeite hart!",
      "targetText": "Lucrează din greu!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „a lucra“ klingt ähnlich wie das deutsche „Lukrativ“ – denke daran, dass Arbeit oft mit dem Ziel verbunden ist, etwas zu verdienen!"
    },
    {
      "lang": "de",
      "text": "Nutze die Konjugation: „Eu lucrez“ (ich arbeite), „Am lucrat“ (ich habe gearbeitet) – so verankerst du das Verb besser im Gedächtnis."
    },
    {
      "lang": "de",
      "text": "Verbinde „a lucra“ mit dem deutschen Wort „Luchs“ – stell dir vor, wie ein Luchs konzentriert arbeitet, um Beute zu fangen."
    }
  ],
