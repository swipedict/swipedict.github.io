  "source": {
    "lang": "de",
    "headword": "beschreiben",
    "definition": "etwas detailliert erklären oder darstellen",
    "pronunciation": "/bəˈʃʁaɪ̯bən/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom mittelhochdeutschen „beschrîben“, was „mit Worten beschreiben“ bedeutet. Enthält das Präfix „be-“.",
        "targetText": "Derivat din germana mijlocie „beschrîben“, care înseamnă „a descrie cu cuvinte“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird häufig im Kontext von Erklärungen, Berichten oder Beschreibungen verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a descrie",
    "definition": "a explica sau a prezenta ceva în detaliu",
    "pronunciation": "/a deˈskri.e/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom lateinischen „describere“ abgeleitet, was „beschreiben“ oder „niederschreiben“ bedeutet. Das Präfix „de-“ verstärkt die Bedeutung.",
        "targetText": "Derivat din latinescul „describere“, care înseamnă „a descrie“ sau „a scrie detaliat“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-ie). Häufig verwendet, um Dinge detailliert darzustellen."
  },
  "relatedWords": [
    {
      "sourceText": "Beispiel",
      "targetText": "exemplu"
    },
    {
      "sourceText": "Darstellung",
      "targetText": "reprezentare"
    },
    {
      "sourceText": "Details",
      "targetText": "detalii"
    },
    {
      "sourceText": "Erklärung",
      "targetText": "explicație"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verheimlichen",
      "targetText": "ascunde"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich beschreibe das Bild.",
      "targetText": "Eu descriu imaginea."
    },
    {
      "sourceText": "Beschreibst du den Ort?",
      "targetText": "Descrei tu locul?"
    },
    {
      "sourceText": "Er beschreibt die Situation.",
      "targetText": "El descrie situația."
    },
    {
      "sourceText": "Wir beschreiben die Ereignisse.",
      "targetText": "Noi descriem evenimentele."
    },
    {
      "sourceText": "Beschreibt ihr den Plan?",
      "targetText": "Descreiți planul?"
    },
    {
      "sourceText": "Sie beschreiben die Details.",
      "targetText": "Ei descriu detaliile."
    },
    {
      "sourceText": "Ich habe das Buch beschrieben.",
      "targetText": "Am descris cartea."
    },
    {
      "sourceText": "Sie beschrieb den Vorfall.",
      "targetText": "Ea descria incidentul."
    },
    {
      "sourceText": "Ich werde die Geschichte beschreiben.",
      "targetText": "Voi descrie povestea."
    },
    {
      "sourceText": "Ich würde es beschreiben, wenn ich wüsste.",
      "targetText": "Aș descrie dacă aș ști."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Achte auf die Präsensendungen: „-u“ (ich), „-i“ (du), „-e“ (er/sie/es) – das hilft dir, die Formen zu erkennen."
    },
    {
      "lang": "de",
      "text": "Das rumänische „a descrie“ kommt vom lateinischen „describere“, das „beschreiben“ und „schreiben“ bedeutet – merke dir die Verbindung zum Schreiben!"
    }
  ],
