  "source": {
    "lang": "de",
    "headword": "vollständig",
    "definition": "etwas in allen Teilen oder Aspekten vorhanden sein",
    "pronunciation": "/fɔlˈʃtɛndɪç/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Adjektiv „vollständig“ setzt sich aus „voll“ und „ständig“ zusammen und bedeutet, dass etwas ganz oder komplett ist.",
        "targetText": "Das deutsche „vollständig“ ist zusammengesetzt aus „voll“ und „ständig“ und bedeutet „ganz“ oder „komplett“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": ""
  },
  "target": {
    "lang": "ro",
    "headword": "complet",
    "genus": "masculine",
    "definition": "în întregime, fără lipsuri",
    "pronunciation": "/komˈplet/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „complet“ stammt vom lateinischen „completus“, was „vollständig“ oder „abgeschlossen“ bedeutet.",
        "targetText": "Românescul „complet“ provine din latină, de la „completus“, care înseamnă „complet“ sau „încheiat“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": ""
  },
