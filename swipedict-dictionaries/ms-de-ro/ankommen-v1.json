  "source": {
    "lang": "de",
    "headword": "ankommen",
    "definition": "an einem Zielort eintreffen oder ankommen",
    "pronunciation": "/ˈanˌkɔmən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort 'ankommen' besteht aus dem Präfix ‚an-‘ und dem Verb ‚kommen‘, das vom althochdeutschen ‚queman‘ stammt und ‚herkommen‘ bedeutet.",
        "targetText": "Cuvântul „ankommen“ este format din prefixul „an-“ și verbul „kommen“, care provine din germana veche „queman“ și înseamnă „a veni“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird verwendet, wenn jemand oder etwas einen bestimmten Ort erreicht."
  },
  "target": {
    "lang": "ro",
    "headword": "a sosi",
    "definition": "a ajunge la o destinație sau a se prezenta",
    "pronunciation": "/a soˈsi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb ‚a sosi‘ stammt wahrscheinlich vom lateinischen ‚sociāre‘ ab, das ‚verbinden‘ bedeutet, und entwickelte sich im Sinne von ‚zusammenkommen‘ oder ‚ankommen‘.",
        "targetText": "Verbul românesc „a sosi“ provine probabil din latină, din „sociāre“, care înseamnă „a uni“, dezvoltându-se cu sensul de „a veni împreună“ sau „a ajunge“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird häufig verwendet, um die Ankunft an einem bestimmten Ort zu beschreiben."
  },
  "senses": [
    {
      "gloss": "an einen Zielort gelangen",
      "explanation": {
        "sourceText": "'A sosi' beschreibt den Prozess, zu einem Ziel zu gelangen.",
        "targetText": "„A sosi“ descrie procesul de a ajunge la o destinație."
      },
      "examples": [
        {
          "sourceText": "Er kommt morgen an.",
          "targetText": "El sosește mâine."
        }
      ]
    },
    {
      "gloss": "ankommen (Ankunft)",
      "explanation": {
        "sourceText": "'A sosi' bedeutet die Ankunft an einem spezifischen Ort.",
        "targetText": "„A sosi“ înseamnă sosirea într-un loc specific."
      },
      "examples": [
        {
          "sourceText": "Ich komme am Dienstag an.",
          "targetText": "Eu sosesc marți."
        }
      ]
    },
    {
      "gloss": "sich präsentieren",
      "explanation": {
        "sourceText": "'A sosi' kann auch bedeuten, sich einem anderen Ort zu zeigen.",
        "targetText": "„A sosi“ poate însemna și a se prezenta într-un loc."
      },
      "examples": [
        {
          "sourceText": "Kommst du pünktlich an?",
          "targetText": "Sosești la timp?"
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Ankunft",
      "targetText": "sosire"
    },
    {
      "sourceText": "Fahrt",
      "targetText": "călătorie"
    },
    {
      "sourceText": "Reise",
      "targetText": "călătorie"
    },
    {
      "sourceText": "Ziel",
      "targetText": "destinație"
    }
  ],
  "antonyms": [
    {
      "sourceText": "abgeben",
      "targetText": "a da"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich komme am Dienstag an.",
      "targetText": "Eu sosesc marți."
    },
    {
      "sourceText": "Kommst du pünktlich an?",
      "targetText": "Sosești la timp?"
    },
    {
      "sourceText": "Er kommt morgen an.",
      "targetText": "El sosește mâine."
    },
    {
      "sourceText": "Wir kommen am Abend an.",
      "targetText": "Noi sosim seara."
    },
    {
      "sourceText": "Kommt ihr mit dem Zug an?",
      "targetText": "Sosiți cu trenul?"
    },
    {
      "sourceText": "Sie kommen sofort an.",
      "targetText": "Ei sosesc imediat."
    },
    {
      "sourceText": "Ich bin gestern angekommen.",
      "targetText": "Am sosit ieri."
    },
    {
      "sourceText": "Sie kamen immer pünktlich an.",
      "targetText": "Ei sosesc întotdeauna la timp."
    },
    {
      "sourceText": "Ich werde um 8 Uhr ankommen.",
      "targetText": "Voi sosii la ora 8."
    },
    {
      "sourceText": "Ich würde ankommen, wenn das Wetter gut ist.",
      "targetText": "Aș sosi dacă vremea este bună."
    },
    {
      "sourceText": "Komm schnell an!",
      "targetText": "Sosește repede!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Ankommen“ und „a sosi“ klingen ähnlich und sind beide mit dem Reisen verbunden – denk an die ‚Sozi‘, die zusammenkommen."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, wie du an einem neuen Ort ankommst – das macht das Wort lebendig und leicht zu merken."
    },
    {
      "lang": "de",
      "text": "Übe Sätze mit Ankunftszeiten, z.B. ‚Eu sosesc marți‘, um das Wort zu festigen."
    }
  ],
