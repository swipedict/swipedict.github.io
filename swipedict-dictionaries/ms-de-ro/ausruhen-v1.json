  "source": {
    "lang": "de",
    "headword": "ausruhen",
    "definition": "sich entspannen oder eine Pause machen",
    "pronunciation": "/ˈaʊsˌʁuːən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „ausruhen“ setzt sich aus „aus“ und „ruhen“ zusammen. „Ruhen“ stammt vom althochdeutschen „ruohen“ und bedeutet „stillstehen“ oder „sich erholen“.",
        "targetText": "Verbul german „ausruhen“ provine din „aus“ + „ruhen“ (a se odihni), indicând relaxarea sau pauza."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird in verschiedenen Kontexten genutzt, um das \"Sich Entspannen\" oder \"Erholen\" zu beschreiben."
  },
  "target": {
    "lang": "ro",
    "headword": "a se odihni",
    "definition": "a se relaxa sau a face o pauză",
    "pronunciation": "/a se odiˈhni/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a se odihni“ stammt vom lateinischen „otium“, was „Ruhe“ oder „Freizeit“ bedeutet. Es wird verwendet, um das Sich-Erholen oder Entspannen auszudrücken.",
        "targetText": "Verbul român „a se odihni“ derivă din lat. „otium“, însemnând odihnă sau relaxare."
      },
      "source": "AI, Wiktionary, Etymological Dictionaries"
    },
    "additional": "Regelmäßiges reflexives Verb. Verwendung als Ausdruck der Entspannung oder Erholung nach anstrengenden Aktivitäten."
  },
  "senses": [
    {
      "gloss": "Pause machen",
      "explanation": {
        "sourceText": "Bedeutet, eine Pause einzulegen, um sich auszuruhen.",
        "targetText": "Înseamnă a face o pauză pentru odihnă."
      },
      "examples": [
        {
          "sourceText": "Wir machen eine Pause.",
          "targetText": "Facem o pauză."
        }
      ]
    },
    {
      "gloss": "sich entspannen",
      "explanation": {
        "sourceText": "Wird synonym für 'ausruhen' verwendet.",
        "targetText": "Se folosește ca sinonim pentru „a se relaxa“."
      },
      "examples": [
        {
          "sourceText": "Ich entspanne mich im Garten.",
          "targetText": "Mă relaxez în grădină."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Entspannung",
      "targetText": "relaxare"
    },
    {
      "sourceText": "Erholung",
      "targetText": "recuperare"
    },
    {
      "sourceText": "Pause",
      "targetText": "pauză"
    },
    {
      "sourceText": "Schlafen",
      "targetText": "a dormi"
    }
  ],
  "antonyms": [
    {
      "sourceText": "arbeiten",
      "targetText": "a munci"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich ruhe mich aus.",
      "targetText": "Eu mă odihnesc."
    },
    {
      "sourceText": "Ruhst du dich heute aus?",
      "targetText": "Te odihnești astăzi?"
    },
    {
      "sourceText": "Er ruht sich auf dem Sofa aus.",
      "targetText": "El se odihnește pe canapea."
    },
    {
      "sourceText": "Wir ruhen uns nach der Arbeit aus.",
      "targetText": "Noi ne odihnim după muncă."
    },
    {
      "sourceText": "Ruhst ihr euch im Park aus?",
      "targetText": "Vă odihniți în parc?"
    },
    {
      "sourceText": "Sie ruhen sich am Wochenende aus.",
      "targetText": "Ei se odihnesc în weekend."
    },
    {
      "sourceText": "Ich habe mich gestern ausgeruht.",
      "targetText": "M-am odihnit ieri."
    },
    {
      "sourceText": "Ich werde mich nach der Arbeit ausruhen.",
      "targetText": "Mă voi odihni după muncă."
    },
    {
      "sourceText": "Ruh dich aus!",
      "targetText": "Odihnește-te!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„A se odihni“ bedeutet „sich ausruhen“ – stelle dir vor, wie du dich nach harter Arbeit entspannst und neue Energie tankst."
    },
    {
      "lang": "de",
      "text": "Das Wort „odihnă“ (Ruhe) steckt in „odihni“ – verbinde es mit dem deutschen „Ruhe“ für eine starke Eselsbrücke."
    },
    {
      "lang": "de",
      "text": "Visualisiere, wie du dich an einem ruhigen Ort entspannst – so merkst du dir „a se odihni“."
    }
  ],
