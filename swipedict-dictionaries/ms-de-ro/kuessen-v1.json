  "source": {
    "lang": "de",
    "headword": "küssen",
    "definition": "mit den Lippen eine Berührung an einer Person oder einem Objekt machen",
    "pronunciation": "/ˈkʏsən/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom mittelhochdeutschen „küssen“, das die Handlung des Liebkosens beschreibt.",
        "targetText": "Vom mittelhochdeutschen „küssen“, das die Handlung des Liebkosens beschreibt."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird verwendet, um Zuneigung auszudrücken oder als freundlicher Gruß."
  },
  "target": {
    "lang": "ro",
    "headword": "a săruta",
    "definition": "a face o atingere cu buzele unei persoane sau unui obiect",
    "pronunciation": "/a səruˈta/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom lateinischen „sauritare“ abstammend, hat sich „a săruta“ als gängiges Verb für Küssen entwickelt.",
        "targetText": "Vom lateinischen „sauritare“ abstammend, hat sich „a săruta“ als gängiges Verb für Küssen entwickelt."
      },
      "source": "Etymological Dictionaries, Wiktionary"
    },
    "additional": "Regelmäßiges Verb. Häufig verwendet, um zwischen Liebenden oder Freunden Zuneigung auszudrücken."
  },
  "relatedWords": [
    {
      "sourceText": "Kussmund",
      "targetText": "buze sărutătoare"
    },
    {
      "sourceText": "Liebe",
      "targetText": "dragoste"
    },
    {
      "sourceText": "Umarmung",
      "targetText": "îmbrățișare"
    },
    {
      "sourceText": "Zuneigung",
      "targetText": "afecțiune"
    }
  ],
  "antonyms": [
    {
      "sourceText": "abstoßen",
      "targetText": "respinge"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich küsse meine Mutter.",
      "targetText": "Îmi sărut mama."
    },
    {
      "sourceText": "Küssest du deinen Freund?",
      "targetText": "Îl săruți pe prietenul tău?"
    },
    {
      "sourceText": "Er küsst seine Partnerin.",
      "targetText": "El își sărută partenera."
    },
    {
      "sourceText": "Wir küssen uns zum Abschied.",
      "targetText": "Ne sărutăm la revedere."
    },
    {
      "sourceText": "Küsst ihr eure Eltern?",
      "targetText": "Îi sărutați pe părinți?"
    },
    {
      "sourceText": "Sie küssen sich oft.",
      "targetText": "Ei se sărută adesea."
    },
    {
      "sourceText": "Ich habe sie geküsst.",
      "targetText": "Am sărutat-o."
    },
    {
      "sourceText": "Er küsste seine Freundin.",
      "targetText": "El săruta prietena sa."
    },
    {
      "sourceText": "Ich werde dich küssen.",
      "targetText": "Te voi săruta."
    },
    {
      "sourceText": "Küsse dein Kind!",
      "targetText": "Sărută-ți copilul!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„A săruta“ klingt weich und zärtlich – verbinde es mit dem Gefühl von Nähe und Liebe."
    },
    {
      "lang": "de",
      "text": "Übe Sätze wie „Te sărut“ (Ich küsse dich), um die Anwendung im Alltag zu festigen."
    }
  ],
