  ],
  "antonyms": [
    {
      "sourceText": "verschweigen",
      "targetText": "a tăcea"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich erzähle dir eine Geschichte.",
      "targetText": "Îți povestesc o poveste."
    },
    {
      "sourceText": "Erzählst du mir mehr?",
      "targetText": "Îmi povestești mai mult?"
    },
    {
      "sourceText": "Sie erzählt von ihrer Kindheit.",
      "targetText": "Ea povestește despre copilăria ei."
    },
    {
      "sourceText": "Wir erzählen unsere Erlebnisse.",
      "targetText": "Noi povestim experiențele noastre."
    },
    {
      "sourceText": "Erzählt ihr die Wahrheit?",
      "targetText": "Povestiți adevărul?"
    },
    {
      "sourceText": "Sie (Pl.) erzählen ihre Geschichten.",
      "targetText": "Ei povestesc poveștile lor."
    },
    {
      "sourceText": "Ich habe die Geschichte erzählt.",
      "targetText": "Am povestit povestea."
    },
    {
      "sourceText": "Er erzählte in der Schule Geschichten.",
      "targetText": "El povestea povești în școală."
    },
    {
      "sourceText": "Ich werde dir eine Geschichte erzählen.",
      "targetText": "Îți voi povesti o poveste."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Povesti“ klingt wie „Poesie“ – verbinde das Erzählen von Geschichten mit Poesie, um dir das Wort zu merken."
    },
    {
      "lang": "de",
      "text": "Übe Sätze wie „Povestesc despre“ (Ich erzähle über) – so baust du deinen Wortschatz auf."
    }
  ],
