  "source": {
    "lang": "de",
    "headword": "erzählen",
    "definition": "eine Geschichte oder Information mitteilen",
    "pronunciation": "/ɛʁˈt͡sɛːlən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „erzählen“ stammt vom mittelhochdeutschen „verzellen“, was „berichten“ oder „erzählen“ bedeutet.",
        "targetText": "Verbul „erzählen“ provine din germana mijlocie „verzellen“, cu sensul de „a relata“ sau „a povesti“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird verwendet, um Geschichten oder Informationen mitzuteilen."
  },
  "target": {
    "lang": "ro",
    "headword": "a povesti",
    "definition": "a comunica o poveste sau o informație",
    "pronunciation": "/a poˈvesti/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a povesti“ stammt vom lateinischen „pavere“ ab, was „sprechen“ oder „erzählen“ bedeutet. Es betont den narrativen Aspekt der Sprache.",
        "targetText": "Verbul românesc „a povesti“ derivă din latină, de la „pavere“, cu sensul de „a vorbi“ sau „a povesti“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-i). Wichtig für das Erzählen von Geschichten und Berichten."
  },
  "senses": [
    {
      "gloss": "eine Geschichte erzählen",
      "explanation": {
        "sourceText": "Verwendet, um eine Erzählung zu beschreiben.",
        "targetText": "Folosit pentru a descrie o povestire."
      },
      "examples": [
        {
          "sourceText": "Ich möchte dir eine Geschichte erzählen.",
          "targetText": "Vreau să-ți povestesc o poveste."
        }
      ]
    },
    {
      "gloss": "etwas berichten",
      "explanation": {
        "sourceText": "Um Informationen zu teilen.",
        "targetText": "Pentru a împărtăși informații."
      },
      "examples": [
        {
          "sourceText": "Ich berichte über meine Reise.",
          "targetText": "Povestesc despre călătoria mea."
        }
      ]
    }
  ],
  "relatedWords": [
    {
