  "antonyms": [
    {
      "sourceText": "einziehen",
      "targetText": "a intra"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich stelle die Bilder aus.",
      "targetText": "Eu expun imaginile."
    },
    {
      "sourceText": "Stellst du deine Reiseerinnerungen aus?",
      "targetText": "Expui amintirile tale de călătorie?"
    },
    {
      "sourceText": "Sie stellt ihre Kunstwerke aus.",
      "targetText": "Ea expune operele sale de artă."
    },
    {
      "sourceText": "Wir stellen unsere Ideen aus.",
      "targetText": "Noi expunem ideile noastre."
    },
    {
      "sourceText": "Stellt ihr eure Projekte aus?",
      "targetText": "Expuneți proiectele voastre?"
    },
    {
      "sourceText": "Sie (Pl.) stellen ihre Ergebnisse aus.",
      "targetText": "Ei expun rezultatele lor."
    },
    {
      "sourceText": "Ich habe die Werke ausgestellt.",
      "targetText": "Am expus lucrările."
    },
    {
      "sourceText": "Er stellte im Museum immer aus.",
      "targetText": "El expunea întotdeauna în muzeu."
    },
    {
      "sourceText": "Du wirst deine Arbeiten ausstellen.",
      "targetText": "Vei expune lucrările tale."
    },
    {
      "sourceText": "Stelle deine besten Werke aus!",
      "targetText": "Expune cele mai bune lucrări!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „expune“ klingt wie „exponieren“ – stelle dir vor, wie du ein Kunstwerk ins Rampenlicht stellst."
    },
    {
      "lang": "de",
      "text": "Denke an Museen und wie Kunstwerke gezeigt werden – so merkst du dir „a expune“ leicht."
    },
    {
      "lang": "de",
      "text": "Verbinde „expune“ mit Ausstellungen und Präsentationen, um die Bedeutung zu verankern."
    }
  ],
