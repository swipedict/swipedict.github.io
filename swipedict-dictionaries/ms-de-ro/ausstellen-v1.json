  "source": {
    "lang": "de",
    "headword": "ausstellen",
    "definition": "etwas zur Verfügung stellen oder präsentieren",
    "pronunciation": "/ˈaʊsˌʃtɛlən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „ausstellen“ setzt sich aus „aus“ (heraus) und „stellen“ (stellen) zusammen und bedeutet, etwas sichtbar zu machen, oft im kulturellen oder geschäftlichen Kontext.",
        "targetText": "Verbul german „ausstellen“ este compus din „aus“ (afară) și „stellen“ (a pune), însemnând a expune sau a prezenta ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Bezug zur Präsentation oder Ausstellung von Objekten."
  },
  "target": {
    "lang": "ro",
    "headword": "a expune",
    "definition": "a pune ceva la dispoziție sau a prezenta",
    "pronunciation": "/a eksˈpu.ne/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a expune“ stammt vom lateinischen „exponere“ ab, was „herausstellen“ bedeutet und das öffentliche Zeigen beschreibt.",
        "targetText": "Verbul românesc „a expune“ derivă din latină, din „exponere“, care înseamnă „a expune“ sau „a prezenta“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird oft verwendet, wenn man von Ausstellungen oder Präsentationen spricht."
  },
  "senses": [
    {
      "gloss": "ausstellen",
      "explanation": {
        "sourceText": "Das wird verwendet, um etwas öffentlich zu zeigen oder zur Verfügung zu stellen.",
        "targetText": "Folosit pentru a arăta sau a pune ceva la dispoziție public."
      },
      "examples": [
        {
          "sourceText": "Ich stelle die Bilder aus.",
          "targetText": "Eu expun imaginile."
        }
      ]
    },
    {
      "gloss": "ausstellen",
      "explanation": {
        "sourceText": "Verwendet in einem Kontext der Präsentation oder Ausstellung.",
        "targetText": "Folosit în contextul prezentării sau expunerii."
      },
      "examples": [
        {
          "sourceText": "Wir stellen unsere Ideen aus.",
          "targetText": "Noi expunem ideile noastre."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Bescheinigung",
