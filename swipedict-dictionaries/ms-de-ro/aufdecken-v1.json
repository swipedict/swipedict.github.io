  "source": {
    "lang": "de",
    "headword": "aufdecken",
    "definition": "etwas sichtbar machen oder enthüllen",
    "pronunciation": "/ˈaʊ̯fˌdɛkən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „aufdecken“ setzt sich aus „auf“ (nach oben) und „decken“ (bedecken) zusammen. „Decken“ stammt vom mittelhochdeutschen „dekken“, was „bedecken“ bedeutet.",
        "targetText": "Verbul „aufdecken“ este compus din „auf“ (sus) și „decken“ (a acoperi), iar „decken“ provine din germana mijlocie „dekken“, însemnând „a acoperi“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Wort wird häufig im übertragenen Sinn verwendet, z.B. in Bezug auf die Aufdeckung von Informationen oder Wahrheiten."
  },
  "target": {
    "lang": "ro",
    "headword": "a descoperi",
    "definition": "a face ceva vizibil sau a dezvălui",
    "pronunciation": "/a des.koˈpe.ri/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „a descoperi“ stammt vom lateinischen „discooperire“, zusammengesetzt aus „dis-“ (entfernen) und „cooperire“ (bedecken), und bedeutet „etwas enthüllen“.",
        "targetText": "Românescul „a descoperi“ derivă din latină, din „discooperire“, compus din „dis-“ (a separa) și „cooperire“ (a acoperi), însemnând „a dezvălui“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-i). Oft verwendet, wenn es um das Entdecken von Geheimnissen oder die Aufklärung von Situationen geht."
  },
  "senses": [
    {
      "gloss": "Aufdeckung von Informationen",
      "explanation": {
        "sourceText": "Speziell für die Aufdeckung in einem journalistischen Kontext.",
        "targetText": "În special pentru dezvăluiri în context jurnalistic."
      },
      "examples": [
        {
          "sourceText": "Die Aufdeckung der Wahrheit war notwendig.",
          "targetText": "Dezvăluirea adevărului a fost necesară."
        }
      ]
    },
    {
      "gloss": "Entdeckung",
      "explanation": {
        "sourceText": "Für die Entdeckung neuer Informationen.",
        "targetText": "Pentru descoperirea unor informații noi."
      },
      "examples": [
        {
          "sourceText": "Die Entdeckung neuer Fakten hat die Situation verändert.",
          "targetText": "Descoperirea de noi fapte a schimbat situația."
        }
      ]
    },
    {
      "gloss": "Enthüllung",
      "explanation": {
        "sourceText": "Wie im Deutschen: für das Revealing von Geheimnissen.",
        "targetText": "Ca în germană, pentru dezvăluirea secretelor."
      },
      "examples": [
        {
          "sourceText": "Die Enthüllung des Geheimnisses war schockierend.",
          "targetText": "Dezvăluirea secretului a fost șocantă."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Enthüllung",
      "targetText": "dezvăluire"
    },
    {
      "sourceText": "Entwicklung",
      "targetText": "dezvoltare"
    },
    {
      "sourceText": "Offenbarung",
      "targetText": "revelare"
    },
    {
      "sourceText": "Sicht",
      "targetText": "vedere"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verdecken",
      "targetText": "a acoperi"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich decke das Geheimnis auf.",
      "targetText": "Eu descopăr secretul."
    },
    {
      "sourceText": "Deckst du das Rätsel auf?",
      "targetText": "Descoperi tu enigma?"
    },
    {
      "sourceText": "Er deckt die Wahrheit auf.",
      "targetText": "El descoperă adevărul."
    },
    {
      "sourceText": "Wir decken das Problem auf.",
      "targetText": "Noi descoperim problema."
    },
    {
      "sourceText": "Deckt ihr die Lüge auf?",
      "targetText": "Descoperiți minciuna?"
    },
    {
      "sourceText": "Sie (Pl.) decken die Fakten auf.",
      "targetText": "Ei descoperă faptele."
    },
    {
      "sourceText": "Ich habe das Geheimnis aufgedeckt.",
      "targetText": "Am descoperit secretul."
    },
    {
      "sourceText": "Sie haben die Wahrheit aufgedeckt.",
      "targetText": "Au descoperit adevărul."
    },
    {
      "sourceText": "Er deckte die Fakten immer auf.",
      "targetText": "El descoperea întotdeauna faptele."
    },
    {
      "sourceText": "Ich hatte die Lüge schon aufgedeckt.",
      "targetText": "Descoperisem deja minciuna."
    },
    {
      "sourceText": "Ich werde das Geheimnis aufdecken.",
      "targetText": "Voi descoperi secretul."
    },
    {
      "sourceText": "Sie wird die Wahrheit aufdecken.",
      "targetText": "Ea o să descopere adevărul."
    },
    {
      "sourceText": "Ich würde das Geheimnis aufdecken, wenn ich könnte.",
      "targetText": "Aș descoperi secretul dacă aș putea."
    },
    {
      "sourceText": "Es ist notwendig, dass du das Rätsel aufdeckst.",
      "targetText": "Este necesar să descoperi enigma."
    },
    {
      "sourceText": "Deck das Geheimnis auf!",
      "targetText": "Descoperă secretul!"
    },
    {
      "sourceText": "Deckt die Wahrheit auf!",
      "targetText": "Descoperiți adevărul!"
    },
    {
      "sourceText": "Das aufgedeckte Geheimnis ist interessant.",
      "targetText": "Secretul descoperit este interesant."
    },
    {
      "sourceText": "Die Wahrheit ist jetzt aufgedeckt.",
      "targetText": "Adevărul este acum descoperit."
    },
    {
      "sourceText": "Indem ich das Geheimnis aufdeckte, schuf ich Klarheit.",
      "targetText": "Descoperind secretul, am creat claritate."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Aufdecken“ und „a descoperi“ haben eine ähnliche Bedeutung, was das Erinnern erleichtert!"
    },
    {
      "lang": "de",
      "text": "Denke an „descoperi“ als das Enthüllen von etwas Verstecktem – das gibt dir die Möglichkeit, das Wort mit einem Erlebnis zu verbinden!"
    },
    {
      "lang": "de",
      "text": "Mach ein Spiel daraus: Sag „descoperi“ laut, jedes Mal wenn du etwas Neues lernst!"
    },
    {
      "lang": "de",
      "text": "Übe, Fragen zu stellen, die mit „a descoperi“ zusammenhängen, um spannende Kontexte zu schaffen."
    },
    {
      "lang": "de",
      "text": "Visualisiere das Aufdecken von Geheimnissen oder das Öffnen eines Geschenks – das hilft beim Lernen!"
    }
  ],
