  "antonyms": [
    {
      "sourceText": "weinen",
      "targetText": "a plânge"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich lache über den Witz.",
      "targetText": "Râd de gluma."
    },
    {
      "sourceText": "Lachst du oft?",
      "targetText": "Râzi des?"
    },
    {
      "sourceText": "Er lacht herzlich.",
      "targetText": "El râde din toată inima."
    },
    {
      "sourceText": "Wir lachen zusammen.",
      "targetText": "Râdem împreună."
    },
    {
      "sourceText": "Lacht ihr im Kino?",
      "targetText": "Râdeți la cinema?"
    },
    {
      "sourceText": "Sie lachen viel.",
      "targetText": "Ei râd mult."
    },
    {
      "sourceText": "Ich habe viel gelacht.",
      "targetText": "Am râs mult."
    },
    {
      "sourceText": "Er lachte über den Film.",
      "targetText": "El râdea de film."
    },
    {
      "sourceText": "Ich werde lachen.",
      "targetText": "Voi râde."
    },
    {
      "sourceText": "Lache mehr!",
      "targetText": "Râde mai mult!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„A râde“ stammt vom lateinischen „ridere“ – verbinde es mit fröhlichen Momenten, um es besser zu behalten."
    },
    {
      "lang": "de",
      "text": "Übe den Satz „Râd de...“ (Ich lache über...) mit verschiedenen Themen, um es im Gespräch zu nutzen."
    }
  ],
