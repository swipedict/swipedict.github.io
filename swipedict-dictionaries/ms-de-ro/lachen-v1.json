  "source": {
    "lang": "de",
    "headword": "lachen",
    "definition": "eine laute, freudige Äußerung, die oft mit einem Ausdruck von Glück oder Humor verbunden ist",
    "pronunciation": "/ˈlaxən/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom mittelhochdeutschen „lachen“, das den Ausdruck von Freude beschreibt.",
        "targetText": "Vom mittelhochdeutschen „lachen“, das den Ausdruck von Freude beschreibt."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird verwendet, um Freude auszudrücken oder über Humor zu lachen."
  },
  "target": {
    "lang": "ro",
    "headword": "a râde",
    "definition": "o exprimare sonoră de bucurie, adesea asociată cu umorul",
    "pronunciation": "/a ˈri.de/",
    "etymology": {
      "explanation": {
        "sourceText": "Vom lateinischen „ridere“ abgeleitet, bedeutet es lachen und Freude ausdrücken.",
        "targetText": "Vom lateinischen „ridere“ abgeleitet, bedeutet es lachen und Freude ausdrücken."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Kommt häufig in sozialen Interaktionen vor und drückt Freude und Spaß aus."
  },
  "relatedWords": [
    {
      "sourceText": "Freude",
      "targetText": "bucurie"
    },
    {
      "sourceText": "Lächeln",
      "targetText": "zâmbet"
