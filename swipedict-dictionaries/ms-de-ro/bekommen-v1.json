    }
  ],
  "antonyms": [
    {
      "sourceText": "verlieren",
      "targetText": "a pierde"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich bekomme ein Geschenk.",
      "targetText": "Eu primesc un cadou."
    },
    {
      "sourceText": "Er bekommt die Infos rechtzeitig.",
      "targetText": "El primește informațiile la timp."
    },
    {
      "sourceText": "Wir bekommen die Einladung.",
      "targetText": "Noi primim invitația."
    },
    {
      "sourceText": "Bekommt ihr die Tickets?",
      "targetText": "Primiți biletele?"
    },
    {
      "sourceText": "Sie bekommen die Unterlagen morgen.",
      "targetText": "Ei primesc documentele mâine."
    },
    {
      "sourceText": "Ich habe die Daten heute bekommen.",
      "targetText": "Am primit datele astăzi."
    },
    {
      "sourceText": "Sie bekam oft Geschenke.",
      "targetText": "Ea primea adesea cadouri."
    },
    {
      "sourceText": "Ich werde das Paket morgen bekommen.",
      "targetText": "Voi primi pachetul mâine."
    },
    {
      "sourceText": "Ich würde es gerne bekommen.",
      "targetText": "Aș dori să primesc."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Merke dir den Unterschied zwischen „a primi“ (bekommen) und „a înțelege“ (verstehen), um Verwechslungen zu vermeiden."
    },
    {
      "lang": "de",
      "text": "Nutze das Verb mit verschiedenen Objekten, um die vielseitige Verwendung von „a primi“ zu lernen."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, wie du etwas bekommst – das hilft, das Wort „primi“ im Gedächtnis zu verankern."
    }
  ],
