  "source": {
    "lang": "de",
    "headword": "bekommen",
    "definition": "etwas erhalten oder in den Besitz von etwas gelangen",
    "pronunciation": "/bəˈkɔmən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „bekommen“ stammt vom mittelhochdeutschen „becomen“ ab, was „erhalten“ oder „bekommen“ bedeutet. Es beschreibt den Vorgang, etwas zu empfangen.",
        "targetText": "Verbul german „bekommen“ provine din germana mijlocie „becomen“, care înseamnă a primi sau a obține ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Häufig verwendet, wenn etwas erhalten wird, sei es physisch oder emotional, z. B. Geschenke oder Informationen."
  },
  "target": {
    "lang": "ro",
    "headword": "a primi",
    "definition": "a obține sau a căpăta ceva",
    "pronunciation": "/a priˈmi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a primi“ stammt vom lateinischen „recipere“ ab, was „empfangen“ oder „erhalten“ bedeutet. Es beschreibt den Akt des Empfangens von Dingen oder Gefühlen.",
        "targetText": "Verbul românesc „a primi“ provine din latină, de la „recipere“, care înseamnă a primi sau a obține ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation (-i). Oft verwendet, um sowohl materielle als auch immaterielle Dinge zu empfangen, z. B. Geschenke, Briefe oder Nachrichten."
  },
  "relatedWords": [
    {
      "sourceText": "Geld",
      "targetText": "bani"
    },
