      "targetText": "neprocesat"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich verarbeite die Daten.",
      "targetText": "Eu procesez datele."
    },
    {
      "sourceText": "Verarbeitest du die Meldungen?",
      "targetText": "Procesezi mesajele?"
    },
    {
      "sourceText": "Der Computer verarbeitet die Informationen.",
      "targetText": "Calculatorul procesează informațiile."
    },
    {
      "sourceText": "Wir verarbeiten das Material.",
      "targetText": "Noi procesăm materialul."
    },
    {
      "sourceText": "Verarbeitet ihr die Ergebnisse?",
      "targetText": "Procesezi rezultatele?"
    },
    {
      "sourceText": "Sie verarbeiten die Anfrage.",
      "targetText": "Ei procesează cererea."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„A procesa“ erinnert an „Prozess“ – denke an eine Abfolge von Schritten, um etwas zu bearbeiten."
    },
    {
      "lang": "de",
      "text": "Achte auf die Präsensendungen: -ez, -ești, -ează – sie sind regelmäßig und helfen beim Lernen."
    },
    {
      "lang": "de",
      "text": "Übe mit Sätzen wie „Eu procesez“ (Ich verarbeite) und „Eu am procesat“ (Ich habe verarbeitet)."
    }
  ],
