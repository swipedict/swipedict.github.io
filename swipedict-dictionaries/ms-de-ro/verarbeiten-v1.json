  "source": {
    "lang": "de",
    "headword": "verarbeiten",
    "definition": "etwas mit einem bestimmten Ziel bearbeiten oder umformen",
    "pronunciation": "/fɛʁˈaʁ.baɪ.tən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „verarbeiten“ kombiniert die Vorsilbe „ver-“ mit „arbeiten“ und bedeutet, etwas zu bearbeiten oder umzuwandeln.",
        "targetText": "Verbul „verarbeiten“ combină prefixul „ver-“ cu „arbeiten“, însemnând a prelucra sau transforma ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": ""
  },
  "target": {
    "lang": "ro",
    "headword": "a procesa",
    "definition": "a manipula sau a transforma ceva cu un scop anume",
    "pronunciation": "/a proˈtʃe.za/",
    "etymology": {
      "explanation": {
        "sourceText": "„A procesa“ stammt vom lateinischen „processare“, was „voranschreiten“ oder „fortschreiten“ bedeutet und sich auf die Bearbeitung oder Umwandlung bezieht.",
        "targetText": "Verbul „a procesa“ derivă din latina „processare“, însemnând a avansa sau a prelucra ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Wird in industriellen, kulinarischen und digitalen Kontexten häufig verwendet."
  },
  "senses": [
    {
      "gloss": "Daten verarbeiten",
      "explanation": {
        "sourceText": "Daten werden in verschiedene Formate umgewandelt.",
        "targetText": "Datele sunt transformate în diferite formate."
      },
      "examples": [
        {
          "sourceText": "Ich verarbeite die Daten.",
          "targetText": "Eu procesez datele."
        }
      ]
    },
    {
      "gloss": "Informationen verarbeiten",
      "explanation": {
        "sourceText": "Informationen werden strukturiert und genutzt.",
        "targetText": "Informațiile sunt structurate și utilizate."
      },
      "examples": [
        {
          "sourceText": "Der Computer verarbeitet die Informationen.",
          "targetText": "Calculatorul procesează informațiile."
        }
      ]
    },
    {
      "gloss": "Material verarbeiten",
      "explanation": {
        "sourceText": "Das Umwandeln von Rohmaterial in Endprodukte.",
        "targetText": "Transformarea materiilor prime în produse finite."
      },
      "examples": [
        {
          "sourceText": "Wir verarbeiten das Material.",
          "targetText": "Noi procesăm materialul."
        }
      ]
    }
  ],
