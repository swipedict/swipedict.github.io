  "source": {
    "lang": "de",
    "headword": "bedrohen",
    "definition": "jemanden in eine Situation bringen, in der er Angst hat oder sich bedroht fühlt",
    "pronunciation": "/bəˈdroːən/",
    "etymology": {
      "explanation": {
        "sourceText": "Zusammensetzung aus „bedrängen“ und „drohen“ – drängen oder in Gefahr bringen.",
        "targetText": "Das deutsche Wort setzt sich aus „bedrängen“ (drängen) und „drohen“ zusammen."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Es hat oft eine negative Konnotation und wird in der Kriminalität verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a amenința",
    "definition": "a pune pe cineva într-o situație care îl face să se simtă speriat sau în pericol",
    "pronunciation": "/a ameˈni.t͡sa/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a amenința“ stammt vom lateinischen „minitari“ ab, was „drohen“ bedeutet.",
        "targetText": "Verbul românesc „a amenința“ derivă din latină, din „minitari“, care înseamnă „a amenința“."
      },
      "source": "Etymological Dictionaries, Wiktionary"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation. Es wird häufig in rechtlichen und kriminellen Kontexten verwendet."
  },
  "relatedWords": [
    {
      "sourceText": "Angst",
      "targetText": "frică"
    },
    {
      "sourceText": "Drohung",
      "targetText": "amenințare"
    },
    {
      "sourceText": "Gefahr",
      "targetText": "pericol"
    },
    {
      "sourceText": "Sicherheit",
      "targetText": "siguranță"
    }
  ],
  "antonyms": [
    {
      "sourceText": "beschützen",
      "targetText": "a proteja"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich bedrohe die Angreifer.",
      "targetText": "Eu ameninț atacatorii."
    },
    {
      "sourceText": "Bedrohst du mich?",
      "targetText": "Mă ameninți?"
    },
    {
      "sourceText": "Der Raubüberfall bedroht die Sicherheit.",
      "targetText": "Jaful amenință siguranța."
    },
    {
      "sourceText": "Wir bedrohen die Rivalen.",
      "targetText": "Noi amenințăm rivalii."
    },
    {
      "sourceText": "Bedroht ihr die Aussagen?",
      "targetText": "Amenințați mărturiile?"
    },
    {
      "sourceText": "Sie bedrohen die Behörden.",
      "targetText": "Ei amenință autoritățile."
    },
    {
      "sourceText": "Ich habe ihn bedroht.",
      "targetText": "L-am amenințat."
    },
    {
      "sourceText": "Er bedrohte die Zeugen.",
      "targetText": "El amenința martorii."
    },
    {
      "sourceText": "Ich werde dich bedrohen.",
      "targetText": "Te voi amenința."
    },
    {
      "sourceText": "Ich würde die Polizei bedrohen, wenn ich könnte.",
      "targetText": "Aș amenința poliția, dacă aș putea."
    },
    {
      "sourceText": "Bedrohe mich nicht!",
      "targetText": "Nu mă amenința!"
    },
    {
      "sourceText": "Die bedrohte Person fühlte sich unsicher.",
      "targetText": "Persoana amenințată se simțea nesigură."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das Wort „amenința“ klingt geheimnisvoll – stell dir eine ernste Drohung vor, die Angst macht."
    },
    {
      "lang": "de",
      "text": "Merke dir die Konjugation: -ez, -ezi, -ează, -ăm, -ați, -ează – so kannst du „a amenința“ richtig verwenden."
    }
  ],
