  "source": {
    "lang": "de",
    "headword": "entstehen",
    "definition": "sich bilden, herauskommen oder entwickelt werden",
    "pronunciation": "/ɛntˈʃteːn/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „entstehen“ setzt sich aus dem Präfix „ent-“ und dem Verb „stehen“ zusammen und bedeutet, dass etwas neu entsteht oder sich bildet.",
        "targetText": "Verbul „entstehen“ este format din prefixul „ent-“ și verbul „stehen“ și înseamnă că ceva nou se formează sau apare."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Verwendung in Kontexten von Entwicklung und Schaffung."
  },
  "target": {
    "lang": "ro",
    "headword": "a ieși",
    "definition": "a se forma, a ieși sau a se dezvolta",
    "pronunciation": "/a jeˈsi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a ieși“ stammt vom lateinischen „exire“ ab, was „herausgehen“ oder „entstehen“ bedeutet.",
        "targetText": "Verbul românesc „a ieși“ provine din latină, din „exire“, care înseamnă „a ieși afară“ sau „a apărea“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation. Wird häufig zur Beschreibung von Prozessen oder Erscheinungen verwendet."
  },
  "relatedWords": [
    {
      "sourceText": "Entwicklung",
      "targetText": "dezvoltare"
    },
    {
      "sourceText": "Schöpfung",
      "targetText": "creație"
    },
    {
      "sourceText": "Ursprung",
      "targetText": "origine"
    },
    {
      "sourceText": "Vorkommen",
      "targetText": "aparținere"
    }
  ],
  "antonyms": [
    {
      "sourceText": "vergehen",
      "targetText": "a dispărea"
    }
  ],
  "examples": [
    {
      "sourceText": "Ein neues Projekt entsteht.",
      "targetText": "Un nou proiect iese."
    },
    {
      "sourceText": "Entstehst du durch Zusammenarbeit?",
      "targetText": "Ieși prin colaborare?"
    },
    {
      "sourceText": "Das Bild entsteht Schritt für Schritt.",
      "targetText": "Imaginea iese pas cu pas."
    },
    {
      "sourceText": "Wir entstehen als Team.",
      "targetText": "Noi ieșim ca echipă."
    },
    {
      "sourceText": "Entsteht ihr aus den Idealen?",
      "targetText": "Ieșiți din idealuri?"
    },
    {
      "sourceText": "Sie entstehen schnell und einfach.",
      "targetText": "Ei ies rapid și ușor."
    },
    {
      "sourceText": "Ein neues Produkt ist entstanden.",
      "targetText": "Un nou produs a ieșit."
    },
    {
      "sourceText": "Das Projekt entstand während der Zusammenarbeit.",
      "targetText": "Proiectul a ieșit în timpul colaborării."
    },
    {
      "sourceText": "Ich werde entstehen.",
      "targetText": "Voi ieși."
    },
    {
      "sourceText": "Ich würde entstehen, wenn ich die Chance hätte.",
      "targetText": "Aș ieși dacă aș avea ocazia."
    },
    {
      "sourceText": "Entstehst du schnell?",
      "targetText": "Ieși repede?"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „a ieși“ bedeutet „herauskommen“ – denk an „entstehen“ als etwas, das aus etwas herauskommt."
    },
    {
      "lang": "de",
      "text": "Merke dir: Ohne „rausgehen“ (ieși) kann nichts Neues entstehen – so verbindet sich Bewegung mit Entstehung."
    }
  ],
