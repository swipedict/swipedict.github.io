  "source": {
    "lang": "de",
    "headword": "zusammenarbeiten",
    "definition": "gemeinsam an einer Aufgabe arbeiten",
    "pronunciation": "/ʊnˈʁaɪ̯tən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort setzt sich aus dem Präfix „zusammen-“ und dem Verb „arbeiten“ zusammen, was Zusammenarbeit beschreibt.",
        "targetText": "Cuvântul este format din prefixul „zusammen-“ și verbul „arbeiten“, indicând colaborarea."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Häufig im professionellen Kontext verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a colabora",
    "definition": "a lucra împreună la o sarcină",
    "pronunciation": "/a kolaˈboɾa/",
    "etymology": {
      "explanation": {
        "sourceText": "Abgeleitet vom lateinischen „collaborare“, was „gemeinsam arbeiten“ bedeutet.",
        "targetText": "Derivat din latină „collaborare“, care înseamnă „a lucra împreună“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a)."
  },
