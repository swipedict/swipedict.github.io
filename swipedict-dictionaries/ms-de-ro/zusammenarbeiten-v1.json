  "learningTips": [
    {
      "lang": "de",
      "text": "Das Wort „colaborez“ klingt wie „Kolaborez“ – das hilft dir, es mit Teamarbeit zu verbinden."
    },
    {
      "lang": "de",
      "text": "Denk an einen ‚Kollaborateur‘ als Freund, der mit dir zusammenarbeitet – so bleibt das Wort im Kopf."
    },
    {
      "lang": "de",
      "text": "Verb „a colabora“ klingt ähnlich wie „Kollege“ und „Kooperation“ – stell dir vor, wie Kollegen zusammenarbeiten."
    }
  ],
