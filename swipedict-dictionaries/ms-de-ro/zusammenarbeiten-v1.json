  "examples": [
    {
      "sourceText": "Ich arbeite zusammen mit dir.",
      "targetText": "Colaborez cu tine."
    },
    {
      "sourceText": "Arbeitest du zusammen mit mir?",
      "targetText": "Colaborezi cu mine?"
    },
    {
      "sourceText": "Sie arbeitet zusammen mit dem Team.",
      "targetText": "Ea colaborează cu echipa."
    },
    {
      "sourceText": "Wir arbeiten zusammen.",
      "targetText": "Noi colaborăm."
    },
    {
      "sourceText": "Arbeitet ihr zusammen?",
      "targetText": "Colaborați împreună?"
    },
    {
      "sourceText": "Sie arbeiten zusammen.",
      "targetText": "Ei colaborează."
    },
    {
