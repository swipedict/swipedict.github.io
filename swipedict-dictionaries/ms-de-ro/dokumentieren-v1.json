  "source": {
    "lang": "de",
    "headword": "dokumentieren",
    "definition": "etwas schriftlich festhalten oder aufzeichnen",
    "pronunciation": "/do.ku.mentˈiː.ʁən/",
    "etymology": {
      "explanation": {
        "sourceText": "Entlehnt aus dem Lateinischen „documentum”, was „Beweisstück, Lehrmittel“ bedeutet. Es beschreibt die Handlung des Festhaltens oder Aufzeichnens von Informationen.",
        "targetText": "Verbul „dokumentieren“ stammt din latină „documentum“ și desemnează actul de a înregistra sau nota informații în scris."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Vor allem in akademischen und bürokratischen Kontexten verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a documenta",
    "definition": "a înregistra sau a nota ceva în scris",
    "pronunciation": "/a do.coˈmen.ta/",
    "etymology": {
      "explanation": {
        "sourceText": "Abgeleitet vom lateinischen „documentare”, was „festhalten, aufzeichnen” bedeutet, steht es für die Handlung, Informationen schriftlich festzuhalten.",
        "targetText": "Derivat din latină „documentare”, însemnând „a înregistra” sau „a nota” informații în scris."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Wird häufig in akademischen, kommerziellen oder behördlichen Kontexten verwendet. Bezieht sich oft auf das Erstellen von Berichten oder Protokollen."
  },
  "senses": [
    {
      "gloss": "Aufzeichnung",
      "explanation": {
        "sourceText": "Dies bedeutet das Festhalten von Informationen.",
        "targetText": "Înseamnă înregistrarea informațiilor."
      },
      "examples": [
        {
          "sourceText": "Ich mache eine Aufzeichnung.",
          "targetText": "Fac o înregistrare."
        }
      ]
    },
    {
      "gloss": "Bericht",
      "explanation": {
        "sourceText": "Ein Dokument wird oft in Form eines Berichts präsentiert.",
        "targetText": "Un document este adesea prezentat sub formă de raport."
      },
      "examples": [
        {
          "sourceText": "Ich schreibe einen Bericht.",
          "targetText": "Scriu un raport."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Aufzeichnung",
      "targetText": "înregistrare"
    },
    {
      "sourceText": "Bericht",
      "targetText": "raport"
    },
    {
      "sourceText": "Notiz",
      "targetText": "notă"
    },
    {
      "sourceText": "Unterlage",
      "targetText": "document"
    }
  ],
  "antonyms": [
    {
      "sourceText": "vergessen",
      "targetText": "a uita"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich dokumentiere die Ergebnisse.",
      "targetText": "Eu documentez rezultatele."
    },
    {
      "sourceText": "Dokumentierst du die Sitzung?",
      "targetText": "Documentezi ședința?"
    },
    {
      "sourceText": "Er dokumentiert den Prozess.",
      "targetText": "El documentează procesul."
    },
    {
      "sourceText": "Wir dokumentieren die Abläufe.",
      "targetText": "Noi documentăm fluxurile."
    },
    {
      "sourceText": "Dokumentiert ihr alles gründlich?",
      "targetText": "Documentați totul temeinic?"
    },
    {
      "sourceText": "Sie dokumentieren jede Veränderung.",
      "targetText": "Ei documentează fiecare schimbare."
    },
    {
      "sourceText": "Ich habe die Daten dokumentiert.",
      "targetText": "Am documentat datele."
    },
    {
      "sourceText": "Sie haben die Verfahrensanweisung dokumentiert.",
      "targetText": "Au documentat instrucțiunile procedurale."
    },
    {
      "sourceText": "Er dokumentierte oft die Fortschritte.",
      "targetText": "El documenta adesea progresele."
    },
    {
      "sourceText": "Ich hatte die Änderungen dokumentiert.",
      "targetText": "Documentasem modificările."
    },
    {
      "sourceText": "Ich werde die Informationen dokumentieren.",
      "targetText": "Voi documenta informațiile."
    },
    {
      "sourceText": "Er wird seine Erkenntnisse dokumentieren.",
      "targetText": "El o să documenteze concluziile sale."
    },
    {
      "sourceText": "Ich würde die Ergebnisse gerne dokumentieren.",
      "targetText": "Aș dori să documentez rezultatele."
    },
    {
      "sourceText": "Es ist wichtig, dass du alles dokumentierst.",
      "targetText": "Este important să documentezi totul."
    },
    {
      "sourceText": "Dokumentiere die Notizen!",
      "targetText": "Documentează notițele!"
    },
    {
      "sourceText": "Dokumentieren Sie alles gründlich!",
      "targetText": "Documentați totul temeinic!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Dokumentieren“ und „a documenta“ sind Kognaten – das macht das Lernen einfach!"
    },
    {
      "lang": "de",
      "text": "Merke dir die Präsensendungen: -ez, -ezi, -ează, -ăm, -ați, -ează – für die Konjugation von „a documenta“."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du hältst wichtige Beweise schriftlich fest – so merkst du dir „documenta“."
    }
  ],
