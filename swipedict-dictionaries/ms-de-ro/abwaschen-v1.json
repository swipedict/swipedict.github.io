  },
  "source": {
    "lang": "de",
    "headword": "abwaschen",
    "definition": "etwas sauber machen, indem man Wasser, Seife oder ein anderes Reinigungsmittel verwendet",
    "pronunciation": "/ˈapˌvaʃən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb setzt sich aus ‚ab-‘ und ‚waschen‘ zusammen, was die Handlung des Entfernens von Schmutz durch Wasser beschreibt.",
        "targetText": "Verbul este compus din prefixul „ab-“ și verbul „waschen“ care înseamnă „a spăla“, indicând acțiunea de a curăța ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Das Verb wird oft im Zusammenhang mit dem Geschirrspülen oder der Körperpflege verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a spăla",
    "definition": "a curăța ceva cu apă, săpun sau un alt detergent",
    "pronunciation": "/a spəˈla/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische ‚a spăla‘ stammt vom lateinischen ‚spoliare‘ ab, das ‚entkleiden‘ oder ‚wegnehmen‘ bedeutet, und entwickelte sich zur Bedeutung ‚waschen‘.",
        "targetText": "Verbul românesc „a spăla“ provine din latină, de la „spoliare“, care înseamnă „a dezbrăca“ sau „a lua“, evoluând spre sensul de „a spăla“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Wird häufig verwendet, um sowohl das Waschen von Kleidung, Tellern als auch die Körperpflege zu beschreiben."
  },
  "relatedWords": [
    {
      "sourceText": "Geschirrtuch",
      "targetText": "pânză de bucătărie"
    },
    {
      "sourceText": "Reinigung",
      "targetText": "curățare"
    },
    {
      "sourceText": "Seife",
      "targetText": "săpun"
    },
    {
      "sourceText": "Wasser",
      "targetText": "apă"
    }
  ],
  "antonyms": [
    {
      "sourceText": "schmutzig machen",
      "targetText": "a murdări"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich wasche das Geschirr ab.",
      "targetText": "Eu spăl vasele."
    },
    {
      "sourceText": "Wäschst du deine Hände vor dem Essen?",
      "targetText": "Te speli pe mâini înainte de masă?"
    },
    {
      "sourceText": "Sie wäscht das Auto.",
      "targetText": "Ea spală mașina."
    },
    {
      "sourceText": "Wir waschen die Wäsche.",
      "targetText": "Noi spălăm rufele."
    },
    {
      "sourceText": "Wäschst ihr die Obst?",
      "targetText": "Spălați fructele?"
    },
    {
      "sourceText": "Sie (Pl.) waschen die Fenster.",
      "targetText": "Ei spală ferestrele."
    },
    {
      "sourceText": "Ich habe die Teller abgewaschen.",
      "targetText": "Am spălat farfuriile."
    },
    {
      "sourceText": "Er wusch das Auto regelmäßig.",
      "targetText": "El spăla mașina regulat."
    },
    {
      "sourceText": "Ich werde das Geschirr abwaschen.",
      "targetText": "Voi spăla vasele."
    },
    {
      "sourceText": "Ich würde das Bad abwaschen, wenn ich Zeit hätte.",
      "targetText": "Aș spăla baia, dacă aș avea timp."
    },
    {
      "sourceText": "Wasche die Hände!",
      "targetText": "Spală-ți mâinile!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „a spăla“ klingt wie „spülen“ – stell dir vor, du spülst das Geschirr mit Wasser und Seife."
    },
    {
      "lang": "de",
      "text": "Merke dir die Präsensendungen: ich -ez, du -i, er/sie -ă, wir -ăm, ihr -ați, sie -ă – das hilft beim Konjugieren von „a spăla“."
    }
  ],
