  "source": {
    "lang": "de",
    "headword": "anerkennen",
    "definition": "jemanden oder etwas als wahr, gültig oder legitim akzeptieren",
    "pronunciation": "/ˈa.nəˌʁɛk.nən/",
    "etymology": {
      "explanation": {
        "sourceText": "Setzt sich aus dem Präfix „an“ und dem Verb „erkennen“ zusammen, was „wahrnehmen“ oder „identifizieren“ bedeutet.",
        "targetText": "Provine din prefixul „an-“ și verbul „erkennen” care înseamnă „a recunoaște” sau „a identifica”."
      },
      "source": "AI"
    },
    "additional": "Ein regelmäßiges Verb, das sowohl in formellen als auch in informellen Kontexten verwendet wird, um Zustimmung oder Bestätigung auszudrücken."
  },
  "target": {
    "lang": "ro",
    "headword": "a recunoaște",
    "definition": "a accepta pe cineva sau ceva ca fiind adevărat, valid sau legitim",
    "pronunciation": "/a rekunoˈaʃtʲe/",
    "etymology": {
      "explanation": {
        "sourceText": "Abgeleitet vom lateinischen „recognoscere“, zusammengesetzt aus „re-“, was „wieder“ bedeutet und „cognoscere“, was „erkennen“ bedeutet. Es bedeutet „wiedererkennen“ oder „anerkennen“.",
        "targetText": "Provine din latinescul „recognoscere”, compus din „re-” (din nou) și „cognoscere” (a cunoaște)."
      },
      "source": "AI, Wiktionary"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Oft verwendet, um Zustimmung oder Anerkennung auszusprechen, zum Beispiel in formellen oder rechtlichen Kontexten."
  },
  "relatedWords": [
    {
      "sourceText": "Anerkennung",
      "targetText": "recunoaștere"
    },
    {
      "sourceText": "Bestätigung",
      "targetText": "confirmare"
    },
    {
      "sourceText": "Respekt",
      "targetText": "respect"
    },
    {
      "sourceText": "Wertschätzung",
      "targetText": "aprecire"
    }
  ],
  "antonyms": [
    {
      "sourceText": "ablehnen",
      "targetText": "refuza"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich erkenne die Dokumente an.",
      "targetText": "Eu recunosc documentele."
    },
    {
      "sourceText": "Erkennst du das Land an?",
      "targetText": "Recunoști țara?"
    },
    {
      "sourceText": "Sie erkennt die Ergebnisse an.",
      "targetText": "Ea recunoaște rezultatele."
    },
    {
      "sourceText": "Wir erkennen die Vereinbarung an.",
      "targetText": "Noi recunoaștem acordul."
    },
    {
      "sourceText": "Erkennt ihr das Problem an?",
      "targetText": "Recunoașteți problema?"
    },
    {
      "sourceText": "Sie erkennen die Gesetze an.",
      "targetText": "Ei recunosc legile."
    },
    {
      "sourceText": "Ich habe die Vereinbarung anerkannt.",
      "targetText": "Am recunoscut acordul."
    },
    {
      "sourceText": "Er erkannte die Schwierigkeiten an.",
      "targetText": "El recunoștea dificultățile."
    },
    {
      "sourceText": "Ich werde die Zertifizierung anerkennen.",
      "targetText": "Voi recunoaște certificarea."
    },
    {
      "sourceText": "Ich würde das Angebot anerkennen, wenn es fair wäre.",
      "targetText": "Aș recunoaște oferta dacă ar fi corectă."
    },
    {
      "sourceText": "Erkenne die Fakten an!",
      "targetText": "Recunoaște faptele!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "'Recunoaște' klingt ähnlich wie 'roagă' (bitten) – beide haben mit Aufmerksamkeit und Anerkennung zu tun."
    },
    {
      "lang": "de",
      "text": "Denk an 'Cunoștință' (Wissen) – Anerkennung kommt oft durch Wissen, also verbinde das mit 'recunoaște'."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du gibst jemandem einen Daumen hoch – das ist 'Anerkennung' und hilft dir, 'a recunoaște' zu merken."
    },
    {
      "lang": "de",
      "text": "Stelle dir vor, du setzt eine Brille auf, um klarer zu sehen und etwas zu erkennen – so merkst du dir 'a recunoaște'."
    }
  ],
