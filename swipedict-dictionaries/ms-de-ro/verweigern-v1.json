  "source": {
    "lang": "de",
    "headword": "verweigern",
    "definition": "nicht bereit sein, etwas zu akzeptieren oder zu tun",
    "pronunciation": "/fɛʁˈvaɪɡɐn/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „verweigern“ setzt sich aus dem Präfix „ver-“ (negativ) und „wehren“ (sich schützen) zusammen, was die Ablehnung einer Handlung ausdrückt.",
        "targetText": "Das deutsche Verb „verweigern“ stammt vom althochdeutschen „werhen“ (abwehren) und dem negierenden Präfix „ver-“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Ein unregelmäßiges Verb. Wird oft verwendet, um die Ablehnung oder das Verweigern von Anfragen oder Anforderungen auszudrücken."
  },
  "target": {
    "lang": "ro",
    "headword": "a refuza",
    "definition": "a nu fi dispus să accepte sau să facă ceva",
    "pronunciation": "/a re.fuˈza/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische „a refuza“ stammt vom lateinischen „refusare“, was „zurückweisen“ bedeutet und wird verwendet, um Ablehnung auszudrücken.",
        "targetText": "Verbul românesc „a refuza“ provine din latină, de la „refusare“, care înseamnă „a respinge“ și exprimă ideea de refuz."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a), häufig in sozialen und rechtlichen Kontexten verwendet."
  },
  "senses": [
    {
      "gloss": "Ablehnen",
      "explanation": {
        "sourceText": "Wird verwendet, um das Nichtakzeptieren von etwas auszudrücken.",
        "targetText": "Este folosit pentru a exprima neacceptarea a ceva."
      },
      "examples": [
        {
          "sourceText": "Ich lehne die Anfrage ab.",
          "targetText": "Refuz cererea."
        }
      ]
    },
    {
      "gloss": "Verboten",
      "explanation": {
        "sourceText": "Kann auch im Kontext von etwas verwendet werden, das nicht erlaubt ist.",
        "targetText": "Poate fi folosit și în contextul a ceva interzis."
      },
      "examples": [
        {
          "sourceText": "Das ist mir verboten.",
          "targetText": "Este interzis pentru mine."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "Ablehnung",
      "targetText": "refuz"
    },
    {
      "sourceText": "Einverständnis",
      "targetText": "consimțământ"
    },
    {
      "sourceText": "Entscheidung",
      "targetText": "decizie"
    },
    {
      "sourceText": "Zustimmung",
      "targetText": "aprobat"
    }
  ],
  "antonyms": [
    {
      "sourceText": "annehmen",
      "targetText": "a accepta"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich verweigere die Zustimmung.",
      "targetText": "Eu refuz acordul."
    },
    {
      "sourceText": "Verweigert du die Hilfe?",
      "targetText": "Refuzi ajutorul?"
    },
    {
      "sourceText": "Der Zeuge verweigert seine Aussage.",
      "targetText": "Martorul refuză declarația sa."
    },
    {
      "sourceText": "Wir verweigern das Angebot.",
      "targetText": "Noi refuzăm oferta."
    },
    {
      "sourceText": "Verweigert ihr die Versicherung?",
      "targetText": "Refuzați asigurarea?"
    },
    {
      "sourceText": "Sie verweigern die Verantwortung.",
      "targetText": "Ei refuză responsabilitatea."
    },
    {
      "sourceText": "Ich habe die Anfrage verweigert.",
      "targetText": "Am refuzat cererea."
    },
    {
      "sourceText": "Er verweigerte die Erlaubnis.",
      "targetText": "El refuza permisiunea."
    },
    {
      "sourceText": "Wir hatten die Zusammenarbeit verweigert, als sie anriefen.",
      "targetText": "Refuzasem colaborarea când au sunat."
    },
    {
      "sourceText": "Ich werde die Änderung verweigern.",
      "targetText": "Voi refuza schimbarea."
    },
    {
      "sourceText": "Ich würde es verweigern, wenn ich könnte.",
      "targetText": "Aș refuza dacă aș putea."
    },
    {
      "sourceText": "Verweigere die Vorschläge!",
      "targetText": "Refuză propunerile!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Refuza“ klingt wie das englische „refuse“ – das hilft dir, die Bedeutung zu behalten!"
    },
    {
      "lang": "de",
      "text": "Denke daran, dass „a refuza“ oft mit Ablehnung von Hilfe oder Angeboten verbunden ist."
    },
    {
      "lang": "de",
      "text": "Übe Sätze mit „Eu refuz“ und verschiedenen Objekten, um das Verb zu festigen."
    }
  ],
