  "source": {
    "lang": "de",
    "headword": "blicken",
    "definition": "einen kurzen Blick werfen; schauen",
    "pronunciation": "/ˈblɪkən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb stammt vom mittelhochdeutschen „blicken“ und hat dieselbe Bedeutung. Es bezieht sich auf das Sehen oder den visuellen Eindruck von etwas.",
        "targetText": "Verbul german „blicken“ provine din mijlocul german și înseamnă a privi scurt sau a arunca o privire."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb, das oft in feststehenden Wendungen verwendet wird, wie z.B. „blicken auf“ oder „blicken in die Zukunft“."
  },
  "target": {
    "lang": "ro",
    "headword": "a privi",
    "definition": "a arunca o privire scurtă; a se uita",
    "pronunciation": "/a priˈvi/",
    "etymology": {
      "explanation": {
        "sourceText": "„A privi“ stammt vom lateinischen „providere“, was „vorausschauen“ oder „sehen“ bedeutet. Es setzt sich aus „pro-“ (vor) und „videre“ (sehen) zusammen.",
        "targetText": "Verbul românesc „a privi“ provine din latină, din „providere“, format din „pro-“ (înainte) și „videre“ (a vedea), însemnând a privi sau a observa."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 4. Konjugation, wird oft im Kontext von Beobachtungen verwendet. Es hat auch figurative Bedeutungen wie „die Zukunft sehen“."
  },
  "relatedWords": [
    {
      "sourceText": "ansehen",
      "targetText": "a analiza"
    },
    {
      "sourceText": "blick",
      "targetText": "privire"
    },
    {
      "sourceText": "schauen",
      "targetText": "a se uita"
    },
    {
      "sourceText": "sehen",
      "targetText": "a vedea"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verstecken",
      "targetText": "a ascunde"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich blicke aus dem Fenster.",
      "targetText": "Eu privesc pe fereastră."
    },
    {
      "sourceText": "Blickst du oft in den Himmel?",
      "targetText": "Privești des în cer?"
    },
    {
      "sourceText": "Er blickt nach Süden.",
      "targetText": "El privește spre sud."
    },
    {
      "sourceText": "Wir blicken in die Zukunft.",
      "targetText": "Noi privim în viitor."
    },
    {
      "sourceText": "Blickt ihr gerne nach oben?",
      "targetText": "Priviți cu plăcere în sus?"
    },
    {
      "sourceText": "Sie blicken auf die Berge.",
      "targetText": "Ei privesc către munți."
    },
    {
      "sourceText": "Ich habe auf das Bild geblickt.",
      "targetText": "Am privit la imagine."
    },
    {
      "sourceText": "Er blickte in die Ferne.",
      "targetText": "El privea în depărtare."
    },
    {
      "sourceText": "Ich werde auf das Video blicken.",
      "targetText": "Voi privi la video."
    },
    {
      "sourceText": "Ich würde gerne in die Zukunft blicken.",
      "targetText": "Aș dori să privesc în viitor."
    },
    {
      "sourceText": "Blicke nach vorn!",
      "targetText": "Privește în față!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „a privi“ klingt fast wie „privat“ – stell dir vor, du wirfst einen kurzen privaten Blick auf etwas."
    },
    {
      "lang": "de",
      "text": "Übe Sätze wie „Eu privesc la soare“ (Ich blicke zur Sonne), um das Verb im Alltag zu verankern."
    },
    {
      "lang": "de",
      "text": "Visualisiere, wie du durch ein Fernglas „priviri“ (Blicke) wirfst – das hilft dir, das Wort zu behalten."
    }
  ],
