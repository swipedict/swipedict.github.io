  "source": {
    "lang": "de",
    "headword": "nennen",
    "definition": "jemanden oder etwas so benennen oder angeben",
    "pronunciation": "/ˈnɛnən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb stammt aus dem Althochdeutschen „nenna“, was „nennen, rufen“ bedeutet.",
        "targetText": "Verbul provine din althochdeutsch „nenna“, care înseamnă „a numi, a chema“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb, häufig in der Form „jemanden beim Namen nennen“ verwendet."
  },
  "target": {
    "lang": "ro",
    "headword": "a numi",
    "definition": "a desemna oder a indica pe cineva sau ceva",
    "pronunciation": "/a nuˈmi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a numi“ stammt vom lateinischen „nominare“, was „benennen“ bedeutet.",
        "targetText": "Verbul românesc „a numi“ provine din latină „nominare“, care înseamnă „a numi“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-i), oft mit Namen oder Titeln verwendet."
  },
  "relatedWords": [
    {
      "sourceText": "Begriff",
      "targetText": "concept"
    },
    {
      "sourceText": "Benennung",
      "targetText": "denumire"
    },
    {
      "sourceText": "Namen",
      "targetText": "nume"
    },
    {
      "sourceText": "Titel",
      "targetText": "titlu"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verschweigen",
      "targetText": "a tăcea"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich nenne dich meinen Freund.",
      "targetText": "Te numesc prietenul meu."
    },
    {
      "sourceText": "Nennst du die Stadt beim Namen?",
      "targetText": "Îi numești orașul pe nume?"
    },
    {
      "sourceText": "Der Lehrer nennt das Thema.",
      "targetText": "Profesorul numește tema."
    },
    {
      "sourceText": "Wir nennen das Kind beim Namen.",
      "targetText": "Noi numim copilul pe nume."
    },
    {
      "sourceText": "Nennt ihr die wichtigsten Punkte?",
      "targetText": "Numești cele mai importante puncte?"
    },
    {
      "sourceText": "Sie nennen es ein Wunder.",
      "targetText": "Ei numesc asta o minune."
    },
    {
      "sourceText": "Ich habe das Buch so genannt.",
      "targetText": "Am numit cartea așa."
    },
    {
      "sourceText": "Ich werde das Unternehmen neu nennen.",
      "targetText": "Îi voi numi compania în mod nou."
    },
    {
      "sourceText": "Nenne es beim Namen!",
      "targetText": "Numeste-l pe nume!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Nennen“ und „a numi“ sind Kognaten – die Bedeutung ist fast identisch, das hilft beim Lernen!"
    },
    {
      "lang": "de",
      "text": "Achte auf die Präsens-Endungen, sie sind wichtig für die richtige Verwendung von „a numi“."
    },
    {
      "lang": "de",
      "text": "Merke dir, dass „a numi“ oft ein direktes Objekt verlangt, ähnlich wie im Deutschen: „Te numesc *pe tine*“."
    }
  ],
