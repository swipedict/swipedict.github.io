  "source": {
    "lang": "de",
    "headword": "benennen",
    "definition": "etwas einen Namen geben oder bezeichnen",
    "pronunciation": "/bəˈnɛnən/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb besteht aus dem Präfix „be-“ und dem Verb „nennen“, das vom althochdeutschen „nennan“ stammt und „einen Namen geben“ bedeutet.",
        "targetText": "Verbul este format din prefixul „be-“ și verbul „nennen“ (a numi), care provine din germana veche și înseamnă „a da un nume“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird häufig in der Verbindung mit der Benennung von Personen, Orten oder Dingen genutzt."
  },
  "target": {
    "lang": "ro",
    "headword": "a numi",
    "definition": "a da un nume sau a desemna ceva",
    "pronunciation": "/a nuˈmi/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a numi“ stammt vom lateinischen „nominare“ ab, was „benennen“ oder „nennen“ bedeutet. Es ist eng mit der Identifikation und Klassifikation verbunden.",
        "targetText": "Verbul românesc „a numi“ derivă din latinescul „nominare“, care înseamnă „a da un nume“ sau „a numi“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Häufig in der Anwendung: „Eu numesc pe el“ (Ich nenne ihn)."
  },
  "relatedWords": [
    {
      "sourceText": "Bezeichnung",
      "targetText": "denumire"
    },
    {
      "sourceText": "Kategorisierung",
      "targetText": "categorizare"
    },
    {
      "sourceText": "Name",
      "targetText": "nume"
    },
    {
      "sourceText": "Titel",
      "targetText": "titlu"
    }
  ],
  "antonyms": [
    {
      "sourceText": "vergessen",
      "targetText": "a uita"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich benenne das neue Produkt.",
      "targetText": "Eu numesc noul produs."
    },
    {
      "sourceText": "Benennst du den neuen Chef?",
      "targetText": "Îl numești pe noul șef?"
    },
    {
      "sourceText": "Er benennt das Buch.",
      "targetText": "El numește cartea."
    },
    {
      "sourceText": "Wir benennen die Hauptstadt.",
      "targetText": "Noi numim capitala."
    },
    {
      "sourceText": "Benennt bitte die nächsten Schritte!",
      "targetText": "Numiți, vă rog, următorii pași!"
    },
    {
      "sourceText": "Sie benennen die Gewinner.",
      "targetText": "Ei numesc câștigătorii."
    },
    {
      "sourceText": "Ich habe den Hund benannt.",
      "targetText": "L-am numit pe câine."
    },
    {
      "sourceText": "Sie benannten die Straßen nach bekannten Persönlichkeiten.",
      "targetText": "Ei numeau străzile după personalități cunoscute."
    },
    {
      "sourceText": "Ich werde das Thema benennen.",
      "targetText": "Voi numi subiectul."
    },
    {
      "sourceText": "Benenne den Film!",
      "targetText": "Numeste filmul!"
    },
    {
      "sourceText": "Der benannte Verantwortliche ist abwesend.",
      "targetText": "Responsabilul numit este absent."
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „nume“ bedeutet „Name“ – das Verb „a numi“ heißt „benennen“. So kannst du dir leicht merken, dass es um Namen geht!"
    },
    {
      "lang": "de",
      "text": "Nutze Eselsbrücken: „numi“ klingt wie „Namen“ – beide Wörter haben mit Bezeichnungen zu tun."
    },
    {
      "lang": "de",
      "text": "Stell dir vor, du gibst deinen Freunden Namen: „Eu numesc prietenii mei“ – so verknüpfst du das Verb mit der Handlung des Benennens."
    }
  ],
