  "source": {
    "lang": "de",
    "headword": "antworten",
    "definition": "auf eine Frage oder Aussage reagieren",
    "pronunciation": "/ˈantˌvʁeːn/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Wort ‚antworten‘ stammt vom Mittelhochdeutschen ‚antworten‘, zusammengesetzt aus ‚ant‘ (vor) und ‚wort‘ (Wort).",
        "targetText": "Cuvântul „antworten“ provine din germana mijlocie „antworten“, format din „ant“ (înainte) și „wort“ (cuvânt)."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Wird in verbaler Kommunikation verwendet, um auf Fragen oder Aussagen zu reagieren."
  },
  "target": {
    "lang": "ro",
    "headword": "a răspunde",
    "definition": "a răspunde la o întrebare sau afirmație",
    "pronunciation": "/a rəˈspundɛ/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb stammt vom lateinischen ‚respondere‘ ab, was ‚zurückantworten‘ bedeutet.",
        "targetText": "Verbul românesc provine din latină, din „respondere“, care înseamnă „a răspunde“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Verwendet in Fragen- und Antwortsituationen mit vielen festen Ausdrücken."
  },
  "relatedWords": [
    {
      "sourceText": "liefern",
      "targetText": "a livra"
    },
    {
      "sourceText": "nehmen",
      "targetText": "a lua"
    },
    {
      "sourceText": "übergeben",
      "targetText": "a înmâna"
    },
    {
      "sourceText": "verschenken",
      "targetText": "a oferi"
    }
  ],
  "antonyms": [
    {
      "sourceText": "bekommen",
      "targetText": "a primi"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich antworte auf die Frage.",
      "targetText": "Eu răspund la întrebare."
    },
    {
      "sourceText": "Antwortest du auf seine Nachricht?",
      "targetText": "Răspunzi la mesajul lui?"
    },
    {
      "sourceText": "Er antwortet schnell.",
      "targetText": "El răspunde repede."
    },
    {
      "sourceText": "Wir antworten gemeinsam.",
      "targetText": "Noi răspundem împreună."
    },
    {
      "sourceText": "Antwortet ihr freundlich?",
      "targetText": "Răspundeți amabil?"
    },
    {
      "sourceText": "Sie antworten auf die Fragen.",
      "targetText": "Ei răspund la întrebări."
    },
    {
      "sourceText": "Ich habe auf die Frage geantwortet.",
      "targetText": "Am răspuns la întrebare."
    },
    {
      "sourceText": "Sie antwortete ruhig.",
      "targetText": "Ea răspundea calm."
    },
    {
      "sourceText": "Ich werde morgen antworten.",
      "targetText": "Voi răspunde mâine."
    },
    {
      "sourceText": "Ich würde gerne antworten.",
      "targetText": "Aș dori să răspund."
    },
    {
      "sourceText": "Antworte bitte!",
      "targetText": "Răspunde, te rog!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "„Antworten“ und „a răspunde“ sind sehr ähnlich – denk an ‚wort‘ und ‚spunde‘ als ‚Wort zurückgeben‘."
    },
    {
      "lang": "de",
      "text": "Das Wort ‚răspunde‘ reimt sich auf ‚bune‘ (gut) – denk daran, dass gute Antworten wichtig sind!"
    },
    {
      "lang": "de",
      "text": "Kombiniere ‚a răspunde‘ mit ‚a întreba‘ (fragen), z.B. ‚Eu întreb, tu răspunzi‘."
    },
    {
      "lang": "de",
      "text": "Merke, dass ‚a răspunde‘ meist ein direktes Objekt benötigt, z.B. ‚la întrebare‘ (auf die Frage)."
    },
    {
      "lang": "de",
      "text": "Übe einfache Sätze wie ‚Eu răspund‘ (ich antworte) und ‚Am răspuns‘ (ich habe geantwortet)."
    }
  ],
