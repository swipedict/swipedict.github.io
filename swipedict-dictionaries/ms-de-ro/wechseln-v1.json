  "examples": [
    {
      "sourceText": "Ich wechsle die Batteries.",
      "targetText": "Eu schimb bateriile."
    },
    {
      "sourceText": "Wechselst du den Platz?",
      "targetText": "Schimbi locul?"
    },
    {
      "sourceText": "Er wechselt die Kleidung.",
      "targetText": "El schimbă îmbrăcămintea."
    },
    {
      "sourceText": "Wir wechseln die Strategie.",
      "targetText": "Noi schimbăm strategia."
    },
    {
      "sourceText": "Wechselt ihr die Musik?",
      "targetText": "Schimbați voi muzica?"
    },
    {
      "sourceText": "Sie wechseln die Route.",
      "targetText": "Ei schimbă ruta."
    },
    {
      "sourceText": "Ich habe die Öl gewechselt.",
      "targetText": "Am schimbat uleiul."
    },
    {
      "sourceText": "Er wechselte häufig das Thema.",
      "targetText": "El schimba des subiectul frecvent."
    },
    {
      "sourceText": "Ich werde die Kanäle wechseln.",
      "targetText": "Voi schimba canalele."
    },
    {
      "sourceText": "Wechsel die Richtung!",
      "targetText": "Schimbă direcția!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das lateinische „cambiare“ steckt in „schimba“ – denk an den „Kampf“ (kampf = change) beim Wechseln."
    },
    {
      "lang": "de",
      "text": "Das rumänische „schimba“ klingt ähnlich wie das deutsche „schimpfen“ – stelle dir vor, du „schimpfst“ und „wechselst“ gleichzeitig die Meinung!"
    }
  ],
