  "source": {
    "lang": "de",
    "headword": "wechseln",
    "definition": "etwas gegen etwas anderes eintauschen oder ersetzen",
    "pronunciation": "/ˈvɛksl̩n/",
    "etymology": {
      "explanation": {
        "sourceText": "Das deutsche Verb „wechseln“ stammt vom mittelhochdeutschen „wechslēn“, verwandt mit „wandeln“ und „wechseln“, und geht auf das althochdeutsche „wehsal“ (Wechsel) zurück.",
        "targetText": "Verbul german „wechseln“ provine din germana mijlocie „wechslēn“, înrudit cu „wandeln“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Wird oft verwendet, um den Austausch oder die Veränderung von Dingen oder Zuständen zu beschreiben, z.B. „Die Kleider wechseln“. Das Wort \"Wechsel\" hat auch eine spezielle wirtschaftliche Bedeutung."
  },
  "target": {
    "lang": "ro",
    "headword": "a schimba",
    "definition": "a înlocui ceva cu altceva sau a face un schimb",
    "pronunciation": "/a ʃkimˈba/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a schimba“ stammt vom lateinischen „cambiare“, was „ändern“ oder „auswechseln“ bedeutet. Es hat sich im Rumänischen erhalten und wird in vielfältigen Kontexten verwendet, z.B. „schimb valutar“ (Währungswechsel).",
        "targetText": "Verbul românesc „a schimba“ provine din latină vulgară „cambiare“, cu sensul de a schimba sau înlocui."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Verwendung in der Praxis: „Ich wechsle die Reifen“ („Eu schimb anvelopele“)."
  },
  "senses": [
    {
      "gloss": "Bank / Sitzbank",
      "explanation": {
        "sourceText": "Auch für die Sitzbank (oft im Park).",
        "targetText": "De asemenea, pentru o bancă de șezut (de obicei în parc)."
      },
      "examples": [
        {
          "sourceText": "Setzen wir uns auf die Bank.",
          "targetText": "Să ne așezăm pe bancă."
        }
      ]
    },
    {
      "gloss": "Sandbank",
      "explanation": {
        "sourceText": "Eine 'Sandbank' ist 'banc' (sächlich).",
        "targetText": "O bancă de nisip se numește „banc“ (neutru)."
      },
      "examples": [
        {
          "sourceText": "Das Schiff lief auf eine Bank.",
          "targetText": "Nava a lovit un banc."
        }
      ]
    },
    {
      "gloss": "Ufer / Flussufer",
      "explanation": {
        "sourceText": "Achtung: Für 'Flussufer' verwendet man 'mal' (sächlich).",
        "targetText": "Atenție: pentru malul râului se folosește „mal“ (neutru)."
      },
      "examples": [
        {
          "sourceText": "Das Boot liegt an der Bank.",
          "targetText": "Barca este pe mal."
        }
      ]
    },
    {
      "gloss": "Wechsel (Finanzinstitut)",
      "explanation": {
        "sourceText": "Wie im Deutschen: für Geldinstitute.",
        "targetText": "Ca și în germană, se referă la instituții financiare."
      },
      "examples": [
        {
          "sourceText": "Ich gehe zur Wechsel.",
          "targetText": "Merg la bancă."
        },
        {
          "sourceText": "Die Wechsel schließen um 17 Uhr.",
          "targetText": "Banca închide la ora 17."
        }
      ]
    }
  ],
