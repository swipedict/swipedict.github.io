  "source": {
    "lang": "de",
    "headword": "aussprechen",
    "definition": "lautlich äußern; aussprechen",
    "pronunciation": "/ˈaʊsˌpʁeːçn̩/",
    "etymology": {
      "explanation": {
        "sourceText": "Das Verb „aussprechen“ setzt sich aus „aus“ (heraus) und „sprechen“ (reden) zusammen und bedeutet, etwas hörbar zu machen, das vorher nicht gesagt wurde.",
        "targetText": "Verbul german „aussprechen“ este compus din „aus“ (afară) și „sprechen“ (a vorbi), însemnând a rosti ceva care anterior nu a fost spus."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb. Oft in Bezug auf das Ausdrücken von Gedanken oder Gefühlen, häufig in formellen Kontexten."
  },
  "target": {
    "lang": "ro",
    "headword": "a pronunța",
    "definition": "a exprima sonor; a spune",
    "pronunciation": "/a pro.nunˈt͡sa/",
    "etymology": {
      "explanation": {
        "sourceText": "Das rumänische Verb „a pronunța“ stammt vom lateinischen „pronuntiare“ ab, was „öffentlich bekannt machen“ bedeutet und das Aussprechen von Wörtern beschreibt.",
        "targetText": "Verbul românesc „a pronunța“ derivă din latină, din „pronuntiare“, care înseamnă „a face cunoscut public“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regelmäßiges Verb der 1. Konjugation (-a). Häufig im Bildungskontext und bei Diskussionen verwendet."
  },
  "relatedWords": [
    {
      "sourceText": "Laut",
      "targetText": "sunet"
    },
    {
      "sourceText": "Satz",
      "targetText": "propoziție"
    },
    {
      "sourceText": "Stimme",
      "targetText": "voce"
    },
    {
      "sourceText": "Wort",
      "targetText": "cuvânt"
    }
  ],
  "antonyms": [
    {
      "sourceText": "verschweigen",
      "targetText": "a ascunde"
    }
  ],
  "examples": [
    {
      "sourceText": "Ich spreche es deutlich aus.",
      "targetText": "Eu pronunț clar."
    },
    {
      "sourceText": "Sprich es bitte aus!",
      "targetText": "Pronunță-l, te rog!"
    },
    {
      "sourceText": "Er spricht das Wort oft falsch aus.",
      "targetText": "El pronunță cuvântul adesea greșit."
    },
    {
      "sourceText": "Wir sprechen unsere Ideen aus.",
      "targetText": "Noi pronunțăm ideile noastre."
    },
    {
      "sourceText": "Sprecht ihr das neue Wort aus?",
      "targetText": "Pronunțați cuvântul nou?"
    },
    {
      "sourceText": "Sie (Pl.) sprechen die Regeln aus.",
      "targetText": "Ei pronunță regulile."
    },
    {
      "sourceText": "Ich habe das Wort schon ausgesprochen.",
      "targetText": "Am pronunțat cuvântul deja."
    },
    {
      "sourceText": "Sie sprachen während des Meetings aus.",
      "targetText": "Ei pronunțau în timpul întâlnirii."
    },
    {
      "sourceText": "Du wirst es jetzt aussprechen.",
      "targetText": "Vei pronunța acum."
    },
    {
      "sourceText": "Sprich es laut aus!",
      "targetText": "Pronunță-l tare!"
    }
  ],
  "learningTips": [
    {
      "lang": "de",
      "text": "Das rumänische „pronunța“ klingt ähnlich wie „Pronuntiare“ (lateinisch für ankündigen) – stelle dir vor, du kündigst etwas laut an."
    },
    {
      "lang": "de",
      "text": "Nutze die Verbformen, um dich daran zu erinnern, dass es oft in der Schule oder bei Präsentationen verwendet wird."
    },
    {
      "lang": "de",
      "text": "Verbinde „pronunța“ mit dem deutschen „pro“ und „nennen“ – also etwas klar und deutlich nennen."
    }
  ],
