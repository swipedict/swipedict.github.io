  "source": {
    "lang": "en",
    "headword": "show",
    "definition": "to make something visible or to present it publicly",
    "pronunciation": "/ʃoʊ/",
    "etymology": {
      "explanation": {
        "sourceText": "Derived from Old English 'sceawian' meaning 'to look at, see, or observe', which comes from Proto-Germanic roots related to viewing or seeing.",
        "targetText": "Cuvântul englezesc „show” provine din engleza veche „sceawian”, care înseamnă „a privi, a vedea sau a observa”, având rădăcini proto-germanice legate de actul de a vedea sau a privi."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Commonly used in technical contexts, for example to display information or visually present data."
  },
  "target": {
    "lang": "ro",
    "headword": "a arăta",
    "definition": "a face ceva vizibil sau public",
    "pronunciation": "/a a.rəˈta/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb 'a arăta' originates from the Latin 'arătare', meaning 'to show' or 'to make visible'.",
        "targetText": "Verbul românesc 'a arăta' provine din latină, din 'arătare', care înseamnă 'a arăta' sau 'a face vizibil'."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Verwendet in Technik, Kunst und Kommunikation."
  },
  "senses": [
    {
      "gloss": "illustrate",
      "explanation": {
        "sourceText": "Also means to make something understandable or visible.",
        "targetText": "Înseamnă a face ceva vizibil sau ușor de înțeles."
      },
      "examples": [
        {
          "sourceText": "He shows the advertisement.",
          "targetText": "El arată reclama."
        }
      ]
    },
    {
      "gloss": "display",
      "explanation": {
        "sourceText": "The verb is used to show or present something.",
        "targetText": "Verbul este folosit pentru a arăta sau prezenta ceva."
      },
      "examples": [
        {
          "sourceText": "I show the results.",
          "targetText": "Eu arăt rezultatele."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "information",
      "targetText": "informație"
    },
    {
      "sourceText": "announcement",
      "targetText": "anunț"
