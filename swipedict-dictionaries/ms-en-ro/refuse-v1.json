    }
  ],
  "antonyms": [
    {
      "sourceText": "accept",
      "targetText": "a accepta"
    }
  ],
  "examples": [
    {
      "sourceText": "I refuse the offer.",
      "targetText": "Refuz oferta."
    },
    {
      "sourceText": "Do you refuse the invitation?",
      "targetText": "Refuzi invitația?"
    },
    {
      "sourceText": "She refuses the cooperation.",
      "targetText": "Ea refuză colaborarea."
    },
    {
      "sourceText": "We refuse the proposals.",
      "targetText": "Refuzăm propunerile."
    },
    {
      "sourceText": "Do you refuse the project?",
      "targetText": "Refuzați proiectul?"
    },
    {
      "sourceText": "They refuse the conditions.",
      "targetText": "Ei refuză condițiile."
    },
    {
      "sourceText": "I have refused the offer.",
      "targetText": "Am refuzat oferta."
    },
    {
      "sourceText": "He refused the invitation every month.",
      "targetText": "El refuza invitația în fiecare lună."
    },
    {
      "sourceText": "I will refuse the project.",
      "targetText": "Voi refuza proiectul."
    },
    {
      "sourceText": "I would refuse it if I were you.",
      "targetText": "Aș refuza, dacă aș fi tu."
    },
    {
      "sourceText": "Don't refuse that!",
      "targetText": "Nu refuza!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember 'refuse' sounds like 're-fuse' — think of 'fuse' as joining, so 'refuse' means to not join or accept."
    },
    {
      "lang": "en",
      "text": "The Romanian word 'refuza' is a close cognate to English 'refuse', making it easier to remember their meanings."
    },
    {
      "lang": "en",
      "text": "Think of 'refuse' as saying 'no' firmly, like refusing an unwanted invitation or offer."
    },
    {
      "lang": "en",
      "text": "Practice with everyday situations: 'I refuse the offer' = 'Eu refuz oferta' helps solidify usage."
    }
  ],
