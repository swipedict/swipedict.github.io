  "source": {
    "lang": "en",
    "headword": "refuse",
    "definition": "to decline to accept or agree to something",
    "pronunciation": "/rɪˈfjuz/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"refuse\" comes from the Latin verb \"refusare\", meaning 'to reject' or 'to decline'. It entered English through Old French and has been used since the Middle Ages to indicate the act of rejecting or not accepting something.",
        "targetText": "Cuvântul englezesc „refuse” provine din verbul latin „refusare”, care înseamnă „a respinge” sau „a refuza”. A intrat în limba engleză prin franceza veche și este folosit din Evul Mediu pentru a indica actul de a respinge sau a nu accepta ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Commonly used in formal contexts when declining consent or an offer."
  },
  "target": {
    "lang": "ro",
    "headword": "a refuza",
    "definition": "a nu accepta ceva sau a nu fi de acord",
    "pronunciation": "/a re.fuˈza/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb \"a refuza\" derives from the French \"refuser\", which comes from the Latin \"refutare\" meaning 'to reject' or 'to refuse'.",
        "targetText": "Verbul românesc „a refuza“ provine din francezul „refuser“, derivat din latinescul „refutare“, care înseamnă „a respinge“ sau „a refuza“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular first conjugation verb (-a). Often used in negative contexts when declining offers, invitations, or proposals."
  },
  "senses": [
    {
      "gloss": "Refusal",
      "explanation": {
        "sourceText": "The act of declining an offer or proposal.",
        "targetText": "Refuzul unei oferte sau propuneri."
      },
      "examples": [
        {
          "sourceText": "I refuse the offer.",
          "targetText": "Refuz oferta."
        },
        {
          "sourceText": "Do you refuse the invitation?",
          "targetText": "Refuzi invitația?"
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "decision",
      "targetText": "decizie"
    },
    {
