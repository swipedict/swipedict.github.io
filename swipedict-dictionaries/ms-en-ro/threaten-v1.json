  "source": {
    "lang": "en",
    "headword": "threaten",
    "definition": "to put someone in a situation where they feel fear or at risk",
    "pronunciation": "/ˈθrɛtən/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb 'threaten' comes from the Old English 'threaten', related to 'threat', meaning to express an intention to cause harm or danger.",
        "targetText": "Verbul englezesc „threaten“ provine din engleza veche „threaten“, legat de „threat“, care înseamnă a exprima intenția de a cauza rău sau pericol."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Often used with a negative connotation, especially in legal and criminal contexts."
  },
  "target": {
    "lang": "ro",
    "headword": "a amenința",
    "definition": "a pune pe cineva într-o situație care îl face să se simtă speriat sau în pericol",
    "pronunciation": "/a ameˈni.t͡sa/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a amenința“ derives from the Latin „minitari“, meaning „to threaten“.",
        "targetText": "Verbul românesc „a amenința“ derivă din latină, din „minitari“, care înseamnă „a amenința“."
      },
      "source": "Etymological Dictionaries, Wiktionary"
    },
    "additional": "Regular verb of the 1st conjugation. Frequently used in legal and criminal contexts."
  },
  "relatedWords": [
    {
      "sourceText": "fear",
      "targetText": "frică"
    },
    {
      "sourceText": "threat",
      "targetText": "amenințare"
    },
    {
      "sourceText": "danger",
      "targetText": "pericol"
    },
    {
      "sourceText": "security",
      "targetText": "siguranță"
    }
  ],
  "antonyms": [
    {
      "sourceText": "protect",
      "targetText": "a proteja"
    }
  ],
  "examples": [
    {
      "sourceText": "I threaten the attackers.",
      "targetText": "Eu ameninț atacatorii."
    },
    {
      "sourceText": "Are you threatening me?",
      "targetText": "Mă ameninți?"
    },
    {
      "sourceText": "The robbery threatens security.",
      "targetText": "Jaful amenință siguranța."
    },
    {
      "sourceText": "We threaten the rivals.",
      "targetText": "Noi amenințăm rivalii."
    },
    {
      "sourceText": "Are you threatening the testimonies?",
      "targetText": "Amenințați mărturiile?"
    },
    {
      "sourceText": "They threaten the authorities.",
      "targetText": "Ei amenință autoritățile."
    },
    {
      "sourceText": "I threatened him.",
      "targetText": "L-am amenințat."
    },
    {
      "sourceText": "He threatened the witnesses.",
      "targetText": "El amenința martorii."
    },
    {
      "sourceText": "I will threaten you.",
      "targetText": "Te voi amenința."
    },
    {
      "sourceText": "I would threaten the police if I could.",
      "targetText": "Aș amenința poliția, dacă aș putea."
    },
    {
      "sourceText": "Don't threaten me!",
      "targetText": "Nu mă amenința!"
    },
    {
      "sourceText": "The threatened person felt unsafe.",
      "targetText": "Persoana amenințată se simțea nesigură."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember 'threaten' by thinking of 'threat'—both start with 'thr' and involve danger or fear."
    },
    {
      "lang": "en",
      "text": "The Romanian 'a amenința' sounds like 'amen' + 'in' + 'tsa'—imagine saying a serious 'amen' to a threat."
    },
    {
      "lang": "en",
      "text": "Think of 'threaten' as 'throwing a warning'—both start with 'thr' and involve warning someone."
    },
    {
      "lang": "en",
      "text": "Conjugate 'a amenința' by remembering the endings -ez, -ezi, -ează, -ăm, -ați, -ează, similar to many Romanian verbs."
    }
  ],
