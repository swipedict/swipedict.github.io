  "source": {
    "lang": "en",
    "headword": "lose",
    "definition": "To become lighter in weight or to reduce body mass",
    "pronunciation": "/luːz/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"lose\" comes from Old English \"losian\" meaning 'to perish, be lost'. It is related to the concept of something becoming missing or no longer possessed.",
        "targetText": "Cuvântul englezesc „lose” provine din engleza veche „losian”, care înseamnă „a pieri, a se pierde”. Este legat de conceptul de a nu mai avea ceva sau de a-l pierde."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Commonly used in contexts of weight loss or losing possession of something."
  },
  "target": {
    "lang": "ro",
    "headword": "a pierde",
    "definition": "a pierde în greutate sau a deveni mai suplu",
    "pronunciation": "/a ˈpjeɾ.de/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a pierde“ derives from the Latin „perdere“, meaning „to lose“. It is related to the English verb \"lose\".",
        "targetText": "Verbul românesc „a pierde“ provine din latinescul „perdere“, care înseamnă „a pierde“ și este înrudit cu verbul englez „lose“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regulă verb de conjugarea a 2-a. Folosit frecvent în legătură cu pierderea în greutate sau pierderea obiectelor."
  },
  "senses": [
    {
      "gloss": "To lose weight",
      "explanation": {
        "sourceText": "In the context of weight loss.",
        "targetText": "În contextul pierderii în greutate."
      },
      "examples": [
        {
          "sourceText": "I want to lose weight and stay fit.",
          "targetText": "Vreau să pierd în greutate și să rămân în formă."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "diet",
      "targetText": "dietă"
    },
    {
      "sourceText": "nutrition",
      "targetText": "nutriție"
    },
    {
      "sourceText": "weight",
      "targetText": "greutate"
    },
    {
      "sourceText": "sport",
      "targetText": "sport"
    }
  ],
  "antonyms": [
    {
      "sourceText": "gain weight",
      "targetText": "a câștiga în greutate"
    }
  ],
  "examples": [
    {
      "sourceText": "I lose 5 kilograms.",
      "targetText": "Pierd 5 kilograme."
    },
    {
      "sourceText": "Are you losing weight too?",
      "targetText": "Pierzi și tu?"
    },
    {
      "sourceText": "He loses weight quickly.",
      "targetText": "El pierde repede."
    },
    {
      "sourceText": "We are losing more and more.",
      "targetText": "Noi pierdem tot mai mult."
    },
    {
      "sourceText": "Do you take medication?",
      "targetText": "Pireți medicamente?"
    },
    {
      "sourceText": "They lose their luggage.",
      "targetText": "Ei își pierd bagajele."
    },
    {
      "sourceText": "I have lost 2 kilograms.",
      "targetText": "Am pierdut 2 kilograme."
    },
    {
      "sourceText": "She lost weight every month.",
      "targetText": "Ea pierdea fiecare lună."
    },
    {
      "sourceText": "I will lose weight.",
      "targetText": "Voi pierde."
    },
    {
      "sourceText": "I would lose weight if I exercised more.",
      "targetText": "Aș pierde dacă aș antrena mai mult."
    },
    {
      "sourceText": "Lose weight!",
      "targetText": "Pierde!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "The English verb \"lose\" and the Romanian \"a pierde\" both relate to the idea of losing something, making it easier to remember."
    },
    {
      "lang": "en",
      "text": "Think of the phrase: \"I lose weight\" = „Eu pierd greutate“ to connect the English and Romanian meanings."
    },
    {
      "lang": "en",
      "text": "Remember that \"lose\" sounds like \"loose\" which can remind you of something becoming less tight, similar to losing weight."
    },
    {
      "lang": "en",
      "text": "Create a mental image of losing something valuable, like weight or objects, to reinforce the meaning of \"a pierde\"."
    }
  ],
