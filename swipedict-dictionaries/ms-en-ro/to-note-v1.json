  "source": {
    "lang": "en",
    "headword": "to note",
    "definition": "to write something down to remember or record it",
    "pronunciation": "/tuː noʊt/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb 'to note' comes from the Latin 'nota', meaning a mark or sign. It evolved to mean making a written record or observation.",
        "targetText": "Verbul englezesc „to note” provine din latină, de la „nota”, care înseamnă un semn sau marcă, și a evoluat să însemne a face o înregistrare scrisă sau o observație."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Commonly used to record information or make written reminders."
  },
  "target": {
    "lang": "ro",
    "headword": "a nota",
    "definition": "a scrie ceva în mod scris",
    "pronunciation": "/a noˈta/",
    "etymology": {
      "explanation": {
        "sourceText": "The verb 'a nota' derives from the Latin 'nota', meaning 'mark' or 'sign'. It means to write something down or to record.",
        "targetText": "Verbul românesc „a nota“ provine din latină, de la „nota“, care înseamnă „semn“ sau „notă“, și înseamnă a scrie ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Wird häufig in akademischen oder beruflichen Kontexten verwendet."
  },
  "senses": [
    {
      "gloss": "Writing down to help learning",
      "explanation": {
        "sourceText": "Often used when learning new information.",
        "targetText": "Folosit frecvent pentru învățarea de informații noi."
      },
      "examples": [
        {
          "sourceText": "I write down the vocabulary.",
          "targetText": "Eu notez vocabularul."
        }
      ]
    },
    {
      "gloss": "Taking notes",
      "explanation": {
        "sourceText": "In academic and professional contexts.",
        "targetText": "În contexte academice și profesionale."
      },
      "examples": [
        {
          "sourceText": "We had to write everything down.",
          "targetText": "Trebuia să notăm totul."
        }
      ]
    },
    {
      "gloss": "Recording important information",
      "explanation": {
        "sourceText": "Also used for keeping track of important details.",
        "targetText": "De asemenea, pentru a reține informații importante."
      },
      "examples": [
        {
          "sourceText": "I note the most important points.",
          "targetText": "Notez cele mai importante puncte."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "book",
      "targetText": "carte"
    },
    {
      "sourceText": "note",
      "targetText": "notiță"
    },
    {
      "sourceText": "paper",
      "targetText": "hârtie"
    },
    {
      "sourceText": "pen",
      "targetText": "stilou"
    }
  ],
  "antonyms": [
    {
      "sourceText": "to forget",
      "targetText": "a uita"
    }
  ],
  "examples": [
    {
      "sourceText": "I write everything down.",
      "targetText": "Eu notez totul."
    },
    {
      "sourceText": "Do you note the meeting?",
      "targetText": "Notați întâlnirea?"
    },
    {
      "sourceText": "He writes down the plan.",
      "targetText": "El notează planul."
    },
    {
      "sourceText": "We write down the task.",
      "targetText": "Noi notăm sarcina."
    },
    {
      "sourceText": "Do you write down your ideas?",
      "targetText": "Notati-vă ideile?"
    },
    {
      "sourceText": "They quickly write down the minutes.",
      "targetText": "Ei notează rapid procesul-verbal."
    },
    {
      "sourceText": "I have written it down.",
      "targetText": "L-am notat."
    },
    {
      "sourceText": "They have written down the notes.",
      "targetText": "Au notat notițele."
    },
    {
      "sourceText": "He wrote down his thoughts.",
      "targetText": "El nota ideile sale."
    },
    {
      "sourceText": "I had written everything down when they called.",
      "targetText": "Notasem totul când au sunat."
    },
    {
      "sourceText": "I will write it down.",
      "targetText": "Voi nota."
    },
    {
      "sourceText": "He will write down his notes.",
      "targetText": "El o să noteze notițele."
    },
    {
      "sourceText": "I would write it down if I had time.",
      "targetText": "Aș nota dacă aș avea timp."
    },
    {
      "sourceText": "It is important that you write everything down.",
      "targetText": "Este important să notezi totul."
    },
    {
      "sourceText": "Write it down!",
      "targetText": "Notează!"
    },
    {
      "sourceText": "Write down (plural)!",
      "targetText": "Notați!"
    },
    {
      "sourceText": "The written word is important.",
      "targetText": "Cuvântul notat este important."
    },
    {
      "sourceText": "While writing down, I missed the point.",
      "targetText": "Notând, am ratat punctul."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Think of 'note' as a quick mark or sign you make to remember something important."
    },
    {
      "lang": "en",
      "text": "The Romanian 'nota' sounds like 'note' in English, so it’s easy to remember it means to write something down."
    },
    {
      "lang": "en",
      "text": "Imagine taking notes in class: writing down key points to help you study later."
    },
    {
      "lang": "en",
      "text": "Remember the phrase 'take note' in English, which means to pay attention or write something down."
    }
  ],
