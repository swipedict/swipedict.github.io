    },
    {
      "sourceText": "goal",
      "targetText": "scop"
    }
  ],
  "antonyms": [
    {
      "sourceText": "to spoil",
      "targetText": "distruge"
    }
  ],
  "examples": [
    {
      "sourceText": "I serve the people.",
      "targetText": "Eu servesc poporul."
    },
    {
      "sourceText": "Do you serve the customer well?",
      "targetText": "Servești bine clientul?"
    },
    {
      "sourceText": "The waiter serves the guests.",
      "targetText": "Ospătarul servește oaspeții."
    },
    {
      "sourceText": "We serve people in need.",
      "targetText": "Noi servim oamenii în nevoie."
    },
    {
      "sourceText": "Do you serve the community?",
      "targetText": "Serviți comunitatea?"
    },
    {
      "sourceText": "They serve science.",
      "targetText": "Ei servesc științei."
    },
    {
      "sourceText": "I served the teacher.",
      "targetText": "Am servit profesorului."
    },
    {
      "sourceText": "They served the association.",
      "targetText": "Au servit asociației."
    },
    {
      "sourceText": "He served in the army.",
      "targetText": "El servea armata."
    },
    {
      "sourceText": "I had served the family.",
      "targetText": "Servisem familiei."
    },
    {
      "sourceText": "I will serve the program.",
      "targetText": "Voi servi programului."
    },
    {
      "sourceText": "He will serve society.",
      "targetText": "El o să servească societății."
    },
    {
      "sourceText": "I would serve the project if I could.",
      "targetText": "Aș servi proiectului dacă aș putea."
    },
    {
      "sourceText": "It is important that you serve the team.",
      "targetText": "Este important să servești echipei."
    },
    {
      "sourceText": "Serve your neighbor!",
      "targetText": "Servește-ți vecinul!"
    },
    {
      "sourceText": "Serve the guests!",
      "targetText": "Serviți oaspeții!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember that \"serve\" sounds like \"service\"—both relate to helping or providing for others."
    },
    {
      "lang": "en",
      "text": "Think of a waiter who 'serves' food; this links the English word to the Romanian \"a servi\" easily."
    },
    {
      "lang": "en",
      "text": "The Romanian verb endings -esc, -ești, -ește, -im, -iți, -esc are typical for many Romanian verbs, so learning \"a servi\" helps with conjugation patterns."
    },
    {
      "lang": "en",
      "text": "Imagine 'serving' as an act of kindness or duty, which helps you connect the meaning across both languages."
    }
  ],
