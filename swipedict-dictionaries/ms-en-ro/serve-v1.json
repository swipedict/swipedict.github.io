  "source": {
    "lang": "en",
    "headword": "serve",
    "definition": "to provide help, assistance, or a service to a person or cause",
    "pronunciation": "/sɜːrv/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"serve\" originates from the Latin word \"servire\", meaning 'to be a servant' or 'to perform duties for'. It entered English through Old French and has been used to describe acts of helping, assisting, or performing duties for others.",
        "targetText": "Cuvântul englezesc „serve“ provine din latină, din cuvântul „servire“, care înseamnă „a fi servitor“ sau „a îndeplini datorii pentru cineva“. A intrat în limba engleză prin franceza veche și este folosit pentru a descrie acțiuni de ajutor, asistență sau îndeplinire a unor sarcini pentru alții."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "It is an irregular verb often used in contexts involving service, assistance, or obedience."
  },
  "target": {
    "lang": "ro",
    "headword": "a servi",
    "definition": "a oferi ajutor sau suport unei cauze sau unei persoane",
    "pronunciation": "/a serˈvi/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb \"a servi\" derives from the Latin \"servire\", meaning 'to serve' or 'to attend to', and expresses the idea of offering help or service.",
        "targetText": "Verbul românesc „a servi“ derivă din latină „servire“, însemnând „a sluji“ sau „a deservi“ și exprimă ideea de a oferi ajutor sau serviciu."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "The verb is often used in the sense of 'to attend to someone' or 'to provide a service'."
  },
  "senses": [
    {
      "gloss": "Serving (Obedience)",
      "explanation": {
        "sourceText": "Refers to following or obeying an authority.",
        "targetText": "Se referă la a asculta sau a se supune unei autorități."
      },
      "examples": [
        {
          "sourceText": "I serve the command.",
          "targetText": "Servesc poruncii."
        }
      ]
    },
    {
      "gloss": "Serving (Help)",
      "explanation": {
        "sourceText": "The verb means to offer support or help.",
        "targetText": "Verbul înseamnă a oferi sprijin sau ajutor."
      },
      "examples": [
        {
          "sourceText": "I am here to serve.",
          "targetText": "Sunt aici pentru a servi."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "friend",
      "targetText": "prieten"
    },
    {
      "sourceText": "to help",
      "targetText": "a ajuta"
    },
    {
      "sourceText": "support",
