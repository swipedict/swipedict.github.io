  "source": {
    "lang": "en",
    "headword": "wake up",
    "definition": "to open one's eyes suddenly and rise from sleep",
    "pronunciation": "/weɪk ʌp/",
    "etymology": {
      "explanation": {
        "sourceText": "The English phrasal verb \"wake up\" combines \"wake,\" meaning to stop sleeping, with the particle \"up,\" indicating a movement to an upright position. It describes the process of becoming awake from sleep.",
        "targetText": "Cuvântul englezesc „wake up” combină verbul „wake”, care înseamnă a înceta să dormi, cu particula „up”, indicând o mișcare în poziție verticală. Descrie procesul de a deveni treaz din somn."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb phrase. Commonly used in everyday contexts when referring to the act of awakening from sleep."
  },
  "target": {
    "lang": "ro",
    "headword": "a se trezi",
    "definition": "a deschide ochii brusc și a se ridica din somn",
    "pronunciation": "/a se treˈzi/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb \"a se trezi\" originates from Old Church Slavonic \"trezvŭ\", meaning \"sober\" or \"awake.\"",
        "targetText": "Verbul românesc „a se trezi” provine din slavonă, din „trezvŭ”, care înseamnă „treaz” sau „a deveni conștient”."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Reflexive verb of the 2nd conjugation. Frequently used in various tenses and contexts."
  },
  "relatedWords": [
    {
      "sourceText": "morning",
      "targetText": "dimineață"
    },
    {
      "sourceText": "sleep",
      "targetText": "somn"
    },
    {
      "sourceText": "dream",
      "targetText": "vis"
    },
    {
      "sourceText": "alarm clock",
      "targetText": "ceas deșteptător"
    }
  ],
  "antonyms": [
    {
      "sourceText": "fall asleep",
      "targetText": "a adormi"
    }
  ],
  "examples": [
    {
      "sourceText": "I always wake up early.",
      "targetText": "Eu mă trezesc întotdeauna devreme."
    },
    {
      "sourceText": "Do you wake up on time?",
      "targetText": "Te trezești la timp?"
    },
    {
      "sourceText": "She always wakes up tired.",
      "targetText": "Ea se trezește întotdeauna obosită."
    },
    {
      "sourceText": "We wake up together.",
      "targetText": "Noi ne trezim împreună."
    },
    {
      "sourceText": "Do you all wake up like that?",
      "targetText": "Vă treziți și voi așa?"
    },
    {
      "sourceText": "They always wake up happy.",
      "targetText": "Ei se trezesc întotdeauna fericiți."
    },
    {
      "sourceText": "I woke up early today.",
      "targetText": "M-am trezit devreme astăzi."
    },
    {
      "sourceText": "They woke up yesterday.",
      "targetText": "Ei s-au trezit ieri."
    },
    {
      "sourceText": "He woke up every morning.",
      "targetText": "El se trezea în fiecare dimineață."
    },
    {
      "sourceText": "I had already woken up when the alarm rang.",
      "targetText": "Mă trezisem deja când a sunat ceasul."
    },
    {
      "sourceText": "I will wake up early tomorrow.",
      "targetText": "Mă voi trezi mâine dimineață."
    },
    {
      "sourceText": "She will wake up on the weekend.",
      "targetText": "Ea o să se trezească în weekend."
    },
    {
      "sourceText": "I would wake up if you call me.",
      "targetText": "M-aș trezi dacă mă suni."
    },
    {
      "sourceText": "It is important that you wake up on time.",
      "targetText": "Este important să te trezești la timp."
    },
    {
      "sourceText": "Wake up!",
      "targetText": "Trezeste!"
    },
    {
      "sourceText": "Wake up (plural)!",
      "targetText": "Treziti-vă!"
    },
    {
      "sourceText": "The awakened man was confused.",
      "targetText": "Bărbatul trezit era confuz."
    },
    {
      "sourceText": "I have woken up.",
      "targetText": "M-am trezit."
    },
    {
      "sourceText": "I feel good after I have woken up.",
      "targetText": "Mă simt bine după ce m-am trezit."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember the phrase \"wake up\" by thinking of opening your eyes and standing up—both actions happen when you wake up."
    },
    {
      "lang": "en",
      "text": "The Romanian verb \"a se trezi\" sounds like \"treasure\"—imagine waking up to find a treasure every morning!"
    },
    {
      "lang": "en",
      "text": "Practice saying \"Mă trezesc devreme\" to get used to the sound and meaning of waking up early."
    },
    {
      "lang": "en",
      "text": "Link the English word \"wake\" with \"a se trezi\" by remembering that both involve becoming alert and conscious."
    }
  ],
