  "source": {
    "lang": "en",
    "headword": "touch",
    "definition": "to make physical contact with something using the hand or an object",
    "pronunciation": "/tʌtʃ/",
    "etymology": {
      "explanation": {
        "sourceText": "Derived from Old French 'touchier', meaning 'to handle, feel, or hit'. The English word evolved to mean making contact by hand or feeling.",
        "targetText": "Cuvântul englezesc „touch“ provine din franceza veche „touchier“, care înseamnă „a mânui, a simți sau a lovi“. În engleză, a ajuns să însemne a face contact cu mâna sau a simți."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Can refer to both physical contact and emotional impact."
  },
  "target": {
    "lang": "ro",
    "headword": "a atinge",
    "definition": "a face contact cu ceva cu mâna sau un obiect",
    "pronunciation": "/a aˈtin.dʒe/",
    "etymology": {
      "explanation": {
        "sourceText": "Derived from Latin 'attingere', meaning 'to touch' or 'to reach'. It includes both physical and metaphorical senses.",
        "targetText": "Derivat din latinescul „attingere“, care înseamnă „a atinge“ sau „a ajunge la“. Include sensuri fizice și metaforice."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb of the 3rd conjugation (-e). Can be used both physically and metaphorically."
  },
  "senses": [
    {
      "gloss": "to be emotionally touched",
      "explanation": {
        "sourceText": "Used for emotional reactions.",
        "targetText": "Folosit pentru reacții emoționale."
      },
      "examples": [
        {
          "sourceText": "I feel touched by your words.",
          "targetText": "Mă simt atins de cuvintele tale."
        }
      ]
    },
    {
      "gloss": "the touch",
      "explanation": {
        "sourceText": "Can also be used in the sense of emotional touching.",
        "targetText": "Poate fi folosit și în sensul de atingere emoțională."
      },
      "examples": [
        {
          "sourceText": "The music touches me.",
          "targetText": "Muzica mă atinge."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "touch",
      "targetText": "atingere"
    },
    {
      "sourceText": "finger",
      "targetText": "deget"
    },
    {
      "sourceText": "skin",
