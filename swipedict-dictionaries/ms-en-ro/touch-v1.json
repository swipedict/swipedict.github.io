      "targetText": "contact"
    }
  ],
  "antonyms": [
    {
      "sourceText": "turn away",
      "targetText": "îndepărta"
    }
  ],
  "examples": [
    {
      "sourceText": "I touch the wall.",
      "targetText": "Eu ating peretele."
    },
    {
      "sourceText": "Do you touch the flower?",
      "targetText": "Atingi floarea?"
    },
    {
      "sourceText": "She touches the refrigerator.",
      "targetText": "Ea atinge frigiderul."
    },
    {
      "sourceText": "We touch the keys.",
      "targetText": "Noi atingem tastele."
    },
    {
      "sourceText": "Do you touch the water?",
      "targetText": "Atingeți apa?"
    },
    {
      "sourceText": "They touch the pictures.",
      "targetText": "Ei ating imaginile."
    },
    {
      "sourceText": "I touched the surface.",
      "targetText": "Am atins suprafața."
    },
    {
      "sourceText": "He touched her gently.",
      "targetText": "El o atingea ușor."
    },
    {
      "sourceText": "I will touch the ball.",
      "targetText": "Voi atinge mingea."
    },
    {
      "sourceText": "I would touch it if I could.",
      "targetText": "Aș atinge dacă aș putea."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "The English word 'touch' is easy to remember because it sounds like 'touch' in everyday English, meaning to physically or emotionally connect."
    },
    {
      "lang": "en",
      "text": "Think of 'touch' as the action you do with your hands or feelings, which helps link it to the Romanian 'atinge'."
    },
    {
      "lang": "en",
      "text": "The ending '-e' in Romanian 'atinge' is typical for many verbs, similar to English infinitives ending in '-e' sounds like 'change'."
    },
    {
      "lang": "en",
      "text": "Remember the phrase 'touch and feel' to associate the physical and emotional meanings of 'atinge'."
    }
  ],
