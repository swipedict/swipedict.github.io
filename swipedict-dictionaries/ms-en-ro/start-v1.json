  ],
  "examples": [
    {
      "sourceText": "I start the project.",
      "targetText": "Eu încep proiectul."
    },
    {
      "sourceText": "Are you starting today?",
      "targetText": "Începi astăzi?"
    },
    {
      "sourceText": "She starts tomorrow.",
      "targetText": "Ea începe mâine."
    },
    {
      "sourceText": "We start now.",
      "targetText": "Noi începem acum."
    },
    {
      "sourceText": "Are you starting soon?",
      "targetText": "Începeți în curând?"
    },
    {
      "sourceText": "They start the round.",
      "targetText": "Ei încep runda."
    },
    {
      "sourceText": "I have started the book.",
      "targetText": "Am început cartea."
    },
    {
      "sourceText": "He started working back then.",
      "targetText": "El începea atunci să lucreze."
    },
    {
      "sourceText": "I will start soon.",
      "targetText": "Voi începe în curând."
    },
    {
      "sourceText": "I would start if I had time.",
      "targetText": "Aș începe dacă aș avea timp."
    },
    {
      "sourceText": "Start!",
      "targetText": "Începe!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember 'a începe' means 'to start' — think of starting a race or a new project."
    },
    {
      "lang": "en",
      "text": "The Romanian 'începe' sounds like 'in-che-peh' — imagine 'in' the 'che'ckpoint to begin a journey."
    },
    {
      "lang": "en",
      "text": "Link 'a începe' with the English word 'inception' which also means beginning."
    },
    {
      "lang": "en",
      "text": "Think of 'începe' as the action you do when you 'initiate' something new."
    }
  ],
