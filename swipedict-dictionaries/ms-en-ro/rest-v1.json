  "source": {
    "lang": "en",
    "headword": "rest",
    "definition": "to relax or take a break to recover energy",
    "pronunciation": "/rɛst/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"rest\" comes from the Old English \"ræstan\", meaning to cease work or movement and to relax. It is related to similar words in other Germanic languages that convey the idea of stopping activity to recover.",
        "targetText": "Cuvântul englezesc „rest” provine din engleza veche „ræstan”, care înseamnă a înceta munca sau mișcarea și a se relaxa. Este legat de cuvinte similare din alte limbi germanice care exprimă ideea de a opri activitatea pentru a se recupera."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Used in various contexts to describe relaxing or recovering after effort."
  },
  "target": {
    "lang": "ro",
    "headword": "a se odihni",
    "definition": "a se relaxa sau a face o pauză",
    "pronunciation": "/a se odiˈhni/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a se odihni” originates from Slavic, from Old Church Slavonic „otъdъchnǫti” meaning \"to rest, to recover\".",
        "targetText": "Verbul românesc „a se odihni” provine din slavonă, din „otъdъchnǫti”, care înseamnă „a se odihni” sau „a se relaxa”."
      },
      "source": "AI, Wiktionary, Etymological Dictionaries"
    },
    "additional": "Regular reflexive verb. Used to express relaxation or recovery after strenuous activities."
  },
  "senses": [
    {
      "gloss": "take a break",
      "explanation": {
        "sourceText": "Means to pause in order to rest.",
        "targetText": "Înseamnă a face o pauză pentru odihnă."
      },
      "examples": [
        {
          "sourceText": "We are taking a break.",
          "targetText": "Facem o pauză."
        }
      ]
    },
    {
      "gloss": "to relax",
      "explanation": {
        "sourceText": "Used synonymously with 'rest'.",
        "targetText": "Se folosește ca sinonim pentru „a se relaxa“."
      },
      "examples": [
        {
          "sourceText": "I am relaxing in the garden.",
          "targetText": "Mă relaxez în grădină."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "relaxation",
      "targetText": "relaxare"
    },
    {
      "sourceText": "recovery",
      "targetText": "recuperare"
    },
    {
      "sourceText": "break",
      "targetText": "pauză"
    },
    {
      "sourceText": "sleep",
      "targetText": "a dormi"
    }
  ],
  "antonyms": [
    {
      "sourceText": "work",
      "targetText": "a munci"
    }
  ],
  "examples": [
    {
      "sourceText": "I am resting.",
      "targetText": "Eu mă odihnesc."
    },
    {
      "sourceText": "Are you resting today?",
      "targetText": "Te odihnești astăzi?"
    },
    {
      "sourceText": "He is resting on the sofa.",
      "targetText": "El se odihnește pe canapea."
    },
    {
      "sourceText": "We rest after work.",
      "targetText": "Noi ne odihnim după muncă."
    },
    {
      "sourceText": "Are you resting in the park?",
      "targetText": "Vă odihniți în parc?"
    },
    {
      "sourceText": "They rest on the weekend.",
      "targetText": "Ei se odihnesc în weekend."
    },
    {
      "sourceText": "I rested yesterday.",
      "targetText": "M-am odihnit ieri."
    },
    {
      "sourceText": "I will rest after work.",
      "targetText": "Mă voi odihni după muncă."
    },
    {
      "sourceText": "Rest yourself!",
      "targetText": "Odihnește-te!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember the Romanian verb \"a se odihni\" means \"to rest\" — think of taking a break after hard work to recharge your energy."
    },
    {
      "lang": "en",
      "text": "The Romanian noun \"odihnă\" (rest) sounds like the English word \"ode\" — imagine a peaceful poem celebrating relaxation."
    },
    {
      "lang": "en",
      "text": "Visualize yourself lying down quietly in a calm place to remember \"a se odihni\" means to relax."
    },
    {
      "lang": "en",
      "text": "Connect \"odihni\" with the English word \"odd\" — think of an odd moment when you stop everything to rest."
    }
  ],
