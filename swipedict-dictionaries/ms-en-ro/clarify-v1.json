  "source": {
    "lang": "en",
    "headword": "clarify",
    "definition": "to make something clear or easier to understand, often by providing more information or explanation",
    "pronunciation": "/ˈklærɪfaɪ/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"clarify\" comes from the Latin root \"clarificare\", meaning \"to make clear\" or \"to brighten.\" It entered English through Old French and has been used since the late Middle Ages.",
        "targetText": "Cuvântul englezesc „clarify” provine din rădăcina latină „clarificare”, care înseamnă „a face clar” sau „a lumina”. A intrat în limba engleză prin franceza veche și este folosit din Evul Mediu târziu."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Commonly used in educational, legal, and everyday contexts to explain or make information understandable."
  },
  "target": {
    "lang": "ro",
    "headword": "a clarifica",
    "definition": "a informa pe cineva despre ceva sau a face ceva mai clar",
    "pronunciation": "/a klarifiˈka/",
    "etymology": {
      "explanation": {
        "sourceText": "The verb „a clarifica” comes from the Latin „clarificare”, meaning „to make clear”.",
        "targetText": "Verbul românesc „a clarifica“ provine din latină, de la „clarificare“, care înseamnă „a face clar“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular first conjugation verb. Often used in legal, academic, or educational contexts to explain information."
  },
  "senses": [
    {
      "gloss": "Clarification / Explanation of information",
      "explanation": {
        "sourceText": "In the context of conveying information.",
        "targetText": "În contextul transmiterii informațiilor."
      },
      "examples": [
        {
          "sourceText": "The teachers clarify the topics.",
          "targetText": "Profesorii clarifică subiectele."
        }
      ]
    },
    {
      "gloss": "Explanation of misunderstandings",
      "explanation": {
        "sourceText": "To make misunderstandings clear.",
        "targetText": "Pentru clarificarea neînțelegerilor."
      },
      "examples": [
        {
          "sourceText": "We clarify the situation.",
          "targetText": "Noi clarificăm situația."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "explain",
      "targetText": "explicare"
    },
    {
      "sourceText": "information",
      "targetText": "informație"
