      "targetText": "învățământ"
    },
    {
      "sourceText": "knowledge",
      "targetText": "cunoștințe"
    }
  ],
  "antonyms": [
    {
      "sourceText": "confuse",
      "targetText": "a confunda"
    }
  ],
  "examples": [
    {
      "sourceText": "I clarify the situation.",
      "targetText": "Eu clarific situația."
    },
    {
      "sourceText": "Do you clarify the misunderstanding?",
      "targetText": "Clarifici neînțelegerea?"
    },
    {
      "sourceText": "She clarifies everything quickly.",
      "targetText": "Ea clarifică totul repede."
    },
    {
      "sourceText": "We clarify the situation.",
      "targetText": "Noi clarificăm situația."
    },
    {
      "sourceText": "Please clarify the facts!",
      "targetText": "Clarificați, vă rog, faptele!"
    },
    {
      "sourceText": "The teachers clarify the topics.",
      "targetText": "Profesorii clarifică subiectele."
    },
    {
      "sourceText": "I have clarified the problem.",
      "targetText": "Am clarificat problema."
    },
    {
      "sourceText": "The commission clarified all questions.",
      "targetText": "Comisia clarificase toate întrebările."
    },
    {
      "sourceText": "I will clarify the data.",
      "targetText": "Voi clarifica datele."
    },
    {
      "sourceText": "I would clarify the matter if I had time.",
      "targetText": "Aș clarifica situația, dacă aș avea timp."
    },
    {
      "sourceText": "Please clarify this!",
      "targetText": "Clarifică, te rog!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember that \"clarify\" sounds like \"clear\" and means to make something clear or understandable, just like the Romanian \"a clarifica\"."
    },
    {
      "lang": "en",
      "text": "Think of \"clarify\" as adding light (from Latin \"clarus\" meaning clear or bright) to a confusing situation, similar to how \"a clarifica\" means to make clear."
    },
    {
      "lang": "en",
      "text": "Both \"clarify\" and \"a clarifica\" share the Latin root \"clar-\" which relates to clarity and brightness, helping you link the words easily."
    },
    {
      "lang": "en",
      "text": "Use the phrase \"to clarify\" when you want to explain or remove confusion, just like \"a clarifica\" in Romanian."
    }
  ],
