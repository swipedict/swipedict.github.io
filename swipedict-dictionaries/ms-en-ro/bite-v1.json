  "source": {
    "lang": "en",
    "headword": "bite",
    "definition": "to use the teeth to cut into or grip something",
    "pronunciation": "/baɪt/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb 'bite' originates from Old English 'bītan', meaning to cut or grip with the teeth. It is related to other Germanic languages with similar forms and meanings.",
        "targetText": "Cuvântul englezesc „bite” provine din engleza veche „bītan”, care înseamnă a tăia sau a înfige cu dinții. Este înrudit cu alte limbi germanice cu forme și sensuri similare."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Irregular verb; commonly used for animals but also for humans who bite or cause pain."
  },
  "target": {
    "lang": "ro",
    "headword": "a mușca",
    "definition": "a înfinge dinții în ceva",
    "pronunciation": "/a muʃˈka/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb 'a mușca' derives from the Latin 'morsicare', meaning to bite, related to 'morsus' (bite). It denotes the action of biting or chewing.",
        "targetText": "Verbul românesc „a mușca” provine din latină, de la „morsicare”, care înseamnă a mușca, legat de „morsus” (mușcătură)."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb of the 1st conjugation (-a). Often used to describe animal behavior but also in human interactions."
  },
  "senses": [
    {
      "gloss": "Bite",
      "explanation": {
        "sourceText": "'Bite' refers to an injury caused by teeth.",
        "targetText": "'Mușcătură' desemnează o rană cauzată de dinți."
      },
      "examples": [
        {
          "sourceText": "He had a bite from the dog.",
          "targetText": "A avut o mușcătură de la câine."
        }
      ]
    },
    {
      "gloss": "Chewing",
      "explanation": {
        "sourceText": "The act of breaking down food with the teeth.",
        "targetText": "Zdrobirea alimentelor cu dinții."
      },
      "examples": [
        {
          "sourceText": "I am chewing the apple.",
          "targetText": "Eu mestec mărul."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "bite",
      "targetText": "mușcătură"
    },
    {
      "sourceText": "eat",
      "targetText": "a mânca"
    },
