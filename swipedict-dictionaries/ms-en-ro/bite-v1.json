    },
    {
      "sourceText": "tooth",
      "targetText": "dinte"
    }
  ],
  "antonyms": [
    {
      "sourceText": "lick",
      "targetText": "a linge"
    }
  ],
  "examples": [
    {
      "sourceText": "I bite into the apple.",
      "targetText": "Eu mușc din măr."
    },
    {
      "sourceText": "Have you already bitten the bread?",
      "targetText": "Ai mușcat deja din pâine?"
    },
    {
      "sourceText": "The dog bites the mailman.",
      "targetText": "Câinele mușcă poștașul."
    },
    {
      "sourceText": "We bite into the chocolate.",
      "targetText": "Noi mușcăm din ciocolată."
    },
    {
      "sourceText": "Please bite carefully!",
      "targetText": "Mușcați cu atenție!"
    },
    {
      "sourceText": "The cats bite through the string.",
      "targetText": "Pisicile mușcă sfoara."
    },
    {
      "sourceText": "I have bitten the apple.",
      "targetText": "Am mușcat din măr."
    },
    {
      "sourceText": "He bit the boy.",
      "targetText": "El a mușcat băiatul."
    },
    {
      "sourceText": "I will bite into the pizza.",
      "targetText": "Voi mușca din pizza."
    },
    {
      "sourceText": "I would bite into the chocolate bar.",
      "targetText": "Aș mușca din batoanele de ciocolată."
    },
    {
      "sourceText": "Don't bite so hard!",
      "targetText": "Nu mușca atât de tare!"
    },
    {
      "sourceText": "The bitten hand needs immediate help.",
      "targetText": "Mâna mușcată are nevoie de ajutor imediat."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Imagine a dog biting a bone to remember 'a mușca' means to bite."
    },
    {
      "lang": "en",
      "text": "Practice saying 'I bite' as 'Eu mușc' to connect the action with the Romanian verb."
    },
    {
      "lang": "en",
      "text": "Link 'mușca' with the English word 'morsel' to recall the meaning related to biting or small bites."
    },
    {
      "lang": "en",
      "text": "Think of 'mușca' sounding like 'moosh-ka'—imagine softly biting into something mushy."
    }
  ],
