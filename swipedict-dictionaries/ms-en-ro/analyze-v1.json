  "source": {
    "lang": "en",
    "headword": "analyze",
    "definition": "To examine something carefully in order to understand its components or characteristics.",
    "pronunciation": "/ˈænəˌlaɪz/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"analyze\" comes from the Greek word 'analysis', meaning 'a breaking up' or 'a loosening'.",
        "targetText": "Cuvântul englezesc „analyze” provine din grecescul 'analysis', care înseamnă 'dezlegare' sau 'descompunere'."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "target": {
    "lang": "ro",
    "headword": "a analiza",
    "definition": "A examina ceva în detaliu pentru a înțelege componentele sau proprietățile sale.",
    "pronunciation": "/a aˈna.li.za/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a analiza” was borrowed from the French „analyser”, which in turn derives from the Greek 'analusis' (analysis, breaking up).",
        "targetText": "Verbul românesc „a analiza” este împrumutat din francezul „analyser”, care provine din grecescul 'analusis' (analiză, descompunere)."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "First conjugation verb."
  },
