  "examples": [
    {
      "sourceText": "I analyze the data carefully.",
      "targetText": "Eu analizez datele cu atenție."
    },
    {
      "sourceText": "We analyzed the problem.",
      "targetText": "Am analizat problema."
    },
    {
      "sourceText": "He analyzed the situation thoroughly.",
      "targetText": "El analiza situația cu atenție."
    },
    {
      "sourceText": "She will analyze the results.",
      "targetText": "Ea va analiza rezultatele."
    },
    {
      "sourceText": "Analyze the information thoroughly!",
      "targetText": "Analizează informațiile temeinic!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "The Romanian verb ends in '-a', typical for first conjugation verbs – practice forms like: eu analizez, tu analizezi, el analizează."
    },
    {
      "lang": "en",
      "text": "The English word 'analyze' and Romanian 'a analiza' sound very similar – both come from the Greek root meaning 'to break down'."
    },
    {
      "lang": "en",
      "text": "Imagine breaking down a puzzle into pieces – 'analyze' means exactly that: to separate something into parts to understand it."
    },
    {
      "lang": "en",
      "text": "Connect 'analyze' with the English noun 'analysis' to remember the meaning and origin more easily."
    }
  ],
