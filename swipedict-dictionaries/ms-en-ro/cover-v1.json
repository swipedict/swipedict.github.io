  "examples": [
    {
      "sourceText": "I cover the table.",
      "targetText": "Eu acopăr masa."
    },
    {
      "sourceText": "Do you cover the bed?",
      "targetText": "Acoperi patul?"
    },
    {
      "sourceText": "The waitress covers the tables.",
      "targetText": "Camerista acoperă mesele."
    },
    {
      "sourceText": "We cover the garden.",
      "targetText": "Noi acoperim grădina."
    },
    {
      "sourceText": "Do you cover the chairs?",
      "targetText": "Acoperiți scaunele?"
    },
    {
      "sourceText": "They cover the appliances.",
      "targetText": "Ei acoperă aparatele."
    },
    {
      "sourceText": "I have covered the chairs.",
      "targetText": "Am acoperit scaunele."
    },
    {
      "sourceText": "They have covered the table.",
      "targetText": "Au acoperit masa."
    },
    {
      "sourceText": "He covered the furniture.",
      "targetText": "El acoperea mobila."
    },
    {
      "sourceText": "I will cover the table tomorrow.",
      "targetText": "Voi acoperi masa mâine."
    },
    {
      "sourceText": "I would cover the garden if it rained.",
      "targetText": "Aș acoperi grădina dacă ar ploua."
    },
    {
      "sourceText": "Cover the table!",
