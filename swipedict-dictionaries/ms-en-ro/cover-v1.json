  "source": {
    "lang": "en",
    "headword": "cover",
    "definition": "to prepare a table by placing dishes, cutlery, and other items for a meal",
    "pronunciation": "/ˈkʌvər/",
    "etymology": {
      "explanation": {
        "sourceText": "The verb \"cover\" originates from the Old French \"covrir\", which comes from the Latin \"cooperire\" meaning 'to cover completely'. It has evolved in English to mean placing something over or preparing a surface.",
        "targetText": "Verbul englezesc „cover“ provine din vechiul francez „covrir“, care la rândul său derivă din latină, din „cooperire“, ce înseamnă „a acoperi complet“. În engleză a evoluat să însemne a pune ceva peste sau a pregăti o suprafață."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Also used to describe placing items over a table, such as dishes or cloth."
  },
  "target": {
    "lang": "ro",
    "headword": "a acoperi",
    "definition": "a pregăti masa pentru o masă",
    "pronunciation": "/a a.koˈpe.ri/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a acoperi“ derives from the Latin „cooperire“, meaning to cover or hide, and is also used for setting a table.",
        "targetText": "Verbul românesc „a acoperi“ derivă din latină, din „cooperire“, care înseamnă a acoperi sau a ascunde."
      },
      "source": "AI, Linguistic Analysis"
    },
    "additional": "Regular verb of the 4th conjugation (-i). Often used for covering furniture or tables."
  },
