  "source": {
    "lang": "en",
    "headword": "to ask",
    "definition": "to request information or make an inquiry",
    "pronunciation": "/tuː æsk/",
    "etymology": {
      "explanation": {
        "sourceText": "Derived from Old English 'ascian' meaning 'to seek, inquire'. It is commonly used in both formal and informal contexts to request information or clarification.",
        "targetText": "Provine din combinarea prefixului „an-“ cu verbul „fragen” (a întreba)."
      },
      "source": "AI"
    },
    "additional": "Regular verb. Frequently used in formal communication to request information or assistance."
  },
  "target": {
    "lang": "ro",
    "headword": "a întreba",
    "definition": "a solicita informații sau a face o cerere",
    "pronunciation": "/ɨnˈtre.ba/",
    "etymology": {
      "explanation": {
        "sourceText": "Derived from the Latin 'interrogare', meaning 'to ask'. It is a common form used to pose questions or request information.",
        "targetText": "Provine din latinescul „interrogare”, care înseamnă „a întreba”."
      },
      "source": "AI, Wiktionary"
    },
    "additional": "Regular verb of the 1st conjugation (-a). Often used in formal contexts to make inquiries."
  },
  "senses": [
    {
      "gloss": "request information",
      "explanation": {
        "sourceText": "Used in official contexts.",
        "targetText": "Folosit în contexte oficiale pentru a solicita informații."
      },
      "examples": [
        {
          "sourceText": "I request information.",
          "targetText": "Cer informații."
        }
      ]
    },
    {
      "gloss": "to inquire",
      "explanation": {
        "sourceText": "Used when asking for information.",
        "targetText": "Folosit pentru a cere informații."
      },
      "examples": [
        {
          "sourceText": "I inquire about information.",
          "targetText": "Eu întreb despre informații."
        }
      ]
    },
    {
      "gloss": "send a message",
      "explanation": {
        "sourceText": "Used in communication to request information.",
        "targetText": "Folosit în comunicare pentru a solicita informații."
      },
      "examples": [
        {
          "sourceText": "I send a request.",
          "targetText": "Trimit o întrebare."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "to answer",
      "targetText": "a răspunde"
    },
    {
      "sourceText": "the call",
      "targetText": "apelul"
    },
    {
      "sourceText": "the exchange of information",
      "targetText": "schimbul de informații"
    },
    {
      "sourceText": "the question",
      "targetText": "întrebarea"
    }
  ],
  "antonyms": [
    {
      "sourceText": "to answer",
      "targetText": "a răspunde"
    }
  ],
  "examples": [
    {
      "sourceText": "I ask about the invoice.",
      "targetText": "Eu întreb de factură."
    },
    {
      "sourceText": "Are you asking about the appointment?",
      "targetText": "Întrebi de întâlnire?"
    },
    {
      "sourceText": "She asks about the results.",
      "targetText": "Ea întreabă despre rezultate."
    },
    {
      "sourceText": "We ask for information.",
      "targetText": "Noi întrebăm despre informații."
    },
    {
      "sourceText": "Are you asking for a solution?",
      "targetText": "Întrebați de o soluție?"
    },
    {
      "sourceText": "They ask for support.",
      "targetText": "Ei întreabă de sprijin."
    },
    {
      "sourceText": "I asked about the price.",
      "targetText": "Am întrebat de preț."
    },
    {
      "sourceText": "He often asked for help.",
      "targetText": "El întreba adesea de ajutor."
    },
    {
      "sourceText": "I will ask about the details.",
      "targetText": "Voi întreba despre detalii."
    },
    {
      "sourceText": "I would ask for advice.",
      "targetText": "Aș întreba despre sfaturi."
    },
    {
      "sourceText": "Ask!",
      "targetText": "Întreabă!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember 'a întreba' sounds like 'in-tre-ba' — think of 'inquire' to connect it with asking questions."
    },
    {
      "lang": "en",
      "text": "The Romanian verb 'a întreba' comes from Latin 'interrogare' — just like 'interrogate' in English, which means to ask questions."
    },
    {
      "lang": "en",
      "text": "Imagine someone raising their hand in class to 'ask' a question — 'a întreba' is your go-to verb for that."
    },
    {
      "lang": "en",
      "text": "Link 'a întreba' with the English word 'inquire' to remember it’s about requesting information."
    }
  ],
