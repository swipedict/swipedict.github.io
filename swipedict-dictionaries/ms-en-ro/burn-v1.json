  "source": {
    "lang": "en",
    "headword": "burn",
    "definition": "to produce flames or heat; to be on fire or cause to be on fire",
    "pronunciation": "/bɜːrn/",
    "etymology": {
      "explanation": {
        "sourceText": "The English word \"burn\" originates from Old English \"beornan\" or \"bærnan\", meaning to consume by fire or to be on fire.",
        "targetText": "Cuvântul englezesc „burn“ provine din engleza veche „beornan“ sau „bærnan“, care înseamnă a consuma prin foc sau a fi în flăcări."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb describing the process of combustion or being on fire."
  },
  "target": {
    "lang": "ro",
    "headword": "a arde",
    "definition": "a produce o flacără sau o căldură; a se aprinde",
    "pronunciation": "/a ˈarde/",
    "etymology": {
      "explanation": {
        "sourceText": "Der Romanian word derives from the Latin \"ardere\", meaning \"to burn\", with similar forms in other Romance languages.",
        "targetText": "Provine din latinescul „ardere“, care înseamnă „a arde“, cu forme similare în alte limbi romanice."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular first conjugation verb (-e). Often used in relation to heat and light."
  },
  "relatedWords": [
    {
      "sourceText": "fire",
      "targetText": "foc"
    },
    {
      "sourceText": "heat",
      "targetText": "căldură"
    },
    {
      "sourceText": "light",
      "targetText": "lumină"
    },
    {
      "sourceText": "smoke",
      "targetText": "fum"
    }
  ],
  "antonyms": [
    {
      "sourceText": "extinguish",
      "targetText": "a stinge"
    }
  ],
  "examples": [
    {
      "sourceText": "I burn the paper.",
      "targetText": "Eu ard hârtia."
    },
    {
      "sourceText": "Are you burning the candle?",
      "targetText": "Arzi lumânarea?"
    },
    {
      "sourceText": "The fire burns hot.",
      "targetText": "Focul arde fierbinte."
    },
    {
      "sourceText": "We burn for the music.",
      "targetText": "Noi ardem pentru muzică."
    },
    {
      "sourceText": "Do you also burn in winter?",
      "targetText": "Ardeți și voi iarna?"
    },
    {
      "sourceText": "The lights burn brightly.",
      "targetText": "Luminile ard strălucitor."
    },
    {
      "sourceText": "I have burned the wood.",
      "targetText": "Am ars lemnul."
    },
    {
      "sourceText": "He burned the picture.",
      "targetText": "El ardea imaginea."
    },
    {
      "sourceText": "We will burn the fire.",
      "targetText": "Noi vom arde focul."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember \"burn\" by thinking of a candle's flame that 'burns' steadily, just like the Romanian verb \"a arde\"."
    },
    {
      "lang": "en",
      "text": "Associate \"a arde\" with the English word \"ardent,\" which means passionate or burning with enthusiasm."
    },
    {
      "lang": "en",
      "text": "Think of the Latin root \"ardere\" shared by both \"burn\" and \"a arde\" to link the words etymologically."
    },
    {
      "lang": "en",
      "text": "Picture a campfire that \"burns\" to remember the action and connect it to the Romanian \"a arde.\""
    }
  ],
