  ],
  "examples": [
    {
      "sourceText": "I am burdening the structure.",
      "targetText": "Eu încarc structura."
    },
    {
      "sourceText": "Are you burdening the team?",
      "targetText": "Încarci echipa?"
    },
    {
      "sourceText": "He burdens the documents.",
      "targetText": "El încarcă documentele."
    },
    {
      "sourceText": "We burden the resources.",
      "targetText": "Noi încărcăm resursele."
    },
    {
      "sourceText": "Are you burdening the devices?",
      "targetText": "Încărcați dispozitivele?"
    },
    {
      "sourceText": "They burden the system.",
      "targetText": "Ei încarcă sistemul."
    },
    {
      "sourceText": "I have burdened the task.",
      "targetText": "Am încărcat sarcina."
    },
    {
      "sourceText": "She often burdened the information.",
      "targetText": "Ea încărca adesea informațiile."
    },
    {
      "sourceText": "I will burden the fields.",
      "targetText": "Voi încărca câmpurile."
    },
    {
      "sourceText": "I would burden it if necessary.",
      "targetText": "Aș încărca dacă ar fi necesar."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Think of 'burden' as carrying a heavy backpack—just like 'a încărca' means to load or weigh down."
    },
    {
      "lang": "en",
      "text": "Remember 'burden' sounds like 'bird in'—imagine a bird sitting on your shoulder, adding weight and pressure."
    },
    {
      "lang": "en",
      "text": "Connect 'burden' with 'a încărca' by picturing loading responsibilities onto someone, just like loading cargo."
    },
    {
      "lang": "en",
      "text": "Use the phrase 'burden of proof' to recall that 'burden' involves carrying responsibility or pressure."
    }
  ],
