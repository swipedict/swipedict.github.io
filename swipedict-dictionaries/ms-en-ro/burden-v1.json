  "source": {
    "lang": "en",
    "headword": "burden",
    "definition": "to make something heavier or to place pressure or responsibility on someone or something",
    "pronunciation": "/ˈbɜːrdən/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"burden\" comes from the Old English \"byrthen,\" meaning a load or something carried. It evolved to mean placing a heavy load or responsibility on someone or something.",
        "targetText": "Cuvântul englezesc „burden“ provine din engleza veche „byrthen“, care înseamnă o încărcătură sau ceva de purtat. A evoluat să însemne a pune o povară sau responsabilitate asupra cuiva sau a ceva."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Often used in contexts of physical or emotional pressure or responsibility."
  },
  "target": {
    "lang": "ro",
    "headword": "a încărca",
    "definition": "a face ceva mai greu sau a exercita presiune asupra cuiva",
    "pronunciation": "/a ɨn.kərˈka/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb \"a încărca\" derives from the Latin \"incaricare,\" meaning to load or to put a burden on. It describes the act of placing loads or responsibility.",
        "targetText": "Verbul românesc „a încărca“ provine din latină, de la „incaricare“, care înseamnă a încărca sau a pune o povară."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular first conjugation verb (-a). Often used to describe both physical and emotional loads."
  },
  "senses": [
    {
      "gloss": "Burden (emotional)",
      "explanation": {
        "sourceText": "Used to describe emotional burden or pressure.",
        "targetText": "Utilizat pentru încărcarea emoțională sau presiune."
      },
      "examples": [
        {
          "sourceText": "Are you burdening the team?",
          "targetText": "Încarci echipa?"
        }
      ]
    },
    {
      "gloss": "Burden (physical)",
      "explanation": {
        "sourceText": "Used to describe physical loading or burden.",
        "targetText": "Utilizat pentru încărcarea fizică sau povară."
      },
      "examples": [
        {
          "sourceText": "I am burdening the structure.",
          "targetText": "Eu încarc structura."
        }
      ]
    }
  ],
