  "source": {
    "lang": "en",
    "headword": "thank",
    "definition": "to express gratitude or appreciation for something",
    "pronunciation": "/θæŋk/",
    "etymology": {
      "explanation": {
        "sourceText": "The verb \"thank\" originates from Old English \"þancian\", meaning \"to give thanks\", related to the noun \"thought\" and the Proto-Germanic root '*thankō'.",
        "targetText": "Cuvântul englezesc „thank” provine din engleza veche „þancian”, care înseamnă „a mulțumi”, fiind înrudit cu substantivul „gând” și rădăcina proto-germanică '*thankō'."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Commonly used to express gratitude or appreciation. Related to the adjective \"thankful\" and the noun \"thankfulness\"."
  },
  "target": {
    "lang": "ro",
    "headword": "a mulțumi",
    "definition": "a exprima recunoștință pentru ceva",
    "pronunciation": "/a mul.tzuˈmi/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb \"a mulțumi\" derives from the Latin adverb \"multum\", meaning \"much\", evolving to mean \"to thank\".",
        "targetText": "Verbul românesc „a mulțumi” derivă din adverbul latin „multum”, care înseamnă „mult”, evoluând spre sensul de „a mulțumi”."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb of the 4th conjugation (-i). Typically used to express thanks. You can also use \"a mulțumi de\" to thank for something."
  },
  "relatedWords": [
    {
      "sourceText": "thanks",
      "targetText": "mulțumire"
    },
    {
      "sourceText": "friend",
      "targetText": "prieten"
    },
    {
      "sourceText": "gift",
      "targetText": "cadou"
    },
    {
      "sourceText": "help",
      "targetText": "ajutor"
    }
  ],
  "antonyms": [
    {
      "sourceText": "to insult",
      "targetText": "a ofensa"
    }
  ],
  "examples": [
    {
      "sourceText": "I thank you for the help.",
      "targetText": "Îți mulțumesc pentru ajutor."
    },
    {
      "sourceText": "Do you thank me for the support?",
      "targetText": "Îmi mulțumești pentru sprijin?"
    },
    {
      "sourceText": "He thanks the teacher.",
      "targetText": "El îi mulțumește profesoarei."
    },
    {
      "sourceText": "We thank for the opportunity.",
      "targetText": "Îi mulțumim pentru oportunitate."
    },
    {
      "sourceText": "Do you thank the helpers?",
      "targetText": "Mulțumiți ajutoarelor?"
    },
    {
      "sourceText": "They thank their friends.",
      "targetText": "Ei mulțumesc prietenilor lor."
    },
    {
      "sourceText": "I have thanked you.",
      "targetText": "Îți mulțumesc."
    },
    {
      "sourceText": "They have thanked the family.",
      "targetText": "Ei au mulțumit familiei."
    },
    {
      "sourceText": "He often thanked for the gifts.",
      "targetText": "El mulțumea adesea pentru cadouri."
    },
    {
      "sourceText": "I had thanked the helpers.",
      "targetText": "Îi mulțumisem ajutoarelor."
    },
    {
      "sourceText": "I will thank you.",
      "targetText": "Îți voi mulțumi."
    },
    {
      "sourceText": "She will thank me.",
      "targetText": "Ea o să-mi mulțumească."
    },
    {
      "sourceText": "I would like to thank you.",
      "targetText": "Ți-aș mulțumi."
    },
    {
      "sourceText": "It is important that you thank.",
      "targetText": "Este important să mulțumești."
    },
    {
      "sourceText": "Thank you for the support!",
      "targetText": "Mulțumește pentru sprijin!"
    },
    {
      "sourceText": "Please thank!",
      "targetText": "Mulțumiți vă rog!"
    },
    {
      "sourceText": "The thankful helper is here.",
      "targetText": "Ajutorul mulțumitor este aici."
    },
    {
      "sourceText": "The family is thankful.",
      "targetText": "Familia este mulțumitoare."
    },
    {
      "sourceText": "I came thanking.",
      "targetText": "Am venit mulțumind."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember that \"a mulțumi\" sounds like \"multi\" — think of thanking many people with a big heart!"
    },
    {
      "lang": "en",
      "text": "The Romanian \"mulțumesc\" is your go-to word for 'thank you' — practice it often to sound natural!"
    },
    {
      "lang": "en",
      "text": "Think of \"mulțumi\" as related to 'multiple' or 'much' — you give a lot of thanks!"
    },
    {
      "lang": "en",
      "text": "Use \"a mulțumi de\" when you want to specify what you are thankful for, like 'thank for the gift'."
    }
  ],
