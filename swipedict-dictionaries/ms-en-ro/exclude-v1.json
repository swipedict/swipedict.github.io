  "source": {
    "lang": "en",
    "headword": "exclude",
    "definition": "to keep someone or something out of a group or not allow participation",
    "pronunciation": "/ɪkˈskluːd/",
    "etymology": {
      "explanation": {
        "sourceText": "The English verb \"exclude\" comes from the Latin verb \"excludere,\" meaning 'to shut out' or 'to keep out.' It is formed from \"ex-\" meaning 'out' and \"claudere\" meaning 'to shut.'",
        "targetText": "Cuvântul englezesc „exclude“ provine din verbul latin „excludere“, care înseamnă „a închide afară“ sau „a ține departe“. Este format din prefixul „ex-“ care înseamnă „afară“ și „claudere“ care înseamnă „a închide“."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Used when someone or something is prevented from joining or participating, often in social contexts."
  },
  "target": {
    "lang": "ro",
    "headword": "a exclude",
    "definition": "a ține pe cineva sau ceva departe de ceva sau a nu permite participarea",
    "pronunciation": "/a eksˈklude/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb „a exclude“ derives from the Latin „excludere“, meaning to keep someone away or not allow participation. It describes the act of preventing entry or involvement of persons or things.",
        "targetText": "Verbul român „a exclude“ derivă din lat. „excludere“, însemnând a ține pe cineva departe sau a nu permite participarea."
      },
      "source": "AI, Wiktionary, Etymological Dictionaries"
    },
    "additional": "Regular first conjugation verb (-e). Often used in social contexts."
  },
  "senses": [
    {
      "gloss": "to exclude (member from a group)",
      "explanation": {
        "sourceText": "This refers to the exclusion of people from social groups.",
        "targetText": "Se referă la excluderea persoanelor din grupuri sociale."
      },
      "examples": [
        {
          "sourceText": "He excludes the members.",
          "targetText": "El exclude membrii."
        }
      ]
    },
    {
      "gloss": "to exclude (part of a possibility)",
      "explanation": {
        "sourceText": "In this context, it means not considering certain options.",
        "targetText": "În acest context, înseamnă a nu lua în considerare anumite opțiuni."
      },
      "examples": [
        {
          "sourceText": "We exclude all possibilities.",
          "targetText": "Noi excludem toate posibilitățile."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "group",
      "targetText": "grup"
    },
    {
