  "source": {
    "lang": "en",
    "headword": "breathe",
    "definition": "to move air in and out of the lungs",
    "pronunciation": "/briːð/",
    "etymology": {
      "explanation": {
        "sourceText": "The verb \"breathe\" originates from Old English \"brǣth\" related to the act of inhaling and exhaling air, describing the vital process of respiration.",
        "targetText": "Cuvântul englezesc „breathe“ provine din engleza veche „brǣth“, legat de actul de a inspira și expira aer, descriind procesul vital al respirației."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular verb. Used both in everyday language and medical contexts."
  },
  "target": {
    "lang": "ro",
    "headword": "a respira",
    "definition": "a mișca aerul în și din corp",
    "pronunciation": "/a res.piˈra/",
    "etymology": {
      "explanation": {
        "sourceText": "The Romanian verb \"a respira\" derives from Latin \"respirare\", composed of \"re-\" (again) and \"spirare\" (to breathe), referring to the vital process of breathing.",
        "targetText": "Verbul românesc „a respira“ derivă din latină, din „respirare“, compus din „re-“ (din nou) și „spirare“ (a respira), desemnând procesul vital de respirație."
      },
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "additional": "Regular first conjugation verb (-a). \"Respirare\" plays an important role both in medicine and philosophy, where it symbolizes life itself."
  },
  "senses": [
    {
      "gloss": "Shortness of breath",
      "explanation": {
        "sourceText": "\"Breathe\" can describe a state or image of difficulty in taking in air.",
        "targetText": "„Atmen“ descrie și starea de dificultate în respirație."
      },
      "examples": [
        {
          "sourceText": "I have shortness of breath.",
          "targetText": "Am dificultăți de respirație."
        }
      ]
    },
    {
      "gloss": "Breathing (air movement)",
      "explanation": {
        "sourceText": "The word is also used in medical contexts.",
        "targetText": "Cuvântul este folosit și în context medical."
      },
      "examples": [
        {
          "sourceText": "Breathe deeply.",
          "targetText": "Respiră adânc."
        }
      ]
    }
  ],
  "relatedWords": [
    {
      "sourceText": "health",
      "targetText": "sănătate"
    },
