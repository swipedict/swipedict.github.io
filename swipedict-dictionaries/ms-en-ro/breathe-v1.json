      "sourceText": "drown",
      "targetText": "a se îneca"
    }
  ],
  "examples": [
    {
      "sourceText": "I breathe deeply.",
      "targetText": "Eu respir adânc."
    },
    {
      "sourceText": "Are you breathing calmly?",
      "targetText": "Respiri liniștit?"
    },
    {
      "sourceText": "The patient breathes heavily.",
      "targetText": "Pacientul respiră greu."
    },
    {
      "sourceText": "We breathe fresh air.",
      "targetText": "Noi respirăm aer proaspăt."
    },
    {
      "sourceText": "Are you breathing calmly?",
      "targetText": "Respirați voi liniștit?"
    },
    {
      "sourceText": "They breathe during meditation.",
      "targetText": "Ei respiră în meditație."
    },
    {
      "sourceText": "I breathed more deeply.",
      "targetText": "Am respirat mai profund."
    },
    {
      "sourceText": "They breathed calmly.",
      "targetText": "Au respirat liniștit."
    },
    {
      "sourceText": "He breathed quickly in excitement.",
      "targetText": "El respira repede de emoție."
    },
    {
      "sourceText": "I had not breathed properly when you arrived.",
      "targetText": "Nu respirasem corect când ai sosit."
    },
    {
      "sourceText": "I will breathe deeply tomorrow.",
      "targetText": "Voi respira adânc mâine."
    },
    {
      "sourceText": "She will breathe more.",
      "targetText": "Ea o să respire mai mult."
    },
    {
      "sourceText": "I would breathe if I could.",
      "targetText": "Aș respira dacă aș putea."
    },
    {
      "sourceText": "It is important that you breathe deeply.",
      "targetText": "Este important să respiri adânc."
    },
    {
      "sourceText": "Breathe calmly!",
      "targetText": "Respiră liniștit!"
    },
    {
      "sourceText": "Breathe deeply!",
      "targetText": "Respirați adânc!"
    },
    {
      "sourceText": "The tired child breathes slowly.",
      "targetText": "Copilul obosit respiră încet."
    },
    {
      "sourceText": "The atmosphere is calm and breathable.",
      "targetText": "Atmosfera este liniștită și respirabilă."
    },
    {
      "sourceText": "While he breathed slowly, he relaxed.",
      "targetText": "Respirând încet, s-a relaxat."
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember that \"breathe\" sounds like \"breath\" which is the air you take in and out—this helps link the action to the word."
    },
    {
      "lang": "en",
      "text": "The Romanian word \"respira\" shares the root with English \"respiration\"—think of 're-' meaning again and 'spirare' meaning to breathe."
    },
    {
      "lang": "en",
      "text": "Practice saying \"respira\" while taking deep breaths to connect the sound with the action."
    },
    {
      "lang": "en",
      "text": "Think of the word \"respire\" in English, which means to breathe, to help remember the Romanian \"respira\"."
    },
    {
      "lang": "en",
      "text": "Visualize fresh air filling your lungs as you say \"respira\" to reinforce the meaning."
    }
  ],
