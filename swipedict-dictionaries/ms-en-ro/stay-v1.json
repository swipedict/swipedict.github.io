  ],
  "examples": [
    {
      "sourceText": "I stay here.",
      "targetText": "Eu rămân aici."
    },
    {
      "sourceText": "Are you staying a bit longer?",
      "targetText": "Rămâi puțin?"
    },
    {
      "sourceText": "He stays at the train station.",
      "targetText": "El rămâne la gară."
    },
    {
      "sourceText": "We stay here for the night.",
      "targetText": "Noi rămânem aici pentru noapte."
    },
    {
      "sourceText": "Please stay here!",
      "targetText": "Rămâneți aici, vă rog!"
    },
    {
      "sourceText": "They are staying home today.",
      "targetText": "Ei rămân acasă astăzi."
    },
    {
      "sourceText": "I have stayed.",
      "targetText": "Am rămas."
    },
    {
      "sourceText": "He stayed all day.",
      "targetText": "El a rămas toată ziua."
    },
    {
      "sourceText": "I will stay here.",
      "targetText": "Voi rămâne aici."
    },
    {
      "sourceText": "I would stay if I could.",
      "targetText": "Aș rămâne dacă aș putea."
    },
    {
      "sourceText": "Stay here!",
      "targetText": "Rămâi aici!"
    }
  ],
  "learningTips": [
    {
      "lang": "en",
      "text": "Remember the Romanian verb \"a rămâne\" by linking it to the English word \"remain,\" which shares the Latin root and similar meaning."
    },
    {
      "lang": "en",
      "text": "Think of \"a rămâne\" as \"to remain\" in place—both words start with 'r' and relate to staying put."
    },
    {
      "lang": "en",
      "text": "Use the phrase \"I remain here\" to practice \"Eu rămân aici\" and reinforce the connection."
    },
    {
      "lang": "en",
      "text": "Imagine a 'ram' standing still and not moving away to remember the sound and meaning of \"rămâne.\""
    }
  ],
